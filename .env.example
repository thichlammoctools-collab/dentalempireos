# MCP Stitch Configuration
STITCH_API_KEY=your_api_key_here
STITCH_ENDPOINT=https://stitch.googleapis.com/mcp

# ============================================================
# Google OAuth
# Hướng dẫn: https://console.cloud.google.com/apis/credentials
# Redirect URI trên Google Console:
#   Dev:  http://localhost:4321/api/auth/callback/google
#   Prod: https://dentalempireos.com/api/auth/callback/google
# ============================================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=set-via-wrangler-secret-put

# ============================================================
# Email (Resend)
# ============================================================
RESEND_API_KEY=re_your_resend_api_key_here

# ============================================================
# Admin
# ============================================================
ADMIN_EMAILS=admin@example.com
