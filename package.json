{
  "name": "dentalempireos",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "db:migrate": "wrangler d1 migrations apply DB --local && wrangler d1 migrations apply DB --remote",
    "db:seed": "node scripts/generate-mdx-migration.js > migrations/seed-books.sql && wrangler d1 execute DB --file=migrations/seed-books.sql --remote",
    "db:seed:local": "node scripts/generate-mdx-migration.js > migrations/seed-books.sql && wrangler d1 execute DB --file=migrations/seed-books.sql --local",
    "db:seed:blog": "wrangler d1 execute DB --file=migrations/seed-blog.sql --remote",
    "db:seed:blog:local": "wrangler d1 execute DB --file=migrations/seed-blog.sql --local",
    "deploy": "node scripts/deploy.mjs"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@better-auth/infra": "^0.3.6",
    "@fontsource/be-vietnam-pro": "^5.2.8",
    "@pdf-lib/fontkit": "^1.1.1",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "astro": "^6.4.7",
    "better-auth": "^1.6.19",
    "isomorphic-dompurify": "^3.18.0",
    "kysely": "^0.29.2",
    "kysely-d1": "^0.4.0",
    "marked": "^18.0.5",
    "pdf-lib": "^1.17.1",
    "resend": "^6.12.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^4.20260617.1",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  }
}
