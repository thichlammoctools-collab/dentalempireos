{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dentalempireos",
  "account_id": "6c99b69a2ef00c1754fae70793262cd3",
  "compatibility_date": "2025-06-17",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist/client"
  },
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "ea368ffff09f407eae2c9b595fe86d9a"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "dentalempireos-db",
      "database_id": "dc3b8890-c22f-4ebb-8172-1db5f4317241"
    }
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "dentalempireos"
    }
  ],
  "vectorize": [
    {
      "binding": "VECTORIZE",
      "index_name": "dental-content"
    }
  ],
  "vars": {},
  "routes": [
    {
      "pattern": "dentalempireos.com",
      "zone_name": "dentalempireos.com",
      "custom_domain": true
    }
  ],
  "images": {}
}
