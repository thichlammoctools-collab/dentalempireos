{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "tier": {
      "type": "number"
    },
    "chapter": {
      "type": "number"
    },
    "description": {
      "type": "string"
    },
    "order": {
      "type": "number"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "slug"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "tier",
    "chapter",
    "description",
    "order"
  ]
}