{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "tier": {
      "type": "number",
      "minimum": 1,
      "maximum": 6
    },
    "chapter": {
      "type": "number"
    },
    "description": {
      "type": "string"
    },
    "order": {
      "type": "number"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "tier",
    "chapter",
    "description",
    "order"
  ]
}