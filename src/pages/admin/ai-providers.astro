---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';
import { listProviders, listModels } from '../../lib/ai-provider-db';

export const prerender = false;

if (!Astro.locals.user) return Astro.redirect('/login');

const providers = await listProviders(env.DB);
const models = await listModels(env.DB);
const modelsByProvider = new Map<number, typeof models>();
for (const m of models) {
  if (!modelsByProvider.has(m.provider_id)) modelsByProvider.set(m.provider_id, []);
  modelsByProvider.get(m.provider_id)!.push(m);
}
---

<AdminLayout title="AI Providers | Admin">
  <div class="mb-6 flex items-center justify-between">
    <div>
      <h2 class="text-3xl font-bold text-white mb-1">AI Providers & Models</h2>
      <p class="text-on-surface-variant text-sm">Cấu hình nhiều provider AI và chọn model cho từng ứng dụng.</p>
    </div>
    <a href="/admin/ai-settings" class="btn-primary-metallic bg-surface-container-high text-on-surface-variant px-4 py-2 rounded-xl text-sm font-medium flex items-center gap-2">
      <span class="material-symbols-outlined text-[16px]">settings</span>
      Cài đặt cũ
    </a>
  </div>

  <!-- Providers list -->
  <div class="space-y-4 mb-8" id="providers-list">
    <div class="flex items-center justify-between">
      <h3 class="text-lg font-bold text-white">Providers</h3>
      <button id="add-provider-btn" class="px-4 py-2 bg-primary text-white text-sm font-semibold rounded-xl flex items-center gap-2 hover:bg-primary/90 transition-all">
        <span class="material-symbols-outlined text-[16px]">add</span>
        Thêm Provider
      </button>
    </div>

    {providers.map((p) => (
      <div class="glass-card rounded-xl p-5 provider-card" data-id={p.id}>
        <div class="flex items-start gap-4">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-3 mb-1">
              <h4 class="text-base font-bold text-white">{p.name}</h4>
              {p.is_default ? (
                <span class="px-2 py-0.5 rounded-full bg-amber-500/20 text-amber-300 text-[10px] font-bold">MẶC ĐỊNH</span>
              ) : ''}
              <span class={`px-2 py-0.5 rounded-full text-[10px] font-bold ${p.is_active ? 'bg-emerald-500/20 text-emerald-300' : 'bg-slate-500/20 text-slate-400'}`}>
                {p.is_active ? 'HOẠT ĐỘNG' : 'TẮT'}
              </span>
            </div>
            <p class="text-xs text-on-surface-variant/60 font-mono truncate">{p.base_url}</p>
            {p.api_key && <p class="text-xs text-on-surface-variant/40 mt-0.5">Key: ••••••••</p>}
          </div>
          <div class="flex items-center gap-1.5 flex-shrink-0">
            <button
              class="toggle-provider-btn w-8 h-8 rounded-lg flex items-center justify-center transition-all"
              data-id={p.id}
              data-active={p.is_active ? 1 : 0}
              title={p.is_active ? 'Tắt provider' : 'Bật provider'}
            >
              <span class={`material-symbols-outlined text-[18px] ${p.is_active ? 'text-emerald-400' : 'text-slate-500'}`}>
                {p.is_active ? 'toggle_on' : 'toggle_off'}
              </span>
            </button>
            <button class="edit-provider-btn btn-icon w-8 h-8 rounded-lg flex items-center justify-center text-on-surface-variant hover:text-primary hover:bg-primary/10" data-id={p.id} title="Sửa">
              <span class="material-symbols-outlined text-[18px]">edit</span>
            </button>
            <button class="delete-provider-btn btn-icon w-8 h-8 rounded-lg flex items-center justify-center text-on-surface-variant hover:text-red-400 hover:bg-red-500/10" data-id={p.id} title="Xóa">
              <span class="material-symbols-outlined text-[18px]">delete</span>
            </button>
          </div>
        </div>

        <!-- Models for this provider -->
        <div class="mt-4 pt-4 border-t border-outline-variant/15">
          <div class="flex items-center justify-between mb-3">
            <span class="text-xs font-semibold text-on-surface-variant/50 uppercase tracking-wider">Models</span>
            <button
              class="add-model-btn text-xs text-primary hover:text-primary/80 font-semibold flex items-center gap-1 transition-colors"
              data-provider-id={p.id}
            >
              <span class="material-symbols-outlined text-[14px]">add</span>
              Thêm model
            </button>
          </div>
          <div class="space-y-2" id={`models-${p.id}`}>
            {(modelsByProvider.get(p.id) || []).map((m) => (
              <div class="flex items-center gap-3 px-3 py-2 rounded-lg bg-surface-container/50 model-row" data-model-id={m.id}>
                <span class={`w-2 h-2 rounded-full flex-shrink-0 ${m.is_active ? 'bg-emerald-400' : 'bg-slate-600'}`}></span>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium text-on-surface">{m.name}</p>
                  <p class="text-xs text-on-surface-variant/50 font-mono">{m.model_id} · max {m.max_tokens || 8192} tokens</p>
                </div>
                <button
                  class="toggle-model-btn w-7 h-7 rounded-md flex items-center justify-center hover:bg-surface-container-high transition-all"
                  data-model-id={m.id}
                  data-active={m.is_active ? 1 : 0}
                >
                  <span class={`material-symbols-outlined text-[16px] ${m.is_active ? 'text-emerald-400' : 'text-slate-600'}`}>
                    {m.is_active ? 'toggle_on' : 'toggle_off'}
                  </span>
                </button>
                <button class="delete-model-btn w-7 h-7 rounded-md flex items-center justify-center text-on-surface-variant/40 hover:text-red-400 hover:bg-red-500/10 transition-all" data-model-id={m.id}>
                  <span class="material-symbols-outlined text-[14px]">close</span>
                </button>
              </div>
            ))}
            {(!modelsByProvider.get(p.id) || modelsByProvider.get(p.id)!.length === 0) && (
              <p class="text-xs text-on-surface-variant/30 py-2">Chưa có model nào.</p>
            )}
          </div>
        </div>
      </div>
    ))}

    {providers.length === 0 && (
      <div class="glass-card rounded-xl p-8 text-center">
        <span class="material-symbols-outlined text-slate-600 text-5xl mb-3">cloud_off</span>
        <p class="text-on-surface-variant">Chưa có provider nào. Nhấn "Thêm Provider" để bắt đầu.</p>
      </div>
    )}
  </div>

  <!-- Modal: Add/Edit Provider -->
  <div id="provider-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm">
    <div class="glass-card rounded-2xl p-6 w-full max-w-lg mx-4 space-y-4">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-bold text-white" id="provider-modal-title">Thêm Provider</h3>
        <button id="close-provider-modal" class="btn-icon w-8 h-8 rounded-lg text-on-surface-variant hover:text-white hover:bg-surface-container-high">
          <span class="material-symbols-outlined text-[20px]">close</span>
        </button>
      </div>
      <input type="hidden" id="pm-id" />
      <div>
        <label class="block text-xs font-semibold text-on-surface-variant/70 mb-1.5">Tên hiển thị</label>
        <input type="text" id="pm-name" placeholder="VD: OpenAI (GPT)" class="w-full px-4 py-2.5 bg-surface-container-high border border-outline-variant/30 text-white text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50" />
      </div>
      <div>
        <label class="block text-xs font-semibold text-on-surface-variant/70 mb-1.5">Slug</label>
        <input type="text" id="pm-slug" placeholder="VD: openai" class="w-full px-4 py-2.5 bg-surface-container-high border border-outline-variant/30 text-white text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50 font-mono" />
      </div>
      <div>
        <label class="block text-xs font-semibold text-on-surface-variant/70 mb-1.5">Base URL</label>
        <input type="url" id="pm-url" placeholder="https://api.openai.com/v1" class="w-full px-4 py-2.5 bg-surface-container-high border border-outline-variant/30 text-white text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50 font-mono" />
      </div>
      <div>
        <label class="block text-xs font-semibold text-on-surface-variant/70 mb-1.5">API Key</label>
        <input type="password" id="pm-key" placeholder="sk-..." class="w-full px-4 py-2.5 bg-surface-container-high border border-outline-variant/30 text-white text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50 font-mono" />
      </div>
      <div class="flex items-center gap-2">
        <input type="checkbox" id="pm-active" class="accent-primary w-4 h-4 rounded" checked />
        <label for="pm-active" class="text-sm text-on-surface">Kích hoạt ngay</label>
      </div>
      <div class="flex gap-3 pt-2">
        <button id="pm-save" class="flex-1 bg-primary text-white py-2.5 rounded-xl font-semibold hover:bg-primary/90 transition-all">Lưu</button>
        <button id="pm-cancel" class="px-5 py-2.5 bg-surface-container-high text-on-surface-variant rounded-xl hover:text-white transition-all">Hủy</button>
      </div>
      <p id="pm-error" class="hidden text-sm text-red-400"></p>
    </div>
  </div>

  <!-- Modal: Add Model -->
  <div id="model-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm">
    <div class="glass-card rounded-2xl p-6 w-full max-w-md mx-4 space-y-4">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-bold text-white">Thêm Model</h3>
        <button id="close-model-modal" class="btn-icon w-8 h-8 rounded-lg text-on-surface-variant hover:text-white hover:bg-surface-container-high">
          <span class="material-symbols-outlined text-[20px]">close</span>
        </button>
      </div>
      <input type="hidden" id="mm-provider-id" />
      <div>
        <label class="block text-xs font-semibold text-on-surface-variant/70 mb-1.5">Tên hiển thị</label>
        <input type="text" id="mm-name" placeholder="VD: GPT-4o" class="w-full px-4 py-2.5 bg-surface-container-high border border-outline-variant/30 text-white text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50" />
      </div>
      <div>
        <label class="block text-xs font-semibold text-on-surface-variant/70 mb-1.5">Model ID</label>
        <input type="text" id="mm-model-id" placeholder="VD: gpt-4o" class="w-full px-4 py-2.5 bg-surface-container-high border border-outline-variant/30 text-white text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50 font-mono" />
      </div>
      <div>
        <label class="block text-xs font-semibold text-on-surface-variant/70 mb-1.5">Max Tokens</label>
        <input type="number" id="mm-max-tokens" value="8192" min="256" class="w-full px-4 py-2.5 bg-surface-container-high border border-outline-variant/30 text-white text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50" />
      </div>
      <div class="flex gap-3 pt-2">
        <button id="mm-save" class="flex-1 bg-primary text-white py-2.5 rounded-xl font-semibold hover:bg-primary/90 transition-all">Lưu</button>
        <button id="mm-cancel" class="px-5 py-2.5 bg-surface-container-high text-on-surface-variant rounded-xl hover:text-white transition-all">Hủy</button>
      </div>
      <p id="mm-error" class="hidden text-sm text-red-400"></p>
    </div>
  </div>
</AdminLayout>

<script>
  function showToast(msg, type) {
    if ((window).showToast) (window).showToast(msg, type); else alert(msg);
  }
  function showModal(id) { const el = document.getElementById(id); if (el) { el.classList.remove('hidden'); el.classList.add('flex'); } }
  function hideModal(id) { const el = document.getElementById(id); if (el) { el.classList.add('hidden'); el.classList.remove('flex'); } }

  // Provider modal
  document.getElementById('add-provider-btn')?.addEventListener('click', () => {
    document.getElementById('pm-id').value = '';
    document.getElementById('pm-name').value = '';
    document.getElementById('pm-slug').value = '';
    document.getElementById('pm-url').value = '';
    document.getElementById('pm-key').value = '';
    document.getElementById('pm-active').checked = true;
    document.getElementById('pm-error').classList.add('hidden');
    document.getElementById('provider-modal-title').textContent = 'Thêm Provider';
    showModal('provider-modal');
  });

  document.querySelectorAll('.edit-provider-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const card = btn.closest('.provider-card');
      const name = card.querySelector('h4')?.textContent || '';
      const slug = card.dataset.id || '';
      const id = btn.dataset.id;
      // Find the provider data from the page
      const id2 = id;
      // Fetch provider data
      fetch('/api/admin/ai-providers').then(r => r.json()).then(data => {
        const p = data.providers.find(p => String(p.id) === String(id2));
        if (p) {
          document.getElementById('pm-id').value = p.id;
          document.getElementById('pm-name').value = p.name;
          document.getElementById('pm-slug').value = p.slug;
          document.getElementById('pm-url').value = p.base_url;
          document.getElementById('pm-key').value = p.api_key ? '••••••••' : '';
          document.getElementById('pm-active').checked = p.is_active === 1;
          document.getElementById('provider-modal-title').textContent = 'Sửa Provider';
          showModal('provider-modal');
        }
      });
    });
  });

  document.getElementById('pm-save')?.addEventListener('click', async () => {
    const id = document.getElementById('pm-id').value;
    const body = {
      action: 'upsert_provider',
      provider: {
        name: document.getElementById('pm-name').value.trim(),
        slug: document.getElementById('pm-slug').value.trim(),
        base_url: document.getElementById('pm-url').value.trim(),
        api_key: document.getElementById('pm-key').value.trim(),
        is_active: document.getElementById('pm-active').checked,
      },
    };
    if (id) (body as any).provider_id = parseInt(id);

    const res = await fetch('/api/admin/ai-providers', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    if (res.ok) {
      hideModal('provider-modal');
      showToast('Đã lưu provider!', 'success');
      setTimeout(() => location.reload(), 600);
    } else {
      const err = await res.json();
      const errEl = document.getElementById('pm-error');
      if (errEl) { errEl.textContent = err.error || 'Lỗi'; errEl.classList.remove('hidden'); }
    }
  });

  document.getElementById('close-provider-modal')?.addEventListener('click', () => hideModal('provider-modal'));
  document.getElementById('pm-cancel')?.addEventListener('click', () => hideModal('provider-modal'));

  // Toggle provider
  document.querySelectorAll('.toggle-provider-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = parseInt(btn.dataset.id || '0');
      const currentActive = parseInt(btn.dataset.active || '0') === 1;
      const res = await fetch('/api/admin/ai-providers', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'toggle_provider', provider_id: id, active: !currentActive }),
      });
      if (res.ok) {
        showToast(currentActive ? 'Đã tắt provider' : 'Đã bật provider', 'success');
        setTimeout(() => location.reload(), 400);
      }
    });
  });

  // Delete provider
  document.querySelectorAll('.delete-provider-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.id;
      if (!confirm('Xóa provider này và tất cả model của nó?')) return;
      const res = await fetch('/api/admin/ai-providers', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'delete_provider', provider_id: parseInt(id || '0') }),
      });
      if (res.ok) { showToast('Đã xóa', 'success'); setTimeout(() => location.reload(), 400); }
      else showToast('Xóa thất bại', 'error');
    });
  });

  // Model modal
  document.querySelectorAll('.add-model-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.getElementById('mm-provider-id').value = btn.dataset.providerId || '';
      document.getElementById('mm-name').value = '';
      document.getElementById('mm-model-id').value = '';
      document.getElementById('mm-max-tokens').value = '8192';
      document.getElementById('mm-error').classList.add('hidden');
      showModal('model-modal');
    });
  });

  document.getElementById('mm-save')?.addEventListener('click', async () => {
    const res = await fetch('/api/admin/ai-providers', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        action: 'upsert_model',
        model: {
          provider_id: parseInt(document.getElementById('mm-provider-id').value),
          name: document.getElementById('mm-name').value.trim(),
          model_id: document.getElementById('mm-model-id').value.trim(),
          max_tokens: parseInt(document.getElementById('mm-max-tokens').value) || 8192,
        },
      }),
    });
    if (res.ok) {
      hideModal('model-modal');
      showToast('Đã thêm model!', 'success');
      setTimeout(() => location.reload(), 600);
    } else {
      const err = await res.json();
      const errEl = document.getElementById('mm-error');
      if (errEl) { errEl.textContent = err.error || 'Lỗi'; errEl.classList.remove('hidden'); }
    }
  });

  document.getElementById('close-model-modal')?.addEventListener('click', () => hideModal('model-modal'));
  document.getElementById('mm-cancel')?.addEventListener('click', () => hideModal('model-modal'));

  // Toggle model
  document.querySelectorAll('.toggle-model-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = parseInt(btn.dataset.modelId || '0');
      const currentActive = parseInt(btn.dataset.active || '0') === 1;
      const res = await fetch('/api/admin/ai-providers', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'toggle_model', model_id: id, active: !currentActive }),
      });
      if (res.ok) setTimeout(() => location.reload(), 300);
    });
  });

  // Delete model
  document.querySelectorAll('.delete-model-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = parseInt(btn.dataset.modelId || '0');
      if (!confirm('Xóa model này?')) return;
      const res = await fetch('/api/admin/ai-providers', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'delete_model', model_id: id }),
      });
      if (res.ok) { showToast('Đã xóa model', 'success'); setTimeout(() => location.reload(), 400); }
    });
  });
</script>
