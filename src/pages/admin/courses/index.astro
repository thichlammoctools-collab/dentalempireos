---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';
import { listCourses } from '../../../lib/course-db';

export const prerender = false;

const db = env.DB;
const courses = await listCourses(db);

const publishedCount = courses.filter((c) => c.is_published === 1).length;
const draftCount = courses.filter((c) => c.is_published === 0).length;

function nanoid(): string {
  return crypto.randomUUID().replace(/-/g, '').slice(0, 16);
}

const newId = nanoid();
---

<AdminLayout title="Khóa Học | Admin">
  <!-- Header -->
  <div class="flex flex-col md:flex-row md:justify-between md:items-end gap-4">
    <div>
      <h2 class="text-3xl font-bold text-white mb-1">Quản lý Khóa Học</h2>
      <p class="text-on-surface-variant">
        {courses.length} khóa học · {publishedCount} đã xuất bản · {draftCount} bản nháp
      </p>
    </div>
    <button
      id="btn-new-course"
      class="bg-primary-container text-white px-6 py-3 rounded-xl font-bold cyan-glow hover:opacity-90 active:scale-95 transition-all flex items-center justify-center gap-2 self-start md:self-auto"
    >
      <span class="material-symbols-outlined text-[20px]">add</span>
      <span class="text-sm">Tạo khóa học mới</span>
    </button>
  </div>

  <!-- New Course Modal -->
  <div id="new-course-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="modal-backdrop"></div>
    <div class="relative glass-card rounded-2xl p-6 w-full max-w-md">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-xl font-bold text-white">Tạo khóa học mới</h3>
        <button id="modal-close" type="button" class="p-2 rounded-lg text-on-surface-variant hover:bg-surface-container-high transition-colors">
          <span class="material-symbols-outlined text-[20px]">close</span>
        </button>
      </div>
      <form id="new-course-form" class="flex flex-col gap-4">
        <input type="hidden" name="id" id="new-id" value={newId} />
        <div>
          <label class="block text-sm font-semibold text-on-surface-variant mb-2">Tiêu đề <span class="text-red-400">*</span></label>
          <input type="text" name="title" required
            class="w-full px-4 py-3 bg-surface-container-high border border-outline-variant rounded-xl text-white placeholder:text-white/30 focus:ring-1 focus:ring-primary focus:outline-none"
            placeholder="VD: Khóa học Quản trị Nha Khoa"
          />
        </div>
        <div>
          <label class="block text-sm font-semibold text-on-surface-variant mb-2">Mô tả</label>
          <textarea name="description" rows="3"
            class="w-full px-4 py-3 bg-surface-container-high border border-outline-variant rounded-xl text-white placeholder:text-white/30 focus:ring-1 focus:ring-primary focus:outline-none resize-none"
            placeholder="Mô tả ngắn về khóa học..."
          ></textarea>
        </div>
        <div>
          <label class="block text-sm font-semibold text-on-surface-variant mb-2">Ảnh bìa</label>
          <div id="course-thumb-picker" class="relative flex flex-col gap-2">
            <input type="hidden" name="thumbnail_url" id="new-thumb-url" value="" />
            <div id="course-thumb-drop" class="relative border-2 border-dashed border-outline-variant rounded-xl p-4 text-center cursor-pointer hover:border-primary/60 hover:bg-surface-container-high/50 transition-all">
              <input type="file" id="course-thumb-input" accept="image/*" class="hidden" />
              <div id="course-thumb-placeholder" class="flex flex-col items-center gap-1">
                <span class="material-symbols-outlined text-3xl text-on-surface-variant/40">add_photo_alternate</span>
                <p class="text-xs text-on-surface-variant/60">Paste ảnh · Kéo thả · Click để chọn</p>
              </div>
              <img id="course-thumb-preview" class="hidden max-h-24 mx-auto rounded-lg object-cover" alt="Preview" />
            </div>
            <div class="flex items-center gap-2">
              <div class="flex-1 h-px bg-outline-variant/30"></div>
              <span class="text-[10px] text-on-surface-variant/40 uppercase font-bold tracking-wider">hoặc</span>
              <div class="flex-1 h-px bg-outline-variant/30"></div>
            </div>
            <div class="flex gap-2">
              <div class="flex-1 relative">
                <input type="text" id="course-thumb-yt" placeholder="Dán YouTube URL để lấy thumbnail..."
                  class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-xl text-white text-sm placeholder:text-white/30 focus:ring-1 focus:ring-primary focus:outline-none" />
                <img id="course-thumb-yt-preview" class="hidden absolute bottom-full left-0 mb-2 w-32 rounded-lg object-cover shadow-lg border border-outline-variant" alt="YouTube thumbnail" />
              </div>
              <button type="button" id="course-thumb-clear" class="hidden px-3 py-2 border border-outline-variant text-on-surface-variant rounded-xl text-sm hover:bg-surface transition-all" title="Xóa ảnh bìa">
                <span class="material-symbols-outlined text-[18px]">delete</span>
              </button>
            </div>
          </div>
        </div>
        <div>
          <label class="block text-sm font-semibold text-on-surface-variant mb-2">Thứ tự</label>
          <input type="number" name="sort_order" value="0"
            class="w-full px-4 py-3 bg-surface-container-high border border-outline-variant rounded-xl text-white focus:ring-1 focus:ring-primary focus:outline-none"
          />
        </div>
        <div class="flex items-center gap-3">
          <input type="checkbox" name="is_published" id="new-published" value="1" class="w-4 h-4 accent-[#2b98dd]" />
          <label for="new-published" class="text-sm text-white">Xuất bản ngay</label>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="button" id="modal-cancel" class="flex-1 px-4 py-3 border border-outline-variant text-on-surface-variant rounded-xl font-bold hover:bg-surface-container-high transition-all">Hủy</button>
          <button type="submit" class="flex-1 px-4 py-3 bg-primary-container text-white rounded-xl font-bold hover:opacity-90 transition-all flex items-center justify-center gap-2">
            <span class="material-symbols-outlined text-[18px]">add</span>
            Tạo
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Courses Table -->
  {courses.length === 0 ? (
    <div class="text-center py-16 glass-card rounded-xl">
      <span class="material-symbols-outlined text-6xl text-on-surface-variant/40">school</span>
      <p class="text-on-surface-variant mt-3">Chưa có khóa học nào</p>
      <button id="btn-new-empty" class="inline-block mt-4 px-4 py-2 bg-primary text-white rounded-lg text-sm font-bold">+ Tạo khóa học đầu tiên</button>
    </div>
  ) : (
    <div class="glass-card rounded-xl overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="border-b border-outline-variant/50">
            <th class="text-left px-4 py-3 text-xs font-bold text-on-surface-variant uppercase tracking-wider">Khóa học</th>
            <th class="text-left px-4 py-3 text-xs font-bold text-on-surface-variant uppercase tracking-wider hidden md:table-cell">Videos</th>
            <th class="text-left px-4 py-3 text-xs font-bold text-on-surface-variant uppercase tracking-wider">Trạng thái</th>
            <th class="text-left px-4 py-3 text-xs font-bold text-on-surface-variant uppercase tracking-wider hidden lg:table-cell">Thứ tự</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant/20">
          {courses.map((course) => (
            <tr class="hover:bg-surface-container-high/50 transition-colors group">
              <td class="px-4 py-3">
                <div class="flex items-center gap-3">
                  {course.thumbnail_url ? (
                    <img src={course.thumbnail_url} alt={course.title} class="w-14 h-10 rounded-lg object-cover shrink-0" />
                  ) : (
                    <div class="w-14 h-10 rounded-lg bg-gradient-to-br from-primary/20 to-brand-cyan/20 shrink-0 flex items-center justify-center">
                      <span class="material-symbols-outlined text-lg text-primary/50">play_circle</span>
                    </div>
                  )}
                  <div class="min-w-0">
                    <p class="font-semibold text-white text-sm truncate max-w-[220px]">{course.title}</p>
                    {course.description && (
                      <p class="text-xs text-on-surface-variant/60 truncate max-w-[220px] mt-0.5">{course.description}</p>
                    )}
                  </div>
                </div>
              </td>
              <td class="px-4 py-3 hidden md:table-cell">
                <span class="text-sm text-on-surface-variant font-semibold">{course.video_count}</span>
              </td>
              <td class="px-4 py-3">
                <span class={`text-xs font-bold px-3 py-1.5 rounded-full ${course.is_published === 1 ? 'text-green-400 bg-green-400/10' : 'text-on-surface-variant bg-surface-container-high'}`}>
                  {course.is_published === 1 ? 'Đã xuất bản' : 'Bản nháp'}
                </span>
              </td>
              <td class="px-4 py-3 text-xs text-on-surface-variant hidden lg:table-cell">
                {course.sort_order}
              </td>
              <td class="px-4 py-3">
                <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                  <a
                    href={`/admin/courses/${course.id}`}
                    class="p-1.5 rounded-lg text-on-surface-variant hover:text-primary hover:bg-surface-container-high transition-all"
                    title="Quản lý videos"
                  >
                    <span class="material-symbols-outlined text-[16px]">video_library</span>
                  </a>
                  <button
                    type="button"
                    data-edit-course={course.id}
                    class="p-1.5 rounded-lg text-on-surface-variant hover:text-primary hover:bg-surface-container-high transition-all"
                    title="Sửa"
                  >
                    <span class="material-symbols-outlined text-[16px]">edit</span>
                  </button>
                  <button
                    type="button"
                    data-delete-course={course.id}
                    class="p-1.5 rounded-lg text-on-surface-variant hover:text-red-400 hover:bg-red-400/10 transition-all"
                    title="Xóa"
                  >
                    <span class="material-symbols-outlined text-[16px]">delete</span>
                  </button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</AdminLayout>

<script>
  declare function showToast(msg: string, type?: string): void;

  // ─── Thumbnail picker helpers ────────────────────────────────────────────────
  function extractYouTubeId(input: string): string | null {
    const patterns = [
      /(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([a-zA-Z0-9_-]{11})/,
      /^[a-zA-Z0-9_-]{11}$/,
    ];
    for (const p of patterns) {
      const m = input.match(p);
      if (m) return m[1];
    }
    return null;
  }

  function getYtThumb(id: string): string {
    return `https://img.youtube.com/vi/${id}/mqdefault.jpg`;
  }

  async function compressImage(file: File, maxW = 1280): Promise<Blob> {
    const bmp = await createImageBitmap(file);
    const scale = Math.min(1, maxW / Math.max(bmp.width, bmp.height));
    const w = Math.round(bmp.width * scale);
    const h = Math.round(bmp.height * scale);
    const canvas = new OffscreenCanvas(w, h);
    canvas.getContext('2d')!.drawImage(bmp, 0, 0, w, h);
    bmp.close();
    return canvas.convertToBlob({ type: 'image/jpeg', quality: 0.82 });
  }

  function setThumbUrl(url: string) {
    const input = document.getElementById('new-thumb-url') as HTMLInputElement;
    const preview = document.getElementById('course-thumb-preview') as HTMLImageElement;
    const placeholder = document.getElementById('course-thumb-placeholder') as HTMLDivElement;
    const clearBtn = document.getElementById('course-thumb-clear') as HTMLButtonElement;
    const drop = document.getElementById('course-thumb-drop') as HTMLDivElement;
    if (input) input.value = url;
    if (preview) { preview.src = url; preview.classList.remove('hidden'); }
    if (placeholder) placeholder.classList.add('hidden');
    if (clearBtn) clearBtn.classList.remove('hidden');
    drop.classList.remove('border-outline-variant', 'hover:border-primary/60');
    drop.classList.add('border-primary/40');
  }

  function clearThumb() {
    const input = document.getElementById('new-thumb-url') as HTMLInputElement;
    const preview = document.getElementById('course-thumb-preview') as HTMLImageElement;
    const placeholder = document.getElementById('course-thumb-placeholder') as HTMLDivElement;
    const clearBtn = document.getElementById('course-thumb-clear') as HTMLButtonElement;
    const fileInput = document.getElementById('course-thumb-input') as HTMLInputElement;
    const drop = document.getElementById('course-thumb-drop') as HTMLDivElement;
    if (input) input.value = '';
    if (preview) { preview.src = ''; preview.classList.add('hidden'); }
    if (placeholder) placeholder.classList.remove('hidden');
    if (clearBtn) clearBtn.classList.add('hidden');
    if (fileInput) fileInput.value = '';
    if (drop) { drop.classList.add('border-outline-variant', 'hover:border-primary/60'); drop.classList.remove('border-primary/40'); }
  }

  async function uploadThumbFile(file: File) {
    try {
      let bodyFile: File;
      if (file.size > 2 * 1024 * 1024) {
        bodyFile = new File([await compressImage(file)], file.name.replace(/\.[^.]+$/, '.jpg'), { type: 'image/jpeg' });
      } else {
        bodyFile = file;
      }
      const fd = new FormData();
      fd.append('file', bodyFile);
      fd.append('purpose', 'course');
      const res = await fetch('/api/admin/upload', { method: 'POST', body: fd });
      if (!res.ok) throw new Error('Upload failed');
      const data = await res.json() as { url?: string };
      setThumbUrl(data.url ?? '');
    } catch {
      showToast('Upload ảnh thất bại', 'error');
    }
  }

  function initThumbPicker() {
    const drop = document.getElementById('course-thumb-drop') as HTMLDivElement;
    const input = document.getElementById('course-thumb-input') as HTMLInputElement;
    const ytInput = document.getElementById('course-thumb-yt') as HTMLInputElement;
    const ytPreview = document.getElementById('course-thumb-yt-preview') as HTMLImageElement;
    const clearBtn = document.getElementById('course-thumb-clear') as HTMLButtonElement;

    // Click to select file
    drop?.addEventListener('click', () => input?.click());

    // File input change
    input?.addEventListener('change', () => {
      const f = input.files?.[0];
      if (f) uploadThumbFile(f);
    });

    // Drag & drop
    drop?.addEventListener('dragover', (e) => { e.preventDefault(); drop.classList.add('border-primary', 'bg-surface-container-high/50'); });
    drop?.addEventListener('dragleave', () => { drop.classList.remove('border-primary', 'bg-surface-container-high/50'); });
    drop?.addEventListener('drop', (e) => {
      e.preventDefault();
      drop.classList.remove('border-primary', 'bg-surface-container-high/50');
      const f = e.dataTransfer?.files[0];
      if (f?.type.startsWith('image/')) uploadThumbFile(f);
    });

    // Paste on drop area
    drop?.addEventListener('paste', (e) => {
      const f = e.clipboardData?.files[0];
      if (f?.type.startsWith('image/')) {
        e.preventDefault();
        uploadThumbFile(f);
      }
    });

    // Global paste (Ctrl+V anywhere in modal)
    document.getElementById('new-course-modal')?.addEventListener('paste', (e) => {
      const f = e.clipboardData?.files[0];
      if (f?.type.startsWith('image/')) {
        e.preventDefault();
        uploadThumbFile(f);
      }
    });

    // YouTube URL → thumbnail preview
    let ytTimer: ReturnType<typeof setTimeout>;
    ytInput?.addEventListener('input', () => {
      clearTimeout(ytTimer);
      const id = extractYouTubeId(ytInput.value);
      if (id) {
        const thumb = getYtThumb(id);
        ytPreview.src = thumb;
        ytPreview.classList.remove('hidden');
        ytTimer = setTimeout(() => setThumbUrl(thumb), 600);
      } else {
        ytPreview.classList.add('hidden');
      }
    });

    // Clear button
    clearBtn?.addEventListener('click', (e) => { e.stopPropagation(); clearThumb(); });
  }

  initThumbPicker();

  // Modal open/close
  function openModal() {
    clearThumb();
    document.getElementById('new-course-modal')?.classList.remove('hidden');
  }
  function closeModal() {
    document.getElementById('new-course-modal')?.classList.add('hidden');
  }
  document.getElementById('btn-new-course')?.addEventListener('click', openModal);
  document.getElementById('btn-new-empty')?.addEventListener('click', openModal);
  document.getElementById('modal-close')?.addEventListener('click', closeModal);
  document.getElementById('modal-cancel')?.addEventListener('click', closeModal);
  document.getElementById('modal-backdrop')?.addEventListener('click', closeModal);

  // New course form
  document.getElementById('new-course-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const formData = new FormData(form);
    const body: Record<string, FormDataEntryValue> = Object.fromEntries(formData.entries());
    body.is_published = (body.is_published ? 1 : 0) as unknown as FormDataEntryValue;
    body.sort_order = (parseInt(body.sort_order as string) || 0) as unknown as FormDataEntryValue;

    const res = await fetch('/api/admin/courses', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });

    if (res.ok) {
      closeModal();
      window.location.href = `/admin/courses/${body.id}`;
    } else {
      const err = await res.json() as { error?: string };
      showToast('Lỗi: ' + (err.error ?? 'Không rõ'), 'error');
    }
  });

  // Edit course
  document.querySelectorAll<HTMLButtonElement>('[data-edit-course]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.editCourse!;
      window.location.href = `/admin/courses/${id}`;
    });
  });

  // Delete course
  document.querySelectorAll<HTMLButtonElement>('[data-delete-course]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.deleteCourse!;
      if (!confirm('Xóa khóa học này? Tất cả video trong khóa học cũng sẽ bị xóa.')) return;
      const res = await fetch(`/api/admin/courses/${id}`, { method: 'DELETE' });
      if (res.ok) {
        btn.closest('tr')?.remove();
      } else {
        showToast('Xóa thất bại', 'error');
      }
    });
  });
</script>
