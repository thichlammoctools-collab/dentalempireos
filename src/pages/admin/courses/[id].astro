---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';
import { getCourse, getCourseVideos } from '../../../lib/course-db';

export const prerender = false;

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/courses');

const course = await getCourse(env.DB, id);
if (!course) return Astro.redirect('/admin/courses');

const videos = await getCourseVideos(env.DB, id);

function nanoid(): string {
  return crypto.randomUUID().replace(/-/g, '').slice(0, 16);
}

const newVideoId = nanoid();
---

<AdminLayout title={`${course.title} | Khóa Học`}>
  <!-- Header -->
  <div class="flex flex-col md:flex-row md:justify-between md:items-end gap-4">
    <div>
      <div class="flex items-center gap-2 text-sm text-on-surface-variant mb-2">
        <a href="/admin/courses" class="hover:text-primary transition-colors flex items-center gap-1">
          <span class="material-symbols-outlined text-[16px]">arrow_back</span>
          Khóa học
        </a>
        <span class="material-symbols-outlined text-[16px]">chevron_right</span>
        <span>{course.title}</span>
      </div>
      <h2 class="text-3xl font-bold text-white">{course.title}</h2>
      <p class="text-on-surface-variant text-sm mt-1">{videos.length} video · {course.is_published === 1 ? 'Đã xuất bản' : 'Bản nháp'}</p>
    </div>
    <div class="flex gap-2">
      <a href={`/courses/${id}`} target="_blank" class="px-4 py-2 border border-outline-variant text-on-surface-variant rounded-xl text-sm font-bold hover:border-primary hover:text-primary transition-all flex items-center gap-2">
        <span class="material-symbols-outlined text-[18px]">visibility</span>
        Xem
      </a>
    </div>
  </div>

  <!-- Course Info Form -->
  <section class="glass-card rounded-xl p-6">
    <h3 class="text-sm font-bold text-white mb-4 flex items-center gap-2">
      <span class="material-symbols-outlined text-primary text-[18px]">info</span>
      Thông tin khóa học
    </h3>
    <form id="course-form" class="flex flex-col sm:grid sm:grid-cols-2 gap-4">
      <input type="hidden" name="id" value={course.id} />
      <div class="sm:col-span-2">
        <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Tiêu đề</label>
        <input type="text" name="title" value={course.title} required
          class="w-full px-4 py-2.5 bg-surface-container-high border border-outline-variant rounded-xl text-white focus:ring-1 focus:ring-primary focus:outline-none" />
      </div>
      <div class="sm:col-span-2">
        <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Mô tả</label>
        <textarea name="description" rows="2"
          class="w-full px-4 py-2.5 bg-surface-container-high border border-outline-variant rounded-xl text-white focus:ring-1 focus:ring-primary focus:outline-none resize-none">{course.description ?? ''}</textarea>
      </div>
      <div>
        <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Ảnh bìa</label>
        <div id="course-thumb-picker" class="relative flex flex-col gap-2">
          <input type="hidden" name="thumbnail_url" id="edit-thumb-url" value={course.thumbnail_url ?? ''} />
          <div id="edit-thumb-drop" class={`relative border-2 border-dashed border-outline-variant rounded-xl p-4 text-center cursor-pointer hover:border-primary/60 hover:bg-surface-container-high/50 transition-all ${course.thumbnail_url ? 'border-primary/40' : ''}`}>
            <input type="file" id="edit-thumb-input" accept="image/*" class="hidden" />
            <div id="edit-thumb-placeholder" class={`flex flex-col items-center gap-1 ${course.thumbnail_url ? 'hidden' : ''}`}>
              <span class="material-symbols-outlined text-3xl text-on-surface-variant/40">add_photo_alternate</span>
              <p class="text-xs text-on-surface-variant/60">Paste ảnh · Kéo thả · Click để chọn</p>
            </div>
            {course.thumbnail_url ? (
              <img id="edit-thumb-preview" src={course.thumbnail_url} class="max-h-24 mx-auto rounded-lg object-cover" alt="Preview" />
            ) : (
              <img id="edit-thumb-preview" class="hidden max-h-24 mx-auto rounded-lg object-cover" alt="Preview" />
            )}
          </div>
          <div class="flex items-center gap-2">
            <div class="flex-1 h-px bg-outline-variant/30"></div>
            <span class="text-[10px] text-on-surface-variant/40 uppercase font-bold tracking-wider">hoặc</span>
            <div class="flex-1 h-px bg-outline-variant/30"></div>
          </div>
          <div class="flex gap-2">
            <div class="flex-1 relative">
              <input type="text" id="edit-thumb-yt" placeholder="Dán YouTube URL để lấy thumbnail..."
                class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-xl text-white text-sm placeholder:text-white/30 focus:ring-1 focus:ring-primary focus:outline-none" />
              <img id="edit-thumb-yt-preview" class="hidden absolute bottom-full left-0 mb-2 w-32 rounded-lg object-cover shadow-lg border border-outline-variant" alt="YouTube thumbnail" />
            </div>
            <button type="button" id="edit-thumb-clear" class={`${course.thumbnail_url ? '' : 'hidden'} px-3 py-2 border border-outline-variant text-on-surface-variant rounded-xl text-sm hover:bg-surface transition-all`} title="Xóa ảnh bìa">
              <span class="material-symbols-outlined text-[18px]">delete</span>
            </button>
          </div>
        </div>
      </div>
      <div>
        <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Thứ tự hiển thị</label>
        <input type="number" name="sort_order" value={course.sort_order}
          class="w-full px-4 py-2.5 bg-surface-container-high border border-outline-variant rounded-xl text-white focus:ring-1 focus:ring-primary focus:outline-none" />
      </div>
      <div class="flex items-center gap-3">
        <input type="checkbox" name="is_published" id="is-published" value="1"
          checked={course.is_published === 1}
          class="w-4 h-4 accent-[#2b98dd]" />
        <label for="is-published" class="text-sm text-white">Xuất bản</label>
      </div>
      <div class="sm:col-span-2 flex justify-end">
        <button type="submit" class="px-6 py-2.5 bg-primary-container text-white rounded-xl font-bold hover:opacity-90 transition-all flex items-center gap-2">
          <span class="material-symbols-outlined text-[18px]">save</span>
          Lưu thay đổi
        </button>
      </div>
    </form>
  </section>

  <!-- Videos Section -->
  <section class="glass-card rounded-xl p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-bold text-white flex items-center gap-2">
        <span class="material-symbols-outlined text-primary text-[18px]">video_library</span>
        Videos ({videos.length})
      </h3>
      <button
        id="btn-add-video"
        class="px-4 py-2 bg-primary-container text-white rounded-xl text-sm font-bold hover:opacity-90 transition-all flex items-center gap-2"
      >
        <span class="material-symbols-outlined text-[18px]">add</span>
        Thêm video
      </button>
    </div>

    <!-- Add Video Form -->
    <div id="add-video-form" class="hidden mb-6 p-4 bg-surface-container-high rounded-xl flex flex-col gap-3">
      <h4 class="text-sm font-bold text-white">Thêm video mới</h4>
      <input type="hidden" name="id" id="video-id" value={newVideoId} />
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1">YouTube ID <span class="text-red-400">*</span></label>
          <input type="text" id="video-youtube-id" required
            class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-xl text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none"
            placeholder="dQw4w9WgXcQ" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1">Tiêu đề <span class="text-red-400">*</span></label>
          <input type="text" id="video-title" required
            class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-xl text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none"
            placeholder="Tên bài giảng" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1">Thứ tự</label>
          <input type="number" id="video-sort-order" value={videos.length}
            class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-xl text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1">Thời lượng (giây)</label>
          <input type="number" id="video-duration"
            class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-xl text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none"
            placeholder="600" />
        </div>
      </div>
      <div>
        <label class="block text-xs font-semibold text-on-surface-variant mb-1">Mô tả</label>
        <textarea id="video-description" rows="2"
          class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-xl text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none resize-none"
          placeholder="Mô tả bài giảng..."></textarea>
      </div>
      <div class="flex gap-2">
        <button type="button" id="btn-cancel-video" class="px-4 py-2 border border-outline-variant text-on-surface-variant rounded-xl text-sm font-bold hover:bg-surface transition-all">Hủy</button>
        <button type="button" id="btn-save-video" class="px-4 py-2 bg-primary-container text-white rounded-xl text-sm font-bold hover:opacity-90 transition-all flex items-center gap-2">
          <span class="material-symbols-outlined text-[16px]">add</span>
          Thêm
        </button>
      </div>
    </div>

    <!-- Videos List -->
    {videos.length === 0 ? (
      <div class="text-center py-10">
        <span class="material-symbols-outlined text-5xl text-on-surface-variant/30">video_library</span>
        <p class="text-on-surface-variant mt-2 text-sm">Chưa có video nào. Thêm video đầu tiên.</p>
      </div>
    ) : (
      <div class="flex flex-col gap-2">
        {videos.map((video, index) => {
          const thumbnailUrl = `https://img.youtube.com/vi/${video.youtube_id}/mqdefault.jpg`;
          return (
            <div class="flex items-start gap-3 p-3 bg-surface-container rounded-xl hover:bg-surface-container-high transition-colors group video-row" data-video-id={video.id}>
              <span class="text-sm font-bold text-on-surface-variant/40 w-6 shrink-0 pt-1">{index + 1}</span>
              <img src={thumbnailUrl} alt={video.title} class="w-32 h-18 rounded-lg object-cover shrink-0" />
              <div class="flex-1 min-w-0">
                <p class="font-semibold text-white text-sm">{video.title}</p>
                <p class="text-xs text-on-surface-variant/60 mt-0.5">{video.youtube_id} · Thứ tự: {video.sort_order}</p>
                <span class={`inline-block text-[10px] font-bold px-2 py-0.5 rounded-full mt-1 ${video.is_published === 1 ? 'text-green-400 bg-green-400/10' : 'text-on-surface-variant bg-surface-container'}`}>
                  {video.is_published === 1 ? 'Đã xuất bản' : 'Bản nháp'}
                </span>
              </div>
              <div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                <button type="button" data-edit-video={video.id}
                  class="p-1.5 rounded-lg text-on-surface-variant hover:text-primary hover:bg-surface transition-all"
                  title="Sửa">
                  <span class="material-symbols-outlined text-[16px]">edit</span>
                </button>
                <button type="button" data-delete-video={video.id}
                  class="p-1.5 rounded-lg text-on-surface-variant hover:text-red-400 hover:bg-red-400/10 transition-all"
                  title="Xóa">
                  <span class="material-symbols-outlined text-[16px]">delete</span>
                </button>
              </div>
            </div>
          );
        })}
      </div>
    )}
  </section>
</AdminLayout>

<script>
  declare function showToast(msg: string, type?: string): void;

  // ─── Thumbnail picker helpers (same as courses/index.astro) ──────────────────
  function extractYouTubeId(input: string): string | null {
    const patterns = [
      /(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([a-zA-Z0-9_-]{11})/,
      /^[a-zA-Z0-9_-]{11}$/,
    ];
    for (const p of patterns) {
      const m = input.match(p);
      if (m) return m[1];
    }
    return null;
  }

  function getYtThumb(id: string): string {
    return `https://img.youtube.com/vi/${id}/mqdefault.jpg`;
  }

  async function compressImage(file: File, maxW = 1280): Promise<Blob> {
    const bmp = await createImageBitmap(file);
    const scale = Math.min(1, maxW / Math.max(bmp.width, bmp.height));
    const w = Math.round(bmp.width * scale);
    const h = Math.round(bmp.height * scale);
    const canvas = new OffscreenCanvas(w, h);
    canvas.getContext('2d')!.drawImage(bmp, 0, 0, w, h);
    bmp.close();
    return canvas.convertToBlob({ type: 'image/jpeg', quality: 0.82 });
  }

  function setEditThumbUrl(url: string) {
    const input = document.getElementById('edit-thumb-url') as HTMLInputElement;
    const preview = document.getElementById('edit-thumb-preview') as HTMLImageElement;
    const placeholder = document.getElementById('edit-thumb-placeholder') as HTMLDivElement;
    const clearBtn = document.getElementById('edit-thumb-clear') as HTMLButtonElement;
    const drop = document.getElementById('edit-thumb-drop') as HTMLDivElement;
    if (input) input.value = url;
    if (preview) { preview.src = url; preview.classList.remove('hidden'); }
    if (placeholder) placeholder.classList.add('hidden');
    if (clearBtn) clearBtn.classList.remove('hidden');
    drop.classList.remove('border-outline-variant', 'hover:border-primary/60');
    drop.classList.add('border-primary/40');
  }

  function clearEditThumb() {
    const input = document.getElementById('edit-thumb-url') as HTMLInputElement;
    const preview = document.getElementById('edit-thumb-preview') as HTMLImageElement;
    const placeholder = document.getElementById('edit-thumb-placeholder') as HTMLDivElement;
    const clearBtn = document.getElementById('edit-thumb-clear') as HTMLButtonElement;
    const fileInput = document.getElementById('edit-thumb-input') as HTMLInputElement;
    const drop = document.getElementById('edit-thumb-drop') as HTMLDivElement;
    if (input) input.value = '';
    if (preview) { preview.src = ''; preview.classList.add('hidden'); }
    if (placeholder) placeholder.classList.remove('hidden');
    if (clearBtn) clearBtn.classList.add('hidden');
    if (fileInput) fileInput.value = '';
    if (drop) { drop.classList.add('border-outline-variant', 'hover:border-primary/60'); drop.classList.remove('border-primary/40'); }
  }

  async function uploadEditThumbFile(file: File) {
    try {
      let bodyFile: File;
      if (file.size > 2 * 1024 * 1024) {
        bodyFile = new File([await compressImage(file)], file.name.replace(/\.[^.]+$/, '.jpg'), { type: 'image/jpeg' });
      } else {
        bodyFile = file;
      }
      const fd = new FormData();
      fd.append('file', bodyFile);
      fd.append('purpose', 'course');
      const res = await fetch('/api/admin/upload', { method: 'POST', body: fd });
      if (!res.ok) throw new Error('Upload failed');
      const data = await res.json() as { url?: string };
      setEditThumbUrl(data.url ?? '');
    } catch {
      showToast('Upload ảnh thất bại', 'error');
    }
  }

  function initEditThumbPicker() {
    const drop = document.getElementById('edit-thumb-drop') as HTMLDivElement;
    const input = document.getElementById('edit-thumb-input') as HTMLInputElement;
    const ytInput = document.getElementById('edit-thumb-yt') as HTMLInputElement;
    const ytPreview = document.getElementById('edit-thumb-yt-preview') as HTMLImageElement;
    const clearBtn = document.getElementById('edit-thumb-clear') as HTMLButtonElement;

    drop?.addEventListener('click', () => input?.click());
    input?.addEventListener('change', () => {
      const f = input.files?.[0];
      if (f) uploadEditThumbFile(f);
    });

    drop?.addEventListener('dragover', (e) => { e.preventDefault(); drop.classList.add('border-primary', 'bg-surface-container-high/50'); });
    drop?.addEventListener('dragleave', () => { drop.classList.remove('border-primary', 'bg-surface-container-high/50'); });
    drop?.addEventListener('drop', (e) => {
      e.preventDefault();
      drop.classList.remove('border-primary', 'bg-surface-container-high/50');
      const f = e.dataTransfer?.files[0];
      if (f?.type.startsWith('image/')) uploadEditThumbFile(f);
    });

    drop?.addEventListener('paste', (e) => {
      const f = e.clipboardData?.files[0];
      if (f?.type.startsWith('image/')) { e.preventDefault(); uploadEditThumbFile(f); }
    });

    document.addEventListener('paste', (e) => {
      const f = e.clipboardData?.files[0];
      if (f?.type.startsWith('image/') && (e.target as HTMLElement).closest('#course-thumb-picker')) {
        e.preventDefault();
        uploadEditThumbFile(f);
      }
    });

    let ytTimer: ReturnType<typeof setTimeout>;
    ytInput?.addEventListener('input', () => {
      clearTimeout(ytTimer);
      const id = extractYouTubeId(ytInput.value);
      if (id) {
        const thumb = getYtThumb(id);
        ytPreview.src = thumb;
        ytPreview.classList.remove('hidden');
        ytTimer = setTimeout(() => setEditThumbUrl(thumb), 600);
      } else {
        ytPreview.classList.add('hidden');
      }
    });

    clearBtn?.addEventListener('click', (e) => { e.stopPropagation(); clearEditThumb(); });
  }

  initEditThumbPicker();

  // Course form save
  document.getElementById('course-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const formData = new FormData(form);
    const body: Record<string, FormDataEntryValue> = Object.fromEntries(formData.entries());
    body.is_published = (body.is_published ? 1 : 0) as unknown as FormDataEntryValue;
    body.sort_order = (parseInt(body.sort_order as string) || 0) as unknown as FormDataEntryValue;
    const id = body.id;
    delete body.id;

    const res = await fetch(`/api/admin/courses/${id}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ ...body, id }),
    });

    if (res.ok) {
      const btn = (e.target as HTMLFormElement).querySelector('button[type="submit"]')!;
      const orig = btn.innerHTML;
      btn.innerHTML = '<span class="material-symbols-outlined text-[18px]">check</span> Đã lưu!';
      btn.classList.add('text-green-400');
      setTimeout(() => { btn.innerHTML = orig; btn.classList.remove('text-green-400'); }, 2000);
    } else {
      showToast('Lỗi khi lưu', 'error');
    }
  });

  // Toggle add video form
  document.getElementById('btn-add-video')?.addEventListener('click', () => {
    document.getElementById('add-video-form')?.classList.toggle('hidden');
  });
  document.getElementById('btn-cancel-video')?.addEventListener('click', () => {
    document.getElementById('add-video-form')?.classList.add('hidden');
  });

  // Add video
  document.getElementById('btn-save-video')?.addEventListener('click', async () => {
    const id = (document.getElementById('video-id') as HTMLInputElement).value;
    const youtube_id = (document.getElementById('video-youtube-id') as HTMLInputElement).value.trim();
    const title = (document.getElementById('video-title') as HTMLInputElement).value.trim();
    const description = (document.getElementById('video-description') as HTMLTextAreaElement).value.trim();
    const sort_order = parseInt((document.getElementById('video-sort-order') as HTMLInputElement).value) || 0;
    const duration_seconds = parseInt((document.getElementById('video-duration') as HTMLInputElement).value) || null;

    if (!youtube_id || !title) {
      showToast('YouTube ID và tiêu đề là bắt buộc', 'error');
      return;
    }

    const courseId = (document.querySelector('[name="id"]') as HTMLInputElement).value;
    const res = await fetch(`/api/admin/courses/${courseId}/videos`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id, youtube_id, title, description: description || null, sort_order, duration_seconds, is_published: 1 }),
    });

    if (res.ok) {
      window.location.reload();
    } else {
      const err = await res.json() as { error?: string };
      showToast('Lỗi: ' + (err.error ?? 'Không rõ'), 'error');
    }
  });

  // Delete video
  document.querySelectorAll<HTMLButtonElement>('[data-delete-video]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const vid = btn.dataset.deleteVideo!;
      if (!confirm('Xóa video này?')) return;
      const res = await fetch(`/api/admin/courses/videos/${vid}`, { method: 'DELETE' });
      if (res.ok) {
        btn.closest('.video-row')?.remove();
      } else {
        showToast('Xóa thất bại', 'error');
      }
    });
  });
</script>
