---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';
import { getAiSettings } from '../../lib/ai-settings-db';
import { hasAiGatewayToken } from '../../lib/ai-gateway';

export const prerender = false;

const settings = await getAiSettings(env.DB);
const gatewayReady = settings.gateway_enabled === 1 && Boolean(settings.gateway_account_id && settings.gateway_default_model);
const gatewayTokenSet = hasAiGatewayToken();
---

<AdminLayout title="Cài đặt AI | Admin">
  <div class="mb-6">
    <h2 class="text-3xl font-bold text-white mb-1">Cài đặt AI</h2>
    <p class="text-on-surface-variant text-sm">Mọi luồng AI của website chạy qua Cloudflare AI Gateway. Token chỉ được lưu dưới dạng Worker secret.</p>
  </div>

  <!-- ============================================================
       SECTION 1: AI Wizard Config
  ============================================================ -->
  <div class="glass-card rounded-xl p-6 mb-6">
    <div class="flex items-center gap-3 mb-5">
      <span class="material-symbols-outlined text-primary text-2xl">auto_awesome</span>
        <h3 class="text-lg font-bold text-white">Cloudflare AI Gateway</h3>
        <span class={`text-xs ml-2 ${gatewayReady ? 'text-emerald-300' : 'text-amber-300'}`}>{gatewayReady ? 'Đang hoạt động' : 'Chưa hoàn tất cấu hình'}</span>
    </div>

    <p class="text-xs text-on-surface-variant/60 mb-5">Cloudflare Unified Billing hoặc BYOK xử lý provider credentials. Không nhập OpenAI/Anthropic API key vào website.</p>
    <form id="gateway-form" class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-xs font-semibold text-on-surface-variant/70 uppercase tracking-wider mb-1.5">Cloudflare Account ID</label>
        <input type="text" id="gateway-account-id" value={settings.gateway_account_id ?? ''} placeholder="32-character account ID"
          class="w-full px-4 py-2.5 bg-surface-container border border-outline-variant/30 text-white text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50" />
      </div>
      <div>
        <label class="block text-xs font-semibold text-on-surface-variant/70 uppercase tracking-wider mb-1.5">Gateway ID</label>
        <input type="text" id="gateway-id" value={settings.gateway_id || 'default'} placeholder="dentalempire"
          class="w-full px-4 py-2.5 bg-surface-container border border-outline-variant/30 text-white text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50" />
      </div>
      <div>
        <label class="block text-xs font-semibold text-on-surface-variant/70 uppercase tracking-wider mb-1.5">Model mặc định</label>
        <input type="text" id="gateway-default-model" value={settings.gateway_default_model ?? ''} placeholder="openai/gpt-4.1-mini"
          class="w-full px-4 py-2.5 bg-surface-container border border-outline-variant/30 text-white text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50" />
      </div>
      <div>
        <label class="block text-xs font-semibold text-on-surface-variant/70 uppercase tracking-wider mb-1.5">Max output tokens</label>
        <input type="number" id="gateway-max-tokens" value={settings.max_tokens} min="256" max="8192"
          class="w-full px-4 py-2.5 bg-surface-container border border-outline-variant/30 text-white text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50" />
      </div>
      <div class="md:col-span-2 flex flex-wrap items-center gap-3">
        <label class="flex items-center gap-2 text-sm text-on-surface"><input type="checkbox" id="gateway-enabled" checked={settings.gateway_enabled === 1} class="accent-primary w-4 h-4" /> Kích hoạt AI Gateway</label>
        <button type="button" id="gateway-test" class="px-4 py-2 bg-surface-container border border-outline-variant/30 text-on-surface-variant text-sm font-medium rounded-xl hover:text-white transition-all">Test Gateway</button>
        <button type="submit" id="gateway-save" class="px-5 py-2 bg-primary text-white text-sm font-semibold rounded-xl hover:bg-primary/90 transition-all">Lưu Gateway</button>
        <span id="gateway-msg" class="hidden text-sm"></span>
      </div>
    </form>
    <p class={`mt-4 text-xs ${gatewayTokenSet ? 'text-emerald-300' : 'text-amber-300/80'}`}>{gatewayTokenSet ? 'Worker secret CF_AI_GATEWAY_TOKEN đã được thiết lập.' : 'Thiết lập secret trước khi bật: npx wrangler secret put CF_AI_GATEWAY_TOKEN. Token cần quyền AI Gateway; không được nhập token vào trang này.'}</p>
  </div>

  <!-- ============================================================
       SECTION 2: Public Chat Assistant Model
  ============================================================ -->
  <div class="glass-card rounded-xl p-6 mb-6">
    <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between mb-2">
      <div class="flex items-center gap-3">
      <span class="material-symbols-outlined text-primary text-2xl">forum</span>
      <div>
        <h3 class="text-lg font-bold text-white">Chat Assistant</h3>
        <p class="text-xs text-on-surface-variant/50">Mô hình phục vụ trợ lý AI hiển thị trên toàn website.</p>
      </div>
      </div>
      <div id="active-chat-status" class={`rounded-xl border px-4 py-3 text-sm ${settings.gateway_chat_model ? 'border-emerald-500/25 bg-emerald-500/10 text-emerald-200' : 'border-amber-500/25 bg-amber-500/10 text-amber-200'}`}>
        <div class="flex items-center gap-2 font-semibold">
          <span class="material-symbols-outlined text-[18px]">{settings.gateway_chat_model ? 'check_circle' : 'info'}</span>
          <span>{settings.gateway_chat_model ? 'AI đang hoạt động' : 'Chưa cấu hình AI chat'}</span>
        </div>
        <p id="active-chat-label" class="mt-1 text-xs opacity-80">
          {settings.gateway_chat_model || 'Nhập Cloudflare model ID rồi bấm Lưu Chat.'}
        </p>
      </div>
    </div>
    <form id="chat-model-form" class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-4 items-end mt-5">
      <div>
        <label for="gateway-chat-model" class="block text-xs font-semibold text-on-surface-variant/70 uppercase tracking-wider mb-1.5">Cloudflare model ID</label>
        <input id="gateway-chat-model" type="text" value={settings.gateway_chat_model ?? ''} placeholder="openai/gpt-4.1-mini"
          class="w-full px-4 py-2.5 bg-surface-container border border-outline-variant/30 text-white text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30" />
      </div>
      <button type="submit" id="chat-save" class="px-5 py-2.5 bg-primary text-white text-sm font-semibold rounded-xl hover:bg-primary/90 transition-all disabled:opacity-60 disabled:cursor-not-allowed">Lưu Chat</button>
      <p id="chat-save-msg" class="hidden md:col-span-2 text-sm"></p>
    </form>
  </div>

  <!-- ============================================================
       SECTION 3: Website Knowledge Base
  ============================================================ -->
  <div class="glass-card rounded-xl p-6 mb-6">
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <div class="flex items-start gap-3">
        <span class="material-symbols-outlined text-primary text-2xl">psychology</span>
        <div>
          <h3 class="text-lg font-bold text-white">Kho tri thức AI</h3>
          <p class="text-xs text-on-surface-variant/60 max-w-2xl">Đọc toàn bộ chương sách, bài viết và tài nguyên, sau đó tạo embedding để Chat Assistant tìm đúng nội dung khi trả lời.</p>
          <p class="text-xs text-amber-300/80 mt-1.5">Cần có một model embedding đang bật, ví dụ <code class="font-mono">text-embedding-3-small</code>. GPT chat không thể thay thế model embedding.</p>
        </div>
      </div>
    </div>
    <form id="embedding-model-form" class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-4 items-end mt-5">
      <div>
        <label for="gateway-embedding-model" class="block text-xs font-semibold text-on-surface-variant/70 uppercase tracking-wider mb-1.5">Cloudflare embedding model ID</label>
        <input id="gateway-embedding-model" type="text" value={settings.gateway_embedding_model ?? ''} placeholder="openai/text-embedding-3-small"
          class="w-full px-4 py-2.5 bg-surface-container border border-outline-variant/30 text-white text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30" />
      </div>
      <button type="submit" id="embedding-save" class="px-5 py-2.5 bg-surface-container-high border border-outline-variant/30 text-white text-sm font-semibold rounded-xl hover:border-primary/60 transition-all disabled:opacity-60 disabled:cursor-not-allowed">Lưu embedding</button>
      <p id="embedding-save-msg" class="hidden md:col-span-2 text-sm"></p>
    </form>
    <div class="mt-5 pt-5 border-t border-outline-variant/15 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
      <p id="embedding-active-label" class={`text-xs ${settings.gateway_embedding_model ? 'text-emerald-300' : 'text-amber-300/80'}`}>
        {settings.gateway_embedding_model ? `Đang dùng: ${settings.gateway_embedding_model}` : 'Chưa chọn model embedding.'}
      </p>
      <button id="rebuild-knowledge-btn" type="button" class="px-5 py-2.5 bg-primary text-white text-sm font-semibold rounded-xl hover:bg-primary/90 transition-all disabled:opacity-60 disabled:cursor-not-allowed flex items-center justify-center gap-2 shrink-0">
        <span class="material-symbols-outlined text-[18px]">database_upload</span>
        Xây dựng lại kho tri thức
      </button>
    </div>
    <p id="knowledge-sync-status" class="hidden mt-4 text-sm"></p>
  </div>

</AdminLayout>

<script>
  function showToast(msg, type) {
    if ((window as any).showToast) (window as any).showToast(msg, type); else alert(msg);
  }

  // ===================== Cloudflare AI Gateway =====================
  const gatewayForm = document.getElementById('gateway-form') as HTMLFormElement;
  const gatewaySaveBtn = document.getElementById('gateway-save') as HTMLButtonElement;
  const gatewayTestBtn = document.getElementById('gateway-test') as HTMLButtonElement;
  const gatewayMsg = document.getElementById('gateway-msg') as HTMLElement;

  gatewayForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    gatewayMsg.classList.add('hidden');
    gatewaySaveBtn.disabled = true;
    const body = {
      gateway_enabled: (document.getElementById('gateway-enabled') as HTMLInputElement).checked,
      gateway_account_id: (document.getElementById('gateway-account-id') as HTMLInputElement).value,
      gateway_id: (document.getElementById('gateway-id') as HTMLInputElement).value,
      gateway_default_model: (document.getElementById('gateway-default-model') as HTMLInputElement).value,
      max_tokens: Number((document.getElementById('gateway-max-tokens') as HTMLInputElement).value),
    };
    const res = await fetch('/api/admin/ai-settings', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
    });
    const data = await res.json() as { error?: string };
    gatewaySaveBtn.disabled = false;
    if (res.ok) { gatewayMsg.textContent = 'Đã lưu Cloudflare AI Gateway.'; gatewayMsg.className = 'text-sm text-emerald-400'; }
    else { gatewayMsg.textContent = data.error || 'Không thể lưu Gateway.'; gatewayMsg.className = 'text-sm text-rose-400'; }
    gatewayMsg.classList.remove('hidden');
  });

  gatewayTestBtn.addEventListener('click', async () => {
    gatewayTestBtn.disabled = true;
    gatewayMsg.textContent = 'Đang kiểm tra Cloudflare AI Gateway...';
    gatewayMsg.className = 'text-sm text-on-surface-variant';
    try {
      const res = await fetch('/api/admin/ai-test', { method: 'POST' });
      const data = await res.json() as { error?: string; model?: string };
      gatewayMsg.textContent = res.ok ? `Kết nối thành công với ${data.model}.` : data.error || 'Kiểm tra Gateway thất bại.';
      gatewayMsg.className = `text-sm ${res.ok ? 'text-emerald-400' : 'text-rose-400'}`;
    } catch {
      gatewayMsg.textContent = 'Không thể kết nối đến máy chủ để kiểm tra Gateway.';
      gatewayMsg.className = 'text-sm text-rose-400';
    } finally {
      gatewayTestBtn.disabled = false;
      gatewayMsg.classList.remove('hidden');
    }
  });

  // ===================== Public Chat model =====================
  const chatModel = document.getElementById('gateway-chat-model') as HTMLInputElement | null;
  const chatSaveBtn = document.getElementById('chat-save') as HTMLButtonElement | null;
  const chatSaveMsg = document.getElementById('chat-save-msg') as HTMLElement | null;
  const activeChatStatus = document.getElementById('active-chat-status') as HTMLElement | null;
  const activeChatLabel = document.getElementById('active-chat-label') as HTMLElement | null;

  function setChatSaveMessage(message: string, type: 'success' | 'error' | 'muted') {
    if (!chatSaveMsg) return;
    const color = type === 'success' ? 'text-emerald-400' : type === 'error' ? 'text-rose-400' : 'text-on-surface-variant';
    chatSaveMsg.textContent = message;
    chatSaveMsg.className = `${color} md:col-span-3 text-sm`;
  }

  function updateActiveChatStatus() {
    if (!chatModel || !activeChatStatus || !activeChatLabel) return;
    const hasSelection = Boolean(chatModel.value.trim());

    activeChatStatus.className = hasSelection
      ? 'rounded-xl border px-4 py-3 text-sm border-emerald-500/25 bg-emerald-500/10 text-emerald-200'
      : 'rounded-xl border px-4 py-3 text-sm border-amber-500/25 bg-amber-500/10 text-amber-200';
    const title = activeChatStatus.querySelector('span:last-child');
    const icon = activeChatStatus.querySelector('.material-symbols-outlined');
    if (title) title.textContent = hasSelection ? 'AI đang hoạt động' : 'Chưa cấu hình AI chat';
    if (icon) icon.textContent = hasSelection ? 'check_circle' : 'info';
    activeChatLabel.textContent = hasSelection
      ? chatModel.value.trim()
      : 'Nhập Cloudflare model ID rồi bấm Lưu Chat.';
  }
  chatModel?.addEventListener('change', () => setChatSaveMessage('Có thay đổi chưa lưu.', 'muted'));
  document.getElementById('chat-model-form')?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!chatModel?.value.trim()) { showToast('Nhập Cloudflare model ID cho Chat Assistant.', 'error'); return; }
    if (chatSaveBtn) chatSaveBtn.disabled = true;
    setChatSaveMessage('Đang lưu cấu hình Chat Assistant...', 'muted');
    try {
      const res = await fetch('/api/admin/ai-settings', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ gateway_chat_model: chatModel.value }),
      });
      if (res.ok) {
        updateActiveChatStatus();
        setChatSaveMessage('Đã lưu thành công. AI chat đang dùng cấu hình này.', 'success');
        showToast('Đã lưu mô hình Chat Assistant.', 'success');
      } else {
        const data = await res.json() as { error?: string };
        setChatSaveMessage(data.error || 'Không thể lưu cấu hình chat.', 'error');
        showToast(data.error || 'Không thể lưu cấu hình chat.', 'error');
      }
    } catch {
      setChatSaveMessage('Không thể kết nối để lưu cấu hình chat.', 'error');
      showToast('Không thể kết nối để lưu cấu hình chat.', 'error');
    } finally {
      if (chatSaveBtn) chatSaveBtn.disabled = false;
    }
  });

  // ===================== Website knowledge base =====================
  const embeddingModel = document.getElementById('gateway-embedding-model') as HTMLInputElement | null;
  const embeddingSaveBtn = document.getElementById('embedding-save') as HTMLButtonElement | null;
  const embeddingSaveMsg = document.getElementById('embedding-save-msg') as HTMLElement | null;
  const embeddingActiveLabel = document.getElementById('embedding-active-label') as HTMLElement | null;
  const rebuildKnowledgeBtn = document.getElementById('rebuild-knowledge-btn') as HTMLButtonElement | null;
  const knowledgeSyncStatus = document.getElementById('knowledge-sync-status') as HTMLElement | null;

  async function readJsonResponse<T>(response: Response): Promise<T & { error?: string }> {
    const text = await response.text();
    if (!text.trim()) {
      throw new Error(`Máy chủ trả về phản hồi rỗng (HTTP ${response.status}). Hãy kiểm tra bản deploy mới nhất.`);
    }
    try {
      return JSON.parse(text) as T & { error?: string };
    } catch {
      const summary = text.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim().slice(0, 180);
      throw new Error(`Máy chủ trả về phản hồi không hợp lệ (HTTP ${response.status})${summary ? `: ${summary}` : ''}`);
    }
  }

  function setEmbeddingSaveMessage(message: string, type: 'success' | 'error' | 'muted') {
    if (!embeddingSaveMsg) return;
    const color = type === 'success' ? 'text-emerald-400' : type === 'error' ? 'text-rose-400' : 'text-on-surface-variant';
    embeddingSaveMsg.textContent = message;
    embeddingSaveMsg.className = `${color} md:col-span-3 text-sm`;
  }

  embeddingModel?.addEventListener('change', () => setEmbeddingSaveMessage('Có thay đổi chưa lưu.', 'muted'));
  document.getElementById('embedding-model-form')?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!embeddingModel?.value.trim()) { showToast('Nhập Cloudflare embedding model ID.', 'error'); return; }
    if (embeddingSaveBtn) embeddingSaveBtn.disabled = true;
    setEmbeddingSaveMessage('Đang lưu model embedding...', 'muted');
    try {
      const response = await fetch('/api/admin/ai-settings', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ gateway_embedding_model: embeddingModel.value }),
      });
      const data = await readJsonResponse<{ error?: string }>(response);
      if (!response.ok) throw new Error(data.error || 'Không thể lưu model embedding.');
      if (embeddingActiveLabel) {
        embeddingActiveLabel.textContent = `Đang dùng: ${embeddingModel.value.trim()}`;
        embeddingActiveLabel.className = 'text-xs text-emerald-300';
      }
      setEmbeddingSaveMessage('Đã lưu model embedding.', 'success');
      showToast('Đã lưu model embedding.', 'success');
    } catch (error) {
      const message = error instanceof Error ? error.message : 'Không thể lưu model embedding.';
      setEmbeddingSaveMessage(message, 'error');
      showToast(message, 'error');
    } finally {
      if (embeddingSaveBtn) embeddingSaveBtn.disabled = false;
    }
  });

  function setKnowledgeSyncStatus(message: string, type: 'success' | 'error' | 'muted') {
    if (!knowledgeSyncStatus) return;
    const color = type === 'success' ? 'text-emerald-400' : type === 'error' ? 'text-rose-400' : 'text-on-surface-variant';
    knowledgeSyncStatus.textContent = message;
    knowledgeSyncStatus.className = `mt-4 text-sm ${color}`;
  }

  rebuildKnowledgeBtn?.addEventListener('click', async () => {
    rebuildKnowledgeBtn.disabled = true;
    const originalContent = rebuildKnowledgeBtn.innerHTML;
    rebuildKnowledgeBtn.innerHTML = '<span class="material-symbols-outlined text-[18px] animate-spin">progress_activity</span> Đang chuẩn bị...';

    try {
      setKnowledgeSyncStatus('Đang đọc và chia nhỏ nội dung sách, blog và tài nguyên...', 'muted');
      const rebuildResponse = await fetch('/api/admin/sync-website-content', {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({}),
      });
      const rebuildData = await readJsonResponse<{ chunks?: number; counts?: Record<string, number>; error?: string }>(rebuildResponse);
      if (!rebuildResponse.ok) throw new Error(rebuildData.error || 'Không thể xây dựng kho tri thức.');

      const totalChunks = rebuildData.chunks || 0;
      let embedded = 0;
      let remaining = totalChunks;
      do {
        setKnowledgeSyncStatus(`Đang tạo embedding: ${embedded}/${totalChunks} đoạn...`, 'muted');
        const vectorResponse = await fetch('/api/admin/sync-website-content-vectors', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ limit: 25 }),
        });
        const vectorData = await readJsonResponse<{ embedded?: number; remaining?: number; error?: string; errors?: string[] }>(vectorResponse);
        if (!vectorResponse.ok) throw new Error(vectorData.error || vectorData.errors?.[0] || 'Không thể tạo embedding.');
        embedded += vectorData.embedded || 0;
        remaining = vectorData.remaining || 0;
        if ((vectorData.embedded || 0) === 0 && remaining > 0) {
          throw new Error(vectorData.errors?.[0] || 'Không thể hoàn tất embedding.');
        }
      } while (remaining > 0);

      const bookCount = rebuildData.counts?.book || 0;
      setKnowledgeSyncStatus(`Hoàn tất: ${totalChunks} đoạn đã được index, gồm ${bookCount} đoạn từ sách. Chat Assistant có thể tra cứu kho tri thức mới.`, 'success');
      showToast('Đã xây dựng lại kho tri thức AI.', 'success');
    } catch (error) {
      const message = error instanceof Error ? error.message : 'Không thể xây dựng kho tri thức.';
      setKnowledgeSyncStatus(message, 'error');
      showToast(message, 'error');
    } finally {
      rebuildKnowledgeBtn.disabled = false;
      rebuildKnowledgeBtn.innerHTML = originalContent;
    }
  });

</script>
