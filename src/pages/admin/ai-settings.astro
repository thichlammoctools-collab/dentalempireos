---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';
import { getAiSettings } from '../../lib/ai-settings-db';

export const prerender = false;

const settings = await getAiSettings(env.DB);
---

<AdminLayout title="Cài đặt AI | Admin">
  <div class="mb-6">
    <h2 class="text-3xl font-bold text-white mb-1">Cài đặt AI</h2>
    <p class="text-on-surface-variant text-sm">
      API Key dùng cho AI Wizard tạo cấu hình ứng dụng. Để cấu hình provider cho app chạy thực tế, vào <a href="/admin/ai-providers" class="text-primary underline">AI Providers</a>.
    </p>
  </div>

  <form id="ai-form" class="flex flex-col gap-6">

    <!-- AI Status -->
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-amber-500 text-2xl">smart_toy</span>
          <h3 class="text-lg font-bold text-white">AI Analysis</h3>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox" id="f-is_active" class="sr-only peer" checked={settings.is_active === 1} />
          <div class="w-11 h-6 bg-surface-container border border-outline-variant/30 rounded-full peer peer-checked:after:translate-x-full peer-checked:bg-primary after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-on-surface-variant after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:bg-white"></div>
        </label>
      </div>
      <p class="text-sm text-on-surface-variant" id="status-text">
        {settings.is_active === 1 ? '✅ Đang hoạt động' : '⏸️ Tạm tắt'}
      </p>
    </div>

    <!-- API Configuration -->
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center gap-3 mb-5">
        <span class="material-symbols-outlined text-primary text-2xl">key</span>
        <h3 class="text-lg font-bold text-white">Cấu hình API</h3>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="md:col-span-2">
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Base URL</label>
          <input
            type="url"
            id="f-base_url"
            value={settings.base_url}
            placeholder="https://api.anthropic.com"
            class="w-full px-4 py-3 bg-surface-container border border-outline-variant/30 text-white text-sm rounded-lg focus:ring-1 focus:ring-primary focus:border-primary outline-none"
          />
          <p class="text-xs text-on-surface-variant mt-1.5">
            Endpoint API. Anthropic: <code class="text-amber-400">https://api.anthropic.com</code> · Custom: nhập URL proxy của bạn
          </p>
        </div>

        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">API Key</label>
          <input
            type="password"
            id="f-api_key"
            value={settings.api_key ? '•••' : ''}
            placeholder="sk-ant-..."
            class="w-full px-4 py-3 bg-surface-container border border-outline-variant/30 text-white text-sm rounded-lg focus:ring-1 focus:ring-primary focus:border-primary outline-none"
          />
          <p class="text-xs text-on-surface-variant mt-1.5" id="key-status">
            {settings.api_key ? `Đã lưu: ${settings.api_key}` : 'Chưa có API key'}
          </p>
        </div>

        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Model</label>
          <input
            type="text"
            id="f-model"
            value={settings.model}
            placeholder="claude-opus-4-8"
            class="w-full px-4 py-3 bg-surface-container border border-outline-variant/30 text-white text-sm rounded-lg focus:ring-1 focus:ring-primary focus:border-primary outline-none"
          />
          <p class="text-xs text-on-surface-variant mt-1.5">
            Claude Opus: <code class="text-amber-400">claude-opus-4-8</code> · Sonnet: <code class="text-amber-400">claude-sonnet-4-6</code> · Haiku: <code class="text-amber-400">claude-haiku-4-5-20251001</code>
          </p>
        </div>

        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Max Tokens</label>
          <input
            type="number"
            id="f-max_tokens"
            value={settings.max_tokens}
            min={256}
            max={8192}
            class="w-full px-4 py-3 bg-surface-container border border-outline-variant/30 text-white text-sm rounded-lg focus:ring-1 focus:ring-primary focus:border-primary outline-none"
          />
        </div>
      </div>
    </div>

    <!-- Actions -->
    <div class="flex justify-between items-center">
      <p class="text-xs text-on-surface-variant">
        {settings.updated_at ? `Cập nhật lần cuối: ${settings.updated_at}` : 'Chưa lưu lần nào'}
      </p>
      <div class="flex gap-3">
        <button
          type="button"
          id="btn-test"
          class="px-5 py-2.5 bg-surface-container border border-outline-variant/30 text-on-surface-variant text-sm font-semibold rounded-lg hover:text-white transition-all"
        >
          <span class="material-symbols-outlined text-base mr-1">play_arrow</span>
          Test Connection
        </button>
        <button
          type="submit"
          id="btn-save"
          class="px-5 py-2.5 bg-primary text-white text-sm font-semibold rounded-lg hover:bg-primary/90 transition-all"
        >
          <span class="material-symbols-outlined text-base mr-1">save</span>
          Lưu cài đặt
        </button>
      </div>
    </div>

    <p id="save-message" class="hidden text-sm"></p>
  </form>
</AdminLayout>

<script>
  const form = document.getElementById('ai-form') as HTMLFormElement;
  const btnSave = document.getElementById('btn-save') as HTMLButtonElement;
  const btnTest = document.getElementById('btn-test') as HTMLButtonElement;
  const msgEl = document.getElementById('save-message') as HTMLElement;
  const keyInput = document.getElementById('f-api_key') as HTMLInputElement;
  const keyStatus = document.getElementById('key-status') as HTMLElement;

  // Prevent password autofill from overwriting the placeholder
  keyInput.addEventListener('focus', () => {
    if (keyInput.value === '•••') keyInput.value = '';
  });
  keyInput.addEventListener('blur', () => {
    if (keyInput.value === '') keyInput.value = '•••';
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    msgEl.classList.add('hidden');
    btnSave.disabled = true;

    const isActive = (document.getElementById('f-is_active') as HTMLInputElement).checked;
    const baseUrl = (document.getElementById('f-base_url') as HTMLInputElement).value;
    const apiKey = (document.getElementById('f-api_key') as HTMLInputElement).value;
    const model = (document.getElementById('f-model') as HTMLInputElement).value;
    const maxTokens = parseInt((document.getElementById('f-max_tokens') as HTMLInputElement).value) || 4096;

    try {
      const res = await fetch('/api/admin/ai-settings', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          is_active: isActive,
          base_url: baseUrl,
          api_key: apiKey,
          model: model,
          max_tokens: maxTokens,
        }),
      });
      const data = await res.json() as { error?: string; settings?: { api_key_set?: boolean; api_key?: string } };

      if (!res.ok) throw new Error(data.error || 'Save failed');

      msgEl.textContent = '✅ Đã lưu cài đặt';
      msgEl.className = 'text-sm text-emerald-400';
      msgEl.classList.remove('hidden');

      // Update status
      const statusText = document.getElementById('status-text');
      if (statusText) statusText.textContent = isActive ? '✅ Đang hoạt động' : '⏸️ Tạm tắt';

      // Update key display
      if (data.settings?.api_key_set) {
        keyStatus.textContent = `Đã lưu: ${data.settings.api_key}`;
      }
    } catch (err) {
      msgEl.textContent = `❌ ${err instanceof Error ? err.message : 'Lỗi lưu'}`;
      msgEl.className = 'text-sm text-rose-400';
      msgEl.classList.remove('hidden');
    }

    btnSave.disabled = false;
  });

  // Test Connection button
  btnTest.addEventListener('click', async () => {
    msgEl.classList.add('hidden');
    btnTest.disabled = true;
    btnTest.textContent = '⏳ Đang test...';

    const baseUrl = (document.getElementById('f-base_url') as HTMLInputElement).value;
    const apiKey = (document.getElementById('f-api_key') as HTMLInputElement).value;
    const model = (document.getElementById('f-model') as HTMLInputElement).value;

    try {
      const res = await fetch(`${baseUrl.replace(/\/+$/, '')}/v1/messages`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-api-key': apiKey === '•••' ? '' : apiKey,
          'anthropic-version': '2023-06-01',
        },
        body: JSON.stringify({
          model,
          max_tokens: 50,
          messages: [{ role: 'user', content: 'Hello, respond with "OK" only.' }],
        }),
      });

      if (res.ok) {
        msgEl.textContent = '✅ Kết nối thành công! API key hoạt động.';
        msgEl.className = 'text-sm text-emerald-400';
      } else {
        const err = await res.text();
        msgEl.textContent = `❌ Lỗi ${res.status}: ${err.slice(0, 200)}`;
        msgEl.className = 'text-sm text-rose-400';
      }
    } catch (err) {
      msgEl.textContent = `❌ Không kết nối được: ${err instanceof Error ? err.message : 'Unknown'}`;
      msgEl.className = 'text-sm text-rose-400';
    }

    msgEl.classList.remove('hidden');
    btnTest.disabled = false;
    btnTest.innerHTML = '<span class="material-symbols-outlined text-base mr-1">play_arrow</span>Test Connection';
  });
</script>
