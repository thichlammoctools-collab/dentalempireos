---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';
import { getAiSettings } from '../../lib/ai-settings-db';
import { listProviders, listModels } from '../../lib/ai-provider-db';

export const prerender = false;

const settings = await getAiSettings(env.DB);
const providers = await listProviders(env.DB);
const models = await listModels(env.DB);
const modelsByProvider = new Map<number, typeof models>();
for (const m of models) {
  if (!modelsByProvider.has(m.provider_id)) modelsByProvider.set(m.provider_id, []);
  modelsByProvider.get(m.provider_id)!.push(m);
}
---

<AdminLayout title="Cài đặt AI | Admin">
  <div class="mb-6">
    <h2 class="text-3xl font-bold text-white mb-1">Cài đặt AI</h2>
    <p class="text-on-surface-variant text-sm">Cấu hình API cho AI Wizard tạo ứng dụng và AI Providers cho app chạy thực tế.</p>
  </div>

  <!-- ============================================================
       SECTION 1: AI Wizard Config
  ============================================================ -->
  <div class="glass-card rounded-xl p-6 mb-6">
    <div class="flex items-center gap-3 mb-5">
      <span class="material-symbols-outlined text-primary text-2xl">auto_awesome</span>
      <h3 class="text-lg font-bold text-white">AI Wizard</h3>
      <span class="text-xs text-on-surface-variant/50 ml-2">Dùng khi Wizard tạo ứng dụng mới</span>
    </div>

    <form id="wizard-form" class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="block text-xs font-semibold text-on-surface-variant/70 uppercase tracking-wider mb-1.5">Base URL</label>
        <input type="url" id="wiz-base_url" value={settings.base_url} placeholder="https://api.nkq.vn"
          class="w-full px-4 py-2.5 bg-surface-container border border-outline-variant/30 text-white text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50" />
      </div>
      <div>
        <label class="block text-xs font-semibold text-on-surface-variant/70 uppercase tracking-wider mb-1.5">API Key</label>
        <input type="password" id="wiz-api_key" value={settings.api_key ? '•••••••••••••••••••' : ''} placeholder="sk-ant-..."
          class="w-full px-4 py-2.5 bg-surface-container border border-outline-variant/30 text-white text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50" />
      </div>
      <div>
        <label class="block text-xs font-semibold text-on-surface-variant/70 uppercase tracking-wider mb-1.5">Model</label>
        <input type="text" id="wiz-model" value={settings.model} placeholder="claude-sonnet-4-6"
          class="w-full px-4 py-2.5 bg-surface-container border border-outline-variant/30 text-white text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50" />
      </div>
      <div class="md:col-span-3 flex items-center gap-3">
        <button type="button" id="wiz-test" class="px-4 py-2 bg-surface-container border border-outline-variant/30 text-on-surface-variant text-sm font-medium rounded-xl hover:text-white transition-all">▶ Test</button>
        <button type="submit" id="wiz-save" class="px-5 py-2 bg-primary text-white text-sm font-semibold rounded-xl hover:bg-primary/90 transition-all">Lưu</button>
        <span id="wiz-msg" class="hidden text-sm"></span>
      </div>
    </form>
  </div>

  <!-- ============================================================
       SECTION 2: AI Providers
  ============================================================ -->
  <div class="glass-card rounded-xl p-6">
    <div class="flex items-center justify-between mb-5">
      <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-primary text-2xl">cloud</span>
        <div>
          <h3 class="text-lg font-bold text-white">AI Providers</h3>
          <p class="text-xs text-on-surface-variant/50">Dùng khi app AI chạy thực tế với người dùng</p>
        </div>
      </div>
      <button id="add-provider-btn" class="px-4 py-2 bg-primary text-white text-sm font-semibold rounded-xl flex items-center gap-2 hover:bg-primary/90 transition-all">
        <span class="material-symbols-outlined text-[16px]">add</span> Thêm Provider
      </button>
    </div>

    <div class="space-y-4" id="providers-list">
      {providers.map((p) => (
        <div class="rounded-xl p-5 bg-surface-container/50 border border-outline-variant/15 provider-card" data-id={p.id}>
          <div class="flex items-start gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-3 mb-1">
                <h4 class="text-base font-bold text-white">{p.name}</h4>
                <span class={`px-2 py-0.5 rounded-full text-[10px] font-bold ${p.is_active ? 'bg-emerald-500/20 text-emerald-300' : 'bg-slate-500/20 text-slate-400'}`}>
                  {p.is_active ? 'HOẠT ĐỘNG' : 'TẮT'}
                </span>
              </div>
              <p class="text-xs text-on-surface-variant/60 font-mono truncate">{p.base_url}</p>
              {p.api_key && <p class="text-xs text-on-surface-variant/40 mt-0.5">Key: ••••••••</p>}
            </div>
            <div class="flex items-center gap-1.5 flex-shrink-0">
              <button class="toggle-provider-btn w-8 h-8 rounded-lg flex items-center justify-center transition-all" data-id={p.id} data-active={p.is_active ? 1 : 0} title={p.is_active ? 'Tắt' : 'Bật'}>
                <span class={`material-symbols-outlined text-[18px] ${p.is_active ? 'text-emerald-400' : 'text-slate-500'}`}>{p.is_active ? 'toggle_on' : 'toggle_off'}</span>
              </button>
              <button class="test-provider-btn w-8 h-8 rounded-lg flex items-center justify-center text-on-surface-variant hover:text-emerald-400 hover:bg-emerald-500/10" data-id={p.id} data-url={p.base_url} data-key={p.api_key} title="Test">
                <span class="material-symbols-outlined text-[18px]">play_arrow</span>
              </button>
              <button class="edit-provider-btn w-8 h-8 rounded-lg flex items-center justify-center text-on-surface-variant hover:text-primary hover:bg-primary/10" data-id={p.id} title="Sửa">
                <span class="material-symbols-outlined text-[18px]">edit</span>
              </button>
              <button class="delete-provider-btn w-8 h-8 rounded-lg flex items-center justify-center text-on-surface-variant hover:text-red-400 hover:bg-red-500/10" data-id={p.id} title="Xóa">
                <span class="material-symbols-outlined text-[18px]">delete</span>
              </button>
            </div>
          </div>

          <!-- Models -->
          <div class="mt-4 pt-4 border-t border-outline-variant/15">
            <div class="flex items-center justify-between mb-3">
              <span class="text-xs font-semibold text-on-surface-variant/50 uppercase tracking-wider">Models</span>
              <button class="add-model-btn text-xs text-primary hover:text-primary/80 font-semibold flex items-center gap-1" data-provider-id={p.id}>
                <span class="material-symbols-outlined text-[14px]">add</span> Thêm model
              </button>
            </div>
            <div class="space-y-2" id={`models-${p.id}`}>
              {(modelsByProvider.get(p.id) || []).map((m) => (
                <div class="flex items-center gap-3 px-3 py-2 rounded-lg bg-surface/50 model-row" data-model-id={m.id}>
                  <span class={`w-2 h-2 rounded-full flex-shrink-0 ${m.is_active ? 'bg-emerald-400' : 'bg-slate-600'}`}></span>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-on-surface">{m.name}</p>
                    <p class="text-xs text-on-surface-variant/50 font-mono">{m.model_id} · max {m.max_tokens || 8192} tokens</p>
                  </div>
                  <button class="toggle-model-btn w-7 h-7 rounded-md flex items-center justify-center hover:bg-surface-container-high" data-model-id={m.id} data-active={m.is_active ? 1 : 0}>
                    <span class={`material-symbols-outlined text-[16px] ${m.is_active ? 'text-emerald-400' : 'text-slate-600'}`}>{m.is_active ? 'toggle_on' : 'toggle_off'}</span>
                  </button>
                  <button class="delete-model-btn w-7 h-7 rounded-md flex items-center justify-center text-on-surface-variant/40 hover:text-red-400" data-model-id={m.id}>
                    <span class="material-symbols-outlined text-[14px]">close</span>
                  </button>
                </div>
              ))}
              {(!modelsByProvider.get(p.id) || modelsByProvider.get(p.id)!.length === 0) && (
                <p class="text-xs text-on-surface-variant/30 py-2">Chưa có model nào.</p>
              )}
            </div>
          </div>
        </div>
      ))}

      {providers.length === 0 && (
        <div class="text-center py-8">
          <span class="material-symbols-outlined text-slate-600 text-4xl mb-3">cloud_off</span>
          <p class="text-on-surface-variant text-sm">Chưa có provider nào.</p>
        </div>
      )}
    </div>
  </div>
</AdminLayout>

<!-- Modal: Provider -->
<div id="provider-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm">
  <div class="glass-card rounded-2xl p-6 w-full max-w-lg mx-4 space-y-4">
    <div class="flex items-center justify-between">
      <h3 class="text-lg font-bold text-white" id="provider-modal-title">Thêm Provider</h3>
      <button id="close-provider-modal" class="w-8 h-8 rounded-lg text-on-surface-variant hover:text-white hover:bg-surface-container-high flex items-center justify-center">
        <span class="material-symbols-outlined text-[20px]">close</span>
      </button>
    </div>
    <input type="hidden" id="pm-id" />
    <div>
      <label class="block text-xs font-semibold text-on-surface-variant/70 mb-1.5">Tên hiển thị</label>
      <input type="text" id="pm-name" placeholder="VD: OpenAI (GPT)" class="w-full px-4 py-2.5 bg-surface-container-high border border-outline-variant/30 text-white text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50" />
    </div>
    <div>
      <label class="block text-xs font-semibold text-on-surface-variant/70 mb-1.5">Slug</label>
      <input type="text" id="pm-slug" placeholder="VD: openai" class="w-full px-4 py-2.5 bg-surface-container-high border border-outline-variant/30 text-white text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50 font-mono" />
    </div>
    <div>
      <label class="block text-xs font-semibold text-on-surface-variant/70 mb-1.5">Base URL</label>
      <input type="url" id="pm-url" placeholder="https://api.openai.com/v1" class="w-full px-4 py-2.5 bg-surface-container-high border border-outline-variant/30 text-white text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50 font-mono" />
    </div>
    <div>
      <label class="block text-xs font-semibold text-on-surface-variant/70 mb-1.5">API Key</label>
      <input type="password" id="pm-key" placeholder="sk-..." class="w-full px-4 py-2.5 bg-surface-container-high border border-outline-variant/30 text-white text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50 font-mono" />
    </div>
    <div class="flex items-center gap-2">
      <input type="checkbox" id="pm-active" class="accent-primary w-4 h-4 rounded" checked />
      <label for="pm-active" class="text-sm text-on-surface">Kích hoạt ngay</label>
    </div>
    <div class="flex gap-3 pt-2">
      <button id="pm-save" class="flex-1 bg-primary text-white py-2.5 rounded-xl font-semibold hover:bg-primary/90 transition-all">Lưu</button>
      <button id="pm-cancel" class="px-5 py-2.5 bg-surface-container-high text-on-surface-variant rounded-xl hover:text-white transition-all">Hủy</button>
    </div>
    <p id="pm-error" class="hidden text-sm text-red-400"></p>
  </div>
</div>

<!-- Modal: Model -->
<div id="model-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm">
  <div class="glass-card rounded-2xl p-6 w-full max-w-md mx-4 space-y-4">
    <div class="flex items-center justify-between">
      <h3 class="text-lg font-bold text-white">Thêm Model</h3>
      <button id="close-model-modal" class="w-8 h-8 rounded-lg text-on-surface-variant hover:text-white hover:bg-surface-container-high flex items-center justify-center">
        <span class="material-symbols-outlined text-[20px]">close</span>
      </button>
    </div>
    <input type="hidden" id="mm-provider-id" />
    <div>
      <label class="block text-xs font-semibold text-on-surface-variant/70 mb-1.5">Tên hiển thị</label>
      <input type="text" id="mm-name" placeholder="VD: GPT-4o" class="w-full px-4 py-2.5 bg-surface-container-high border border-outline-variant/30 text-white text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50" />
    </div>
    <div>
      <label class="block text-xs font-semibold text-on-surface-variant/70 mb-1.5">Model ID</label>
      <input type="text" id="mm-model-id" placeholder="VD: gpt-4o" class="w-full px-4 py-2.5 bg-surface-container-high border border-outline-variant/30 text-white text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50 font-mono" />
    </div>
    <div>
      <label class="block text-xs font-semibold text-on-surface-variant/70 mb-1.5">Max Tokens</label>
      <input type="number" id="mm-max-tokens" value="8192" min="256" class="w-full px-4 py-2.5 bg-surface-container-high border border-outline-variant/30 text-white text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50" />
    </div>
    <div class="flex gap-3 pt-2">
      <button id="mm-save" class="flex-1 bg-primary text-white py-2.5 rounded-xl font-semibold hover:bg-primary/90 transition-all">Lưu</button>
      <button id="mm-cancel" class="px-5 py-2.5 bg-surface-container-high text-on-surface-variant rounded-xl hover:text-white transition-all">Hủy</button>
    </div>
    <p id="mm-error" class="hidden text-sm text-red-400"></p>
  </div>
</div>

<script>
  function showToast(msg, type) {
    if ((window as any).showToast) (window as any).showToast(msg, type); else alert(msg);
  }
  function showModal(id: string) { const el = document.getElementById(id); if (el) { el.classList.remove('hidden'); el.classList.add('flex'); } }
  function hideModal(id: string) { const el = document.getElementById(id); if (el) { el.classList.add('hidden'); el.classList.remove('flex'); } }

  // ===================== Wizard form =====================
  const wizForm = document.getElementById('wizard-form') as HTMLFormElement;
  const wizSaveBtn = document.getElementById('wiz-save') as HTMLButtonElement;
  const wizTestBtn = document.getElementById('wiz-test') as HTMLButtonElement;
  const wizMsg = document.getElementById('wiz-msg') as HTMLElement;
  const wizKey = document.getElementById('wiz-api_key') as HTMLInputElement;
  wizKey.addEventListener('focus', () => { if (wizKey.value.includes('•')) wizKey.value = ''; });

  wizForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    wizMsg.classList.add('hidden');
    wizSaveBtn.disabled = true;
    const body: Record<string, unknown> = {
      is_active: true,
      base_url: (document.getElementById('wiz-base_url') as HTMLInputElement).value,
      model: (document.getElementById('wiz-model') as HTMLInputElement).value,
      max_tokens: 4096,
    };
    const keyVal = wizKey.value.trim();
    // Only send api_key if user typed something new (not just the masked dots)
    if (keyVal && keyVal.replace(/[^\S ]/g, '').length > 0 && !/^[\s•]+$/.test(keyVal)) {
      body.api_key = keyVal;
    }
    const res = await fetch('/api/admin/ai-settings', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
    });
    const data = await res.json() as { error?: string };
    wizSaveBtn.disabled = false;
    if (res.ok) { wizMsg.textContent = '✅ Đã lưu'; wizMsg.className = 'text-sm text-emerald-400'; }
    else { wizMsg.textContent = `❌ ${data.error || 'Lỗi'}`; wizMsg.className = 'text-sm text-rose-400'; }
    wizMsg.classList.remove('hidden');
  });

  wizTestBtn.addEventListener('click', async () => {
    wizTestBtn.disabled = true; wizTestBtn.textContent = '⏳...';
    const baseUrl = (document.getElementById('wiz-base_url') as HTMLInputElement).value;
    const apiKey = (document.getElementById('wiz-api_key') as HTMLInputElement).value;
    const model = (document.getElementById('wiz-model') as HTMLInputElement).value;
    try {
      const res = await fetch(`${baseUrl.replace(/\/+$/, '')}/v1/messages`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'x-api-key': apiKey, 'anthropic-version': '2023-06-01' },
        body: JSON.stringify({ model, max_tokens: 10, messages: [{ role: 'user', content: 'Hi' }] }),
      });
      wizMsg.textContent = res.ok ? '✅ Kết nối thành công' : `❌ Lỗi ${res.status}`;
      wizMsg.className = `text-sm ${res.ok ? 'text-emerald-400' : 'text-rose-400'}`;
    } catch { wizMsg.textContent = '❌ Không kết nối được'; wizMsg.className = 'text-sm text-rose-400'; }
    wizMsg.classList.remove('hidden');
    wizTestBtn.disabled = false; wizTestBtn.textContent = '▶ Test';
  });

  // ===================== Provider CRUD =====================
  document.getElementById('add-provider-btn')?.addEventListener('click', () => {
    (document.getElementById('pm-id') as HTMLInputElement).value = '';
    (document.getElementById('pm-name') as HTMLInputElement).value = '';
    (document.getElementById('pm-slug') as HTMLInputElement).value = '';
    (document.getElementById('pm-url') as HTMLInputElement).value = '';
    (document.getElementById('pm-key') as HTMLInputElement).value = '';
    (document.getElementById('pm-active') as HTMLInputElement).checked = true;
    (document.getElementById('pm-error') as HTMLElement).classList.add('hidden');
    (document.getElementById('provider-modal-title') as HTMLElement).textContent = 'Thêm Provider';
    showModal('provider-modal');
  });

  document.querySelectorAll('.edit-provider-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-id') || '';
      fetch('/api/admin/ai-providers').then(r => r.json()).then(data => {
        const p = data.providers.find((x: any) => String(x.id) === id);
        if (p) {
          (document.getElementById('pm-id') as HTMLInputElement).value = p.id;
          (document.getElementById('pm-name') as HTMLInputElement).value = p.name;
          (document.getElementById('pm-slug') as HTMLInputElement).value = p.slug;
          (document.getElementById('pm-url') as HTMLInputElement).value = p.base_url;
          (document.getElementById('pm-key') as HTMLInputElement).value = p.api_key ? '••••••••' : '';
          (document.getElementById('pm-active') as HTMLInputElement).checked = p.is_active === 1;
          (document.getElementById('provider-modal-title') as HTMLElement).textContent = 'Sửa Provider';
          showModal('provider-modal');
        }
      });
    });
  });

  // Test provider button
  document.querySelectorAll('.test-provider-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const url = btn.getAttribute('data-url') || '';
      const key = btn.getAttribute('data-key') || '';
      if (!key) { alert('Provider này chưa có API key'); return; }
      const icon = btn.querySelector('span');
      if (icon) { icon.textContent = 'sync'; icon.style.animation = 'spin 1s linear infinite'; }
      try {
        const base = url.replace(/\/+$/, '').replace(/\/v1$/, '');
        // Try OpenAI-compatible endpoint
        const res = await fetch(`${base}/v1/chat/completions`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${key}` },
          body: JSON.stringify({ model: 'gpt-4o', max_tokens: 5, messages: [{ role: 'user', content: 'Hi' }] }),
        });
        const msg = res.ok ? '✅ Kết nối thành công!' : `❌ Lỗi ${res.status}`;
        alert(msg);
      } catch { alert('❌ Không kết nối được'); }
      if (icon) { icon.textContent = 'play_arrow'; icon.style.animation = ''; }
    });
  });

  document.getElementById('pm-save')?.addEventListener('click', async () => {
    const id = (document.getElementById('pm-id') as HTMLInputElement).value;
    const keyVal = (document.getElementById('pm-key') as HTMLInputElement).value.trim();
    const body: any = {
      action: 'upsert_provider',
      provider: {
        name: (document.getElementById('pm-name') as HTMLInputElement).value.trim(),
        slug: (document.getElementById('pm-slug') as HTMLInputElement).value.trim(),
        base_url: (document.getElementById('pm-url') as HTMLInputElement).value.trim(),
        // Only send api_key if user typed a real value (not the masked dots placeholder)
        ...(keyVal && !/^[\s•]+$/.test(keyVal) ? { api_key: keyVal } : {}),
        is_active: (document.getElementById('pm-active') as HTMLInputElement).checked,
      },
    };
    if (id) body.provider_id = parseInt(id);
    const res = await fetch('/api/admin/ai-providers', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
    if (res.ok) { hideModal('provider-modal'); showToast('Đã lưu provider!', 'success'); setTimeout(() => location.reload(), 600); }
    else { const err = await res.json(); const el = document.getElementById('pm-error'); if (el) { el.textContent = err.error || 'Lỗi'; el.classList.remove('hidden'); } }
  });

  document.getElementById('close-provider-modal')?.addEventListener('click', () => hideModal('provider-modal'));
  document.getElementById('pm-cancel')?.addEventListener('click', () => hideModal('provider-modal'));

  document.querySelectorAll('.toggle-provider-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = parseInt(btn.getAttribute('data-id') || '0');
      const active = parseInt(btn.getAttribute('data-active') || '0') === 1;
      const res = await fetch('/api/admin/ai-providers', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'toggle_provider', provider_id: id, active: !active }) });
      if (res.ok) setTimeout(() => location.reload(), 300);
    });
  });

  document.querySelectorAll('.delete-provider-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-id');
      if (!confirm('Xóa provider này?')) return;
      const res = await fetch('/api/admin/ai-providers', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'delete_provider', provider_id: parseInt(id || '0') }) });
      if (res.ok) { showToast('Đã xóa', 'success'); setTimeout(() => location.reload(), 400); }
      else showToast('Xóa thất bại', 'error');
    });
  });

  // ===================== Model CRUD =====================
  document.querySelectorAll('.add-model-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      (document.getElementById('mm-provider-id') as HTMLInputElement).value = btn.getAttribute('data-provider-id') || '';
      (document.getElementById('mm-name') as HTMLInputElement).value = '';
      (document.getElementById('mm-model-id') as HTMLInputElement).value = '';
      (document.getElementById('mm-max-tokens') as HTMLInputElement).value = '8192';
      (document.getElementById('mm-error') as HTMLElement).classList.add('hidden');
      showModal('model-modal');
    });
  });

  document.getElementById('mm-save')?.addEventListener('click', async () => {
    const res = await fetch('/api/admin/ai-providers', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        action: 'upsert_model',
        model: {
          provider_id: parseInt((document.getElementById('mm-provider-id') as HTMLInputElement).value),
          name: (document.getElementById('mm-name') as HTMLInputElement).value.trim(),
          model_id: (document.getElementById('mm-model-id') as HTMLInputElement).value.trim(),
          max_tokens: parseInt((document.getElementById('mm-max-tokens') as HTMLInputElement).value) || 8192,
        },
      }),
    });
    if (res.ok) { hideModal('model-modal'); showToast('Đã thêm model!', 'success'); setTimeout(() => location.reload(), 600); }
    else { const err = await res.json(); const el = document.getElementById('mm-error'); if (el) { el.textContent = err.error || 'Lỗi'; el.classList.remove('hidden'); } }
  });

  document.getElementById('close-model-modal')?.addEventListener('click', () => hideModal('model-modal'));
  document.getElementById('mm-cancel')?.addEventListener('click', () => hideModal('model-modal'));

  document.querySelectorAll('.toggle-model-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = parseInt(btn.getAttribute('data-model-id') || '0');
      const active = parseInt(btn.getAttribute('data-active') || '0') === 1;
      const res = await fetch('/api/admin/ai-providers', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'toggle_model', model_id: id, active: !active }) });
      if (res.ok) setTimeout(() => location.reload(), 300);
    });
  });

  document.querySelectorAll('.delete-model-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = parseInt(btn.getAttribute('data-model-id') || '0');
      if (!confirm('Xóa model này?')) return;
      const res = await fetch('/api/admin/ai-providers', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'delete_model', model_id: id }) });
      if (res.ok) { showToast('Đã xóa model', 'success'); setTimeout(() => location.reload(), 400); }
    });
  });
</script>
