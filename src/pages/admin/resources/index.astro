---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { resourceCategories } from '../../../data/resources';
---

<AdminLayout title="Resources | Dental Empire Admin">
  <!-- Header -->
  <div class="flex flex-col md:flex-row md:justify-between md:items-end gap-4">
    <div>
      <h2 class="text-3xl font-bold text-white mb-1">Quản lý Resources</h2>
      <p class="text-on-surface-variant" id="resource-stats">Đang tải...</p>
    </div>
    <div class="flex items-center gap-3 self-start md:self-auto">
      <a
        href="/resources"
        class="border-2 border-outline text-on-surface-variant px-5 py-3 rounded-xl font-bold hover:border-primary hover:text-primary active:scale-95 transition-all flex items-center gap-2"
      >
        <span class="material-symbols-outlined text-[20px]">visibility</span>
        <span class="text-sm">Xem trang public</span>
      </a>
      <button
        type="button"
        id="btn-add-resource"
        class="bg-primary-container text-white px-6 py-3 rounded-xl font-bold cyan-glow hover:opacity-90 active:scale-95 transition-all flex items-center gap-2"
      >
        <span class="material-symbols-outlined text-[20px]">upload_file</span>
        <span class="text-sm">Thêm tài nguyên</span>
      </button>
    </div>
  </div>

  <!-- Filters -->
  <div class="flex flex-wrap items-center gap-2" id="resource-filters">
    {resourceCategories.map((c, i) => (
      <button
        type="button"
        data-filter={c.id}
        class:list={[
          'filter-chip px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider border transition-all active:scale-95',
          i === 0
            ? 'bg-primary text-on-primary border-primary'
            : 'bg-surface-container-high text-on-surface-variant border-outline-variant',
        ]}
      >
        {c.label}
      </button>
    ))}
  </div>

  <!-- Resource grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="resource-list"></div>

  <!-- Empty state -->
  <div id="resource-empty" class="hidden text-center py-16">
    <span class="material-symbols-outlined text-6xl text-on-surface-variant/40">search_off</span>
    <p class="text-on-surface-variant mt-3">Không có tài nguyên nào khớp bộ lọc</p>
  </div>

  <!-- Modal: Create / Edit Resource -->
  <div
    id="resource-modal"
    class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/70 backdrop-blur-md p-4"
  >
    <div class="w-full max-w-2xl max-h-[90vh] overflow-y-auto bg-surface-container border border-outline-variant rounded-2xl shadow-2xl animate-scale-in scrollbar-hide">
      <!-- Modal Header -->
      <div class="sticky top-0 z-10 flex items-center justify-between px-6 py-4 bg-surface-container border-b border-outline-variant/60 rounded-t-2xl">
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-xl bg-primary/10 flex items-center justify-center">
            <span class="material-symbols-outlined text-[20px] text-primary" id="modal-icon">add_circle</span>
          </div>
          <h3 class="text-lg font-bold text-white" id="modal-title">Thêm tài nguyên mới</h3>
        </div>
        <button
          type="button"
          id="modal-close"
          class="w-8 h-8 rounded-lg flex items-center justify-center text-on-surface-variant hover:text-white hover:bg-surface-container-high transition-all"
        >
          <span class="material-symbols-outlined text-[20px]">close</span>
        </button>
      </div>

      <form id="resource-form" class="p-6 space-y-6">
        <input type="hidden" id="f-id" value="" />

        <!-- Section: Thông tin cơ bản -->
        <div class="space-y-4">
          <div class="flex items-center gap-2 mb-1">
            <span class="material-symbols-outlined text-[16px] text-primary">info</span>
            <span class="text-xs font-bold text-on-surface-variant uppercase tracking-wider">Thông tin cơ bản</span>
          </div>

          <!-- Title -->
          <div>
            <label class="block text-xs font-bold text-on-surface-variant mb-1.5">Tiêu đề <span class="text-error">*</span></label>
            <input
              id="f-title"
              type="text"
              required
              class="w-full px-4 py-2.5 bg-surface-container-high border border-outline-variant/60 rounded-xl text-white text-sm placeholder:text-on-surface-variant/50 focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none transition-all"
              placeholder="VD: Quy trình đón tiếp bệnh nhân"
            />
          </div>

          <!-- Description -->
          <div>
            <label class="block text-xs font-bold text-on-surface-variant mb-1.5">Mô tả</label>
            <textarea
              id="f-description"
              rows={2}
              class="w-full px-4 py-2.5 bg-surface-container-high border border-outline-variant/60 rounded-xl text-white text-sm placeholder:text-on-surface-variant/50 focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none resize-none transition-all"
              placeholder="Mô tả ngắn gọn nội dung tài nguyên..."
            ></textarea>
          </div>
        </div>

        <div class="h-px bg-outline-variant/30"></div>

        <!-- Section: Phân loại -->
        <div class="space-y-4">
          <div class="flex items-center gap-2 mb-1">
            <span class="material-symbols-outlined text-[16px] text-tertiary">label</span>
            <span class="text-xs font-bold text-on-surface-variant uppercase tracking-wider">Phân loại</span>
          </div>

          <!-- Row: Category + Tier -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-bold text-on-surface-variant mb-1.5">Danh mục</label>
              <div class="relative">
                <select id="f-category" class="w-full px-4 py-2.5 bg-surface-container-high border border-outline-variant/60 rounded-xl text-white text-sm appearance-none focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none transition-all cursor-pointer">
                  <option value="bieu_mau">📄 Biểu mẫu</option>
                  <option value="checklist">✅ Checklist</option>
                  <option value="sops">📋 SOPs</option>
                  <option value="cong_cu">🔧 Công cụ</option>
                  <option value="tham_khao">📚 Tham khảo</option>
                </select>
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-[18px] text-on-surface-variant pointer-events-none">expand_more</span>
              </div>
            </div>
            <div>
              <label class="block text-xs font-bold text-on-surface-variant mb-1.5">Loại</label>
              <div class="relative">
                <select id="f-tier" class="w-full px-4 py-2.5 bg-surface-container-high border border-outline-variant/60 rounded-xl text-white text-sm appearance-none focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none transition-all cursor-pointer">
                  <option value="free">🆓 Miễn phí</option>
                  <option value="premium">⭐ Premium</option>
                </select>
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-[18px] text-on-surface-variant pointer-events-none">expand_more</span>
              </div>
            </div>
          </div>

          <!-- Row: File ext + Tag -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-bold text-on-surface-variant mb-1.5">Định dạng</label>
              <div class="relative">
                <select id="f-file_ext" class="w-full px-4 py-2.5 bg-surface-container-high border border-outline-variant/60 rounded-xl text-white text-sm appearance-none focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none transition-all cursor-pointer">
                  <option value="pdf">📄 PDF</option>
                  <option value="xlsx">📊 Excel (XLSX)</option>
                  <option value="docx">📝 Word (DOCX)</option>
                  <option value="mp4">🎬 Video (MP4)</option>
                </select>
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-[18px] text-on-surface-variant pointer-events-none">expand_more</span>
              </div>
            </div>
            <div>
              <label class="block text-xs font-bold text-on-surface-variant mb-1.5">Tag hiển thị</label>
              <input
                id="f-tag"
                type="text"
                class="w-full px-4 py-2.5 bg-surface-container-high border border-outline-variant/60 rounded-xl text-white text-sm placeholder:text-on-surface-variant/50 focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none transition-all"
                placeholder="VD: Vận hành, KPI, Marketing..."
              />
            </div>
          </div>
        </div>

        <div class="h-px bg-outline-variant/30"></div>

        <!-- Section: File & Icon -->
        <div class="space-y-4">
          <div class="flex items-center gap-2 mb-1">
            <span class="material-symbols-outlined text-[16px] text-primary">attach_file</span>
            <span class="text-xs font-bold text-on-surface-variant uppercase tracking-wider">Tệp tin</span>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-bold text-on-surface-variant mb-1.5">Icon (Material)</label>
              <div class="relative">
                <span class="material-symbols-outlined absolute left-3.5 top-1/2 -translate-y-1/2 text-[18px] text-primary pointer-events-none" id="icon-preview">description</span>
                <input
                  id="f-icon"
                  type="text"
                  class="w-full pl-11 pr-4 py-2.5 bg-surface-container-high border border-outline-variant/60 rounded-xl text-white text-sm placeholder:text-on-surface-variant/50 focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none transition-all"
                  placeholder="description"
                  value="description"
                />
              </div>
            </div>
            <div>
              <label class="block text-xs font-bold text-on-surface-variant mb-1.5">File tải xuống</label>
              <input type="hidden" id="f-file_url" value="" />
              <div class="relative">
                <input
                  id="f-file_url_text"
                  type="url"
                  class="w-full pl-11 pr-4 py-2.5 bg-surface-container-high border border-outline-variant/60 rounded-xl text-white text-sm placeholder:text-on-surface-variant/50 focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none transition-all"
                  placeholder="Hoặc dán URL: https://drive.google.com/..."
                />
                <span class="material-symbols-outlined absolute left-3.5 top-1/2 -translate-y-1/2 text-[18px] text-on-surface-variant pointer-events-none">link</span>
              </div>
            </div>
          </div>

          <!-- Upload zone -->
          <div
            id="upload-zone"
            class="relative border-2 border-dashed border-outline-variant/60 rounded-xl p-4 text-center cursor-pointer hover:border-primary/60 hover:bg-primary/5 transition-all group"
          >
            <input type="file" id="f-file-input" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" accept=".pdf,.xlsx,.docx,.mp4,.pptx" />
            <div class="flex flex-col items-center gap-1.5 pointer-events-none">
              <span class="material-symbols-outlined text-[28px] text-on-surface-variant/50 group-hover:text-primary transition-colors">cloud_upload</span>
              <p class="text-xs text-on-surface-variant">
                <span class="font-bold text-primary group-hover:underline">Chọn file</span> hoặc kéo thả vào đây
              </p>
              <p class="text-[10px] text-on-surface-variant/50">PDF, Excel, Word, MP4, PPTX — tối đa 100MB</p>
            </div>
          </div>

          <!-- Upload progress -->
          <div id="upload-progress" class="hidden">
            <div class="flex items-center gap-3 bg-surface-container-high rounded-xl p-3 border border-outline-variant/30">
              <div class="relative w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-[20px] text-primary" id="upload-file-icon">description</span>
                <div class="absolute inset-0 rounded-lg border-2 border-primary/30 border-t-primary animate-spin" id="upload-spinner"></div>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-xs font-bold text-white truncate" id="upload-file-name">Đang tải lên...</p>
                <div class="w-full h-1 bg-surface-container-highest rounded-full mt-1.5 overflow-hidden">
                  <div class="h-full bg-primary rounded-full transition-all duration-300" id="upload-bar" style="width:0%"></div>
                </div>
              </div>
              <button type="button" id="upload-cancel-btn" class="text-on-surface-variant hover:text-error transition-colors pointer-events-auto">
                <span class="material-symbols-outlined text-[18px]">close</span>
              </button>
            </div>
          </div>

          <!-- Upload success -->
          <div id="upload-success" class="hidden">
            <div class="flex items-center gap-3 bg-emerald-500/10 rounded-xl p-3 border border-emerald-500/20">
              <div class="w-10 h-10 rounded-lg bg-emerald-500/15 flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-[20px] text-emerald-400">check_circle</span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-xs font-bold text-emerald-300 truncate" id="upload-success-name">File đã tải lên</p>
                <p class="text-[10px] text-on-surface-variant mt-0.5">Lưu vào R2 thành công</p>
              </div>
              <button type="button" id="upload-remove-btn" class="text-on-surface-variant hover:text-error transition-colors">
                <span class="material-symbols-outlined text-[18px]">delete</span>
              </button>
            </div>
          </div>
        </div>

        <div class="h-px bg-outline-variant/30"></div>

        <!-- Section: Cài đặt -->
        <div class="space-y-4">
          <div class="flex items-center gap-2 mb-1">
            <span class="material-symbols-outlined text-[16px] text-tertiary">tune</span>
            <span class="text-xs font-bold text-on-surface-variant uppercase tracking-wider">Cài đặt</span>
          </div>

          <div>
            <label class="block text-xs font-bold text-on-surface-variant mb-1.5">Thứ tự sắp xếp</label>
            <div class="relative max-w-[140px]">
              <input
                id="f-sort_order"
                type="number"
                class="w-full px-4 py-2.5 bg-surface-container-high border border-outline-variant/60 rounded-xl text-white text-sm focus:ring-2 focus:ring-primary/40 focus:border-primary outline-none transition-all"
                value="0"
                min="0"
              />
            </div>
          </div>
        </div>

        <!-- Actions -->
        <div class="flex items-center gap-3 pt-2">
          <button
            type="submit"
            id="modal-submit"
            class="flex-1 btn-primary-metallic py-3 rounded-xl font-bold text-sm flex items-center justify-center gap-2"
          >
            <span class="material-symbols-outlined text-[18px]">save</span>
            Lưu tài nguyên
          </button>
          <button
            type="button"
            id="modal-cancel"
            class="px-5 py-3 rounded-xl font-bold text-sm border border-outline-variant text-on-surface-variant hover:border-white hover:text-white hover:bg-surface-container-high transition-all"
          >
            Hủy
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Confirm Delete Dialog -->
  <div
    id="delete-modal"
    class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm"
  >
    <div class="glass-card-elevated rounded-2xl w-full max-w-sm mx-4 p-6 animate-scale-in text-center">
      <span class="material-symbols-outlined text-5xl text-error mb-3">warning</span>
      <h3 class="text-lg font-bold text-white mb-1">Xóa tài nguyên?</h3>
      <p class="text-on-surface-variant text-sm mb-6" id="delete-name"></p>
      <div class="flex items-center gap-3">
        <button type="button" id="delete-cancel" class="flex-1 px-4 py-3 rounded-xl font-bold border-2 border-outline text-on-surface-variant hover:border-white hover:text-white transition-all">
          Hủy
        </button>
        <button type="button" id="delete-confirm" class="flex-1 bg-error text-white py-3 rounded-xl font-bold hover:opacity-90 active:scale-95 transition-all">
          Xóa
        </button>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  // ── Types ─────────────────────────────────────────────────
  interface Resource {
    id: string; title: string; description: string; category: string;
    tier: string; file_ext: string; tag: string; icon: string;
    file_url: string; sort_order: number; is_active: number; updated_at?: string;
  }
  declare function showToast(message: string, type?: string, duration?: number): void;

  // ── State ─────────────────────────────────────────────────
  let allResources: Resource[] = [];
  let activeFilter = 'all';
  let editingId: string | null = null;
  let deletingId: string | null = null;

  const extColors: Record<string, string> = {
    pdf: 'text-rose-300 bg-rose-500/10',
    xlsx: 'text-emerald-300 bg-emerald-500/10',
    docx: 'text-sky-300 bg-sky-500/10',
    mp4: 'text-amber-300 bg-amber-500/10',
  };

  // ── DOM refs ──────────────────────────────────────────────
  const listEl = el('resource-list')!;
  const emptyEl = el('resource-empty')!;
  const statsEl = el('resource-stats')!;
  const chips = Array.from(document.querySelectorAll('.filter-chip'));

  const modal = el('resource-modal')!;
  const modalTitle = el('modal-title')!;
  const modalClose = el('modal-close')!;
  const modalCancel = el('modal-cancel')!;
  const modalSubmit = el('modal-submit')!;
  const form = el('resource-form')! as HTMLFormElement;

  const deleteModal = el('delete-modal')!;
  const deleteName = el('delete-name')!;
  const deleteCancel = el('delete-cancel')!;
  const deleteConfirm = el('delete-confirm')!;

  // ── Helpers ─────────────────────────────────────────────
  function val(id: string) { return (document.getElementById(id) as HTMLInputElement)?.value ?? ''; }
  function setVal(id: string, v: string) { const el = document.getElementById(id) as HTMLInputElement; if (el) el.value = v; }
  function el(id: string) { return document.getElementById(id); }

  // ── Fetch & Render ────────────────────────────────────────
  async function loadResources() {
    try {
      const res = await fetch('/api/admin/resources', { credentials: 'include' });
      if (!res.ok) {
        const err = await res.text();
        statsEl.textContent = `Lỗi: ${res.status} ${err}`;
        return;
      }
      allResources = await res.json();
      render();
    } catch (err) {
      statsEl.textContent = `Lỗi kết nối: ${err}`;
    }
  }

  function render() {
    const visible = allResources.filter(
      (r) => activeFilter === 'all' || r.category === activeFilter
    );

    // Stats
    const total = allResources.length;
    const freeCount = allResources.filter((r) => r.tier === 'free').length;
    statsEl.textContent = `${total} tài nguyên · ${freeCount} miễn phí · ${total - freeCount} premium`;

    // Cards
    listEl.innerHTML = visible
      .map((r) => {
        const colors = extColors[r.file_ext] ?? 'text-gray-300 bg-gray-500/10';
        const tierBadge =
          r.tier === 'free'
            ? '<span class="text-[10px] font-bold px-1.5 py-0.5 rounded uppercase text-primary bg-primary/10">Free</span>'
            : '<span class="text-[10px] font-bold px-1.5 py-0.5 rounded uppercase text-tertiary bg-tertiary/10">Premium</span>';

        return `
          <article class="resource-card glass-card rounded-xl p-5 flex items-start gap-4" data-category="${r.category}">
            <div class="w-14 h-14 rounded-xl bg-surface-container-highest border border-outline-variant/15 flex items-center justify-center shrink-0 text-primary">
              <span class="material-symbols-outlined text-[30px]">${r.icon}</span>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-1.5 mb-1.5">
                <span class="text-[10px] font-bold px-1.5 py-0.5 rounded uppercase ${colors}">${r.file_ext}</span>
                ${tierBadge}
                <span class="text-[10px] font-semibold text-on-surface-variant uppercase tracking-wider ml-auto">${r.tag}</span>
              </div>
              <h4 class="text-base font-bold text-white truncate">${r.title}</h4>
              <p class="text-xs text-on-surface-variant mt-1 line-clamp-2">${r.description}</p>
              <div class="flex items-center gap-3 mt-3 pt-3 border-t border-outline-variant/60">
                <span class="text-[11px] text-on-surface-variant flex items-center gap-1">
                  <span class="material-symbols-outlined text-[14px]">schedule</span>
                  ${r.updated_at ? new Date(r.updated_at).toLocaleDateString('vi-VN') : ''}
                </span>
                <div class="flex items-center gap-2 ml-auto">
                  <button type="button" data-edit="${r.id}" class="text-on-surface-variant hover:text-primary transition-colors" aria-label="Chỉnh sửa">
                    <span class="material-symbols-outlined text-[18px]">edit</span>
                  </button>
                  <button type="button" data-delete="${r.id}" class="text-on-surface-variant hover:text-error transition-colors" aria-label="Xóa">
                    <span class="material-symbols-outlined text-[18px]">delete</span>
                  </button>
                </div>
              </div>
            </div>
          </article>`;
      })
      .join('');

    // Empty state
    emptyEl.classList.toggle('hidden', visible.length !== 0);
    listEl.classList.toggle('hidden', visible.length === 0);

    // Rebind card action buttons
    listEl.querySelectorAll('[data-edit]').forEach((btn) =>
      btn.addEventListener('click', () => { const id = (btn as HTMLElement).dataset.edit; if (id) openEdit(id); })
    );
    listEl.querySelectorAll('[data-delete]').forEach((btn) =>
      btn.addEventListener('click', () => { const id = (btn as HTMLElement).dataset.delete; if (id) openDelete(id); })
    );
  }

  // ── Filter chips ──────────────────────────────────────────
  function applyChipStyles() {
    chips.forEach((chip) => {
      const isActive = (chip as HTMLElement).dataset.filter === activeFilter;
      chip.classList.toggle('bg-primary', isActive);
      chip.classList.toggle('text-on-primary', isActive);
      chip.classList.toggle('border-primary', isActive);
      chip.classList.toggle('bg-surface-container-high', !isActive);
      chip.classList.toggle('text-on-surface-variant', !isActive);
      chip.classList.toggle('border-outline-variant', !isActive);
    });
  }

  chips.forEach((chip) =>
    chip.addEventListener('click', () => {
      activeFilter = (chip as HTMLElement).dataset.filter ?? 'all';
      applyChipStyles();
      render();
    })
  );

  // ── File upload to R2 ────────────────────────────────────
  let uploadedFileUrl: string | null = null;
  const fFileInput = el('f-file-input') as HTMLInputElement;
  const uploadZone = el('upload-zone')!;
  const uploadProgress = el('upload-progress')!;
  const uploadSuccess = el('upload-success')!;
  const urlTextInput = el('f-file_url_text') as HTMLInputElement;
  const fileUrlHidden = el('f-file_url') as HTMLInputElement;

  const fileIconMap = { pdf: 'picture_as_pdf', xlsx: 'table_chart', docx: 'article', mp4: 'movie', pptx: 'slideshow' };

  fFileInput?.addEventListener('change', async () => {
    const file = fFileInput.files?.[0];
    if (!file) return;
    await uploadFile(file);
  });

  // Drag & drop
  uploadZone?.addEventListener('dragover', (e) => { e.preventDefault(); uploadZone.classList.add('border-primary', 'bg-primary/5'); });
  uploadZone?.addEventListener('dragleave', () => { uploadZone.classList.remove('border-primary', 'bg-primary/5'); });
  uploadZone?.addEventListener('drop', async (e) => {
    e.preventDefault();
    uploadZone.classList.remove('border-primary', 'bg-primary/5');
    const file = e.dataTransfer?.files?.[0];
    if (file) await uploadFile(file);
  });

  async function uploadFile(file: File) {
    const ext = file.name.split('.').pop()?.toLowerCase() || '';
    if (fileIconMap[ext as keyof typeof fileIconMap]) {
      setVal('f-file_ext', ext);
    }

    uploadZone.classList.add('hidden');
    uploadProgress.classList.remove('hidden');
    uploadSuccess.classList.add('hidden');
    if (urlTextInput) urlTextInput.disabled = true;

    el('upload-file-name')!.textContent = file.name;
    el('upload-file-icon')!.textContent = fileIconMap[ext as keyof typeof fileIconMap] || 'description';
    const bar = el('upload-bar')!;
    const spinner = el('upload-spinner')!;

    // Fake progress
    let pct = 0;
    const iv = setInterval(() => { pct = Math.min(pct + Math.random() * 15, 90); bar.style.width = pct + '%'; }, 80);

    try {
      const fd = new FormData();
      fd.append('file', file);
      fd.append('purpose', 'resource');

      const res = await fetch('/api/admin/upload', { method: 'POST', body: fd });
      if (!res.ok) {
        const err = await res.json().catch(() => ({} as Record<string, string>));
        throw new Error((err as Record<string, string>).error || 'Upload failed');
      }

      const data = await res.json() as { r2_key: string };
      clearInterval(iv);
      bar.style.width = '100%';
      spinner.classList.add('hidden');

      uploadedFileUrl = data.r2_key;
      if (fileUrlHidden) fileUrlHidden.value = data.r2_key;

      setTimeout(() => {
        uploadProgress.classList.add('hidden');
        uploadSuccess.classList.remove('hidden');
        el('upload-success-name')!.textContent = file.name;
      }, 300);
    } catch (err: unknown) {
      clearInterval(iv);
      bar.style.width = '0%';
      spinner.classList.add('hidden');
      showToast('Lỗi tải lên: ' + (err instanceof Error ? err.message : 'Lỗi không xác định'), 'error');
      hideUploadUI();
    }
  }

  function hideUploadUI() {
    uploadZone?.classList.remove('hidden');
    uploadProgress?.classList.add('hidden');
    uploadSuccess?.classList.add('hidden');
    if (urlTextInput) urlTextInput.disabled = false;
    uploadedFileUrl = null;
    if (fileUrlHidden) fileUrlHidden.value = '';
    if (fFileInput) fFileInput.value = '';
  }

  el('upload-cancel-btn')?.addEventListener('click', () => { hideUploadUI(); });
  el('upload-remove-btn')?.addEventListener('click', () => { hideUploadUI(); });

  // Sync URL text input to hidden field
  urlTextInput?.addEventListener('input', () => {
    if (!uploadedFileUrl) {
      fileUrlHidden.value = urlTextInput.value.trim();
    }
  });

  // ── Modal helpers ─────────────────────────────────────────
  const _fields = ['id', 'title', 'description', 'category', 'tier', 'file_ext', 'tag', 'icon', 'file_url', 'sort_order'];
  const modalIcon = el('modal-icon') as HTMLElement | null;
  const iconPreview = el('icon-preview');
  const iconInput = el('f-icon') as HTMLInputElement | null;

  // Live icon preview
  iconInput?.addEventListener('input', () => {
    const val = iconInput.value.trim() || 'description';
    if (iconPreview) iconPreview.textContent = val;
  });

  // ── Category → default icon mapping ──────────────────────
  const categoryDefaultIcons: Record<string, string> = {
    bieu_mau: 'description',
    checklist: 'checklist',
    sops: 'rule',
    cong_cu: 'construction',
    tham_khao: 'menu_book',
  };
  let _iconAutoFromCategory = true;
  const categorySelect = el('f-category') as HTMLSelectElement | null;
  categorySelect?.addEventListener('change', () => {
    const def = categoryDefaultIcons[categorySelect.value];
    if (def && iconInput) {
      iconInput.value = def;
      if (iconPreview) iconPreview.textContent = def;
      _iconAutoFromCategory = true;
    }
  });
  iconInput?.addEventListener('input', () => {
    _iconAutoFromCategory = false;
  });

  function resetForm() {
    editingId = null;
    modalTitle.textContent = 'Thêm tài nguyên mới';
    modalSubmit.querySelector('span:last-child')?.textContent; // keep inner structure
    // Update button text
    modalSubmit.innerHTML = '<span class="material-symbols-outlined text-[18px]">save</span> Lưu tài nguyên';
    if (modalIcon) modalIcon.textContent = 'add_circle';
    setVal('f-id', '');
    setVal('f-title', '');
    setVal('f-description', '');
    setVal('f-category', 'bieu_mau');
    setVal('f-tier', 'free');
    setVal('f-file_ext', 'pdf');
    setVal('f-tag', '');
    setVal('f-icon', 'description');
    setVal('f-file_url', '');
    setVal('f-sort_order', '0');
    if (iconPreview) iconPreview.textContent = 'description';
    hideUploadUI();
  }

  function openModal() {
    modal.classList.remove('hidden');
    // Trigger animation
    const panel = modal.querySelector('div');
    if (panel) {
      panel.style.opacity = '0';
      panel.style.transform = 'scale(0.95) translateY(12px)';
      requestAnimationFrame(() => {
        panel.style.transition = 'opacity 0.25s cubic-bezier(0.16, 1, 0.3, 1), transform 0.25s cubic-bezier(0.16, 1, 0.3, 1)';
        panel.style.opacity = '1';
        panel.style.transform = 'scale(1) translateY(0)';
      });
    }
    // Focus first input
    setTimeout(() => (el('f-title') as HTMLInputElement)?.focus(), 150);
  }

  function closeModal() {
    const panel = modal.querySelector('div');
    if (panel) {
      panel.style.transition = 'opacity 0.15s ease-in, transform 0.15s ease-in';
      panel.style.opacity = '0';
      panel.style.transform = 'scale(0.97) translateY(8px)';
      setTimeout(() => {
        modal.classList.add('hidden');
        panel.style.transition = '';
        panel.style.opacity = '';
        panel.style.transform = '';
        resetForm();
      }, 150);
    } else {
      modal.classList.add('hidden');
      resetForm();
    }
  }

  function openEdit(id: string) {
    const r = allResources.find((x) => x.id === id);
    if (!r) return;
    editingId = id;
    modalTitle.textContent = 'Chỉnh sửa tài nguyên';
    if (modalIcon) modalIcon.textContent = 'edit';
    modalSubmit.innerHTML = '<span class="material-symbols-outlined text-[18px]">update</span> Cập nhật';
    setVal('f-id', r.id);
    setVal('f-title', r.title);
    setVal('f-description', r.description);
    setVal('f-category', r.category);
    setVal('f-tier', r.tier);
    setVal('f-file_ext', r.file_ext);
    setVal('f-tag', r.tag);
    setVal('f-icon', r.icon);
    setVal('f-file_url', r.file_url);
    if (urlTextInput) urlTextInput.value = r.file_url;
    setVal('f-sort_order', String(r.sort_order));
    // If existing resource has an R2 file_url (not external URL), show success state
    if (r.file_url && !r.file_url.startsWith('http')) {
      uploadedFileUrl = r.file_url;
      uploadZone?.classList.add('hidden');
      uploadProgress?.classList.add('hidden');
      uploadSuccess?.classList.remove('hidden');
      const name = r.file_url.split('/').pop() || r.file_url;
      el('upload-success-name')!.textContent = name;
      urlTextInput.disabled = true;
    }
    if (iconPreview) iconPreview.textContent = r.icon;
    openModal();
  }

  // Add button
  el('btn-add-resource')!.addEventListener('click', () => {
    resetForm();
    openModal();
  });
  modalClose.addEventListener('click', closeModal);
  modalCancel.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  // ── Form submit (create / update) ─────────────────────────
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const payload = {
      title: val('f-title').trim(),
      description: val('f-description').trim(),
      category: val('f-category'),
      tier: val('f-tier'),
      file_ext: val('f-file_ext'),
      tag: val('f-tag').trim(),
      icon: val('f-icon').trim() || 'description',
      file_url: val('f-file_url').trim() || (urlTextInput?.value.trim() || ''),
      sort_order: parseInt(val('f-sort_order'), 10) || 0,
    };

    if (!payload.title) return;

    let res;
    if (editingId) {
      res = await fetch(`/api/admin/resources/${editingId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(payload),
      });
    } else {
      res = await fetch('/api/admin/resources', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(payload),
      });
    }

    if (res.ok) {
      closeModal();
      await loadResources();
    }
  });

  // ── Delete confirm dialog ─────────────────────────────────
  function openDelete(id: string) {
    const r = allResources.find((x) => x.id === id);
    if (!r) return;
    deletingId = id;
    deleteName.textContent = `"${r.title}" sẽ bị xóa vĩnh viễn.`;
    deleteModal.classList.remove('hidden');
  }

  deleteCancel.addEventListener('click', () => {
    deletingId = null;
    deleteModal.classList.add('hidden');
  });
  deleteModal.addEventListener('click', (e) => {
    if (e.target === deleteModal) {
      deletingId = null;
      deleteModal.classList.add('hidden');
    }
  });

  deleteConfirm.addEventListener('click', async () => {
    if (!deletingId) return;
    const res = await fetch(`/api/admin/resources/${deletingId}`, { method: 'DELETE' });
    if (res.ok) {
      deletingId = null;
      deleteModal.classList.add('hidden');
      await loadResources();
    }
  });

  // ── Init ──────────────────────────────────────────────────
  loadResources();
</script>
