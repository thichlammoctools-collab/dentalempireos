---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';

export const prerender = false;

const products = await env.DB
  .prepare('SELECT * FROM "product" ORDER BY "created_at" DESC')
  .all<{
    id: string;
    name: string;
    type: string;
    price: number;
    description: string;
    duration_days: number | null;
    is_active: number;
    created_at: string;
    updated_at: string;
  }>();
---

<AdminLayout title="Quản lý Sản phẩm | Admin">
  <div class="mb-6">
    <h2 class="text-3xl font-bold text-white mb-1">Quản lý Sản phẩm</h2>
    <p class="text-on-surface-variant text-sm">
      Quản lý giá và trạng thái các sản phẩm thanh toán.
    </p>
  </div>

  <div class="glass-card rounded-xl overflow-hidden">
    <table class="w-full">
      <thead>
        <tr class="text-left bg-surface-container-high/50">
          <th class="px-4 py-3 text-xs font-semibold text-on-surface-variant">ID</th>
          <th class="px-4 py-3 text-xs font-semibold text-on-surface-variant">Tên sản phẩm</th>
          <th class="px-4 py-3 text-xs font-semibold text-on-surface-variant">Loại</th>
          <th class="px-4 py-3 text-xs font-semibold text-on-surface-variant">Giá (VND)</th>
          <th class="px-4 py-3 text-xs font-semibold text-on-surface-variant">Thời hạn</th>
          <th class="px-4 py-3 text-xs font-semibold text-on-surface-variant">Trạng thái</th>
          <th class="px-4 py-3 text-xs font-semibold text-on-surface-variant"></th>
        </tr>
      </thead>
      <tbody>
        {products.results.map((p) => (
          <tr class="border-t border-outline-variant/15 hover:bg-surface-container-high/30">
            <td class="px-4 py-3 text-xs font-mono text-on-surface-variant">{p.id}</td>
            <td class="px-4 py-3 text-sm text-white font-semibold">{p.name}</td>
            <td class="px-4 py-3 text-xs">
              <span class="px-2 py-1 rounded-full bg-primary/10 text-primary font-semibold">
                {p.type}
              </span>
            </td>
            <td class="px-4 py-3 text-sm text-white font-semibold">
              {new Intl.NumberFormat('vi-VN').format(p.price)}
            </td>
            <td class="px-4 py-3 text-sm text-on-surface-variant">
              {p.duration_days ? `${p.duration_days} ngày` : 'Vĩnh viễn'}
            </td>
            <td class="px-4 py-3">
              <span class={`px-2 py-1 rounded-full text-xs font-semibold ${p.is_active ? 'bg-emerald-500/10 text-emerald-400' : 'bg-red-500/10 text-red-400'}`}>
                {p.is_active ? 'Hoạt động' : 'Tắt'}
              </span>
            </td>
            <td class="px-4 py-3 text-right">
              <button
                class="edit-btn text-xs font-semibold px-3 py-1.5 rounded-lg border border-outline-variant/30 text-on-surface-variant hover:text-white hover:bg-surface-container-high transition-all"
                data-id={p.id}
                data-name={p.name}
                data-price={p.price}
                data-active={p.is_active}
              >
                Chỉnh sửa
              </button>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Edit Modal -->
  <div id="edit-modal" class="hidden fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4">
    <div class="glass-card rounded-2xl p-6 w-full max-w-md">
      <h3 class="text-xl font-bold text-white mb-4">Chỉnh sửa sản phẩm</h3>
      <form id="edit-form" class="flex flex-col gap-4">
        <input type="hidden" id="edit-id" />
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Tên sản phẩm</label>
          <input type="text" id="edit-name" class="w-full px-4 py-2.5 bg-surface-container border border-outline-variant/30 text-white text-sm rounded-lg" readonly />
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Giá (VND)</label>
          <input type="number" id="edit-price" class="w-full px-4 py-2.5 bg-surface-container border border-outline-variant/30 text-white text-sm rounded-lg focus:ring-1 focus:ring-primary focus:border-primary outline-none" min="0" step="1000" />
        </div>
        <div class="flex items-center gap-3">
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" id="edit-active" class="sr-only peer" />
            <div class="w-11 h-6 bg-surface-container border border-outline-variant/30 rounded-full peer peer-checked:after:translate-x-full peer-checked:bg-primary after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-on-surface-variant after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:bg-white"></div>
          </label>
          <span class="text-sm text-on-surface-variant">Hoạt động</span>
        </div>
        <div class="flex justify-end gap-3 mt-4">
          <button type="button" id="btn-cancel" class="px-4 py-2 bg-surface-container border border-outline-variant/30 text-on-surface-variant text-sm rounded-lg hover:text-white">Hủy</button>
          <button type="submit" id="btn-save" class="px-4 py-2 bg-primary text-white text-sm font-semibold rounded-lg hover:bg-primary/90">Lưu thay đổi</button>
        </div>
        <p id="save-msg" class="hidden text-sm"></p>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  const modal = document.getElementById('edit-modal') as HTMLElement;
  const form = document.getElementById('edit-form') as HTMLFormElement;
  const saveMsg = document.getElementById('save-msg') as HTMLElement;

  // Open modal
  document.querySelectorAll<HTMLElement>('.edit-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.id;
      const name = btn.dataset.name;
      const price = btn.dataset.price;
      const active = btn.dataset.active === '1';

      (document.getElementById('edit-id') as HTMLInputElement).value = id ?? '';
      (document.getElementById('edit-name') as HTMLInputElement).value = name ?? '';
      (document.getElementById('edit-price') as HTMLInputElement).value = price ?? '';
      (document.getElementById('edit-active') as HTMLInputElement).checked = active;

      saveMsg.classList.add('hidden');
      modal.classList.remove('hidden');
    });
  });

  // Close modal
  document.getElementById('btn-cancel')?.addEventListener('click', () => {
    modal.classList.add('hidden');
  });
  modal.addEventListener('click', (e) => {
    if (e.target === modal) modal.classList.add('hidden');
  });

  // Save
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = (document.getElementById('edit-id') as HTMLInputElement).value;
    const price = parseInt((document.getElementById('edit-price') as HTMLInputElement).value) || 0;
    const is_active = (document.getElementById('edit-active') as HTMLInputElement).checked;

    try {
      const res = await fetch('/api/admin/products/' + encodeURIComponent(id), {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ price, is_active }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Failed');
      saveMsg.textContent = '✅ Đã lưu';
      saveMsg.className = 'text-sm text-emerald-400';
      saveMsg.classList.remove('hidden');
      setTimeout(() => window.location.reload(), 1000);
    } catch (err) {
      saveMsg.textContent = `❌ ${err instanceof Error ? err.message : 'Error'}`;
      saveMsg.className = 'text-sm text-red-400';
      saveMsg.classList.remove('hidden');
    }
  });
</script>
