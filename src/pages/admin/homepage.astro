---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';
import { getHomepageSettings, getDefaults } from '../../lib/homepage-db';

export const prerender = false;

const settings = await getHomepageSettings(env.DB) ?? getDefaults();
---

<AdminLayout title="Chỉnh sửa Trang Chủ | Admin">
  <div class="mb-6">
    <h2 class="text-3xl font-bold text-white mb-1">Chỉnh sửa Trang Chủ</h2>
    <p class="text-on-surface-variant text-sm">
      Tuỳ chỉnh nội dung và hình ảnh hiển thị trên trang chủ.
    </p>
  </div>

  <form id="homepage-form" class="flex flex-col gap-6">

    <!-- ══════════════ HERO ══════════════ -->
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center gap-3 mb-5">
        <span class="material-symbols-outlined text-primary text-2xl">home</span>
        <h3 class="text-lg font-bold text-white">Hero Section</h3>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Badge Text</label>
          <input type="text" id="f-badge_text" value={settings.badge_text}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
        <div class="md:col-span-2">
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Hero Image URL</label>
          
          <!-- Upload area -->
          <div class="mb-3 p-4 border-2 border-dashed border-outline-variant rounded-lg hover:border-primary transition-colors cursor-pointer" id="hero-upload-area">
            <input
              type="file"
              id="hero-file-input"
              accept="image/*"
              class="hidden"
            />
            <div class="flex flex-col items-center justify-center text-center">
              <span class="material-symbols-outlined text-[32px] text-on-surface-variant mb-2">cloud_upload</span>
              <p class="text-sm text-on-surface-variant font-medium">Kéo thả hoặc click để upload</p>
              <p class="text-xs text-on-surface-variant mt-1">PNG, JPG, WebP, SVG (tối đa 10MB)</p>
            </div>
            <div id="hero-upload-progress" class="hidden mt-3">
              <div class="w-full h-2 bg-surface-container rounded-full overflow-hidden">
                <div id="hero-progress-bar" class="h-full bg-primary transition-all duration-300" style="width: 0%"></div>
              </div>
              <p id="hero-upload-status" class="text-xs text-on-surface-variant mt-2">Đang upload...</p>
            </div>
          </div>

          <!-- URL input and preview -->
          <div class="flex items-center gap-2">
            <input type="text" id="f-hero_image_url" value={settings.hero_image_url}
              class="flex-1 px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none font-mono" />
            <div class="shrink-0 w-10 h-10 rounded-lg overflow-hidden border border-outline-variant">
              <img id="hero-img-preview" src={settings.hero_image_url} alt="preview" class="w-full h-full object-cover" onerror="this.style.display='none'" loading="lazy" />
            </div>
          </div>
          <p class="text-xs text-on-surface-variant mt-1.5">Hoặc nhập đường dẫn URL trực tiếp.</p>
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Title Line 1</label>
          <input type="text" id="f-hero_title_line1" value={settings.hero_title_line1}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Title Line 2</label>
          <input type="text" id="f-hero_title_line2" value={settings.hero_title_line2}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
        <div class="md:col-span-2">
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Description</label>
          <textarea id="f-hero_description" rows="2"
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none resize-y">{settings.hero_description}</textarea>
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">CTA Primary Text</label>
          <input type="text" id="f-hero_cta_primary" value={settings.hero_cta_primary}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">CTA Secondary Text</label>
          <input type="text" id="f-hero_cta_secondary" value={settings.hero_cta_secondary}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
        <div class="md:col-span-2">
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Stats Text</label>
          <input type="text" id="f-hero_stats_text" value={settings.hero_stats_text}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
      </div>
    </div>

    <!-- ══════════════ TIERS ══════════════ -->
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center gap-3 mb-5">
        <span class="material-symbols-outlined text-primary text-2xl">layers</span>
        <h3 class="text-lg font-bold text-white">3 Tầng Cốt Lõi</h3>
      </div>
      <div class="space-y-6">
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Section Heading</label>
          <input type="text" id="f-tier_section_heading" value={settings.tier_section_heading}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Section Subheading</label>
          <input type="text" id="f-tier_section_subheading" value={settings.tier_section_subheading}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>

        {['1', '2', '3'].map((n) => (
          <div class="p-4 bg-surface-container rounded-xl border border-outline-variant/30">
            <p class="text-xs font-bold text-primary mb-3">Tier {n}</p>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Name</label>
                <input type="text" id={`f-tier${n}_name`} value={settings[`tier${n}_name` as keyof typeof settings] as string}
                  class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Subtitle</label>
                <input type="text" id={`f-tier${n}_subtitle`} value={settings[`tier${n}_subtitle` as keyof typeof settings] as string}
                  class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Icon (Material Symbol)</label>
                <input type="text" id={`f-tier${n}_icon`} value={settings[`tier${n}_icon` as keyof typeof settings] as string}
                  class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none font-mono" />
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- ══════════════ TESTIMONIALS ══════════════ -->
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center gap-3 mb-5">
        <span class="material-symbols-outlined text-primary text-2xl">format_quote</span>
        <h3 class="text-lg font-bold text-white">Testimonials</h3>
      </div>
      <div class="space-y-4 mb-4">
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Section Heading</label>
          <input type="text" id="f-testimonial_section_heading" value={settings.testimonial_section_heading}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Section Subheading</label>
          <input type="text" id="f-testimonial_section_subheading" value={settings.testimonial_section_subheading}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
      </div>

      {['1', '2', '3'].map((n) => (
        <div class="p-4 bg-surface-container rounded-xl border border-outline-variant/30 mb-3">
          <p class="text-xs font-bold text-primary mb-3">Testimonial {n}</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="md:col-span-2">
              <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Quote</label>
              <textarea id={`f-testimonial${n}_quote`} rows="2"
                class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none resize-y">{settings[`testimonial${n}_quote` as keyof typeof settings] as string}</textarea>
            </div>
            <div>
              <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Name</label>
              <input type="text" id={`f-testimonial${n}_name`} value={settings[`testimonial${n}_name` as keyof typeof settings] as string}
                class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Role</label>
              <input type="text" id={`f-testimonial${n}_role`} value={settings[`testimonial${n}_role` as keyof typeof settings] as string}
                class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
            </div>
            <div class="md:col-span-2">
              <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Avatar URL</label>
              <div class="flex items-center gap-2">
                <input type="text" id={`f-testimonial${n}_avatar`} value={settings[`testimonial${n}_avatar` as keyof typeof settings] as string}
                  class="flex-1 px-3 py-2 bg-surface border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none font-mono" />
                <div class="shrink-0 w-10 h-10 rounded-full overflow-hidden border border-outline-variant">
                  <img id={`test-img-preview-${n}`} src={settings[`testimonial${n}_avatar` as keyof typeof settings] as string} alt="preview" class="w-full h-full object-cover" onerror="this.style.display='none'" />
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- ══════════════ FOUNDER ══════════════ -->
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center gap-3 mb-5">
        <span class="material-symbols-outlined text-primary text-2xl">person</span>
        <h3 class="text-lg font-bold text-white">Founder Section</h3>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Badge</label>
          <input type="text" id="f-founder_badge" value={settings.founder_badge}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Founder Name</label>
          <input type="text" id="f-founder_name" value={settings.founder_name}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Founder Title</label>
          <input type="text" id="f-founder_title" value={settings.founder_title}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Heading</label>
          <input type="text" id="f-founder_heading" value={settings.founder_heading}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Link Text</label>
          <input type="text" id="f-founder_link_text" value={settings.founder_link_text}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
        <div class="md:col-span-2 lg:col-span-3">
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Bio</label>
          <textarea id="f-founder_bio" rows="3"
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none resize-y">{settings.founder_bio}</textarea>
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Stat 1 Value</label>
          <input type="text" id="f-founder_stat1_value" value={settings.founder_stat1_value}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Stat 1 Label</label>
          <input type="text" id="f-founder_stat1_label" value={settings.founder_stat1_label}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Stat 2 Value</label>
          <input type="text" id="f-founder_stat2_value" value={settings.founder_stat2_value}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Stat 2 Label</label>
          <input type="text" id="f-founder_stat2_label" value={settings.founder_stat2_label}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
        <div class="md:col-span-2 lg:col-span-3">
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Founder Image URL</label>
          
          <!-- Upload area -->
          <div class="mb-3 p-4 border-2 border-dashed border-outline-variant rounded-lg hover:border-primary transition-colors cursor-pointer" id="founder-upload-area">
            <input
              type="file"
              id="founder-file-input"
              accept="image/*"
              class="hidden"
            />
            <div class="flex flex-col items-center justify-center text-center">
              <span class="material-symbols-outlined text-[32px] text-on-surface-variant mb-2">cloud_upload</span>
              <p class="text-sm text-on-surface-variant font-medium">Kéo thả hoặc click để upload</p>
              <p class="text-xs text-on-surface-variant mt-1">PNG, JPG, WebP, SVG (tối đa 10MB)</p>
            </div>
            <div id="founder-upload-progress" class="hidden mt-3">
              <div class="w-full h-2 bg-surface-container rounded-full overflow-hidden">
                <div id="founder-progress-bar" class="h-full bg-primary transition-all duration-300" style="width: 0%"></div>
              </div>
              <p id="founder-upload-status" class="text-xs text-on-surface-variant mt-2">Đang upload...</p>
            </div>
          </div>

          <!-- URL input and preview -->
          <div class="flex items-center gap-2">
            <input type="text" id="f-founder_image_url" value={settings.founder_image_url}
              class="flex-1 px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none font-mono" />
            <div class="shrink-0 w-10 h-10 rounded-lg overflow-hidden border border-outline-variant">
              <img id="founder-img-preview" src={settings.founder_image_url} alt="preview" class="w-full h-full object-cover" onerror="this.style.display='none'" loading="lazy" />
            </div>
          </div>
          <p class="text-xs text-on-surface-variant mt-1.5">Hoặc nhập đường dẫn URL trực tiếp.</p>
        </div>
      </div>
    </div>

    <!-- ══════════════ CTA ══════════════ -->
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center gap-3 mb-5">
        <span class="material-symbols-outlined text-primary text-2xl">campaign</span>
        <h3 class="text-lg font-bold text-white">CTA Section</h3>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="md:col-span-2">
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Heading</label>
          <input type="text" id="f-cta_heading" value={settings.cta_heading}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
        <div class="md:col-span-2">
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Subtext</label>
          <textarea id="f-cta_subtext" rows="2"
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none resize-y">{settings.cta_subtext}</textarea>
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Primary Button Text</label>
          <input type="text" id="f-cta_primary_text" value={settings.cta_primary_text}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Secondary Button Text</label>
          <input type="text" id="f-cta_secondary_text" value={settings.cta_secondary_text}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Primary Button Icon</label>
          <input type="text" id="f-cta_primary_icon" value={settings.cta_primary_icon}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none font-mono" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Secondary Button Icon</label>
          <input type="text" id="f-cta_secondary_icon" value={settings.cta_secondary_icon}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none font-mono" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Primary Button Link</label>
          <input type="text" id="f-cta_primary_link" value={settings.cta_primary_link}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none font-mono" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Secondary Button Link</label>
          <input type="text" id="f-cta_secondary_link" value={settings.cta_secondary_link}
            class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none font-mono" />
        </div>
      </div>
    </div>

    <!-- ══════════════ ABOUT PAGE ══════════════ -->
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center gap-3 mb-5">
        <span class="material-symbols-outlined text-primary text-2xl">info</span>
        <h3 class="text-lg font-bold text-white">Trang About</h3>
      </div>

      <!-- About Hero -->
      <p class="text-xs font-bold text-primary mb-3">Hero Section</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Badge</label>
          <input type="text" id="f-about_hero_badge" value={settings.about_hero_badge}
            class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Gradient Text</label>
          <input type="text" id="f-about_hero_gradient" value={settings.about_hero_gradient}
            class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5">Title Line 1</label>
