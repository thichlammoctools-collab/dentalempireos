<script>
  const form = document.getElementById('homepage-form') as HTMLFormElement;
  const saveStatus = document.getElementById('save-status')!;

  // Hero image upload handlers
  const heroUploadArea = document.getElementById('hero-upload-area')!;
  const heroFileInput = document.getElementById('hero-file-input') as HTMLInputElement;
  const heroUrlField = document.getElementById('f-hero_image_url') as HTMLInputElement;
  const heroProgressContainer = document.getElementById('hero-upload-progress')!;
  const heroProgressBar = document.getElementById('hero-progress-bar')!;
  const heroUploadStatus = document.getElementById('hero-upload-status')!;

  // Founder image upload handlers
  const founderUploadArea = document.getElementById('founder-upload-area')!;
  const founderFileInput = document.getElementById('founder-file-input') as HTMLInputElement;
  const founderUrlField = document.getElementById('f-founder_image_url') as HTMLInputElement;
  const founderProgressContainer = document.getElementById('founder-upload-progress')!;
  const founderProgressBar = document.getElementById('founder-progress-bar')!;
  const founderUploadStatus = document.getElementById('founder-upload-status')!;

  // Auto-save a single field to D1 after image upload
  async function autoSaveField(field: string, value: string): Promise<boolean> {
    try {
      const res = await fetch('/api/admin/homepage-settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ [field]: value }),
      });
      return res.ok;
    } catch {
      return false;
    }
  }

  // Image preview on URL change
  const previewMap: Record<string, string> = {
    'f-hero_image_url': 'hero-img-preview',
    'f-founder_image_url': 'founder-img-preview',
    'f-about_story_image_url': 'about-story-preview',
    'f-about_founder_image_url': 'about-founder-preview',
  };
  for (const [inputId, previewId] of Object.entries(previewMap)) {
    const input = document.getElementById(inputId) as HTMLInputElement | null;
    const preview = document.getElementById(previewId) as HTMLImageElement | null;
    if (input && preview) {
      input.addEventListener('input', () => {
        preview.src = input.value;
        preview.style.display = '';
      });
    }
  }

  // Hero image upload handlers
  heroUploadArea.addEventListener('click', () => heroFileInput.click());

  heroUploadArea.addEventListener('dragover', (e) => {
    e.preventDefault();
    heroUploadArea.classList.add('border-primary', 'bg-primary/5');
  });

  heroUploadArea.addEventListener('dragleave', () => {
    heroUploadArea.classList.remove('border-primary', 'bg-primary/5');
  });

  heroUploadArea.addEventListener('drop', (e) => {
    e.preventDefault();
    heroUploadArea.classList.remove('border-primary', 'bg-primary/5');
    
    const files = e.dataTransfer?.files;
    if (files && files.length > 0) {
      heroFileInput.files = files;
      handleHeroImageUpload(files[0]);
    }
  });

  heroFileInput.addEventListener('change', () => {
    if (heroFileInput.files && heroFileInput.files.length > 0) {
      handleHeroImageUpload(heroFileInput.files[0]);
    }
  });

  // Founder image upload handlers
  founderUploadArea.addEventListener('click', () => founderFileInput.click());

  founderUploadArea.addEventListener('dragover', (e) => {
    e.preventDefault();
    founderUploadArea.classList.add('border-primary', 'bg-primary/5');
  });

  founderUploadArea.addEventListener('dragleave', () => {
    founderUploadArea.classList.remove('border-primary', 'bg-primary/5');
  });

  founderUploadArea.addEventListener('drop', (e) => {
    e.preventDefault();
    founderUploadArea.classList.remove('border-primary', 'bg-primary/5');
    
    const files = e.dataTransfer?.files;
    if (files && files.length > 0) {
      founderFileInput.files = files;
      handleFounderImageUpload(files[0]);
    }
  });

  founderFileInput.addEventListener('change', () => {
    if (founderFileInput.files && founderFileInput.files.length > 0) {
      handleFounderImageUpload(founderFileInput.files[0]);
    }
  });

  async function handleHeroImageUpload(file: File) {
    // Validate file type
    if (!file.type.startsWith('image/')) {
      alert('Vui lòng chọn file ảnh');
      return;
    }

    if (file.size > 10 * 1024 * 1024) {
      alert('File quá lớn (tối đa 10MB)');
      return;
    }

    // Show progress
    heroProgressContainer.classList.remove('hidden');
    heroProgressBar.style.width = '0%';
    heroUploadStatus.textContent = 'Đang upload...';

    try {
      const formData = new FormData();
      formData.append('file', file);
      formData.append('purpose', 'homepage');

      const res = await fetch('/api/admin/upload', {
        method: 'POST',
        credentials: 'include',
        body: formData,
      });

      if (!res.ok) {
        const error = await res.text();
        throw new Error(error);
      }

      const data = await res.json() as { r2_key: string };
      
      // Update URL field with the R2 key
      const mediaUrl = `/media/${data.r2_key}`;
      heroUrlField.value = mediaUrl;

      // Update preview
      const preview = document.getElementById('hero-img-preview') as HTMLImageElement;
      if (preview) {
        preview.src = mediaUrl;
        preview.style.display = '';
      }

      heroProgressBar.style.width = '100%';
      heroUploadStatus.textContent = 'Đang lưu...';

      // Auto-save to D1
      const saved = await autoSaveField('hero_image_url', mediaUrl);
      heroUploadStatus.textContent = saved ? '✓ Upload & lưu thành công' : '✓ Upload thành công (chưa lưu — nhấn Lưu thay đổi)';

      setTimeout(() => {
        heroProgressContainer.classList.add('hidden');
      }, 2500);
    } catch (err) {
      heroProgressContainer.classList.add('hidden');
      alert(`Lỗi upload: ${err instanceof Error ? err.message : 'Unknown error'}`);
    }
  }

  async function handleFounderImageUpload(file: File) {
    // Validate file type
    if (!file.type.startsWith('image/')) {
      alert('Vui lòng chọn file ảnh');
      return;
    }

    if (file.size > 10 * 1024 * 1024) {
      alert('File quá lớn (tối đa 10MB)');
      return;
    }

    // Show progress
    founderProgressContainer.classList.remove('hidden');
    founderProgressBar.style.width = '0%';
    founderUploadStatus.textContent = 'Đang upload...';

    try {
      const formData = new FormData();
      formData.append('file', file);
      formData.append('purpose', 'homepage');

      const res = await fetch('/api/admin/upload', {
        method: 'POST',
        credentials: 'include',
        body: formData,
      });

      if (!res.ok) {
        const error = await res.text();
        throw new Error(error);
      }

      const data = await res.json() as { r2_key: string };
      
      // Update URL field with the R2 key
      const mediaUrl = `/media/${data.r2_key}`;
      founderUrlField.value = mediaUrl;

      // Update preview
      const preview = document.getElementById('founder-img-preview') as HTMLImageElement;
      if (preview) {
        preview.src = mediaUrl;
        preview.style.display = '';
      }

      founderProgressBar.style.width = '100%';
      founderUploadStatus.textContent = 'Đang lưu...';

      // Auto-save to D1
      const saved = await autoSaveField('founder_image_url', mediaUrl);
      founderUploadStatus.textContent = saved ? '✓ Upload & lưu thành công' : '✓ Upload thành công (chưa lưu — nhấn Lưu thay đổi)';

      setTimeout(() => {
        founderProgressContainer.classList.add('hidden');
      }, 2500);
    } catch (err) {
      founderProgressContainer.classList.add('hidden');
      alert(`Lỗi upload: ${err instanceof Error ? err.message : 'Unknown error'}`);
    }
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    saveStatus.textContent = 'Đang lưu...';

    const fields = [
      'badge_text', 'hero_title_line1', 'hero_title_line2', 'hero_description',
      'hero_cta_primary', 'hero_cta_secondary', 'hero_stats_text', 'hero_image_url',
      'tier_section_heading', 'tier_section_subheading',
      'tier1_name', 'tier1_subtitle', 'tier1_icon',
      'tier2_name', 'tier2_subtitle', 'tier2_icon',
      'tier3_name', 'tier3_subtitle', 'tier3_icon',
      'testimonial_section_heading', 'testimonial_section_subheading',
      'testimonial1_quote', 'testimonial1_name', 'testimonial1_role', 'testimonial1_avatar',
      'testimonial2_quote', 'testimonial2_name', 'testimonial2_role', 'testimonial2_avatar',
      'testimonial3_quote', 'testimonial3_name', 'testimonial3_role', 'testimonial3_avatar',
      'founder_badge', 'founder_heading', 'founder_bio',
      'founder_stat1_value', 'founder_stat1_label',
      'founder_stat2_value', 'founder_stat2_label',
      'founder_name', 'founder_title', 'founder_image_url', 'founder_link_text',
      'cta_heading', 'cta_subtext',
      'cta_primary_text', 'cta_secondary_text',
      'cta_primary_icon', 'cta_secondary_icon',
      'cta_primary_link', 'cta_secondary_link',
      // About page
      'about_hero_badge', 'about_hero_line1', 'about_hero_line2', 'about_hero_gradient',
      'about_hero_description', 'about_hero_cta_primary', 'about_hero_cta_secondary',
      'about_story_image_url', 'about_story_heading',
      'about_story_para1', 'about_story_para2',
      'about_story_stat1_value', 'about_story_stat1_label',
      'about_story_stat2_value', 'about_story_stat2_label',
      'about_founder_image_url', 'about_founder_name', 'about_founder_title',
      'about_founder_quote', 'about_founder_role1_label', 'about_founder_role1_desc',
      'about_founder_role2_label', 'about_founder_role2_desc',
      'about_values_heading',
      'about_values_card1_title', 'about_values_card1_desc',
      'about_values_card2_title', 'about_values_card2_desc',
      'about_values_card3_title', 'about_values_card3_desc',
      'about_values_card4_title', 'about_values_card4_desc',
      'about_cta_line1', 'about_cta_line2',
      'about_cta_primary', 'about_cta_secondary',
      'about_cta_primary_link', 'about_cta_secondary_link',
    ];

    const data: Record<string, string> = {};
    for (const field of fields) {
      const el = document.getElementById(`f-${field}`) as HTMLInputElement | HTMLTextAreaElement | null;
      if (el) data[field] = el.value;
    }

    try {
      const res = await fetch('/api/admin/homepage-settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(data),
      });

      if (res.ok) {
        saveStatus.textContent = '✓ Đã lưu';
        setTimeout(() => { saveStatus.textContent = ''; }, 3000);
      } else {
        saveStatus.textContent = '✗ Lỗi khi lưu';
      }
    } catch {
      saveStatus.textContent = '✗ Lỗi kết nối';
    } finally {
      btn.disabled = false;
    }
  });
</script>