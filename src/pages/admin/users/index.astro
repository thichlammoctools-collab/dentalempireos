---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';
import { listUsers } from '../../../lib/user-db';

export const prerender = false;

const users = await listUsers(env.DB);
const total = users.length;
const activeCount = users.filter((u) => u.is_active === 1).length;
const inactiveCount = total - activeCount;
---

<AdminLayout title="Người dùng | Dental Empire Admin">
  <div class="flex flex-col md:flex-row md:justify-between md:items-end gap-4">
    <div>
      <h2 class="text-3xl font-bold text-white mb-1">Quản lý Người dùng</h2>
      <p class="text-on-surface-variant">
        {total} người dùng · {activeCount} kích hoạt · {inactiveCount} chờ kích hoạt
      </p>
    </div>
  </div>

  {total === 0 ? (
    <div class="text-center py-16 glass-card rounded-xl">
      <span class="material-symbols-outlined text-6xl text-on-surface-variant/40">people</span>
      <p class="text-on-surface-variant mt-3">Chưa có người dùng nào</p>
    </div>
  ) : (
    <div class="glass-card rounded-xl overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
          <thead>
            <tr class="border-b border-outline-variant/20 text-on-surface-variant uppercase text-xs tracking-wider">
              <th class="px-6 py-4 font-bold">Tên</th>
              <th class="px-6 py-4 font-bold">Email</th>
              <th class="px-6 py-4 font-bold">Ngày đăng ký</th>
              <th class="px-6 py-4 font-bold text-center">Trạng thái</th>
              <th class="px-6 py-4 font-bold text-center">Thao tác</th>
            </tr>
          </thead>
          <tbody>
            {users.map((user) => (
              <tr class="border-b border-outline-variant/10 hover:bg-surface-container-high/50 transition-colors" data-user-id={user.id}>
                <td class="px-6 py-4 font-medium text-on-surface">{user.name}</td>
                <td class="px-6 py-4 text-on-surface-variant">{user.email}</td>
                <td class="px-6 py-4 text-on-surface-variant">
                  {new Date(user.createdAt).toLocaleDateString('vi-VN')}
                </td>
                <td class="px-6 py-4 text-center">
                  {user.is_active === 1 ? (
                    <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-bold bg-green-500/15 text-green-400 border border-green-500/30">
                      <span class="material-symbols-outlined text-[14px]">check_circle</span>
                      Kích hoạt
                    </span>
                  ) : (
                    <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-bold bg-yellow-500/15 text-yellow-400 border border-yellow-500/30">
                      <span class="material-symbols-outlined text-[14px]">pending</span>
                      Chờ kích hoạt
                    </span>
                  )}
                </td>
                <td class="px-6 py-4 text-center">
                  <button
                    type="button"
                    class="toggle-active-btn inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-xs font-bold transition-all active:scale-95 cursor-pointer"
                    class:list={[
                      user.is_active === 1
                        ? 'bg-red-500/15 text-red-400 border border-red-500/30 hover:bg-red-500/25'
                        : 'bg-primary/15 text-primary border border-primary/30 hover:bg-primary/25',
                    ]}
                    data-user-id={user.id}
                  >
                    <span class="material-symbols-outlined text-[16px]">
                      {user.is_active === 1 ? 'person_off' : 'person_add'}
                    </span>
                    {user.is_active === 1 ? 'Vô hiệu hóa' : 'Kích hoạt'}
                  </button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  )}

  <script>
    document.querySelectorAll('.toggle-active-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const userId = (btn as HTMLElement).dataset.userId;
        if (!userId) return;

        (btn as HTMLButtonElement).disabled = true;
        try {
          const res = await fetch('/api/admin/users', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId }),
          });
          if (res.ok) {
            window.location.reload();
          } else {
            const data = await res.json();
            alert(data.error || 'Lỗi khi cập nhật');
          }
        } catch {
          alert('Lỗi kết nối');
        } finally {
          (btn as HTMLButtonElement).disabled = false;
        }
      });
    });
  </script>
</AdminLayout>
