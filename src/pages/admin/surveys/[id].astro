---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';
import { getSurveyResponse, updateAiAnalysis, buildAnalysisContext } from '../../../lib/survey-db';
import { analyzeSurvey } from '../../../lib/ai-survey-analysis';
import { getAiSettings, isAiEnabled } from '../../../lib/ai-settings-db';
import { marked } from 'marked';

export const prerender = false;

const id = parseInt(Astro.params.id ?? '', 10);
if (!id || Number.isNaN(id)) {
  return Astro.redirect('/admin/surveys');
}

// Handle reanalyze action
if (Astro.url.searchParams.has('reanalyze')) {
  const row = await getSurveyResponse(env.DB, id);
  const settings = await getAiSettings(env.DB);
  if (row && settings.is_active === 1 && settings.api_key) {
    const context = buildAnalysisContext(row);
    try {
      const analysis = await analyzeSurvey(settings.api_key, row, context, {
        baseUrl: settings.base_url,
        model: settings.model,
      });
      await updateAiAnalysis(env.DB, id, analysis);
    } catch (err) {
      console.error('Reanalyze failed:', err);
    }
  }
  return Astro.redirect(`/admin/surveys/${id}`);
}

const row = await getSurveyResponse(env.DB, id);
if (!row) {
  return new Response('Not found', { status: 404 });
}

const aiEnabled = await isAiEnabled(env.DB);

marked.setOptions({ gfm: true, breaks: true });
const analysisHtml = row.ai_analysis ? (marked.parse(row.ai_analysis) as string) : '';

function scoreColor(s: number | null): string {
  if (s == null) return '#6b7280';
  if (s >= 75) return '#10b981';
  if (s >= 55) return '#3b82f6';
  if (s >= 35) return '#f59e0b';
  return '#ef4444';
}

const parts = [
  { key: 'roots', name: 'ROOTS', score: row.score_roots },
  { key: 'sky', name: 'SKY', score: row.score_sky },
  { key: 'stars', name: 'S.T.A.R.S', score: row.score_stars },
  { key: 'living', name: 'Hệ thống sống', score: row.score_living },
];

// Helper: render a score bar row
const openAnswer = (val: string | null) => val && val.trim() ? val : '—';
---

<AdminLayout title={`Survey #${id} | Admin`}>
  <!-- Header -->
  <div class="flex flex-col md:flex-row md:justify-between md:items-end gap-4 mb-6">
    <div>
      <a href="/admin/surveys" class="text-on-surface-variant text-sm hover:text-primary inline-flex items-center gap-1 mb-2">
        <span class="material-symbols-outlined text-base">arrow_back</span>
        Quay lại danh sách
      </a>
      <h2 class="text-3xl md:text-[32px] leading-tight font-bold text-white mb-1">
        {row.clinic_name ?? 'Phòng khám'}
      </h2>
      <p class="text-base text-on-surface-variant">
        ID #{row.id} · {row.owner_name ?? '—'} · {row.created_at}
      </p>
    </div>
    <div class="flex flex-wrap gap-2">
      <a
        href={`/api/survey/${row.id}/pdf`}
        class="px-4 py-2 bg-primary text-white text-sm font-semibold rounded-lg hover:bg-primary/90 transition-all flex items-center gap-2"
      >
        <span class="material-symbols-outlined text-base">download</span>
        Tải PDF
      </a>
      <a
        href={`/survey/result/${row.id}`}
        target="_blank"
        class="px-4 py-2 bg-surface-container text-on-surface-variant text-sm font-semibold rounded-lg border border-outline-variant/30 hover:text-white transition-all flex items-center gap-2"
      >
        <span class="material-symbols-outlined text-base">open_in_new</span>
        Trang công khai
      </a>
      <a
        href={`/admin/surveys/${row.id}?reanalyze=1`}
        class="px-4 py-2 bg-tertiary/10 border border-tertiary/30 text-tertiary text-sm font-semibold rounded-lg hover:bg-tertiary/20 transition-all flex items-center gap-2"
      >
        <span class="material-symbols-outlined text-base">refresh</span>
        Phân tích lại AI
      </a>
    </div>
  </div>

  <!-- Score overview -->
  <div class="glass-card rounded-xl p-6 mb-6">
    <div class="flex flex-wrap items-end gap-8 mb-6">
      <div>
        <p class="text-xs uppercase tracking-wider text-on-surface-variant font-bold mb-1">Tổng điểm</p>
        <div class="flex items-baseline gap-1">
          <span
            class="text-6xl font-extrabold"
            style={`color: ${scoreColor(row.score_total)}`}
          >{row.score_total ?? 0}</span>
          <span class="text-xl text-on-surface-variant">/100</span>
        </div>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 flex-1 min-w-[280px]">
        {parts.map((p) => (
          <div>
            <p class="text-[10px] uppercase tracking-wider text-on-surface-variant font-bold">{p.name}</p>
            <p class="text-2xl font-bold mt-0.5" style={`color: ${scoreColor(p.score)}`}>{p.score ?? 0}</p>
            <div class="h-1.5 bg-surface-container rounded-full overflow-hidden mt-1.5">
              <div
                class="h-full transition-all"
                style={`width: ${p.score ?? 0}%; background: ${scoreColor(p.score)}`}
              ></div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 pt-4 border-t border-outline-variant/15">
      <div>
        <p class="text-[10px] uppercase tracking-wider text-on-surface-variant font-bold">Email</p>
        <p class="text-sm text-white mt-0.5 break-all">{row.email ?? '—'}</p>
      </div>
      <div>
        <p class="text-[10px] uppercase tracking-wider text-on-surface-variant font-bold">Số năm HĐ</p>
        <p class="text-sm text-white mt-0.5">{row.years_in_operation ?? '—'}</p>
      </div>
      <div>
        <p class="text-[10px] uppercase tracking-wider text-on-surface-variant font-bold">Nhân sự</p>
        <p class="text-sm text-white mt-0.5">{row.staff_count ?? '—'}</p>
      </div>
      <div>
        <p class="text-[10px] uppercase tracking-wider text-on-surface-variant font-bold">Ngôn ngữ</p>
        <p class="text-sm text-white mt-0.5 uppercase">{row.lang}</p>
      </div>
    </div>
  </div>

  <!-- AI Analysis -->
  <div class="glass-card rounded-xl p-6 mb-6">
    <div class="flex justify-between items-start mb-4">
      <div>
        <p class="text-xs uppercase tracking-wider text-amber-500 font-bold">Phân tích từ AI</p>
        <h3 class="text-xl font-bold text-white mt-1">Bản soi chiếu hệ thống</h3>
      </div>
      {row.ai_analyzed_at && (
        <span class="text-xs text-on-surface-variant">{row.ai_analyzed_at}</span>
      )}
    </div>

    {analysisHtml ? (
      <article class="prose-content" set:html={analysisHtml}></article>
    ) : (
      <div class="text-center py-8 text-on-surface-variant">
        <span class="material-symbols-outlined text-4xl mb-2 block">pending</span>
        <p>Chưa có phân tích AI. Hệ thống sẽ tự động tạo sau khi nhận được response.</p>
        {aiEnabled && (
          <a
            href={`/admin/surveys/${row.id}?reanalyze=1`}
            class="inline-block mt-4 px-4 py-2 bg-primary text-white text-sm font-semibold rounded-lg"
          >
            Tạo phân tích ngay
          </a>
        )}
      </div>
    )}
  </div>

  <!-- All answers (collapsible) -->
  <details class="glass-card rounded-xl p-6">
    <summary class="cursor-pointer text-white font-bold text-lg flex items-center gap-2 select-none">
      <span class="material-symbols-outlined text-on-surface-variant">expand_more</span>
      Toàn bộ câu trả lời ({(row.roots_q1 ? 1 : 0) + (row.roots_q2 ? 1 : 0) + (row.roots_q3 ? 1 : 0) + (row.roots_q4 ? 1 : 0) + (row.sky_sin_open ? 1 : 0) + (row.sky_k_open ? 1 : 0) + (row.sky_y_open ? 1 : 0) + (row.stars_s_open ? 1 : 0) + (row.stars_t_open ? 1 : 0) + (row.stars_a_open ? 1 : 0) + (row.stars_syn_open ? 1 : 0) + (row.living_o1 ? 1 : 0) + (row.living_o2 ? 1 : 0) + (row.future_o1 ? 1 : 0) + (row.future_o2 ? 1 : 0) + (row.future_o3 ? 1 : 0) + (row.commit_o1 ? 1 : 0) + (row.commit_o2 ? 1 : 0)}/{18} câu mở)
    </summary>

    <div class="mt-6 space-y-6">
      <section>
        <h4 class="text-base font-bold text-amber-500 mb-3">ROOTS</h4>
        <div class="space-y-3">
          <div><p class="text-xs text-on-surface-variant font-bold">Câu neo #1 — Mất mát nếu PK không còn:</p><p class="text-sm text-white mt-1 whitespace-pre-wrap">{openAnswer(row.roots_q1)}</p></div>
          <div><p class="text-xs text-on-surface-variant font-bold">Lý do tồn tại:</p><p class="text-sm text-white mt-1 whitespace-pre-wrap">{openAnswer(row.roots_q2)}</p></div>
          <div><p class="text-xs text-on-surface-variant font-bold">3 giá trị cốt lõi:</p><p class="text-sm text-white mt-1 whitespace-pre-wrap">{openAnswer(row.roots_q3)}</p></div>
          <div><p class="text-xs text-on-surface-variant font-bold">Tình huống đứng vững giá trị:</p><p class="text-sm text-white mt-1 whitespace-pre-wrap">{openAnswer(row.roots_q4)}</p></div>
          <div><p class="text-xs text-on-surface-variant font-bold">Khi xung đột giá trị vs DT:</p><p class="text-sm text-white mt-1">{row.roots_q4_choice ?? '—'}</p></div>
        </div>
      </section>

      <section>
        <h4 class="text-base font-bold text-amber-500 mb-3">SKY</h4>
        <div class="space-y-3">
          <div><p class="text-xs text-on-surface-variant font-bold">Sincerity — VD từ chối DV:</p><p class="text-sm text-white mt-1 whitespace-pre-wrap">{openAnswer(row.sky_sin_open)}</p></div>
          <div><p class="text-xs text-on-surface-variant font-bold">Kindness — Cảm nhận của BN:</p><p class="text-sm text-white mt-1 whitespace-pre-wrap">{openAnswer(row.sky_k_open)}</p></div>
          <div><p class="text-xs text-on-surface-variant font-bold">Yielding — Lần thừa nhận sai:</p><p class="text-sm text-white mt-1 whitespace-pre-wrap">{openAnswer(row.sky_y_open)}</p></div>
        </div>
      </section>

      <section>
        <h4 class="text-base font-bold text-amber-500 mb-3">S.T.A.R.S</h4>
        <div class="space-y-3">
          <div><p class="text-xs text-on-surface-variant font-bold">Ai đúng giá trị nhất / cần phát triển:</p><p class="text-sm text-white mt-1 whitespace-pre-wrap">{openAnswer(row.stars_s_open)}</p></div>
          <div><p class="text-xs text-on-surface-variant font-bold">VD đội ngũ hành động đúng / sai:</p><p class="text-sm text-white mt-1 whitespace-pre-wrap">{openAnswer(row.stars_t_open)}</p></div>
          <div><p class="text-xs text-on-surface-variant font-bold">1 kỹ năng cần đào tạo thêm:</p><p class="text-sm text-white mt-1 whitespace-pre-wrap">{openAnswer(row.stars_a_open)}</p></div>
          <div><p class="text-xs text-on-surface-variant font-bold">Tự hào & lo lắng về đội ngũ:</p><p class="text-sm text-white mt-1 whitespace-pre-wrap">{openAnswer(row.stars_syn_open)}</p></div>
          <div><p class="text-xs text-on-surface-variant font-bold">Synergy hiện tại:</p><p class="text-sm text-white mt-1">{row.stars_syn_choice ?? '—'}</p></div>
        </div>
      </section>

      <section>
        <h4 class="text-base font-bold text-amber-500 mb-3">HỆ THỐNG SỐNG</h4>
        <div class="space-y-3">
          <div><p class="text-xs text-on-surface-variant font-bold">Tự đánh giá:</p><p class="text-sm text-white mt-1 whitespace-pre-wrap">{openAnswer(row.living_o1)}</p></div>
          <div><p class="text-xs text-on-surface-variant font-bold">Sống tốt nhất / yếu nhất:</p><p class="text-sm text-white mt-1 whitespace-pre-wrap">{openAnswer(row.living_o2)}</p></div>
        </div>
      </section>

      <section>
        <h4 class="text-base font-bold text-amber-500 mb-3">TIỀM NĂNG</h4>
        <div class="space-y-3">
          <div><p class="text-xs text-on-surface-variant font-bold">Tầm nhìn 3 năm:</p><p class="text-sm text-white mt-1 whitespace-pre-wrap">{openAnswer(row.future_o1)}</p></div>
          <div><p class="text-xs text-on-surface-variant font-bold">Áp lực lớn nhất:</p><p class="text-sm text-white mt-1 whitespace-pre-wrap">{openAnswer(row.future_o2)}</p></div>
          <div><p class="text-xs text-on-surface-variant font-bold">Đã thử nhiều lần chưa thành công:</p><p class="text-sm text-white mt-1 whitespace-pre-wrap">{openAnswer(row.future_o3)}</p></div>
        </div>
      </section>

      <section>
        <h4 class="text-base font-bold text-amber-500 mb-3">CAM KẾT</h4>
        <div class="space-y-3">
          <div><p class="text-xs text-on-surface-variant font-bold">Sẵn sàng nhìn thấy sự thật:</p><p class="text-sm text-white mt-1 whitespace-pre-wrap">{openAnswer(row.commit_o1)}</p></div>
          <div><p class="text-xs text-on-surface-variant font-bold">1 điều nhỏ làm ngay:</p><p class="text-sm text-white mt-1 whitespace-pre-wrap">{openAnswer(row.commit_o2)}</p></div>
          <div><p class="text-xs text-on-surface-variant font-bold">Mức cam kết:</p><p class="text-sm text-white mt-1">{row.commit_choice ?? '—'}</p></div>
          {row.signature && (
            <div><p class="text-xs text-on-surface-variant font-bold">Chữ ký:</p><p class="text-sm text-white mt-1 italic">{row.signature}</p></div>
          )}
        </div>
      </section>
    </div>
  </details>
</AdminLayout>

<style>
  .prose-content {
    color: var(--on-surface, #d4d4d8);
    line-height: 1.75;
    font-size: 0.95rem;
  }
  .prose-content :global(h1) { font-size: 1.4rem; font-weight: 700; color: #fff; margin: 1.5rem 0 0.5rem; }
  .prose-content :global(h2) { font-size: 1.15rem; font-weight: 700; color: #fff; margin: 1.25rem 0 0.5rem; }
  .prose-content :global(h3) { font-size: 1rem; font-weight: 700; color: #fff; margin: 1rem 0 0.5rem; }
  .prose-content :global(p) { margin: 0 0 0.85rem; }
  .prose-content :global(ul), .prose-content :global(ol) { margin: 0 0 0.85rem; padding-left: 1.5rem; }
  .prose-content :global(li) { margin-bottom: 0.3rem; }
  .prose-content :global(strong) { color: #f59e0b; }
  .prose-content :global(em) { color: #a1a1aa; }
  .prose-content :global(blockquote) {
    border-left: 3px solid #f59e0b;
    padding: 0.25rem 0 0.25rem 1rem;
    margin: 1rem 0;
    color: #a1a1aa;
    font-style: italic;
  }
  .prose-content :global(hr) { border: 0; border-top: 1px solid #27272a; margin: 1.5rem 0; }
</style>
