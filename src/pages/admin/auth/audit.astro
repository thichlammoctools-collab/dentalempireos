---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';

export const prerender = false;

const db = env.DB;

const limit = 50;
const result = await db.prepare(`
  SELECT
    s."createdAt" as createdAt,
    s."ipAddress",
    s."userAgent",
    u."name" as userName,
    u."email" as userEmail
  FROM "session" s
  LEFT JOIN "user" u ON u."id" = s."userId"
  ORDER BY s."createdAt" DESC
  LIMIT ?
`).bind(limit).all<{
  createdAt: string;
  ipAddress: string | null;
  userAgent: string | null;
  userName: string | null;
  userEmail: string | null;
}>();

const sessions = result.results ?? [];
const total = sessions.length;
---

<AdminLayout title="Nhật ký | Auth Admin">
  <div class="flex flex-col md:flex-row md:justify-between md:items-end gap-4">
    <div>
      <h2 class="text-3xl font-bold text-white mb-1">Nhật ký Hoạt động</h2>
      <p class="text-on-surface-variant">{total} phiên gần nhất</p>
    </div>
    <button id="btn-refresh" type="button" class="flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-bold bg-surface-container border border-outline-variant/30 text-on-surface hover:border-primary hover:text-primary transition-all cursor-pointer">
      <span class="material-symbols-outlined text-lg">refresh</span>
      Làm mới
    </button>
  </div>

  <!-- Info banner -->
  <div class="mt-4 px-4 py-3 rounded-xl bg-surface-container border border-outline-variant/20 text-sm text-on-surface-variant">
    <span class="material-symbols-outlined text-base align-middle mr-1">info</span>
    Nhật ký được tổng hợp từ các phiên đăng nhập gần nhất. Không có bảng audit log riêng.
  </div>

  <!-- Events list -->
  <div class="glass-card rounded-xl overflow-hidden mt-4">
    <div class="overflow-x-auto">
      <table class="w-full text-sm text-left">
        <thead>
          <tr class="border-b border-outline-variant/20 text-on-surface-variant uppercase text-xs tracking-wider">
            <th class="px-6 py-4 font-bold">Thời gian</th>
            <th class="px-6 py-4 font-bold">Người dùng</th>
            <th class="px-6 py-4 font-bold">IP</th>
            <th class="px-6 py-4 font-bold">Trình duyệt</th>
          </tr>
        </thead>
        <tbody>
          {sessions.length === 0 ? (
            <tr>
              <td colspan="4" class="px-6 py-12 text-center text-on-surface-variant/50">Chưa có phiên hoạt động nào</td>
            </tr>
          ) : sessions.map(session => (
            <tr class="border-b border-outline-variant/10 hover:bg-surface-container-high/50 transition-colors">
              <td class="px-6 py-4 text-on-surface-variant whitespace-nowrap">
                {new Date(session.createdAt).toLocaleString('vi-VN')}
              </td>
              <td class="px-6 py-4">
                <div class="flex items-center gap-2">
                  <div class="w-7 h-7 rounded-full bg-primary/20 border border-primary/30 flex items-center justify-center text-primary font-bold text-xs flex-shrink-0">
                    {session.userName?.charAt(0)?.toUpperCase() ?? '?'}
                  </div>
                  <div>
                    <div class="font-medium text-on-surface text-sm">{session.userName ?? 'N/A'}</div>
                    <div class="text-xs text-on-surface-variant">{session.userEmail ?? '-'}</div>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 text-on-surface-variant font-mono text-xs">
                {session.ipAddress ?? '-'}
              </td>
              <td class="px-6 py-4 text-on-surface-variant text-xs">
                {session.userAgent ? (() => {
                  const ua = session.userAgent;
                  if (ua.includes('Chrome') && !ua.includes('Edg')) return 'Chrome';
                  if (ua.includes('Firefox')) return 'Firefox';
                  if (ua.includes('Safari') && !ua.includes('Chrome')) return 'Safari';
                  if (ua.includes('Edg')) return 'Edge';
                  if (ua.includes('Mobile')) return 'Mobile';
                  return ua.slice(0, 40);
                })() : '-'}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <div class="flex items-center justify-between px-6 py-4 border-t border-outline-variant/10">
      <span class="text-xs text-on-surface-variant">Hiển thị {sessions.length} phiên gần nhất</span>
    </div>
  </div>
</AdminLayout>

<script>
document.getElementById('btn-refresh')?.addEventListener('click', () => {
  window.location.reload();
});
</script>
