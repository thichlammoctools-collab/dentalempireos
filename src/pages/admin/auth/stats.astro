---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';

export const prerender = false;

const db = env.DB;

const totalResult = await db.prepare('SELECT COUNT(*) as total FROM "user"').first<{ total: number }>();

const today = new Date();
today.setHours(0, 0, 0, 0);
const dayStart = today.toISOString();
const weekStart = new Date(today);
weekStart.setDate(weekStart.getDate() - weekStart.getDay());
const monthStart = new Date(today.getFullYear(), today.getMonth(), 1);

const [dailyResult, weeklyResult, monthlyResult] = await Promise.all([
  db.prepare('SELECT COUNT(*) as count FROM "user" WHERE "createdAt" >= ?').bind(dayStart).first<{ count: number }>(),
  db.prepare('SELECT COUNT(*) as count FROM "user" WHERE "createdAt" >= ?').bind(weekStart.toISOString()).first<{ count: number }>(),
  db.prepare('SELECT COUNT(*) as count FROM "user" WHERE "createdAt" >= ?').bind(monthStart.toISOString()).first<{ count: number }>(),
]);

const activeDay = new Date(Date.now() - 86400000).toISOString();
const activeWeek = new Date(Date.now() - 7 * 86400000).toISOString();
const activeMonth = new Date(Date.now() - 30 * 86400000).toISOString();

const [activeDaily, activeWeekly, activeMonthly] = await Promise.all([
  db.prepare('SELECT COUNT(DISTINCT "userId") as count FROM "session" WHERE "updatedAt" >= ?').bind(activeDay).first<{ count: number }>(),
  db.prepare('SELECT COUNT(DISTINCT "userId") as count FROM "session" WHERE "updatedAt" >= ?').bind(activeWeek).first<{ count: number }>(),
  db.prepare('SELECT COUNT(DISTINCT "userId") as count FROM "session" WHERE "updatedAt" >= ?').bind(activeMonth).first<{ count: number }>(),
]);

// Graph: đăng ký theo ngày (14 ngày gần nhất)
const graph14: { label: string; newUsers: number }[] = [];
for (let i = 13; i >= 0; i--) {
  const d = new Date();
  d.setDate(d.getDate() - i);
  d.setHours(0, 0, 0, 0);
  const start = d.toISOString();
  d.setDate(d.getDate() + 1);
  const end = d.toISOString();
  const r = await db.prepare('SELECT COUNT(*) as count FROM "user" WHERE "createdAt" >= ? AND "createdAt" < ?').bind(start, end).first<{ count: number }>();
  graph14.push({
    label: d.toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit' }),
    newUsers: r?.count ?? 0,
  });
}
---

<AdminLayout title="Thống kê | Auth Admin">
  <div class="flex flex-col md:flex-row md:justify-between md:items-end gap-4">
    <div>
      <h2 class="text-3xl font-bold text-white mb-1">Thống kê Người dùng</h2>
      <p class="text-on-surface-variant">Dữ liệu hoạt động và đăng ký người dùng</p>
    </div>
  </div>

  <!-- Summary cards -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-6">
    <div class="glass-card rounded-xl px-5 py-4">
      <div class="text-xs text-on-surface-variant uppercase tracking-wider font-semibold mb-1">Tổng người dùng</div>
      <div class="text-3xl font-bold text-white">{totalResult?.total ?? 0}</div>
    </div>
    <div class="glass-card rounded-xl px-5 py-4">
      <div class="text-xs text-on-surface-variant uppercase tracking-wider font-semibold mb-1">Đăng ký hôm nay</div>
      <div class="text-3xl font-bold text-blue-400">{dailyResult?.count ?? 0}</div>
    </div>
    <div class="glass-card rounded-xl px-5 py-4">
      <div class="text-xs text-on-surface-variant uppercase tracking-wider font-semibold mb-1">Đăng ký tuần này</div>
      <div class="text-3xl font-bold text-purple-400">{weeklyResult?.count ?? 0}</div>
    </div>
    <div class="glass-card rounded-xl px-5 py-4">
      <div class="text-xs text-on-surface-variant uppercase tracking-wider font-semibold mb-1">Đăng ký tháng này</div>
      <div class="text-3xl font-bold text-primary">{monthlyResult?.count ?? 0}</div>
    </div>
  </div>

  <!-- Active users -->
  <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mt-4">
    <div class="glass-card rounded-xl px-5 py-4">
      <div class="text-xs text-on-surface-variant uppercase tracking-wider font-semibold mb-1">Hoạt động hôm nay</div>
      <div class="text-3xl font-bold text-green-400">{activeDaily?.count ?? 0}</div>
    </div>
    <div class="glass-card rounded-xl px-5 py-4">
      <div class="text-xs text-on-surface-variant uppercase tracking-wider font-semibold mb-1">Hoạt động tuần này</div>
      <div class="text-3xl font-bold text-green-500">{activeWeekly?.count ?? 0}</div>
    </div>
    <div class="glass-card rounded-xl px-5 py-4">
      <div class="text-xs text-on-surface-variant uppercase tracking-wider font-semibold mb-1">Hoạt động tháng này</div>
      <div class="text-3xl font-bold text-green-600">{activeMonthly?.count ?? 0}</div>
    </div>
  </div>

  <!-- Graph -->
  <div class="glass-card rounded-xl mt-6 p-6">
    <h3 class="text-lg font-bold text-white mb-4">Biểu đồ đăng ký (14 ngày gần nhất)</h3>
    <div id="chart" class="h-48 flex items-end gap-1"></div>
    <div id="chart-labels" class="flex gap-1 mt-2 overflow-hidden"></div>
  </div>
</AdminLayout>

<script>
const data = JSON.parse('{JSON.stringify(graph14)}');
const chart = document.getElementById('chart')!;
const labels = document.getElementById('chart-labels')!;

const max = Math.max(...data.map(d => d.newUsers), 1);

data.forEach((d: any) => {
  const pct = (d.newUsers / max) * 100;
  const bar = document.createElement('div');
  bar.style.flex = '1';
  bar.style.minHeight = '4px';
  bar.style.height = Math.max(pct, 2) + '%';
  bar.style.background = d.newUsers > 0 ? 'var(--color-primary)' : 'rgba(255,255,255,0.1)';
  bar.style.borderRadius = '4px 4px 0 0';
  bar.title = `${d.label}: ${d.newUsers} đăng ký`;
  chart.appendChild(bar);

  const el = document.createElement('div');
  el.style.flex = '1';
  el.style.textAlign = 'center';
  el.className = 'text-[10px] text-on-surface-variant/60';
  el.textContent = d.label;
  labels.appendChild(el);
});
</script>
