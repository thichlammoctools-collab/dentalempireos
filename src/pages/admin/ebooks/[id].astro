---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import SectionItem from '../../../components/admin/SectionItem.astro';
import { env } from 'cloudflare:workers';
import { getChapterTree } from '../../../lib/book-db';
import type { SectionNode } from '../../../lib/book-db';

export const prerender = false;

const { id } = Astro.params;
if (!id) {
  return Astro.redirect('/admin/ebooks');
}

const tree = await getChapterTree(env.DB, id);
if (!tree) {
  return new Response('Không tìm thấy chương', { status: 404 });
}

const ch = tree.chapter;
// Build flat section list (id, level, title) for the dropdown when creating blocks
const flatSections: { id: string; label: string; level: number }[] = [];
function walk(sections: SectionNode[], prefix = '') {
  for (const s of sections) {
    flatSections.push({ id: s.id, label: prefix + s.title, level: s.level });
    if (s.children.length > 0) walk(s.children, prefix + '— ');
  }
}
walk(tree.sections);

// Tree data for move feature
const treeData: { id: string; title: string; children: any[] }[] = tree.sections.map((s: any) => ({ id: s.id, title: s.title, children: s.children }));

// Build flat section list WITH outline numbers — used for the block-move menu
const flatSectionsNumbered: { id: string; label: string; level: number }[] = [];
function walkNumbered(sections: SectionNode[], prefix = '') {
  sections.forEach((s, idx) => {
    const num = prefix ? `${prefix}.${idx + 1}` : String(idx + 1);
    flatSectionsNumbered.push({ id: s.id, label: `${num}. ${s.title}`, level: s.level });
    if (s.children.length > 0) walkNumbered(s.children, num);
  });
}
walkNumbered(tree.sections);

// Compute outline numbers (1, 1.1, 1.2, 2.3.1…) for each section
const sectionNumbers: Record<string, string> = {};
function buildNumbers(sections: SectionNode[], parentNum = '') {
  sections.forEach((s, idx) => {
    const num = parentNum ? `${parentNum}.${idx + 1}` : String(idx + 1);
    sectionNumbers[s.id] = num;
    if (s.children.length > 0) buildNumbers(s.children, num);
  });
}
buildNumbers(tree.sections);

const selectedSectionId = flatSections[0]?.id ?? '';
---

<AdminLayout title={`${ch.title} | Editor`}>

  <div class="max-w-[1200px] w-full mx-auto flex flex-col gap-6">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:justify-between md:items-end gap-4">
      <div>
        <div class="flex items-center gap-3 mb-2">
          <span class="text-xs font-bold tracking-[0.1em] uppercase text-on-surface-variant">Chương {ch.chapter_no}</span>
          <span class="text-xs font-bold tracking-[0.1em] uppercase text-primary">Tầng {ch.tier}</span>
          <span class={`text-xs font-bold tracking-[0.1em] uppercase px-2 py-0.5 rounded ${
            ch.status === 'published' ? 'text-primary bg-primary/10' : 'text-on-surface-variant bg-surface-container-high'
          }`}>{ch.status === 'published' ? 'Đã xuất bản' : 'Bản nháp'}</span>
        </div>
        <h2 class="text-3xl font-bold text-white">{ch.title}</h2>
        <p class="text-on-surface-variant mt-1">{ch.description}</p>
      </div>
      <div class="flex gap-2">
        <a
          href={`/book/${ch.id}`}
          target="_blank"
          class="px-4 py-2 border border-outline-variant text-on-surface-variant rounded-xl text-sm font-bold hover:border-primary hover:text-primary transition-all flex items-center gap-2"
        >
          <span class="material-symbols-outlined text-[18px]">visibility</span>
          Xem trang
        </a>
        <a
          href="/admin/ebooks"
          class="px-4 py-2 border border-outline-variant text-on-surface-variant rounded-xl text-sm font-bold hover:border-primary hover:text-primary transition-all flex items-center gap-2"
        >
          <span class="material-symbols-outlined text-[18px]">arrow_back</span>
          Quay lại
        </a>
      </div>
    </div>

    <!-- Metadata edit (chapter-level) -->
    <section class="glass-card rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <button type="button" id="meta-toggle" class="flex items-center gap-1.5 text-base font-bold text-white hover:text-primary transition-colors" title="Thu gọn / mở rộng">
          <span class="material-symbols-outlined text-[20px] meta-collapse-icon" style="transition:transform 0.2s">expand_more</span>
          <span>Thông tin chương</span>
        </button>
        <span class="text-xs text-on-surface-variant/60 meta-summary"></span>
      </div>
      <form id="chapter-meta-form" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1">Tiêu đề</label>
          <input name="title" value={ch.title} class="w-full px-3 py-2 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-semibold text-on-surface-variant mb-1">Số thứ tự</label>
            <input name="chapter_no" type="number" min="1" value={ch.chapter_no} class="w-full px-3 py-2 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-on-surface-variant mb-1">Tầng</label>
            <select name="tier" class="w-full px-3 py-2 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none">
              <option value="1" selected={ch.tier === 1}>Tầng 1</option>
              <option value="2" selected={ch.tier === 2}>Tầng 2</option>
              <option value="3" selected={ch.tier === 3}>Tầng 3</option>
            </select>
          </div>
        </div>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1">Trạng thái</label>
          <select name="status" class="w-full px-3 py-2 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none">
            <option value="draft" selected={ch.status === 'draft'}>Bản nháp</option>
            <option value="published" selected={ch.status === 'published'}>Xuất bản</option>
          </select>
        </div>
        <div class="sm:col-span-2">
          <label class="block text-xs font-semibold text-on-surface-variant mb-1">Mô tả</label>
          <input name="description" value={ch.description ?? ''} class="w-full px-3 py-2 bg-surface-container border border-outline-variant rounded-lg text-white text-sm focus:ring-1 focus:ring-primary focus:outline-none" />
        </div>
        <div class="sm:col-span-2 flex justify-end">
          <button type="submit" class="px-4 py-2 bg-primary text-on-primary rounded-lg text-sm font-bold hover:opacity-90 transition-all">
            Lưu thông tin
          </button>
        </div>
      </form>
    </section>

    <!-- Sections tree -->
    <section class="glass-card rounded-xl p-5">
      <div class="flex items-center justify-between mb-3 gap-2 flex-wrap">
        <h3 class="text-base font-bold text-white">Đề mục</h3>
        <div class="flex items-center gap-1.5 flex-wrap">
          <button id="btn-expand-all" type="button" class="px-2 py-1.5 text-on-surface-variant hover:text-primary rounded-lg text-[11px] font-bold transition-all flex items-center gap-0.5" title="Mở tất cả đề mục con">
            <span class="material-symbols-outlined text-[14px]">unfold_more</span>
            Mở
          </button>
          <button id="btn-collapse-all" type="button" class="px-2 py-1.5 text-on-surface-variant hover:text-primary rounded-lg text-[11px] font-bold transition-all flex items-center gap-0.5" title="Đóng tất cả đề mục con">
            <span class="material-symbols-outlined text-[14px]">unfold_less</span>
            Đóng
          </button>
          <button id="btn-bulk-add" type="button" class="px-3 py-1.5 bg-surface-container-high text-on-surface-variant rounded-lg text-xs font-bold hover:text-primary border border-outline-variant transition-all flex items-center gap-1" title="Thêm nhiều đề mục cùng lúc (Ctrl+Shift+S)">
            <span class="material-symbols-outlined text-[16px]">format_list_bulleted_add</span>
            Thêm nhiều
          </button>
          <button id="btn-add-section" type="button" class="px-3 py-1.5 bg-primary/10 text-primary rounded-lg text-xs font-bold hover:bg-primary/20 transition-all flex items-center gap-1" title="Thêm đề mục chính (Ctrl+Shift+S)">
            <span class="material-symbols-outlined text-[16px]">playlist_add</span>
            Thêm đề mục chính
          </button>
        </div>
      </div>

      {flatSections.length === 0 ? (
        <p data-empty-msg class="text-sm text-on-surface-variant py-6 text-center">
          Chưa có đề mục nào. Bấm "Thêm đề mục chính" hoặc "Thêm nhiều" để bắt đầu.
        </p>
      ) : (
        <ul id="section-tree" data-section-list class="flex flex-col gap-1">
          {tree.sections.map((s) => (
            <SectionItem section={s} selectedId={selectedSectionId} depth={0} number={sectionNumbers[s.id] ?? ''} />
          ))}
        </ul>
      )}

      <!-- Hidden data for section list (used by block move feature) -->
      <script is:inline define:vars={{ flatSectionsNumbered, sectionNumbers, treeData }}>
        window.__flatSections = flatSectionsNumbered;
        window.__sectionNumbers = sectionNumbers;
        window.__treeData = treeData;
      </script>

    </section>
  <!-- ═══════════════ Bulk add sections modal ═══════════════ -->
  <div id="bulk-add-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center">
    <div id="bulk-add-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
    <div class="relative bg-surface-container rounded-2xl shadow-2xl border border-outline-variant/30 w-full max-w-xl mx-4 flex flex-col">
      <div class="flex items-center justify-between px-5 pt-5 pb-3">
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-primary text-[20px]">format_list_bulleted_add</span>
          <h3 class="text-base font-bold text-white">Thêm nhiều đề mục</h3>
        </div>
        <button id="bulk-add-close" type="button" class="w-8 h-8 flex items-center justify-center rounded-lg text-on-surface-variant hover:text-white hover:bg-surface-container-high transition-all" title="Đóng">
          <span class="material-symbols-outlined text-[20px]">close</span>
        </button>
      </div>
      <div class="px-5 pb-2">
        <p class="text-xs text-on-surface-variant/70">Nhập tên đề mục, mỗi dòng một đề mục. Tất cả sẽ được tạo làm đề mục chính (cùng cấp).</p>
      </div>
      <div class="px-5 pb-3">
        <textarea id="bulk-add-textarea" rows="10" placeholder="Khám tổng quát&#10;Chụp X-quang&#10;CT Cone Beam&#10;..." class="w-full bg-surface-container-low border border-outline-variant rounded-lg px-3 py-3 text-white text-sm leading-relaxed focus:ring-1 focus:ring-primary focus:outline-none resize-y min-h-[160px] placeholder:text-on-surface-variant/40 font-mono"></textarea>
      </div>
      <div class="flex items-center justify-between px-5 pb-5">
        <span id="bulk-add-count" class="text-xs text-on-surface-variant">0 đề mục</span>
        <button id="bulk-add-submit" type="button" class="px-4 py-2 bg-primary text-on-primary rounded-lg text-sm font-bold hover:opacity-90 transition-all disabled:opacity-40">
          Tạo tất cả
        </button>
      </div>
    </div>
  </div>

  <!-- ═══════════════ Block editor modal ═══════════════ -->
  <div id="section-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center">
    <!-- Backdrop -->
    <div id="modal-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm transition-opacity"></div>

    <!-- Modal panel -->
    <div class="relative bg-surface-container rounded-2xl shadow-2xl border border-outline-variant/30 w-full max-w-6xl max-h-[92vh] flex flex-col mx-4 my-3">
      <!-- Header -->
      <div class="flex items-center justify-between p-5 border-b border-outline-variant/30 shrink-0">
        <div class="flex items-center gap-2 min-w-0">
          <span class="material-symbols-outlined text-primary text-[20px]">menu_book</span>
          <h3 id="modal-section-title" class="text-base font-bold text-white truncate"></h3>
        </div>
        <div class="flex items-center gap-3 shrink-0">
          <span id="modal-save-status" class="text-xs text-on-surface-variant"></span>
          <button id="modal-close-btn" class="w-8 h-8 flex items-center justify-center rounded-lg text-on-surface-variant hover:text-white hover:bg-surface-container-high transition-all" title="Đóng (tự lưu)">
            <span class="material-symbols-outlined text-[20px]">close</span>
          </button>
        </div>
      </div>

      <!-- Body (scrollable) -->
      <div id="modal-blocks-body" class="flex-1 overflow-y-auto min-h-0 p-5">
        <p class="text-sm text-on-surface-variant py-6 text-center">Đang tải...</p>
      </div>

      <!-- Footer: add block buttons -->
      <div class="flex flex-wrap gap-2 p-4 border-t border-outline-variant/30 shrink-0">
        <button data-modal-add-block="text" class="px-3 py-2 bg-surface-container-high text-on-surface-variant rounded-lg text-xs font-bold hover:text-primary hover:border-primary border border-outline-variant transition-all flex items-center gap-1">
          <span class="material-symbols-outlined text-[16px]">notes</span>
          Thêm text
        </button>
        <button data-modal-add-block="image" class="px-3 py-2 bg-surface-container-high text-on-surface-variant rounded-lg text-xs font-bold hover:text-primary hover:border-primary border border-outline-variant transition-all flex items-center gap-1">
          <span class="material-symbols-outlined text-[16px]">image</span>
          Thêm ảnh
        </button>
        <button data-modal-add-block="file" class="px-3 py-2 bg-surface-container-high text-on-surface-variant rounded-lg text-xs font-bold hover:text-primary hover:border-primary border border-outline-variant transition-all flex items-center gap-1">
          <span class="material-symbols-outlined text-[16px]">attach_file</span>
          Thêm biểu mẫu
        </button>
      </div>
    </div>
  </div>

  <!-- ═══════════════ Move block popup (Google Drive-style) ═══════════════ -->
  <div id="move-block-popup" class="hidden fixed inset-0 z-[60] items-center justify-center">
    <div id="move-block-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
    <div class="relative bg-surface-container rounded-2xl shadow-2xl border border-outline-variant/30 w-full max-w-2xl mx-4 flex flex-col max-h-[85vh] overflow-hidden">
      <!-- Header -->
      <div class="flex items-center justify-between px-5 py-4 border-b border-outline-variant/30 shrink-0">
        <div class="flex items-center gap-2 min-w-0">
          <span class="material-symbols-outlined text-primary text-[22px]">drive_file_move</span>
          <div class="min-w-0">
            <h3 class="text-base font-bold text-white">Di chuyển block</h3>
            <p id="move-block-current-path" class="text-[11px] text-on-surface-variant/70 truncate mt-0.5"></p>
          </div>
        </div>
        <button id="move-block-close" type="button" class="w-8 h-8 flex items-center justify-center rounded-lg text-on-surface-variant hover:text-white hover:bg-surface-container-high transition-all" title="Đóng (Esc)">
          <span class="material-symbols-outlined text-[20px]">close</span>
        </button>
      </div>

      <!-- Search bar -->
      <div class="px-5 pt-4 pb-2 shrink-0">
        <div class="relative">
          <span class="material-symbols-outlined text-[18px] text-on-surface-variant/60 absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none">search</span>
          <input id="move-block-search" type="text" placeholder="Tìm đề mục theo tên..." autocomplete="off" class="w-full bg-surface-container-low border border-outline-variant rounded-lg pl-10 pr-3 py-2.5 text-white text-sm placeholder:text-on-surface-variant/50 focus:ring-1 focus:ring-primary focus:border-primary focus:outline-none transition-all" />
        </div>
      </div>

      <!-- Selected destination breadcrumb -->
      <div class="px-5 py-2 border-b border-outline-variant/20 shrink-0 bg-surface-container-low/40">
        <div class="flex items-center gap-1.5 min-h-[20px]">
          <span class="material-symbols-outlined text-[14px] text-primary shrink-0">folder_open</span>
          <span class="text-[11px] text-on-surface-variant/70 shrink-0">Đích:</span>
          <div id="move-block-breadcrumb" class="flex items-center min-w-0 flex-1 truncate">
            <span class="text-on-surface-variant/60 text-xs italic">Chưa chọn đề mục</span>
          </div>
        </div>
      </div>

      <!-- Tree -->
      <div id="move-block-tree" class="flex-1 overflow-y-auto p-3 min-h-[280px] max-h-[50vh]">
        <!-- Tree rendered here -->
      </div>
      <div id="move-block-empty" class="hidden px-5 py-8 text-center text-sm text-on-surface-variant">
        <span class="material-symbols-outlined text-[32px] text-on-surface-variant/40">search_off</span>
        <p class="mt-2">Không tìm thấy đề mục phù hợp</p>
      </div>

      <!-- Footer -->
      <div class="flex items-center justify-end gap-2 px-5 py-3 border-t border-outline-variant/30 shrink-0 bg-surface-container-low/30">
        <button id="move-block-cancel" type="button" class="px-4 py-2 border border-outline-variant text-on-surface-variant rounded-lg text-sm font-bold hover:border-primary hover:text-primary transition-all">
          Huỷ
        </button>
        <button id="move-block-confirm" type="button" disabled class="px-4 py-2 bg-primary text-on-primary rounded-lg text-sm font-bold hover:opacity-90 transition-all disabled:opacity-40 disabled:cursor-not-allowed flex items-center gap-1.5">
          <span class="material-symbols-outlined text-[16px]">drive_file_move</span>
          <span>Chuyển đến đây</span>
        </button>
      </div>
    </div>
  </div>

</AdminLayout>

<script>
  import type { ChapterTree, SectionNode, BlockRow } from '../../../lib/book-db';

  document.addEventListener('DOMContentLoaded', () => {
    const chapterId = window.location.pathname.split('/').pop()!;
    let currentTree: ChapterTree | null = null;

    // ── Modal state ──────────────────────────────────────
    const modal = document.getElementById('section-modal')!;
    const modalBackdrop = document.getElementById('modal-backdrop')!;
    const modalTitle = document.getElementById('modal-section-title')!;
    const modalBody = document.getElementById('modal-blocks-body')!;
    const modalSaveStatus = document.getElementById('modal-save-status')!;
    const modalCloseBtn = document.getElementById('modal-close-btn')!;
    let modalSectionId = '';
    let dirty = false;

    // ── Helpers ──────────────────────────────────────────
    function findSection(sections: SectionNode[], id: string): SectionNode | null {
      for (const s of sections) {
        if (s.id === id) return s;
        const c = findSection(s.children, id);
        if (c) return c;
      }
      return null;
    }

    function escapeHtml(s: string): string {
      return s
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    /** Renumber all visible section items and rebuild __sectionNumbers */
    function renumberAllSections() {
      const treeUl = document.getElementById('section-tree');
      if (!treeUl) return;
      const topItems = Array.from(treeUl.querySelectorAll<HTMLElement>(':scope > [data-section-item]'));
      const nums: Record<string, string> = {};
      topItems.forEach((item, idx) => {
        const num = String(idx + 1);
        applyNumber(item, num, nums);
      });
      // Rebuild window.__sectionNumbers
      (window as any).__sectionNumbers = nums;
      // Rebuild flatSectionsNumbered for the block-move dropdown
      const sectionListData: { id: string; label: string; level: number }[] = (window as any).__flatSections ?? [];
      sectionListData.forEach(s => {
        const n = nums[s.id];
        if (n) {
          // Strip old leading number (e.g. "1. Foo" → "Foo") then prepend new
          s.label = s.label.replace(/^\d[\d.]*\s*/, '');
          s.label = `${n}. ${s.label}`;
        }
      });
    }

    /** Recursively apply number to a section-item and its children */
    function applyNumber(item: HTMLElement, num: string, nums: Record<string, string>) {
      const id = item.dataset.sectionId ?? '';
      item.dataset.sectionNumber = num;
      nums[id] = num;
      // Update or create the number badge span
      let badge = item.querySelector<HTMLElement>(':scope > div > [data-section-number]');
      if (badge) {
        badge.textContent = num;
        badge.title = `Đề mục ${num}`;
      } else if (num) {
        // Insert badge before the title span
        const titleSpan = item.querySelector<HTMLElement>(':scope > div > [data-section-title]');
        if (titleSpan) {
          badge = document.createElement('span');
          badge.setAttribute('data-section-number', '');
          badge.className = 'inline-flex items-center justify-center min-w-[22px] h-[18px] px-1 text-[10px] font-bold tabular-nums rounded bg-surface-container-high text-primary/80 border border-primary/15 shrink-0 select-none';
          badge.title = `Đề mục ${num}`;
          badge.textContent = num;
          titleSpan.parentElement?.insertBefore(badge, titleSpan);
        }
      }
      // Recurse into children
      const childUl = item.querySelector<HTMLElement>(':scope > ul[data-section-list]');
      if (childUl) {
        const childItems = Array.from(childUl.querySelectorAll<HTMLElement>(':scope > [data-section-item]'));
        childItems.forEach((child, idx) => {
          applyNumber(child, `${num}.${idx + 1}`, nums);
        });
      }
    }

    /** Close all open inline input rows (add sub / keywords) */
    function clearInlineInputs() {
      document.querySelectorAll('[data-add-sub-input]').forEach((el) => el.remove());
    }

    /** Ensure a toggle button exists on a parent item that just received children */
    function ensureToggle(sectionItem: HTMLElement) {
      if (sectionItem.querySelector('[data-section-toggle]')) return;
      const handleSpan = sectionItem.querySelector<HTMLElement>('.section-drag-handle');
      if (!handleSpan) return;
      const btn = document.createElement('button');
      btn.setAttribute('data-section-toggle', '');
      btn.className = 'section-toggle-btn p-0.5 rounded hover:bg-white/5 transition-colors shrink-0';
      btn.title = 'Thu gọn / Mở rộng';
      btn.innerHTML = '<span class="material-symbols-outlined text-[14px] section-toggle-icon text-on-surface-variant">expand_more</span>';
      handleSpan.parentElement?.insertBefore(btn, handleSpan.nextSibling);
    }

    /** Expand a section's child list + rotate toggle icon */
    function expandSection(sectionItem: HTMLElement) {
      const childUl = sectionItem.querySelector<HTMLElement>(':scope > ul[data-section-list]');
      if (childUl) childUl.style.display = '';
      const icon = sectionItem.querySelector<HTMLElement>('.section-toggle-icon');
      if (icon) icon.style.transform = 'rotate(0deg)';
    }

    /** Flash animation + scroll to element */
    function flashAndScroll(el: HTMLElement) {
      el.classList.add('reorder-success');
      el.addEventListener('animationend', () => el.classList.remove('reorder-success'), { once: true });
      setTimeout(() => el.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 50);
    }

    // ── Fetch tree ────────────────────────────────────────
    async function loadTree(): Promise<ChapterTree> {
      const res = await fetch(`/api/admin/chapters/${chapterId}`, { credentials: 'include' });
      const tree = await res.json() as ChapterTree;
      currentTree = tree;
      return tree;
    }

    // ── Chapter metadata save ─────────────────────────────
    const chapterForm = document.getElementById('chapter-meta-form') as HTMLFormElement;

    // ── Collapse/expand "Thông tin chương" ────────────────
    const metaToggle = document.getElementById('meta-toggle')!;
    const metaCollapseIcon = document.querySelector<HTMLElement>('.meta-collapse-icon')!;
    const metaSummary = document.querySelector<HTMLElement>('.meta-summary')!;
    const META_KEY = 'admin:ebook:metaCollapsed';

    function updateMetaSummary() {
      const title = (chapterForm?.querySelector<HTMLInputElement>('[name="title"]')?.value ?? '').trim();
      metaSummary.textContent = title ? `“${title}”` : '';
    }

    function applyMetaCollapsed(collapsed: boolean) {
      if (collapsed) {
        chapterForm!.style.display = 'none';
        metaCollapseIcon.style.transform = 'rotate(-90deg)';
      } else {
        chapterForm!.style.display = '';
        metaCollapseIcon.style.transform = 'rotate(0deg)';
      }
    }

    // Initial state — default to collapsed on desktop to keep the editor tidy
    let metaCollapsed: boolean;
    try {
      const saved = localStorage.getItem(META_KEY);
      metaCollapsed = saved === null ? window.matchMedia('(min-width: 768px)').matches : saved === '1';
    } catch {
      metaCollapsed = true;
    }
    applyMetaCollapsed(metaCollapsed);
    updateMetaSummary();
    metaToggle.addEventListener('click', () => {
      metaCollapsed = !metaCollapsed;
      applyMetaCollapsed(metaCollapsed);
      try { localStorage.setItem(META_KEY, metaCollapsed ? '1' : '0'); } catch { /* ignore */ }
    });

    chapterForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(chapterForm);
      const res = await fetch(`/api/admin/chapters/${chapterId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({
          title: fd.get('title'),
          description: fd.get('description'),
          status: fd.get('status'),
        }),
      });
      if (res.ok) {
        updateMetaSummary();
        alert('Đã lưu');
      } else {
        alert('Lỗi khi lưu');
      }
    });

    // ── Expand / Collapse all sections ────────────────────
    document.getElementById('btn-expand-all')?.addEventListener('click', () => {
      document.querySelectorAll<HTMLElement>('[data-section-list]').forEach((ul) => {
        ul.style.display = '';
        // Also update toggle icon rotation
        const parentItem = ul.closest<HTMLElement>('[data-section-item]');
        const icon = parentItem?.querySelector<HTMLElement>('.section-toggle-icon');
        if (icon) icon.style.transform = 'rotate(0deg)';
      });
    });

    document.getElementById('btn-collapse-all')?.addEventListener('click', () => {
      document.querySelectorAll<HTMLElement>('[data-section-list]').forEach((ul) => {
        ul.style.display = 'none';
        const parentItem = ul.closest<HTMLElement>('[data-section-item]');
        const icon = parentItem?.querySelector<HTMLElement>('.section-toggle-icon');
        if (icon) icon.style.transform = 'rotate(-90deg)';
      });
    });

    // ── Inline add main section ──────────────────────────
    // Helper: build a raw section-item LI from a SectionNode (mirrors SectionItem.astro)
    function buildSectionLi(s: SectionNode, depth = 0): HTMLLIElement {
      const li = document.createElement('li');
      li.dataset.sectionItem = '';
      li.dataset.sectionId = s.id;
      li.dataset.sectionOrder = String(s.order);
      li.dataset.sectionDepth = String(depth);
      li.dataset.sectionParentId = s.parent_id ?? '';
      li.dataset.sectionKeywords = s.keywords ?? '[]';
      li.className = 'section-nestable relative flex flex-col gap-1 p-2.5 rounded-lg border bg-surface-container-low border-outline-variant/30 hover:border-outline-variant hover:bg-surface-container transition-all duration-200';
      const isLevel3 = s.level === 3;
      const iconClass = isLevel3 ? 'text-on-surface-variant' : 'text-primary';
      const icon = isLevel3 ? 'subdirectory_arrow_right' : 'menu_book';
      const titleClass = isLevel3 ? 'text-on-surface-variant' : 'text-white font-semibold';
      // Build keyword chips
      let kwChips = '';
      let kwArr: string[] = [];
      try { kwArr = (s.keywords || '').startsWith('[') ? JSON.parse(s.keywords) : s.keywords.split(',').map((x: string) => x.trim()).filter(Boolean); } catch { /* ignore */ }
      if (kwArr.length > 0) {
        kwChips = `<div class="flex flex-wrap gap-1 mt-0.5 pl-9">${kwArr.map((k: string) => `<span class="inline-flex items-center px-1.5 py-0.5 text-[9px] font-medium rounded bg-primary/10 text-primary border border-primary/20">${escapeHtml(k)}</span>`).join('')}</div>`;
      }
      const hasChildren = s.children.length > 0;
      let childUlHtml = '';
      if (hasChildren) {
        const childLis = s.children.map((c: SectionNode) => buildSectionLi(c, depth + 1).outerHTML).join('');
        childUlHtml = `<ul data-section-list class="flex flex-col gap-2 pl-6 mt-1.5 border-l border-outline-variant/20">${childLis}</ul>`;
      }
      const toggleBtn = hasChildren
        ? `<button data-section-toggle class="section-toggle-btn p-0.5 rounded hover:bg-white/5 transition-colors shrink-0" title="Thu gọn / Mở rộng"><span class="material-symbols-outlined text-[14px] section-toggle-icon text-on-surface-variant">expand_more</span></button>`
        : `<span class="material-symbols-outlined text-[16px] ${iconClass}">${icon}</span>`;
      const countBadge = hasChildren ? `<span data-section-count class="text-[10px] text-on-surface-variant/40 tabular-nums select-none">${s.children.length} mục</span>` : '';
      li.innerHTML = `
        <div class="flex items-center gap-2">
          <span class="section-drag-handle group cursor-grab active:cursor-grabbing text-on-surface-variant/50 hover:text-primary shrink-0 flex items-center justify-center w-7 h-8 rounded-md hover:bg-primary/10 transition-all duration-200" title="Kéo để sắp xếp" draggable="true">
            <span class="material-symbols-outlined text-[18px] group-hover:scale-110 transition-transform duration-150">drag_indicator</span>
          </span>
          ${toggleBtn}
          <span data-section-number class="inline-flex items-center justify-center min-w-[22px] h-[18px] px-1 text-[10px] font-bold tabular-nums rounded bg-surface-container-high text-primary/80 border border-primary/15 shrink-0 select-none" style="display:none"></span>
          <span data-section-title class="flex-1 truncate text-sm cursor-pointer hover:text-primary/80 transition-colors ${titleClass}" title="Nhấp đôi để sửa tên">${escapeHtml(s.title)}</span>
          ${countBadge}
          <button data-section-edit class="p-1 rounded text-on-surface-variant hover:text-primary transition-colors" title="Sửa tên">
            <span class="material-symbols-outlined text-[14px]">edit</span>
          </button>
          <button data-section-add-sub class="p-1 rounded text-on-surface-variant hover:text-primary transition-colors" title="Thêm đề mục phụ">
            <span class="material-symbols-outlined text-[14px]">playlist_add</span>
          </button>
          <button data-section-delete class="p-1 rounded text-on-surface-variant hover:text-error transition-colors" title="Xoá">
            <span class="material-symbols-outlined text-[14px]">delete</span>
          </button>
          <button data-section-keywords class="p-1 rounded ${kwArr.length > 0 ? 'text-primary hover:text-primary/80' : 'text-on-surface-variant hover:text-primary'} transition-colors" title="${kwArr.length > 0 ? 'Keywords: ' + kwArr.join(', ') : 'Thêm keywords'}">
            <span class="material-symbols-outlined text-[14px]">sell</span>
          </button>
        </div>
        ${kwChips}
        ${childUlHtml}
      `;
      return li;
    }

    function createInlineInputRow(level: number, placeholder: string, opts: { onSubmit: (value: string, li: HTMLLIElement, input: HTMLInputElement) => Promise<void> }): HTMLLIElement {
      const li = document.createElement('li');
      li.setAttribute('data-add-sub-input', '');
      li.className = 'flex items-center gap-2 px-3 py-2 bg-primary/5 border border-primary/30 rounded-lg';
      const icon = level === 3 ? 'subdirectory_arrow_right' : 'menu_book';
      li.innerHTML = `
        <span class="material-symbols-outlined text-primary text-[18px]">${icon}</span>
        <input type="text" autocomplete="off" placeholder="${placeholder}"
          class="flex-1 bg-transparent text-white text-sm focus:outline-none placeholder:text-on-surface-variant/60" />
        <span class="text-[10px] text-on-surface-variant hidden" data-sub-status>
          <span class="material-symbols-outlined text-[14px] animate-spin inline align-middle">progress_activity</span>
        </span>
        <button type="button" class="p-1 text-on-surface-variant hover:text-error transition-colors" data-cancel-sub-input title="Hủy (Esc)">
          <span class="material-symbols-outlined text-[16px]">close</span>
        </button>
      `;
      const input = li.querySelector('input')!;
      const status = li.querySelector('[data-sub-status]') as HTMLElement;
      const cancelBtn = li.querySelector('[data-cancel-sub-input]')!;
      setTimeout(() => input.focus(), 50);

      let busy = false;
      let finished = false;
      const submit = async () => {
        if (busy || finished) return;
        const title = input.value.trim();
        if (!title) { finished = true; li.remove(); return; }
        busy = true;
        input.disabled = true;
        status.classList.remove('hidden');
        try {
          await opts.onSubmit(title, li, input);
        } finally {
          busy = false;
          finished = true;
          input.disabled = false;
          status.classList.add('hidden');
        }
      };
      input.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Escape') { e.preventDefault(); finished = true; li.remove(); return; }
        if (e.key === 'Enter') { e.preventDefault(); submit(); }
      });
      cancelBtn.addEventListener('click', () => { finished = true; li.remove(); });
      // Blur saves if not already handled by Enter/Escape/cancel
      input.addEventListener('blur', () => { if (!finished) submit(); });
      return li;
    }

    document.getElementById('btn-add-section')?.addEventListener('click', () => {
      clearInlineInputs();
      // Ensure tree UL exists
      let treeUl = document.getElementById('section-tree');
      if (!treeUl) {
        treeUl = document.createElement('ul');
        treeUl.id = 'section-tree';
        treeUl.setAttribute('data-section-list', '');
        treeUl.className = 'flex flex-col gap-1';
        const section = document.querySelector('.glass-card > section, .glass-card')!;
        const emptyMsg = section.querySelector('[data-empty-msg]');
        if (emptyMsg) emptyMsg.remove();
        section.appendChild(treeUl);
      }
      const inputRow = createInlineInputRow(2, 'Tên đề mục chính... (Enter để lưu, Esc để hủy)', {
        onSubmit: async (title, li, input) => {
          const res = await fetch('/api/admin/sections', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({ chapter_id: chapterId, level: 2, title, order: Date.now() }),
          });
          if (res.ok) {
            const { id: newId } = await res.json() as { id: string };
            const node: SectionNode = { id: newId, chapter_id: chapterId, parent_id: null, level: 2, title, slug: '', order: treeUl!.children.length, keywords: '[]', children: [], blocks: [] };
            const newLi = buildSectionLi(node, 0);
            treeUl!.insertBefore(newLi, li);
            flashAndScroll(newLi);
            if (currentTree) currentTree.sections.push(node);
            renumberAllSections();
            input.value = '';
            input.focus();
          }
        }
      });
      treeUl.appendChild(inputRow);
      inputRow.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });

    // ── Bulk add sections modal ──────────────────────────
    const bulkAddModal = document.getElementById('bulk-add-modal')!;
    const bulkAddBackdrop = document.getElementById('bulk-add-backdrop')!;
    const bulkAddTextarea = document.getElementById('bulk-add-textarea') as HTMLTextAreaElement;
    const bulkAddCount = document.getElementById('bulk-add-count')!;
    const bulkAddSubmit = document.getElementById('bulk-add-submit') as HTMLButtonElement;
    const bulkAddClose = document.getElementById('bulk-add-close')!;
    let bulkAdding = false;

    function openBulkAddModal() {
      bulkAddModal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      bulkAddTextarea.value = '';
      bulkAddCount.textContent = '0 đề mục';
      setTimeout(() => bulkAddTextarea.focus(), 50);
    }

    function closeBulkAddModal() {
      bulkAddModal.classList.add('hidden');
      document.body.style.overflow = '';
    }

    document.getElementById('btn-bulk-add')?.addEventListener('click', openBulkAddModal);
    bulkAddClose.addEventListener('click', closeBulkAddModal);
    bulkAddBackdrop.addEventListener('click', closeBulkAddModal);

    bulkAddTextarea.addEventListener('input', () => {
      const lines = bulkAddTextarea.value.split('\n').filter((l: string) => l.trim()).length;
      bulkAddCount.textContent = `${lines} đề mục`;
    });

    bulkAddSubmit.addEventListener('click', async () => {
      if (bulkAdding) return;
      const lines = bulkAddTextarea.value.split('\n').map((l: string) => l.trim()).filter(Boolean);
      if (lines.length === 0) return;
      bulkAdding = true;
      bulkAddSubmit.disabled = true;
      bulkAddSubmit.textContent = `Đang tạo ${lines.length} đề mục...`;
      try {
        // Create all sequentially (one DB write per section)
        let createdCount = 0;
        for (const title of lines) {
          const res = await fetch('/api/admin/sections', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              chapter_id: chapterId,
              level: 2,
              title,
              order: Date.now() + createdCount,
            }),
          });
          if (res.ok) createdCount++;
        }
        closeBulkAddModal();
        location.reload();
      } finally {
        bulkAdding = false;
        bulkAddSubmit.disabled = false;
        bulkAddSubmit.textContent = 'Tạo tất cả';
      }
    });

    // ── Keyboard shortcuts ───────────────────────────────
    document.addEventListener('keydown', (e) => {
      // Ctrl+Shift+S = toggle inline add-main input (inside tree) or close bulk modal
      if ((e.ctrlKey || e.metaKey) && e.shiftKey && e.key === 'S') {
        e.preventDefault();
        if (!bulkAddModal.classList.contains('hidden')) { closeBulkAddModal(); return; }
        const existing = document.querySelector('[data-add-sub-input]');
        if (existing) { (existing as HTMLElement).remove(); return; }
        document.getElementById('btn-add-section')?.click();
        return;
      }
      // Escape = close bulk modal
      if (e.key === 'Escape' && !bulkAddModal.classList.contains('hidden')) {
        closeBulkAddModal();
      }
    });

    // ── Modal helpers ─────────────────────────────────────
    function updateSaveStatus(text: string) {
      modalSaveStatus.textContent = text;
    }

    function markDirty() {
      dirty = true;
      updateSaveStatus('Có thay đổi chưa lưu');
      // Auto-save disabled - user must click save button
    }

    async function openModal(sectionId: string) {
      // Always fetch fresh tree to get latest blocks
      const tree = await loadTree();
      const section = findSection(tree.sections, sectionId);
      if (!section) return;

      modalSectionId = sectionId;
      modalTitle.textContent = section.title;
      dirty = false;
      updateSaveStatus('');
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      renderModalBlocks(section);
    }

    async function closeModal() {
      await saveAllDirtyBlocks();
      modal.classList.add('hidden');
      document.body.style.overflow = '';
      modalSectionId = '';
    }

    // ── Save all dirty blocks ─────────────────────────────
    async function saveAllDirtyBlocks() {
      if (!dirty) return;
      updateSaveStatus('Đang lưu...');

      const items = modalBody.querySelectorAll<HTMLElement>('.block-item[data-dirty]');
      for (const item of items) {
        const blockId = item.dataset.blockId;
        if (!blockId) continue;
        await saveBlockElement(item, blockId);
      }

      dirty = false;
      updateSaveStatus('✓ Đã lưu');

      // Re-render modal so uploaded images/files show immediately
      const tree = await loadTree();
      const section = findSection(tree.sections, modalSectionId);
      if (section) renderModalBlocks(section);

      setTimeout(() => { if (!dirty) updateSaveStatus(''); }, 2500);
    }

    // Save a single block element
    async function saveBlockElement(item: HTMLElement, blockId: string) {
      const body: Record<string, unknown> = {};

      const textEl = item.querySelector<HTMLTextAreaElement>('[data-field="text_md"]');
      if (textEl) body.text_md = textEl.value;

      const altEl = item.querySelector<HTMLInputElement>('[data-field="alt"]');
      if (altEl) body.alt = altEl.value;

      const captionEl = item.querySelector<HTMLInputElement>('[data-field="caption"]');
      if (captionEl) body.caption = captionEl.value;

      const fileInput = item.querySelector<HTMLInputElement>('[data-field="file"]');
      const file = fileInput?.files?.[0];

      if (file) {
        const fd = new FormData();
        fd.append('file', file);
        fd.append('chapterId', chapterId);
        const upRes = await fetch('/api/admin/upload', { method: 'POST', credentials: 'include', body: fd });
        if (upRes.ok) {
          const up = await upRes.json() as { r2_key: string; mime: string; filename: string };
          body.r2_key = up.r2_key;
          body.mime = up.mime;
          body.filename = up.filename;
        }
      }

      await fetch(`/api/admin/blocks/${blockId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(body),
      });

      item.removeAttribute('data-dirty');
      updateBlockSaveButton(item, false);
    }

    // Update save button appearance based on dirty state
    function updateBlockSaveButton(item: HTMLElement, isDirty: boolean) {
      const saveBtn = item.querySelector<HTMLElement>('[data-action="save-block"]');
      if (saveBtn) {
        if (isDirty) {
          saveBtn.classList.remove('opacity-0', 'pointer-events-none');
          saveBtn.classList.add('opacity-100');
        } else {
          saveBtn.classList.add('opacity-0', 'pointer-events-none');
          saveBtn.classList.remove('opacity-100');
        }
      }
    }

    // Save single block by ID
    async function saveSingleBlock(blockId: string) {
      const item = modalBody.querySelector<HTMLElement>(`.block-item[data-block-id="${blockId}"]`);
      if (!item) return;
      
      updateSaveStatus('Đang lưu...');
      await saveBlockElement(item, blockId);
      
      // Check if any blocks still dirty
      const hasDirty = modalBody.querySelector('.block-item[data-dirty]') !== null;
      dirty = hasDirty;
      updateSaveStatus(hasDirty ? 'Có thay đổi chưa lưu' : '✓ Đã lưu');
      
      if (!hasDirty) {
        setTimeout(() => updateSaveStatus(''), 2500);
      }
    }

    // ── Render blocks inside modal ─────────────────────────────
    let lastAddedBlockId = '';

    function renderModalBlocks(section: SectionNode) {
      if (section.blocks.length === 0) {
        modalBody.innerHTML = '<p class="text-sm text-on-surface-variant py-6 text-center">Chưa có nội dung. Thêm block bên dưới.</p>';
        return;
      }

      modalBody.innerHTML = section.blocks
        .sort((a, b) => a.order - b.order)
        .map((b) => renderBlock(b, b.id !== lastAddedBlockId))
        .join('');
      autoResizeAll();
      lastAddedBlockId = '';
    }

    // ── Toggle collapse ───────────────────────────────────
    modalBody.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      // Skip if clicking delete or drag handle button
      if (target.closest('[data-action="delete"]')) return;
      if (target.closest('.block-drag-handle')) return;
      const toggle = target.closest<HTMLElement>('[data-action="toggle-collapse"]');
      if (!toggle) return;
      const item = toggle.closest<HTMLElement>('.block-item');
      if (!item) return;
      const content = item.querySelector<HTMLElement>('.block-content');
      const icon = toggle.querySelector<HTMLElement>('.collapse-icon');
      if (!content || !icon) return;

      const isCollapsed = item.dataset.collapsed === '1';
      if (isCollapsed) {
        item.dataset.collapsed = '0';
        content.style.display = '';
        icon.style.transform = 'rotate(0deg)';
      } else {
        item.dataset.collapsed = '1';
        content.style.display = 'none';
        icon.style.transform = 'rotate(-90deg)';
      }
    });

    function renderBlock(b: BlockRow, collapsed = true): string {
      const preview = b.type === 'text'
        ? `<span class="text-xs text-on-surface-variant/60 truncate max-w-[300px]">${escapeHtml((b.text_md ?? '').slice(0, 60))}</span>`
        : b.type === 'image'
          ? (b.r2_key ? `<img src="/media/${b.r2_key}" class="h-5 rounded" />` : '<span class="text-xs text-error">Chưa có ảnh</span>')
          : (b.filename ? `<span class="text-xs text-on-surface-variant/60">📎 ${escapeHtml(b.filename)}</span>` : '<span class="text-xs text-error">Chưa có file</span>');

      const header = `
        <div class="flex items-center justify-between gap-2 cursor-pointer select-none" data-action="toggle-collapse">
          <div class="flex items-center gap-2 min-w-0">
            <span class="block-drag-handle material-symbols-outlined text-[16px] text-on-surface-variant/40 hover:text-primary cursor-grab active:cursor-grabbing shrink-0" draggable="true" title="Kéo để sắp xếp">drag_indicator</span>
            <span class="material-symbols-outlined text-[16px] text-on-surface-variant collapse-icon" style="transition:transform 0.2s">expand_more</span>
            <span class="text-xs font-bold text-on-surface-variant shrink-0">${b.type === 'text' ? 'Text block' : b.type === 'image' ? 'Image block' : 'File block'}</span>
            ${preview}
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <button data-action="save-block" class="text-on-surface-variant hover:text-primary transition-colors opacity-0 pointer-events-none" title="Lưu block">
              <span class="material-symbols-outlined text-[18px]">save</span>
            </button>
            <button data-action="move-block" class="text-on-surface-variant hover:text-primary transition-colors" title="Di chuyển sang đề mục khác">
              <span class="material-symbols-outlined text-[18px]">drive_file_move</span>
            </button>
            <button data-action="delete" class="text-on-surface-variant hover:text-error transition-colors" title="Xoá block">
              <span class="material-symbols-outlined text-[18px]">delete</span>
            </button>
          </div>
        </div>`;

      if (b.type === 'text') {
        return `
          <div class="block-item relative flex flex-col gap-2 p-4 bg-surface-container-low border border-outline-variant/40 rounded-lg mb-3" data-block-id="${b.id}" data-collapsed="${collapsed ? '1' : '0'}">
            ${header}
            <div class="block-content" style="${collapsed ? 'display:none' : ''}">
              <textarea data-field="text_md" rows="12" class="w-full bg-surface-container border border-outline-variant rounded-lg px-3 py-3 text-white text-sm font-mono leading-relaxed focus:ring-1 focus:ring-primary focus:outline-none resize-y min-h-[200px]" placeholder="Markdown...">${escapeHtml(b.text_md ?? '')}</textarea>
            </div>
          </div>`;
      }
      if (b.type === 'image') {
        const url = b.r2_key ? `/media/${b.r2_key}` : '';
        return `
          <div class="block-item relative flex flex-col gap-2 p-4 bg-surface-container-low border border-outline-variant/40 rounded-lg mb-3" data-block-id="${b.id}" data-collapsed="${collapsed ? '1' : '0'}">
            ${header}
            <div class="block-content" style="${collapsed ? 'display:none' : ''}">
              ${url ? `<img src="${url}" alt="${escapeHtml(b.alt ?? '')}" class="max-h-56 rounded-lg" />` : '<p class="text-xs text-error">Chưa có ảnh</p>'}
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                <div>
                  <label class="block text-xs text-on-surface-variant mb-1">Thay ảnh</label>
                  <input data-field="file" type="file" accept="image/*" class="w-full text-xs text-on-surface-variant file:mr-2 file:py-1 file:px-2 file:rounded file:border-0 file:text-xs file:bg-primary/20 file:text-primary hover:file:bg-primary/30" />
                </div>
                <div>
                  <label class="block text-xs text-on-surface-variant mb-1">Alt text (cho AI)</label>
                  <input data-field="alt" value="${escapeHtml(b.alt ?? '')}" class="w-full bg-surface-container border border-outline-variant rounded-lg px-3 py-1.5 text-white text-xs focus:ring-1 focus:ring-primary focus:outline-none" />
                </div>
              </div>
              <div>
                <label class="block text-xs text-on-surface-variant mb-1">Caption</label>
                <input data-field="caption" value="${escapeHtml(b.caption ?? '')}" class="w-full bg-surface-container border border-outline-variant rounded-lg px-3 py-1.5 text-white text-xs focus:ring-1 focus:ring-primary focus:outline-none" />
              </div>
            </div>
          </div>`;
      }
      // file
      return `
        <div class="block-item relative flex flex-col gap-2 p-4 bg-surface-container-low border border-outline-variant/40 rounded-lg mb-3" data-block-id="${b.id}" data-collapsed="${collapsed ? '1' : '0'}">
          ${header}
          <div class="block-content" style="${collapsed ? 'display:none' : ''}">
            ${b.r2_key ? `<p class="text-sm text-white">📎 <a href="/media/${b.r2_key}" class="underline hover:text-primary" target="_blank">${escapeHtml(b.filename ?? 'Tải file')}</a></p>` : '<p class="text-xs text-error">Chưa có file</p>'}
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              <div>
                <label class="block text-xs text-on-surface-variant mb-1">Thay file</label>
                <input data-field="file" type="file" accept=".pdf,.doc,.docx,.xls,.xlsx,image/*" class="w-full text-xs text-on-surface-variant file:mr-2 file:py-1 file:px-2 file:rounded file:border-0 file:text-xs file:bg-primary/20 file:text-primary hover:file:bg-primary/30" />
              </div>
              <div>
                <label class="block text-xs text-on-surface-variant mb-1">Caption</label>
                <input data-field="caption" value="${escapeHtml(b.caption ?? '')}" class="w-full bg-surface-container border border-outline-variant rounded-lg px-3 py-1.5 text-white text-xs focus:ring-1 focus:ring-primary focus:outline-none" />
              </div>
            </div>
          </div>
        </div>`;
    }

    // ── Auto-resize textarea helper ────────────────────────
    function autoResize(ta: HTMLTextAreaElement) {
      ta.style.height = 'auto';
      ta.style.height = ta.scrollHeight + 'px';
    }
    function autoResizeAll() {
      modalBody.querySelectorAll<HTMLTextAreaElement>('textarea[data-field="text_md"]').forEach(autoResize);
    }

    // ── Modal body: event delegation for inputs & delete ──
    modalBody.addEventListener('input', (e) => {
      const target = e.target as HTMLElement;
      if (target.matches('input[data-field], textarea[data-field]')) {
        const item = target.closest<HTMLElement>('.block-item');
        if (item) {
          item.setAttribute('data-dirty', '1');
          updateBlockSaveButton(item, true);
        }
        markDirty();
      }
      if (target.matches('textarea[data-field="text_md"]')) {
        autoResize(target as HTMLTextAreaElement);
      }
    });
    modalBody.addEventListener('change', (e) => {
      const target = e.target as HTMLElement;
      if (target.matches('input[data-field="file"]')) {
        const item = target.closest<HTMLElement>('.block-item');
        if (item) {
          item.setAttribute('data-dirty', '1');
          updateBlockSaveButton(item, true);
        }
        markDirty();
      }
    });
    modalBody.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      
      // Save button clicked - handle before delete to avoid conflict
      const saveBtn = target.closest<HTMLElement>('[data-action="save-block"]');
      if (saveBtn) {
        const item = saveBtn.closest<HTMLElement>('.block-item');
        const blockId = item?.dataset.blockId;
        if (blockId) {
          saveSingleBlock(blockId);
        }
        return;
      }
      
      // Delete button clicked
      const deleteBtn = target.closest<HTMLElement>('[data-action="delete"]');
      if (!deleteBtn) return;
      const item = deleteBtn.closest<HTMLElement>('.block-item');
      const blockId = item?.dataset.blockId;
      if (!blockId) return;
      if (!confirm('Xoá block này?')) return;
      fetch(`/api/admin/blocks/${blockId}`, { method: 'DELETE', credentials: 'include' }).then(() => {
        item?.remove();
        dirty = true;
        updateSaveStatus('Đã xoá');
        // Check if empty now
        if (!modalBody.querySelector('.block-item')) {
          modalBody.innerHTML = '<p class="text-sm text-on-surface-variant py-6 text-center">Chưa có nội dung. Thêm block bên dưới.</p>';
        }
      });
    });

    // ── Block: move to another section (Google Drive-style popup) ─────
    type MoveSectionNode = { id: string; title: string; level: number; children: MoveSectionNode[]; parent_id: string | null };

    function buildMoveTree(sections: SectionNode[]): MoveSectionNode[] {
      return sections.map(s => ({
        id: s.id,
        title: s.title,
        level: s.level,
        parent_id: s.parent_id,
        children: buildMoveTree(s.children),
      }));
    }

    let moveTreeData: MoveSectionNode[] = [];
    try {
      moveTreeData = buildMoveTree((window as any).__treeData ?? []);
      // Fallback: build from currentTree if window var not set
      if (moveTreeData.length === 0 && currentTree) {
        moveTreeData = buildMoveTree((currentTree as ChapterTree).sections);
      }
    } catch { moveTreeData = []; }

    const movePopup = document.getElementById('move-block-popup') as HTMLElement | null;
    const moveBackdrop = document.getElementById('move-block-backdrop');
    const moveSearch = document.getElementById('move-block-search') as HTMLInputElement | null;
    const moveTreeEl = document.getElementById('move-block-tree');
    const moveBreadcrumb = document.getElementById('move-block-breadcrumb');
    const moveCancelBtn = document.getElementById('move-block-cancel');
    const moveConfirmBtn = document.getElementById('move-block-confirm') as HTMLButtonElement | null;
    const moveTitleEl = document.getElementById('move-block-title');
    const moveCurrentPathEl = document.getElementById('move-block-current-path');
    const moveEmptyEl = document.getElementById('move-block-empty');

    let moveActiveBlockId: string | null = null;
    let moveActiveBlockItem: HTMLElement | null = null;
    let moveSelectedId: string | null = null;
    let moveExpandedIds = new Set<string>();
    let moveSearchQuery = '';
    let moveCurrentPath: string[] = []; // breadcrumb of selected section

    function normalizeVN(s: string): string {
      return s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
    }

    function getPathToRoot(treeData: MoveSectionNode[], id: string): MoveSectionNode[] | null {
      function dfs(nodes: MoveSectionNode[], path: MoveSectionNode[]): MoveSectionNode[] | null {
        for (const n of nodes) {
          if (n.id === id) return [...path, n];
          const found = dfs(n.children, [...path, n]);
          if (found) return found;
        }
        return null;
      }
      return dfs(treeData, []);
    }

    function isDescendantOf(treeData: MoveSectionNode[], candidateId: string, ancestorId: string): boolean {
      const path = getPathToRoot(treeData, candidateId);
      if (!path) return false;
      return path.some(n => n.id === ancestorId);
    }

    function sectionMatches(n: MoveSectionNode, q: string): boolean {
      if (!q) return true;
      return normalizeVN(n.title).includes(q);
    }

    function renderMoveTree() {
      if (!moveTreeEl) return;
      const q = normalizeVN(moveSearchQuery);

      // When searching: auto-expand path to every match
      if (q) {
        function findMatches(nodes: MoveSectionNode[], parents: MoveSectionNode[]): { node: MoveSectionNode; path: MoveSectionNode[] }[] {
          const out: { node: MoveSectionNode; path: MoveSectionNode[] }[] = [];
          for (const n of nodes) {
            const path = [...parents, n];
            if (sectionMatches(n, q)) out.push({ node: n, path });
            if (n.children.length) out.push(...findMatches(n.children, path));
          }
          return out;
        }
        const matches = findMatches(moveTreeData, []);
        if (matches.length === 0) {
          moveTreeEl.innerHTML = '';
          moveEmptyEl?.classList.remove('hidden');
          return;
        }
        moveEmptyEl?.classList.add('hidden');

        // Render a flat list of matches with their breadcrumb path
        moveTreeEl.innerHTML = matches.map(({ node, path }) => {
          const isDisabled = node.id === modalSectionId;
          const pathStr = path.slice(0, -1).map(p => escapeHtml(p.title)).join(' › ');
          return `
            <button type="button" data-move-target="${node.id}" ${isDisabled ? 'disabled' : ''} class="move-tree-row ${isDisabled ? 'opacity-40 cursor-not-allowed' : ''} ${moveSelectedId === node.id ? 'move-tree-row-selected' : ''}">
              <div class="flex items-center gap-2 min-w-0 flex-1">
                <span class="material-symbols-outlined text-[18px] ${node.level === 1 ? 'text-primary' : 'text-on-surface-variant'} shrink-0">${node.level === 1 ? 'menu_book' : 'subdirectory_arrow_right'}</span>
                <div class="min-w-0 flex-1">
                  <div class="text-sm font-semibold text-white truncate">${escapeHtml(node.title)}</div>
                  ${pathStr ? `<div class="text-[11px] text-on-surface-variant/70 truncate">${pathStr}</div>` : ''}
                </div>
              </div>
              ${isDisabled ? '<span class="text-[10px] text-on-surface-variant/60 shrink-0">Hiện tại</span>' : ''}
            </button>`;
        }).join('');
        return;
      }

      // No search: render expandable tree
      moveEmptyEl?.classList.add('hidden');

      function renderNode(n: MoveSectionNode): string {
        const isCurrent = n.id === modalSectionId;
        const isSelected = n.id === moveSelectedId;
        const hasChildren = n.children.length > 0;
        const isExpanded = moveExpandedIds.has(n.id);
        return `
          <div class="move-tree-node" data-node-id="${n.id}">
            <button type="button" data-move-target="${n.id}" ${isCurrent ? 'disabled' : ''} class="move-tree-row ${isCurrent ? 'opacity-40 cursor-not-allowed' : ''} ${isSelected ? 'move-tree-row-selected' : ''}">
              ${hasChildren ? `
                <span class="move-tree-toggle shrink-0" data-toggle="${n.id}">
                  <span class="material-symbols-outlined text-[16px] transition-transform ${isExpanded ? 'rotate-90' : ''}">chevron_right</span>
                </span>
              ` : '<span class="w-4 shrink-0"></span>'}
              <span class="material-symbols-outlined text-[18px] ${n.level === 1 ? 'text-primary' : 'text-on-surface-variant'} shrink-0">${n.level === 1 ? 'menu_book' : 'subdirectory_arrow_right'}</span>
              <span class="text-sm font-semibold text-white truncate flex-1 text-left">${escapeHtml(n.title)}</span>
              ${isCurrent ? '<span class="text-[10px] text-on-surface-variant/60 shrink-0">Hiện tại</span>' : ''}
            </button>
            ${hasChildren ? `<div class="move-tree-children ${isExpanded ? '' : 'hidden'}">${n.children.map(renderNode).join('')}</div>` : ''}
          </div>`;
      }

      moveTreeEl.innerHTML = moveTreeData.length === 0
        ? '<div class="text-sm text-on-surface-variant text-center py-6">Chưa có đề mục nào.</div>'
        : moveTreeData.map(renderNode).join('');
    }

    function updateMoveBreadcrumb() {
      if (!moveBreadcrumb) return;
      if (!moveSelectedId) {
        moveBreadcrumb.innerHTML = '<span class="text-on-surface-variant/60 text-xs italic">Chưa chọn đề mục</span>';
        if (moveConfirmBtn) moveConfirmBtn.disabled = true;
        return;
      }
      const path = getPathToRoot(moveTreeData, moveSelectedId);
      if (!path) return;
      moveBreadcrumb.innerHTML = path.map((n, i) => {
        const sep = i < path.length - 1 ? '<span class="text-on-surface-variant/40 mx-1">›</span>' : '';
        const isLast = i === path.length - 1;
        return `<span class="${isLast ? 'text-primary font-semibold' : 'text-on-surface-variant/80'} text-xs">${escapeHtml(n.title)}</span>${sep}`;
      }).join('');
      if (moveConfirmBtn) {
        const disabled = moveSelectedId === modalSectionId;
        moveConfirmBtn.disabled = disabled;
        moveConfirmBtn.classList.toggle('opacity-40', disabled);
      }
    }

    function openMovePopup(blockId: string, blockItem: HTMLElement) {
      moveActiveBlockId = blockId;
      moveActiveBlockItem = blockItem;
      moveSelectedId = null;
      moveSearchQuery = '';
      if (moveSearch) moveSearch.value = '';

      // Show current path of source section
      if (moveCurrentPathEl && modalSectionId) {
        const path = getPathToRoot(moveTreeData, modalSectionId);
        if (path) {
          moveCurrentPathEl.innerHTML = '<span class="text-on-surface-variant/60">Đang ở:</span> ' + path.map(n => escapeHtml(n.title)).join(' › ');
        }
      }

      // Auto-expand top 2 levels by default
      moveExpandedIds = new Set();
      function expandTopLevels(nodes: MoveSectionNode[], depth = 0) {
        if (depth >= 2) return;
        for (const n of nodes) {
          moveExpandedIds.add(n.id);
          expandTopLevels(n.children, depth + 1);
        }
      }
      expandTopLevels(moveTreeData);

      renderMoveTree();
      updateMoveBreadcrumb();
      if (movePopup) {
        movePopup.classList.remove('hidden');
        movePopup.classList.add('flex');
        document.body.style.overflow = 'hidden';
        setTimeout(() => moveSearch?.focus(), 50);
      }
    }

    function closeMovePopup() {
      if (movePopup) {
        movePopup.classList.add('hidden');
        movePopup.classList.remove('flex');
      }
      document.body.style.overflow = '';
      moveActiveBlockId = null;
      moveActiveBlockItem = null;
      moveSelectedId = null;
    }

    async function executeMove() {
      if (!moveSelectedId || !moveActiveBlockId || !moveActiveBlockItem) return;
      if (moveSelectedId === modalSectionId) return;
      const targetPath = getPathToRoot(moveTreeData, moveSelectedId);
      const targetLabel = targetPath ? targetPath.map(n => n.title).join(' › ') : 'đề mục mới';

      // Confirm if target has descendants — moving into a non-leaf will append at end
      const targetSection = findSectionById(moveTreeData, moveSelectedId);
      const isLeaf = !targetSection || targetSection.children.length === 0;

      if (!confirm(`Di chuyển block này sang "${targetLabel}"?`)) return;

      if (moveConfirmBtn) {
        moveConfirmBtn.disabled = true;
        moveConfirmBtn.textContent = 'Đang chuyển...';
      }

      try {
        const res = await fetch(`/api/admin/blocks/${moveActiveBlockId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ section_id: moveSelectedId }),
        });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        moveActiveBlockItem.remove();
        showMoveToast(`Đã chuyển sang "${targetLabel}"`);
        if (!modalBody.querySelector('.block-item')) {
          modalBody.innerHTML = '<p class="text-sm text-on-surface-variant py-6 text-center">Chưa có nội dung. Thêm block bên dưới.</p>';
        }
        if (currentTree) {
          const srcSection = findSection(currentTree.sections, modalSectionId);
          if (srcSection) {
            srcSection.blocks = srcSection.blocks.filter(b => b.id !== moveActiveBlockId);
          }
        }
        closeMovePopup();
      } catch {
        showMoveToast('Lỗi khi di chuyển block', false);
        if (moveConfirmBtn) {
          moveConfirmBtn.disabled = false;
          moveConfirmBtn.textContent = 'Chuyển đến đây';
        }
      }
    }

    function findSectionById(nodes: MoveSectionNode[], id: string): MoveSectionNode | null {
      for (const n of nodes) {
        if (n.id === id) return n;
        const found = findSectionById(n.children, id);
        if (found) return found;
      }
      return null;
    }

    function showMoveToast(msg: string, ok = true) {
      const t = document.createElement('div');
      t.className = `fixed bottom-6 left-1/2 -translate-x-1/2 z-[9999] px-4 py-2 rounded-lg text-sm font-medium shadow-lg transition-opacity duration-300 ${ok ? 'bg-primary/90 text-white' : 'bg-error/90 text-white'}`;
      t.textContent = msg;
      document.body.appendChild(t);
      setTimeout(() => { t.style.opacity = '0'; }, 1800);
      setTimeout(() => t.remove(), 2200);
    }

    // Wire up move-block button → open popup
    modalBody.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const moveBtn = target.closest<HTMLElement>('[data-action="move-block"]');
      if (moveBtn) {
        e.stopPropagation();
        const item = moveBtn.closest<HTMLElement>('.block-item');
        const blockId = item?.dataset.blockId;
        if (blockId && item) openMovePopup(blockId, item);
        return;
      }
    });

    // Tree interactions: select row, toggle expand
    if (moveTreeEl) {
      moveTreeEl.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        // Toggle expand
        const toggle = target.closest<HTMLElement>('[data-toggle]');
        if (toggle) {
          e.stopPropagation();
          const id = toggle.dataset.toggle!;
          if (moveExpandedIds.has(id)) moveExpandedIds.delete(id);
          else moveExpandedIds.add(id);
          renderMoveTree();
          return;
        }
        // Select row
        const row = target.closest<HTMLElement>('[data-move-target]');
        if (row && !row.hasAttribute('disabled')) {
          moveSelectedId = row.dataset.moveTarget!;
          renderMoveTree();
          updateMoveBreadcrumb();
        }
      });
    }

    // Search input
    if (moveSearch) {
      moveSearch.addEventListener('input', () => {
        moveSearchQuery = moveSearch.value;
        renderMoveTree();
      });
    }

    // Cancel + backdrop + ESC
    moveBackdrop?.addEventListener('click', closeMovePopup);
    moveCancelBtn?.addEventListener('click', closeMovePopup);
    document.getElementById('move-block-close')?.addEventListener('click', closeMovePopup);
    moveConfirmBtn?.addEventListener('click', executeMove);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && movePopup && !movePopup.classList.contains('hidden')) {
        closeMovePopup();
      }
    });

    // ── Modal add block buttons ───────────────────────────
    document.querySelectorAll<HTMLButtonElement>('[data-modal-add-block]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        if (!modalSectionId) return;
        const type = btn.dataset.modalAddBlock as 'text' | 'image' | 'file';
        btn.disabled = true;
        try {
          const res = await fetch('/api/admin/blocks', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              section_id: modalSectionId,
              type,
              order: Date.now(),
            }),
          });
          if (res.ok) {
            // Re-fetch tree and re-render modal (new block will be expanded)
            const created = await res.json() as { id: string };
            lastAddedBlockId = created.id;
            const tree = await loadTree();
            const section = findSection(tree.sections, modalSectionId);
            if (section) {
              modalTitle.textContent = section.title;
              renderModalBlocks(section);
            }
          } else {
            alert('Lỗi khi tạo block');
          }
        } finally {
          btn.disabled = false;
        }
      });
    });

    // ── Modal close handlers ──────────────────────────────
    modalCloseBtn.addEventListener('click', closeModal);
    modalBackdrop.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        closeModal();
      }
    });

    // ── Block drag-and-drop reorder inside modal ─────────
    let blockDragSrc: HTMLElement | null = null;

    modalBody.addEventListener('dragstart', (e) => {
      const target = e.target as HTMLElement;
      if (!target.closest('.block-drag-handle')) {
        e.preventDefault();
        return;
      }
      const item = target.closest<HTMLElement>('.block-item');
      if (!item) return;
      blockDragSrc = item;
      item.classList.add('dragging');
      (e as DragEvent).dataTransfer!.effectAllowed = 'move';
    });

    modalBody.addEventListener('dragend', () => {
      if (blockDragSrc) blockDragSrc.classList.remove('dragging');
      blockDragSrc = null;
      modalBody.querySelectorAll('.drag-above, .drag-below').forEach((el) =>
        el.classList.remove('drag-above', 'drag-below'),
      );
    });

    modalBody.addEventListener('dragover', (e) => {
      e.preventDefault();
      const target = e.target as HTMLElement;
      const item = target.closest<HTMLElement>('.block-item');
      if (!item || item === blockDragSrc) return;

      (e as DragEvent).dataTransfer!.dropEffect = 'move';
      const rect = item.getBoundingClientRect();
      const after = e.clientY < rect.top + rect.height / 2;

      modalBody.querySelectorAll('.drag-above, .drag-below').forEach((el) =>
        el.classList.remove('drag-above', 'drag-below'),
      );
      item.classList.add(after ? 'drag-above' : 'drag-below');
    });

    modalBody.addEventListener('drop', async (e) => {
      e.preventDefault();
      const target = e.target as HTMLElement;
      const item = target.closest<HTMLElement>('.block-item');
      if (!item || !blockDragSrc || item === blockDragSrc) return;

      modalBody.querySelectorAll('.drag-above, .drag-below').forEach((el) =>
        el.classList.remove('drag-above', 'drag-below'),
      );

      const items = Array.from(modalBody.querySelectorAll<HTMLElement>('.block-item'));
      const fromIdx = items.indexOf(blockDragSrc);
      const toIdx = items.indexOf(item);
      if (fromIdx < 0 || toIdx < 0) return;

      const rect = item.getBoundingClientRect();
      const after = e.clientY < rect.top + rect.height / 2;
      const insertIdx = after ? toIdx : toIdx + 1;

      // Reorder DOM
      const moved = items.splice(fromIdx, 1)[0];
      const adjusted = insertIdx > fromIdx ? insertIdx - 1 : insertIdx;
      items.splice(adjusted, 0, moved);
      items.forEach((el) => modalBody.appendChild(el));

      // Persist via API
      const ids = items.map((el) => el.dataset.blockId!);
      try {
        const res = await fetch('/api/admin/blocks/reorder', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ ids }),
        });
        if (!res.ok) {
          alert('Lỗi khi lưu thứ tự block. Đang tải lại...');
          location.reload();
        }
        // Update order in current section's blocks array
        if (currentTree) {
          const section = findSection(currentTree.sections, modalSectionId);
          if (section) {
            ids.forEach((id, idx) => {
              const block = section.blocks.find((b) => b.id === id);
              if (block) block.order = idx;
            });
          }
        }
      } catch {
        alert('Lỗi khi lưu thứ tự block. Đang tải lại...');
        location.reload();
      }
    });

    // ── Section tree: event delegation ────────────────────
    document.getElementById('section-tree')?.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;

      // Toggle collapse/expand children
      const toggleBtn = target.closest<HTMLElement>('[data-section-toggle]');
      if (toggleBtn) {
        const sectionItem = toggleBtn.closest<HTMLElement>('[data-section-item]');
        if (sectionItem) {
          const childList = sectionItem.querySelector<HTMLElement>(':scope > [data-section-list]');
          const icon = toggleBtn.querySelector<HTMLElement>('.section-toggle-icon');
          if (childList) {
            const isCollapsed = childList.style.display === 'none';
            childList.style.display = isCollapsed ? '' : 'none';
            if (icon) icon.style.transform = isCollapsed ? 'rotate(0deg)' : 'rotate(-90deg)';
          }
        }
        return;
      }

      // Click title → open modal
      const titleEl = target.closest<HTMLElement>('[data-section-title]');
      if (titleEl) {
        const sectionItem = target.closest<HTMLElement>('[data-section-item]');
        if (sectionItem && currentTree) {
          openModal(sectionItem.dataset.sectionId!);
        }
        return;
      }

      // Edit button → inline rename (no prompt)
      const editBtn = target.closest<HTMLElement>('[data-section-edit]');
      if (editBtn) {
        const sectionItem = target.closest<HTMLElement>('[data-section-item]');
        if (!sectionItem) return;
        const id = sectionItem.dataset.sectionId!;
        const titleEl = sectionItem.querySelector<HTMLElement>('[data-section-title]');
        if (!titleEl) return;
        const currentTitle = titleEl.textContent || '';
        const section = currentTree ? findSection(currentTree.sections, id) : null;
        // Replace title with input
        const input = document.createElement('input');
        input.type = 'text';
        input.value = currentTitle;
        input.className = 'flex-1 bg-surface-container border border-primary rounded px-2 py-1 text-white text-sm focus:outline-none focus:ring-1 focus:ring-primary';
        titleEl.replaceWith(input);
        input.focus();
        input.select();
        let finished = false;
        const finish = async (save: boolean) => {
          if (finished) return;
          finished = true;
          const newTitle = input.value.trim();
          input.replaceWith(titleEl);
          if (!save || !newTitle || newTitle === currentTitle) return;
          await fetch(`/api/admin/sections/${id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              chapter_id: chapterId,
              parent_id: section?.parent_id ?? null,
              level: section?.level ?? 2,
              title: newTitle,
              slug: section?.slug ?? '',
              order: section?.order ?? 0,
            }),
          });
          titleEl.textContent = newTitle;
          if (section) section.title = newTitle;
        };
        input.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') { e.preventDefault(); finish(true); }
          if (e.key === 'Escape') { e.preventDefault(); finish(false); }
        });
        input.addEventListener('blur', () => finish(true));
        return;
      }

      // Delete button
      const deleteBtn = target.closest<HTMLElement>('[data-section-delete]');
      if (deleteBtn) {
        const sectionItem = target.closest<HTMLElement>('[data-section-item]');
        if (!sectionItem) return;
        if (!confirm('Xoá đề mục (kèm blocks bên trong)?')) return;
        fetch(`/api/admin/sections/${sectionItem.dataset.sectionId!}`, { method: 'DELETE', credentials: 'include' })
          .then(() => location.reload());
        return;
      }

      // Edit keywords — inline input (no prompt)
      const kwBtn = target.closest<HTMLElement>('button[data-section-keywords]');
      if (kwBtn) {
        const sectionItem = kwBtn.closest<HTMLElement>('[data-section-item]');
        if (!sectionItem) return;
        const id = sectionItem.dataset.sectionId!;
        const section = currentTree ? findSection(currentTree.sections, id) : null;
        const currentKw = sectionItem.dataset.sectionKeywords || '[]';
        let parsed: string[] = [];
        try {
          parsed = currentKw.startsWith('[') ? JSON.parse(currentKw) : currentKw.split(',').map((s: string) => s.trim()).filter(Boolean);
        } catch { parsed = []; }

        // Close any existing inline input
        clearInlineInputs();

        // Build inline keyword editor below the section item
        const inputLi = document.createElement('li');
        inputLi.setAttribute('data-add-sub-input', '');
        inputLi.className = 'flex items-center gap-2 px-3 py-2 bg-primary/5 border border-primary/30 rounded-lg';
        inputLi.innerHTML = `
          <span class="material-symbols-outlined text-primary text-[18px]">sell</span>
          <input type="text" autocomplete="off" value="${escapeHtml(parsed.join(', '))}"
            placeholder="Keywords (phân tách bằng dấu phẩy)..."
            class="flex-1 bg-transparent text-white text-sm focus:outline-none placeholder:text-on-surface-variant/60" />
          <span class="text-[10px] text-on-surface-variant hidden" data-sub-status>
            <span class="material-symbols-outlined text-[14px] animate-spin inline align-middle">progress_activity</span>
          </span>
          <button type="button" class="p-1 text-on-surface-variant hover:text-error transition-colors" data-cancel-sub-input title="Hủy (Esc)">
            <span class="material-symbols-outlined text-[16px]">close</span>
          </button>
        `;

        // Find the parent UL of this section item
        const parentUl = sectionItem.parentElement;
        if (!parentUl) return;
        parentUl.appendChild(inputLi);

        const kwInput = inputLi.querySelector('input')!;
        kwInput.focus();
        kwInput.select();

        let finished = false;
        const finish = async (save: boolean) => {
          if (finished) return;
          finished = true;
          const val = kwInput.value.trim();
          inputLi.remove();
          if (!save) return;
          const keywords = JSON.stringify(val ? val.split(',').map((s: string) => s.trim()).filter(Boolean) : []);
          // Update data attribute
          sectionItem.dataset.sectionKeywords = keywords;
          // Update chip display
          const existingChips = sectionItem.querySelector(':scope > .flex.flex-wrap');
          if (existingChips) existingChips.remove();
          if (val) {
            const kwArr = val.split(',').map((s: string) => s.trim()).filter(Boolean);
            const chipsDiv = document.createElement('div');
            chipsDiv.className = 'flex flex-wrap gap-1 mt-0.5 pl-9';
            chipsDiv.innerHTML = kwArr.map((k: string) => `<span class="inline-flex items-center px-1.5 py-0.5 text-[9px] font-medium rounded bg-primary/10 text-primary border border-primary/20">${escapeHtml(k)}</span>`).join('');
            sectionItem.appendChild(chipsDiv);
          }
          // Update keyword button appearance
          const kwIcon = kwBtn.querySelector('.material-symbols-outlined');
          if (kwIcon) {
            kwBtn.classList.toggle('text-primary', !!val);
            kwBtn.classList.toggle('hover:text-primary/80', !!val);
            kwBtn.classList.toggle('text-on-surface-variant', !val);
          }
          // Save to server
          await fetch(`/api/admin/sections/${id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
              chapter_id: chapterId,
              parent_id: section?.parent_id ?? null,
              level: section?.level ?? 2,
              title: section?.title ?? '',
              slug: section?.slug ?? '',
              order: section?.order ?? 0,
              keywords,
            }),
          });
          if (section) section.keywords = keywords;
        };

        kwInput.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'Enter') { e.preventDefault(); finish(true); }
          if (e.key === 'Escape') { e.preventDefault(); finish(false); }
        });
        kwInput.addEventListener('blur', () => finish(true));
        return;
      }

      // Add sub-section — inline input instead of prompt
      const addSubBtn = target.closest<HTMLElement>('[data-section-add-sub]');
      if (addSubBtn) {
        const sectionItem = target.closest<HTMLElement>('[data-section-item]');
        if (!sectionItem) return;
        const id = sectionItem.dataset.sectionId!;
        const parentDepth = parseInt(sectionItem.dataset.sectionDepth || '0', 10);

        // Close any other open sub-input
        clearInlineInputs();

        // Ensure parent has a child UL; create if not
        let childUl = sectionItem.querySelector<HTMLElement>(':scope > ul[data-section-list]');
        if (!childUl) {
          childUl = document.createElement('ul');
          childUl.setAttribute('data-section-list', '');
          childUl.className = 'flex flex-col gap-2 pl-6 mt-1.5 border-l border-outline-variant/20';
          sectionItem.appendChild(childUl);
          ensureToggle(sectionItem);
        }
        expandSection(sectionItem);

        const inputRow = createInlineInputRow(3, 'Tên đề mục phụ... (Enter để lưu, Esc để hủy)', {
          onSubmit: async (title, li, input) => {
            const res = await fetch('/api/admin/sections', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              credentials: 'include',
              body: JSON.stringify({ chapter_id: chapterId, parent_id: id, level: 3, title, order: Date.now() }),
            });
            if (res.ok) {
              const { id: newId } = await res.json() as { id: string };
              const node: SectionNode = { id: newId, chapter_id: chapterId, parent_id: id, level: 3, title, slug: '', order: childUl!.querySelectorAll(':scope > [data-section-item]').length, keywords: '[]', children: [], blocks: [] };
              const newLi = buildSectionLi(node, parentDepth + 1);
              childUl!.insertBefore(newLi, li);
              flashAndScroll(newLi);
              // Update the "X mục" count on parent
              const countSpan = sectionItem.querySelector<HTMLElement>('[data-section-count]');
              if (countSpan) {
                const cnt = childUl!.querySelectorAll(':scope > [data-section-item]').length;
                countSpan.textContent = `${cnt} mục`;
              }
              if (currentTree) {
                const parent = findSection(currentTree.sections, id);
                if (parent) parent.children.push(node);
              }
              renumberAllSections();
              input.value = '';
              input.focus();
            }
          }
        });
        childUl.appendChild(inputRow);
        inputRow.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        return;
      }
    });

    // ── Section drag-and-drop (reorder + reparent) ─────────
    const sectionTree = document.getElementById('section-tree');
    let sectionDragSrc: HTMLElement | null = null;
    let dragPlaceholder: HTMLElement | null = null;
    let dragFakeUl: HTMLElement | null = null; // temporary <ul> for "into" on leaf nodes
    let lastDropKey = ''; // cache "tgtId:zone" to avoid DOM thrashing
    let lastDragOverItem: HTMLElement | null = null; // cached target from last dragover
    let lastDragOverZone: 'above' | 'into' | 'below' | null = null; // cached zone from last dragover

    const SECTION_LIST_CLASSES = 'flex flex-col gap-2 pl-6 mt-1.5 border-l border-outline-variant/20';

    function isDragHandle(el: HTMLElement) {
      return el.closest('.section-drag-handle') !== null;
    }

    function isDomDescendant(candidate: HTMLElement, ancestor: HTMLElement): boolean {
      let el = candidate.parentElement;
      while (el) {
        if (el === ancestor) return true;
        el = el.parentElement;
      }
      return false;
    }

    function getItemDepth(item: HTMLElement): number {
      return parseInt(item.dataset.sectionDepth ?? '0', 10);
    }

    function getDropZone(e: DragEvent, item: HTMLElement): 'above' | 'into' | 'below' {
      // Use the title row (first child div) for zone detection,
      // NOT the full <li> which includes children and distorts the zones.
      // "into" = top 85% of title row (drop here to nest as child)
      // "below" = bottom 15% (drop here to reorder below)
      const titleRow = item.querySelector<HTMLElement>(':scope > div.flex');
      const rect = (titleRow ?? item).getBoundingClientRect();
      const ratio = (e.clientY - rect.top) / rect.height;
      if (ratio > 0.85) return 'below';
      return 'into';
    }

    // ── Placeholder management ─────────────────────────────
    function createPlaceholder(zone: 'above' | 'into' | 'below'): HTMLElement {
      const li = document.createElement('li');
      li.setAttribute('data-drag-placeholder', '');
      li.style.listStyle = 'none';
      li.style.pointerEvents = 'none';

      if (zone === 'into') {
        li.classList.add('drag-placeholder-box');
      } else {
        li.classList.add('drag-placeholder-line');
      }
      return li;
    }

    function ensureChildUl(item: HTMLElement): HTMLElement {
      // If the item already has a [data-section-list], return it
      const existing = item.querySelector<HTMLElement>(':scope > ul[data-section-list]');
      if (existing) return existing;

      // Create a temporary <ul> and insert it after the item's content div
      const ul = document.createElement('ul');
      ul.setAttribute('data-section-list', '');
      ul.className = SECTION_LIST_CLASSES;

      // Insert as last child of the <li>
      item.appendChild(ul);

      // Track it so we can remove it if drag is cancelled (empty)
      dragFakeUl = ul;
      return ul;
    }

    function removePlaceholder() {
      if (dragPlaceholder) {
        dragPlaceholder.remove();
        dragPlaceholder = null;
      }
      // Remove fake empty ULs (if they have no children)
      if (dragFakeUl && dragFakeUl.children.length === 0) {
        dragFakeUl.remove();
        dragFakeUl = null;
      }
      lastDropKey = '';
    }

    function showDndError(msg: string) {
      // Simple toast notification
      const toast = document.createElement('div');
      toast.className = 'fixed bottom-6 left-1/2 -translate-x-1/2 z-[9999] px-4 py-2 rounded-lg bg-error/90 text-white text-sm font-medium shadow-lg transition-opacity duration-300';
      toast.textContent = msg;
      document.body.appendChild(toast);
      setTimeout(() => { toast.style.opacity = '0'; }, 2500);
      setTimeout(() => toast.remove(), 3000);
    }

    function flashMovedItem(el: HTMLElement) {
      el.classList.add('reorder-success');
      el.addEventListener('animationend', () => el.classList.remove('reorder-success'), { once: true });
    }

    // ── In-memory tree sync ────────────────────────────────
    function syncTreeAfterMove(srcId: string, tgtId: string | null, zone: 'above' | 'into' | 'below') {
      if (!currentTree) return;

      // Step 1: Extract the moved node from wherever it currently is
      let moved: SectionNode | null = null;
      function extract(nodes: SectionNode[]): SectionNode | null {
        for (let i = 0; i < nodes.length; i++) {
          if (nodes[i].id === srcId) return nodes.splice(i, 1)[0];
          const found = extract(nodes[i].children);
          if (found) return found;
        }
        return null;
      }
      moved = extract(currentTree.sections);
      if (!moved) return;

      // Step 2: Re-insert at new position
      if (zone === 'into') {
        // Make it a child of target (tgtId is the target item)
        const tgtNode = findSection(currentTree.sections, tgtId!);
        if (tgtNode) {
          tgtNode.children.push(moved);
        } else {
          currentTree.sections.push(moved);
        }
      } else {
        // above/below: insert as sibling of target (tgtId is the target item)
        function findParentOf(nodes: SectionNode[], targetId: string): SectionNode | null {
          for (const n of nodes) {
            if (n.children.some(c => c.id === targetId)) return n;
            const found = findParentOf(n.children, targetId);
            if (found) return found;
          }
          return null;
        }

        if (!tgtId) {
          // Target is at root — insert at root level
          if (zone === 'above') {
            currentTree.sections.unshift(moved);
          } else {
            currentTree.sections.push(moved);
          }
        } else {
          const tgtParent = findParentOf(currentTree.sections, tgtId);
          if (tgtParent) {
            const idx = tgtParent.children.findIndex(c => c.id === tgtId);
            const insertIdx = zone === 'above' ? idx : idx + 1;
            tgtParent.children.splice(insertIdx, 0, moved);
          } else {
            currentTree.sections.push(moved);
          }
        }
      }
    }

    // ── DOM reorder helper ─────────────────────────────────
    function getSiblingIds(ul: HTMLElement): string[] {
      return Array.from(ul.querySelectorAll<HTMLElement>(':scope > [data-section-item]'))
        .map(li => li.dataset.sectionId!);
    }

    async function reorderSiblings(ul: HTMLElement): Promise<boolean> {
      const ids = getSiblingIds(ul);
      try {
        const res = await fetch('/api/admin/sections/reorder', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ ids }),
        });
        return res.ok;
      } catch { return false; }
    }

    // ── Drag events ────────────────────────────────────────
    sectionTree?.addEventListener('dragstart', (e) => {
      const target = e.target as HTMLElement;
      if (!isDragHandle(target)) {
        e.preventDefault();
        return;
      }
      const item = target.closest<HTMLElement>('[data-section-item]');
      if (!item) return;
      sectionDragSrc = item;
      item.classList.add('dragging');
      (e as DragEvent).dataTransfer!.effectAllowed = 'move';
      (e as DragEvent).dataTransfer!.dropEffect = 'move';
    });

    sectionTree?.addEventListener('dragend', () => {
      if (sectionDragSrc) sectionDragSrc.classList.remove('dragging');
      sectionDragSrc = null;
      lastDragOverItem = null;
      lastDragOverZone = null;
      removePlaceholder();
    });

    sectionTree?.addEventListener('dragover', (e) => {
      e.preventDefault();
      if (!sectionDragSrc) return;

      const target = e.target as HTMLElement;
      const item = target.closest<HTMLElement>('[data-section-item]');
      if (!item || item === sectionDragSrc) return;

      // Prevent circular: can't drop into self or descendant
      if (isDomDescendant(item, sectionDragSrc)) return;

      const zone = getDropZone(e as DragEvent, item);

      // Skip if same target+zone as last dragover (avoid DOM thrashing)
      const key = `${item.dataset.sectionId}:${zone}`;
      if (key === lastDropKey) return;
      lastDropKey = key;
      lastDragOverItem = item;
      lastDragOverZone = zone;

      (e as DragEvent).dataTransfer!.dropEffect = 'move';

      // Remove old placeholder
      removePlaceholder();

      // Create and insert new placeholder
      dragPlaceholder = createPlaceholder(zone);

      if (zone === 'above') {
        item.parentElement?.insertBefore(dragPlaceholder, item);
      } else if (zone === 'below') {
        item.parentElement?.insertBefore(dragPlaceholder, item.nextSibling);
      } else {
        // into — insert as first child of target's child list
        let childUl: HTMLElement = item.querySelector<HTMLElement>(':scope > ul[data-section-list]') ?? ensureChildUl(item);
        if (!item.querySelector<HTMLElement>(':scope > ul[data-section-list]')) {
          // Auto-expand if collapsed, or create temporary UL for leaf nodes
          dragFakeUl = childUl; // track for cleanup
        }
        // If the child list is hidden (collapsed), expand it
        if (childUl.style.display === 'none') {
          childUl.style.display = '';
        }
        // Insert placeholder as first child
        childUl.insertBefore(dragPlaceholder, childUl.firstChild);
      }
    });

    sectionTree?.addEventListener('drop', async (e) => {
      e.preventDefault();
      // Capture cached state BEFORE removePlaceholder clears it
      const cachedItem = lastDragOverItem;
      const cachedZone = lastDragOverZone;
      removePlaceholder();

      if (!sectionDragSrc) return;
      const dragSrc: HTMLElement = sectionDragSrc;

      // Prefer cached item from last dragover; fall back to DOM resolution
      const item = cachedItem ?? (e.target as HTMLElement).closest<HTMLElement>('[data-section-item]');
      if (!item || item === dragSrc) return;

      const srcId = dragSrc.dataset.sectionId!;
      const tgtId = item.dataset.sectionId!;
      if (isDomDescendant(item, dragSrc)) return;

      // Use cached zone from last dragover (don't recalculate —
      // cursor position at drop time may differ from the visual placeholder zone)
      const zone = cachedZone ?? getDropZone(e as DragEvent, item);

      if (zone === 'into') {
        // ── INTO: Reparent as child of target ──
        await doReparentAsChild(srcId, dragSrc, item, tgtId);
      } else {
        // ── ABOVE / BELOW: Reorder or cross-parent move ──
        const srcParentUl = dragSrc.closest<HTMLElement>('ul[data-section-list]');
        const tgtParentUl = item.closest<HTMLElement>('ul[data-section-list]');
        if (!srcParentUl || !tgtParentUl) return;

        if (srcParentUl === tgtParentUl) {
          // Same parent — reorder in place
          await doSameParentReorder(dragSrc, srcParentUl, zone, e as DragEvent);
        } else {
          // Cross-parent — move as sibling of target
          await doCrossParentMove(srcId, dragSrc, item, tgtParentUl, zone, e as DragEvent);
        }
      }

      sectionDragSrc = null;
    });

    // ── Same-parent reorder ────────────────────────────────
    async function doSameParentReorder(
      srcEl: HTMLElement,
      parentUl: HTMLElement,
      zone: 'above' | 'below',
      e: DragEvent,
    ) {
      const items = Array.from(parentUl.querySelectorAll<HTMLElement>(':scope > [data-section-item]'));
      const fromIdx = items.indexOf(srcEl);
      const targetEl = e.target as HTMLElement;
      const item = targetEl.closest<HTMLElement>('[data-section-item]');
      if (!item) return;
      const toIdx = items.indexOf(item);
      if (fromIdx < 0 || toIdx < 0 || fromIdx === toIdx) return;

      const rect = item.getBoundingClientRect();
      const dropBefore = zone === 'above' || e.clientY < rect.top + rect.height / 2;

      let insertIdx = dropBefore ? toIdx : toIdx + 1;
      if (fromIdx < insertIdx) insertIdx--;

      if (fromIdx === insertIdx) return;

      const moved = items.splice(fromIdx, 1)[0];
      items.splice(insertIdx, 0, moved);
      items.forEach(li => parentUl.appendChild(li));

      flashMovedItem(moved);

      const ok = await reorderSiblings(parentUl);
      if (!ok) { showDndError('Lỗi lưu thứ tự. Đang tải lại...'); location.reload(); }
      renumberAllSections();
    }

    // ── Cross-parent move (above/below) ────────────────────
    async function doCrossParentMove(
      srcId: string,
      srcEl: HTMLElement,
      tgtItem: HTMLElement,
      tgtParentUl: HTMLElement,
      zone: 'above' | 'below',
      e: DragEvent,
    ) {
      // Determine new parent
      const tgtParentItem = tgtParentUl.closest<HTMLElement>('.section-nestable[data-section-item]');
      const newParentId = tgtParentItem?.dataset.sectionId ?? null;
      const newDepth = tgtParentItem ? getItemDepth(tgtParentItem) + 1 : 0;
      const newLevel = newDepth + 2;

      // Determine old parent and its UL (before removing srcEl from DOM)
      const oldParentUl = srcEl.closest<HTMLElement>('ul[data-section-list]');

      // Read source section info from currentTree
      if (!currentTree) return;
      const section = findSection(currentTree.sections, srcId);
      if (!section) return;

      // DOM: remove from old position
      srcEl.remove();

      // DOM: insert at new position
      const rect = tgtItem.getBoundingClientRect();
      const dropBefore = zone === 'above' || e.clientY < rect.top + rect.height / 2;
      if (dropBefore) {
        tgtParentUl.insertBefore(srcEl, tgtItem);
      } else {
        tgtParentUl.insertBefore(srcEl, tgtItem.nextSibling);
      }

      // Update data attributes
      srcEl.dataset.sectionDepth = String(newDepth);
      srcEl.dataset.sectionParentId = newParentId ?? '';

      // Update the icon to reflect new level
      const iconSpans = srcEl.querySelectorAll<HTMLElement>(':scope > div > span.material-symbols-outlined');
      iconSpans.forEach(span => {
        const text = span.textContent?.trim();
        if (text === 'menu_book' || text === 'subdirectory_arrow_right') {
          span.textContent = newLevel === 2 ? 'menu_book' : 'subdirectory_arrow_right';
          span.className = `material-symbols-outlined text-[16px] ${newLevel === 3 ? 'text-on-surface-variant' : 'text-primary'}`;
        }
      });

      flashMovedItem(srcEl);

      // API calls
      // 1. Reorder siblings at old parent (if source was removed from it)
      if (oldParentUl) {
        await reorderSiblings(oldParentUl);
      }

      // 2. Reorder siblings at new parent + update section's parent_id/level
      const newSiblingIds = getSiblingIds(tgtParentUl);
      const res = await fetch(`/api/admin/sections/${srcId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({
          chapter_id: chapterId,
          parent_id: newParentId,
          level: newLevel,
          title: section.title,
          slug: section.slug,
          order: 0,
          sibling_ids: newSiblingIds,
        }),
      });

      if (!res.ok) { showDndError('Lỗi khi di chuyển đề mục.'); location.reload(); return; }

      // Sync in-memory tree — pass target item ID (not parent) for above/below positioning
      const tgtItemId = tgtItem.dataset.sectionId ?? null;
      syncTreeAfterMove(srcId, tgtItemId, zone);
      renumberAllSections();
    }

    // ── Reparent as child (into zone) ──────────────────────
    async function doReparentAsChild(
      srcId: string,
      srcEl: HTMLElement,
      tgtItem: HTMLElement,
      tgtId: string,
    ) {
      if (!currentTree) return;
      const section = findSection(currentTree.sections, srcId);
      if (!section) return;

      const newDepth = getItemDepth(tgtItem) + 1;
      const newLevel = newDepth + 2;

      // Get target's child UL (should exist — either from DOM or created during dragover)
      let childUl: HTMLElement = tgtItem.querySelector<HTMLElement>(':scope > ul[data-section-list]') ?? ensureChildUl(tgtItem);

      // If target's child list was hidden (collapsed), expand it
      if (childUl.style.display === 'none') {
        childUl.style.display = '';
      }

      // Also, add a toggle button to target if it didn't have children before
      const toggleBtn = tgtItem.querySelector<HTMLElement>('[data-section-toggle]');
      if (!toggleBtn) {
        // Target had no children before — add toggle button after drag handle
        const handleSpan = tgtItem.querySelector<HTMLElement>('.section-drag-handle');
        if (handleSpan) {
          const btn = document.createElement('button');
          btn.setAttribute('data-section-toggle', '');
          btn.className = 'section-toggle-btn p-0.5 rounded hover:bg-white/5 transition-colors shrink-0';
          btn.title = 'Thu gọn / Mở rộng';
          btn.innerHTML = '<span class="material-symbols-outlined text-[14px] section-toggle-icon text-on-surface-variant">expand_more</span>';
          handleSpan.parentElement?.insertBefore(btn, handleSpan.nextSibling);
        }
      }

      // DOM: remove source from old parent
      const oldParentUl = srcEl.closest<HTMLElement>('ul[data-section-list]');
      srcEl.remove();

      // DOM: append to new parent's child list
      childUl.appendChild(srcEl);

      // Update the "X mục" count
      const countSpan = tgtItem.querySelector<HTMLElement>('[data-section-count]');
      if (countSpan) {
        const currentCount = childUl.querySelectorAll<HTMLElement>(':scope > [data-section-item]').length;
        countSpan.textContent = `${currentCount} mục`;
      }

      // Update data attributes
      srcEl.dataset.sectionDepth = String(newDepth);
      srcEl.dataset.sectionParentId = tgtId;

      // Update the icon
      const iconSpans = srcEl.querySelectorAll<HTMLElement>(':scope > div > span.material-symbols-outlined');
      iconSpans.forEach(span => {
        const text = span.textContent?.trim();
        if (text === 'menu_book' || text === 'subdirectory_arrow_right') {
          span.textContent = newLevel === 2 ? 'menu_book' : 'subdirectory_arrow_right';
          span.className = `material-symbols-outlined text-[16px] ${newLevel === 3 ? 'text-on-surface-variant' : 'text-primary'}`;
        }
      });

      flashMovedItem(srcEl);

      // Scroll into view
      setTimeout(() => {
        srcEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }, 50);

      // API calls
      // 1. Reorder siblings at old parent
      if (oldParentUl) {
        await reorderSiblings(oldParentUl);
      }

      // 2. Update section + reorder siblings at new parent
      const newSiblingIds = getSiblingIds(childUl);
      const res = await fetch(`/api/admin/sections/${srcId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({
          chapter_id: chapterId,
          parent_id: tgtId,
          level: newLevel,
          title: section.title,
          slug: section.slug,
          order: newSiblingIds.length - 1,
          sibling_ids: newSiblingIds,
        }),
      });

      if (!res.ok) { showDndError('Lỗi khi di chuyển đề mục.'); location.reload(); return; }

      // Sync in-memory tree
      syncTreeAfterMove(srcId, tgtId, 'into');
      renumberAllSections();
    }

    // ── Init ──────────────────────────────────────────────
    loadTree();
  });
</script>

