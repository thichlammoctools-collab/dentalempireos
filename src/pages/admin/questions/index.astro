---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import StatCard from '../../../components/admin/StatCard.astro';
import { env } from 'cloudflare:workers';
import { listAllQuestions, getQuestionStats } from '../../../lib/question-db';
import { listChapters } from '../../../lib/book-db';

export const prerender = false;

const url = Astro.url;
const statusFilter = url.searchParams.get('status') ?? 'all';

const [questions, stats, chapters] = await Promise.all([
  listAllQuestions(env.DB, statusFilter),
  getQuestionStats(env.DB),
  listChapters(env.DB),
]);

// Build chapter title map
const chapterMap = new Map(chapters.map(c => [c.id, c.title]));

function timeAgo(dateStr: string): string {
  const diff = Date.now() - new Date(dateStr).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'vừa xong';
  if (mins < 60) return `${mins} phút trước`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return `${hrs} giờ trước`;
  const days = Math.floor(hrs / 24);
  return `${days} ngày trước`;
}

function statusBadge(status: string) {
  if (status === 'open') return { label: 'Chờ trả lời', cls: 'bg-error/10 text-error border-error/20' };
  if (status === 'answered') return { label: 'Đã trả lời', cls: 'bg-primary/10 text-primary border-primary/20' };
  return { label: 'Đã đóng', cls: 'bg-on-surface-variant/10 text-on-surface-variant border-outline-variant/20' };
}
---

<AdminLayout title="Câu Hỏi | Admin">

  <!-- Header -->
  <div class="flex flex-col md:flex-row md:justify-between md:items-end gap-4">
    <div>
      <h2 class="text-3xl md:text-[32px] leading-tight font-bold text-white mb-1">Câu Hỏi Từ Độc Giả</h2>
      <p class="text-base text-on-surface-variant">
        Quản lý và trả lời câu hỏi của người đọc sách.
      </p>
    </div>
  </div>

  <!-- Stat cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
    <StatCard
      icon="question_answer"
      label="Tổng câu hỏi"
      value={String(stats.total)}
      trend="Tất cả"
      trendDir="flat"
      accent="primary"
      progress={100}
    />
    <StatCard
      icon="pending"
      label="Chờ trả lời"
      value={String(stats.open)}
      trend={stats.total > 0 ? `${Math.round((stats.open / stats.total) * 100)}%` : '0%'}
      trendDir={stats.open > 0 ? 'up' : 'flat'}
      accent="error"
      progress={stats.total > 0 ? (stats.open / stats.total) * 100 : 0}
    />
    <StatCard
      icon="task_alt"
      label="Đã trả lời"
      value={String(stats.answered)}
      trend={stats.total > 0 ? `${Math.round((stats.answered / stats.total) * 100)}%` : '0%'}
      trendDir="up"
      accent="primary"
      progress={stats.total > 0 ? (stats.answered / stats.total) * 100 : 0}
    />
    <StatCard
      icon="archive"
      label="Đã đóng"
      value={String(stats.closed)}
      trend={stats.total > 0 ? `${Math.round((stats.closed / stats.total) * 100)}%` : '0%'}
      trendDir="flat"
      accent="tertiary"
      progress={stats.total > 0 ? (stats.closed / stats.total) * 100 : 0}
    />
  </div>

  <!-- Filter tabs -->
  <div class="flex flex-wrap gap-2">
    {[
      { value: 'all', label: 'Tất cả', count: stats.total },
      { value: 'open', label: 'Chờ trả lời', count: stats.open },
      { value: 'answered', label: 'Đã trả lời', count: stats.answered },
      { value: 'closed', label: 'Đã đóng', count: stats.closed },
    ].map(tab => (
      <a
        href={tab.value === 'all' ? '/admin/questions' : `/admin/questions?status=${tab.value}`}
        class:list={[
          'px-4 py-2 rounded-lg text-sm font-bold transition-all border',
          statusFilter === tab.value
            ? 'bg-primary/10 text-primary border-primary/30'
            : 'bg-surface-container-high text-on-surface-variant border-outline-variant/15 hover:border-primary/20',
        ]}
      >
        {tab.label} ({tab.count})
      </a>
    ))}
  </div>

  <!-- Questions list -->
  <div class="glass-card rounded-xl overflow-hidden">
    {questions.length === 0 ? (
      <div class="p-12 text-center">
        <span class="material-symbols-outlined text-5xl text-on-surface-variant/30 block mb-4">question_answer</span>
        <p class="text-on-surface-variant">Chưa có câu hỏi nào{statusFilter !== 'all' ? ' với trạng thái này' : ''}.</p>
      </div>
    ) : (
      <div class="divide-y divide-outline-variant/15">
        {questions.map(q => {
          const badge = statusBadge(q.status);
          return (
            <a
              href={`/admin/questions/${q.id}`}
              class="flex items-center gap-4 px-6 py-4 hover:bg-surface-container-high/50 transition-colors"
            >
              <!-- Avatar -->
              <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-primary text-lg">person</span>
              </div>

              <!-- Content -->
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <h4 class="text-sm font-bold text-white truncate">{q.title}</h4>
                  <span:list class:list={['px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider rounded border', badge.cls]}>
                    {badge.label}
                  </span>
                </div>
                <div class="flex items-center gap-3 text-xs text-on-surface-variant">
                  <span>{q.user_name || q.user_email}</span>
                  <span>·</span>
                  <span>{chapterMap.get(q.chapter_id) ?? q.chapter_id}</span>
                  <span>·</span>
                  <span>{q.reply_count} replies</span>
                </div>
              </div>

              <!-- Time + Arrow -->
              <div class="flex items-center gap-3 flex-shrink-0">
                <span class="text-xs text-on-surface-variant">{timeAgo(q.createdAt)}</span>
                <span class="material-symbols-outlined text-on-surface-variant text-lg">chevron_right</span>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </div>

</AdminLayout>
