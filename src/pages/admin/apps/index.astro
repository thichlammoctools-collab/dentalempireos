---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';
import { listApps, type App } from '../../../lib/app-db';

export const prerender = false;

// Graceful fallback: ai_application table may not exist yet if migration 0019 hasn't been applied
let apps: Awaited<ReturnType<typeof listApps>> = [];
try {
  apps = await listApps(env.DB);
} catch {
  apps = [];
}

const typeLabels: Record<string, string> = {
  survey: 'Khảo sát',
  ebook_ai: 'Ebook AI',
  course_ai: 'Khóa học AI',
  tool: 'Công cụ',
  generator: 'Tạo nội dung',
};

const typeColors: Record<string, string> = {
  survey: 'bg-purple-500/20 text-purple-300',
  ebook_ai: 'bg-blue-500/20 text-blue-300',
  course_ai: 'bg-green-500/20 text-green-300',
  tool: 'bg-amber-500/20 text-amber-300',
  generator: 'bg-pink-500/20 text-pink-300',
};

const statusLabels: Record<string, string> = {
  draft: 'Bản nháp',
  active: 'Đang hoạt động',
  archived: 'Lưu trữ',
};

const statusColors: Record<string, string> = {
  draft: 'bg-gray-500/20 text-gray-400',
  active: 'bg-green-500/20 text-green-300',
  archived: 'bg-red-500/20 text-red-300',
};

function formatDate(s: string) {
  return new Date(s).toLocaleDateString('vi-VN');
}
---

<AdminLayout title="Ứng dụng AI">
  <div class="p-6 max-w-7xl mx-auto space-y-6">
    <!-- Header -->
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-on-surface">Ứng dụng AI</h1>
        <p class="text-sm text-on-surface-variant mt-1">Quản lý các ứng dụng AI — cấu hình, prompt, trạng thái</p>
      </div>
      <button
        id="open-create-modal"
        class="bg-primary text-white px-4 py-2 rounded-lg font-medium hover:opacity-90 transition-all flex items-center gap-2"
      >
        <span class="material-symbols-outlined text-[20px]">add</span>
        Tạo ứng dụng
      </button>
    </div>

    <!-- Apps table -->
    <div class="glass-card rounded-2xl overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-outline-variant/20 text-on-surface-variant">
            <th class="text-left py-3 px-4 font-medium">Tên</th>
            <th class="text-left py-3 px-4 font-medium">Loại</th>
            <th class="text-left py-3 px-4 font-medium">Trạng thái</th>
            <th class="text-left py-3 px-4 font-medium">Miễn phí</th>
            <th class="text-left py-3 px-4 font-medium">Ngày tạo</th>
            <th class="text-right py-3 px-4 font-medium">Thao tác</th>
          </tr>
        </thead>
        <tbody>
          {apps.length === 0 && (
            <tr>
              <td colspan="6" class="py-12 text-center text-on-surface-variant/60">
                Chưa có ứng dụng AI nào. Nhấn "Tạo ứng dụng" để bắt đầu.
              </td>
            </tr>
          )}
          {apps.map((app: App) => (
            <tr class="border-b border-outline-variant/10 hover:bg-surface-container-high/50 transition-colors">
              <td class="py-3 px-4">
                <a href={`/admin/apps/${app.id}`} class="text-on-surface font-medium hover:text-primary transition-colors">
                  {app.name}
                </a>
                <div class="text-xs text-on-surface-variant/60 mt-0.5">{app.slug}</div>
              </td>
              <td class="py-3 px-4">
                <span class={`inline-block px-2 py-1 rounded-full text-xs font-medium ${typeColors[app.type] ?? 'bg-gray-500/20 text-gray-400'}`}>
                  {typeLabels[app.type] ?? app.type}
                </span>
              </td>
              <td class="py-3 px-4">
                <span class={`inline-block px-2 py-1 rounded-full text-xs font-medium ${statusColors[app.status] ?? 'bg-gray-500/20 text-gray-400'}`}>
                  {statusLabels[app.status] ?? app.status}
                </span>
              </td>
              <td class="py-3 px-4 text-on-surface-variant">
                {app.is_free ? '✅' : '💰'}
              </td>
              <td class="py-3 px-4 text-on-surface-variant">
                {formatDate(app.created_at)}
              </td>
              <td class="py-3 px-4 text-right">
                <a
                  href={`/admin/apps/${app.id}`}
                  class="text-on-surface-variant hover:text-primary transition-colors"
                  title="Chỉnh sửa"
                >
                  <span class="material-symbols-outlined text-[18px]">edit</span>
                </a>
                <button
                  class="delete-btn text-on-surface-variant hover:text-red-400 transition-colors ml-2"
                  data-id={app.id}
                  data-name={app.name}
                  title="Xóa"
                >
                  <span class="material-symbols-outlined text-[18px]">delete</span>
                </button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Create modal -->
  <div
    id="create-modal"
    class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/60 backdrop-blur-sm"
  >
    <div class="glass-card rounded-2xl p-6 w-full max-w-md mx-4 space-y-4">
      <h2 class="text-lg font-bold text-on-surface">Tạo ứng dụng AI mới</h2>
      <form id="create-form" class="space-y-3">
        <div>
          <label class="block text-sm font-medium text-on-surface-variant mb-1">Tên ứng dụng *</label>
          <input type="text" name="name" required class="w-full px-3 py-2 bg-surface-container-high border border-outline-variant/30 rounded-lg text-on-surface focus:outline-none focus:ring-1 focus:ring-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium text-on-surface-variant mb-1">Slug (tự tạo)</label>
          <input type="text" name="slug" class="w-full px-3 py-2 bg-surface-container-high border border-outline-variant/30 rounded-lg text-on-surface focus:outline-none focus:ring-1 focus:ring-primary" placeholder="tự tạo từ tên" />
        </div>
        <div>
          <label class="block text-sm font-medium text-on-surface-variant mb-1">Loại *</label>
          <select name="type" required class="w-full px-3 py-2 bg-surface-container-high border border-outline-variant/30 rounded-lg text-on-surface focus:outline-none focus:ring-1 focus:ring-primary">
            <option value="">— Chọn loại —</option>
            <option value="survey">Khảo sát (Survey)</option>
            <option value="ebook_ai">Ebook AI</option>
            <option value="course_ai">Khóa học AI</option>
            <option value="tool">Công cụ (Tool)</option>
            <option value="generator">Tạo nội dung (Generator)</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-on-surface-variant mb-1">Mô tả</label>
          <textarea name="description" rows="2" class="w-full px-3 py-2 bg-surface-container-high border border-outline-variant/30 rounded-lg text-on-surface focus:outline-none focus:ring-1 focus:ring-primary"></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-on-surface-variant mb-1">Trạng thái</label>
          <select name="status" class="w-full px-3 py-2 bg-surface-container-high border border-outline-variant/30 rounded-lg text-on-surface focus:outline-none focus:ring-1 focus:ring-primary">
            <option value="draft">Bản nháp</option>
            <option value="active">Đang hoạt động</option>
          </select>
        </div>
        <div class="flex items-center gap-2">
          <input type="checkbox" name="is_free" id="is_free" class="accent-primary" />
          <label for="is_free" class="text-sm text-on-surface-variant">Miễn phí (không cần thanh toán)</label>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="submit" class="flex-1 bg-primary text-white py-2 rounded-lg font-medium hover:opacity-90 transition-all">
            Tạo mới
          </button>
          <button type="button" id="close-create-modal" class="px-4 py-2 rounded-lg bg-surface-container-high text-on-surface-variant hover:text-on-surface transition-colors">
            Hủy
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    // Create modal
    const createModal = document.getElementById('create-modal')!;
    document.getElementById('open-create-modal')?.addEventListener('click', () => {
      createModal.classList.remove('hidden');
      createModal.classList.add('flex');
    });
    document.getElementById('close-create-modal')?.addEventListener('click', () => {
      createModal.classList.add('hidden');
      createModal.classList.remove('flex');
    });

    // Create form
    document.getElementById('create-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const fd = new FormData(form);
      const body = {
        name: fd.get('name')?.toString().trim(),
        slug: fd.get('slug')?.toString().trim() || undefined,
        type: fd.get('type')?.toString(),
        description: fd.get('description')?.toString().trim() || null,
        status: fd.get('status')?.toString() || 'draft',
        is_free: fd.has('is_free') ? 1 : 0,
      };
      const res = await fetch('/api/admin/apps', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (res.ok) {
        const { id } = await res.json();
        window.location.href = `/admin/apps/${id}`;
      } else {
        const err = await res.json().catch(() => ({ error: 'Lỗi không xác định' }));
        alert(err.error || 'Tạo ứng dụng thất bại');
      }
    });

    // Delete
    document.querySelectorAll('.delete-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = (btn as HTMLElement).dataset.id;
        const name = (btn as HTMLElement).dataset.name;
        if (!id || !confirm(`Xác nhận xóa ứng dụng "${name}"?`)) return;
        const res = await fetch(`/api/admin/apps/${id}`, { method: 'DELETE' });
        if (res.ok) {
          window.location.reload();
        } else {
          alert('Xóa thất bại');
        }
      });
    });
  </script>
</AdminLayout>
