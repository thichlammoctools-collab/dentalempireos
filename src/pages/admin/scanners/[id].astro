---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';
import { getSurveyDefinitionFull, parseScoringRules, parseAiConfig } from '../../../lib/survey-config-db';

export const prerender = false;

const idParam = Astro.params.id;
const id = idParam ?? '';

let full = null;
let loadError = '';

try {
  full = await getSurveyDefinitionFull(env.DB, id);
} catch (err) {
  loadError = err instanceof Error ? err.message : 'Lỗi tải dữ liệu';
}

if (!full) {
  return Astro.redirect('/admin/scanners');
}

const def = full.definition;
const sections = full.sections;

const scoringRules = parseScoringRules(def.scoring_rules);
const aiConfig = parseAiConfig(def.ai_config);

let chapterRefsList = [];
try { chapterRefsList = def.chapter_refs ? JSON.parse(def.chapter_refs) : []; } catch {}

const statusLabels = { draft: 'Bản nháp', active: 'Đang hoạt động', archived: 'Lưu trữ' };
const typeLabels = { mini: 'Mini', full: 'Full', checklist: 'Checklist' };

const aiConfigJson = JSON.stringify(aiConfig, null, 2);
const scoringRulesJson = JSON.stringify(scoringRules, null, 2);
const chapterRefsValue = chapterRefsList.join(',');

// Build flat list of all questions for the scoring picker
const allQuestions = sections.flatMap((sec) =>
  sec.questions
    .filter((q) => q.type === 'select' || q.type === 'yesno')
    .map((q) => ({
      id: q.question_id,
      label: q.label_vi,
      label_en: q.label_en || '',
      section: sec.title_vi,
      type: q.type,
    })),
);
const allQuestionsJson = JSON.stringify(allQuestions);
const scoringRulesInitJson = JSON.stringify(scoringRules ?? {
  dimensions: [],
  total_formula: 'average',
  thresholds: { excellent: 75, good: 55, needs_work: 35, critical: 0 },
});
---

<AdminLayout title={`${def ? def.title_vi : 'Scanner'} | Admin`}>
  <div
    data-def-id={def ? def.id : ''}
    data-all-questions={allQuestionsJson}
    data-scoring-init={scoringRulesInitJson}
  >
  {loadError && (
    <div class="glass-card rounded-2xl p-6 border border-red-500/30">
      <p class="text-red-300 font-semibold">Lỗi tải dữ liệu</p>
      <p class="text-sm text-on-surface-variant mt-1">{loadError}</p>
    </div>
  )}

  {def && (
    <>
      <header class="flex flex-wrap items-start justify-between gap-4">
        <div class="flex items-start gap-4 min-w-0">
          <a href="/admin/scanners" class="p-2 rounded-lg hover:bg-surface-container text-on-surface-variant hover:text-on-surface transition-colors shrink-0">
            <span class="material-symbols-outlined">arrow_back</span>
          </a>
          <div class="min-w-0">
            <div class="flex items-center gap-2 mb-1 flex-wrap">
              <span class="text-xs uppercase tracking-wider text-on-surface-variant/70 font-bold">Scanner</span>
              <span class="text-xs px-2 py-0.5 rounded-md bg-purple-500/20 text-purple-300 font-semibold">{typeLabels[def.survey_type] || def.survey_type}</span>
              <span class="text-xs px-2 py-0.5 rounded-md bg-surface-container border border-outline-variant/30 text-on-surface-variant font-semibold">{statusLabels[def.status] || def.status}</span>
            </div>
            <h1 class="text-2xl font-bold text-on-surface truncate">{def.title_vi}</h1>
            <p class="text-sm text-on-surface-variant truncate font-mono mt-0.5">{def.id}</p>
          </div>
        </div>
        <div class="flex gap-2 flex-wrap shrink-0">
          <a href={`/scanner/${def.slug}`} target="_blank" class="bg-surface-container border border-outline-variant/30 text-on-surface px-4 py-2 rounded-xl font-semibold text-sm hover:bg-surface-container-high transition-colors flex items-center gap-2">
            <span class="material-symbols-outlined text-[18px]">visibility</span>
            Xem trang
          </a>
          <a href={`/admin/scanners/${def.id}/responses`} class="bg-primary-container text-white px-4 py-2 rounded-xl font-bold text-sm cyan-glow hover:opacity-90 active:scale-95 transition-all flex items-center gap-2">
            <span class="material-symbols-outlined text-[18px]">list_alt</span>
            Responses
          </a>
        </div>
      </header>

      <div class="flex gap-2 border-b border-outline-variant/15 -mb-px overflow-x-auto scrollbar-hide">
        <a href="#info" class="px-4 py-2.5 text-sm font-semibold border-b-2 border-primary text-primary whitespace-nowrap">Thông tin cơ bản</a>
        <a href="#sections" class="px-4 py-2.5 text-sm font-semibold border-b-2 border-transparent text-on-surface-variant hover:text-on-surface whitespace-nowrap">Sections & Questions ({sections.length})</a>
        <a href="#ai" class="px-4 py-2.5 text-sm font-semibold border-b-2 border-transparent text-on-surface-variant hover:text-on-surface whitespace-nowrap">AI Config</a>
        <a href="#scoring" class="px-4 py-2.5 text-sm font-semibold border-b-2 border-transparent text-on-surface-variant hover:text-on-surface whitespace-nowrap">Scoring Rules</a>
      </div>

      <!-- Basic Info -->
      <form id="form-info" class="glass-card rounded-2xl p-6 flex flex-col gap-4">
        <h2 class="text-lg font-bold text-on-surface">Thông tin cơ bản</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="text-xs font-semibold text-on-surface-variant block mb-1">Tiêu đề (VI) *</label>
            <input type="text" name="title_vi" required value={def.title_vi} class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="text-xs font-semibold text-on-surface-variant block mb-1">Tiêu đề (EN)</label>
            <input type="text" name="title_en" value={def.title_en || ''} class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="text-xs font-semibold text-on-surface-variant block mb-1">Slug</label>
            <input type="text" name="slug" value={def.slug} class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface font-mono focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="text-xs font-semibold text-on-surface-variant block mb-1">Trạng thái</label>
            <select name="status" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary">
              <option value="draft" selected={def.status === 'draft'}>Bản nháp</option>
              <option value="active" selected={def.status === 'active'}>Đang hoạt động</option>
              <option value="archived" selected={def.status === 'archived'}>Lưu trữ</option>
            </select>
          </div>
          <div>
            <label class="text-xs font-semibold text-on-surface-variant block mb-1">Loại</label>
            <select name="survey_type" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary">
              <option value="full" selected={def.survey_type === 'full'}>Full</option>
              <option value="mini" selected={def.survey_type === 'mini'}>Mini</option>
              <option value="checklist" selected={def.survey_type === 'checklist'}>Checklist</option>
            </select>
          </div>
          <div>
            <label class="text-xs font-semibold text-on-surface-variant block mb-1">AI free?</label>
            <label class="flex items-center gap-2 mt-2 cursor-pointer">
              <input type="checkbox" name="is_free" checked={def.is_free === 1} value="1" class="w-4 h-4 rounded" />
              <span class="text-sm text-on-surface">Không cần trả phí để xem AI analysis</span>
            </label>
          </div>
        </div>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Mô tả (VI)</label>
          <textarea name="description_vi" rows="3" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary">{def.description_vi || ''}</textarea>
        </div>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Mô tả (EN)</label>
          <textarea name="description_en" rows="3" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary">{def.description_en || ''}</textarea>
        </div>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Chapter refs (vd: Ch.22, Ch.24)</label>
          <input type="text" name="chapter_refs" value={chapterRefsValue} class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface font-mono focus:outline-none focus:border-primary" />
        </div>
        <p id="info-error" class="text-sm text-red-400 hidden"></p>
        <div class="flex justify-end pt-2 border-t border-outline-variant/10">
          <button type="submit" class="bg-primary-container text-white px-5 py-2.5 rounded-xl font-bold text-sm cyan-glow hover:opacity-90 active:scale-95 transition-all">Lưu thông tin</button>
        </div>
      </form>

      <!-- Sections & Questions -->
      <div id="sections" class="glass-card rounded-2xl p-6 flex flex-col gap-3">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-bold text-on-surface">Sections & Questions</h2>
          <button type="button" id="btn-add-section" class="bg-primary-container text-white px-4 py-2 rounded-xl font-bold text-sm cyan-glow hover:opacity-90 active:scale-95 transition-all flex items-center gap-2">
            <span class="material-symbols-outlined text-[18px]">add</span>
            Thêm section
          </button>
        </div>
        {sections.length === 0 ? (
          <p class="text-sm text-on-surface-variant text-center py-4">Chưa có section nào.</p>
        ) : (
          sections.map((section, idx) => (
            <div class="bg-surface-container/40 rounded-xl p-4 border border-outline-variant/15">
              <div class="flex items-center gap-3 mb-2">
                <span class="text-xs text-on-surface-variant/70 font-mono">#{idx + 1}</span>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-semibold text-on-surface truncate">{section.title_vi}</p>
                  {section.ref && <p class="text-xs text-amber-400 font-mono">{section.ref}</p>}
                </div>
                <span class="text-xs text-on-surface-variant">{section.questions.length} câu</span>
                <button type="button" class="btn-edit-section p-1.5 rounded-lg hover:bg-surface-container text-on-surface-variant hover:text-on-surface" data-section-id={section.id} data-name={section.title_vi}>
                  <span class="material-symbols-outlined text-[18px]">edit</span>
                </button>
                <button type="button" class="btn-delete-section p-1.5 rounded-lg hover:bg-red-500/20 text-on-surface-variant hover:text-red-400" data-section-id={section.id} data-name={section.title_vi}>
                  <span class="material-symbols-outlined text-[18px]">delete</span>
                </button>
              </div>
              {section.questions.length > 0 && (
                <ol class="list-decimal list-inside ml-4 flex flex-col gap-1.5 mt-2">
                  {section.questions.map((q) => (
                    <li class="text-sm text-on-surface group">
                      <div class="flex items-start gap-2">
                        <div class="flex-1 min-w-0">
                          <p>{q.label_vi}</p>
                          <p class="text-xs text-on-surface-variant font-mono">
                            {q.question_id} · {q.type}
                            {q.dimension ? ` · dim=${q.dimension}` : ''}
                            {q.required ? ' · required' : ''}
                            {q.anchor ? ' · ⭐' : ''}
                          </p>
                        </div>
                        <button type="button" class="btn-edit-question opacity-0 group-hover:opacity-100 p-1 rounded hover:bg-surface-container text-on-surface-variant" data-question-id={q.id} data-section-id={section.id} data-label={q.label_vi}>
                          <span class="material-symbols-outlined text-[14px]">edit</span>
                        </button>
                        <button type="button" class="btn-delete-question opacity-0 group-hover:opacity-100 p-1 rounded hover:bg-red-500/20 text-on-surface-variant hover:text-red-400" data-question-id={q.id} data-label={q.label_vi}>
                          <span class="material-symbols-outlined text-[14px]">delete</span>
                        </button>
                      </div>
                    </li>
                  ))}
                </ol>
              )}
              <button type="button" class="btn-add-question w-full mt-2 px-3 py-1.5 bg-surface-container border border-outline-variant/30 hover:border-primary rounded-lg text-sm font-semibold flex items-center justify-center gap-1.5" data-section-id={section.id}>
                <span class="material-symbols-outlined text-[16px]">add</span>
                Thêm câu hỏi
              </button>
            </div>
          ))
        )}
      </div>

      <!-- AI Config -->
      <form id="form-ai" class="glass-card rounded-2xl p-6 flex flex-col gap-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-[20px]">psychology</span>
            <h2 class="text-lg font-bold text-on-surface">Cấu hình AI</h2>
          </div>
          <div class="flex items-center gap-2">
            <button type="button" id="btn-ai-json-toggle" class="text-xs font-mono px-2.5 py-1 rounded-lg bg-surface-container border border-outline-variant/30 text-on-surface-variant hover:text-on-surface hover:border-primary/40 transition-all">
              <span id="ai-json-toggle-label">JSON thô</span>
            </button>
            <button type="button" id="btn-ai-reset" class="text-xs px-2.5 py-1 rounded-lg bg-surface-container border border-outline-variant/30 text-on-surface-variant hover:text-red-400 hover:border-red-500/40 transition-all">Reset</button>
          </div>
        </div>

        <!-- Tab navigation -->
        <div id="ai-tabs" class="flex gap-1 border-b border-outline-variant/15 -mb-px">
          <button type="button" class="ai-tab-btn px-4 py-2.5 text-sm font-semibold border-b-2 border-primary text-primary transition-colors" data-tab="prompt">Prompt</button>
          <button type="button" class="ai-tab-btn px-4 py-2.5 text-sm font-semibold border-b-2 border-transparent text-on-surface-variant hover:text-on-surface transition-colors" data-tab="model">Model & Tokens</button>
          <button type="button" class="ai-tab-btn px-4 py-2.5 text-sm font-semibold border-b-2 border-transparent text-on-surface-variant hover:text-on-surface transition-colors" data-tab="sections">Analysis Sections</button>
        </div>

        <!-- JSON raw view (hidden by default) -->
        <div id="ai-panel-json" class="hidden">
          <textarea name="ai_config_json" rows="20" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-3 text-on-surface font-mono text-xs focus:outline-none focus:border-primary">{aiConfigJson}</textarea>
        </div>

        <!-- Structured view (default) -->
        <div id="ai-panel-structured" class="flex flex-col gap-5">
          <!-- Prompt tab -->
          <div id="ai-tab-prompt" class="ai-tab-panel flex flex-col gap-4">
            <p class="text-xs text-on-surface-variant/60">Override prompt mặc định từ <code class="bg-surface-container px-1 py-0.5 rounded font-mono">ai_settings</code>. Dùng placeholder <code class="bg-surface-container px-1 py-0.5 rounded font-mono">{'{{SCORE_<dim>}}'}</code>, <code class="bg-surface-container px-1 py-0.5 rounded font-mono">{'{{SCORE_TOTAL}}'}</code>, <code class="bg-surface-container px-1 py-0.5 rounded font-mono">{'{{LANG}}'}</code>.</p>

            <!-- VI prompt -->
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <label class="text-xs font-semibold text-on-surface-variant flex items-center gap-1">
                  <span class="material-symbols-outlined text-[14px]">edit_note</span>
                  Prompt tiếng Việt
                </label>
                <span id="char-count-vi" class="text-[11px] text-on-surface-variant/40 font-mono">{aiConfig.prompt_vi?.length ?? 0} ký tự</span>
              </div>
              <textarea name="prompt_vi" id="ai-prompt-vi" rows="10" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-3 text-on-surface text-sm leading-relaxed focus:outline-none focus:border-primary transition-all resize-y">{(aiConfig.prompt_vi ?? '')}</textarea>
            </div>

            <!-- EN prompt -->
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <label class="text-xs font-semibold text-on-surface-variant flex items-center gap-1">
                  <span class="material-symbols-outlined text-[14px]">translate</span>
                  Prompt tiếng Anh <span class="text-on-surface-variant/40 font-normal">(tùy chọn)</span>
                </label>
                <span id="char-count-en" class="text-[11px] text-on-surface-variant/40 font-mono">{aiConfig.prompt_en?.length ?? 0} ký tự</span>
              </div>
              <textarea name="prompt_en" id="ai-prompt-en" rows="7" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-3 text-on-surface text-sm leading-relaxed focus:outline-none focus:border-primary transition-all resize-y">{(aiConfig.prompt_en ?? '')}</textarea>
            </div>
          </div>

          <!-- Model & Tokens tab -->
          <div id="ai-tab-model" class="ai-tab-panel hidden flex flex-col gap-4">
            <p class="text-xs text-on-surface-variant/60">Để trống để dùng giá trị mặc định từ <code class="bg-surface-container px-1 py-0.5 rounded font-mono">ai_settings</code>.</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="text-xs font-semibold text-on-surface-variant block mb-1.5">Model override</label>
                <input type="text" name="model_override" id="ai-model-override" value={aiConfig.model_override ?? ''} placeholder="claude-sonnet-4-6" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface font-mono text-sm focus:outline-none focus:border-primary transition-all" />
                <p class="text-[11px] text-on-surface-variant/40 mt-1">Mặc định: claude-sonnet-4-6</p>
              </div>
              <div>
                <label class="text-xs font-semibold text-on-surface-variant block mb-1.5">Max tokens</label>
                <input type="number" name="max_tokens_override" id="ai-max-tokens" value={aiConfig.max_tokens_override ?? ''} placeholder="4096" min="256" max="32000" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface font-mono text-sm focus:outline-none focus:border-primary transition-all" />
                <p class="text-[11px] text-on-surface-variant/40 mt-1">Mặc định: 4096</p>
              </div>
            </div>
            <div class="p-4 bg-surface-container/40 rounded-xl border border-outline-variant/15">
              <p class="text-xs font-semibold text-on-surface mb-2">Preview cấu hình hiện tại</p>
              <div class="grid grid-cols-2 gap-x-6 gap-y-2 text-xs">
                <div>
                  <span class="text-on-surface-variant/50">Model</span>
                  <p class="text-on-surface font-mono mt-0.5">{aiConfig.model_override || '<span class="text-on-surface-variant/40 italic">mặc định</span>'}</p>
                </div>
                <div>
                  <span class="text-on-surface-variant/50">Max tokens</span>
                  <p class="text-on-surface font-mono mt-0.5">{aiConfig.max_tokens_override ?? '<span class="text-on-surface-variant/40 italic">mặc định</span>'}</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Analysis Sections tab -->
          <div id="ai-tab-sections" class="ai-tab-panel hidden flex flex-col gap-4">
            <p class="text-xs text-on-surface-variant/60">Định nghĩa các mục trong báo cáo AI. Báo cáo sẽ có cấu trúc theo các section này. Dùng <code class="bg-surface-container px-1 py-0.5 rounded font-mono">{'{{SCORE_<dim>}}'}</code> trong prompt để hiển thị điểm dimension.</p>

            <div id="analysis-sections-list" class="flex flex-col gap-3">
              {(aiConfig.analysis_sections ?? []).map((sec: any, idx: number) => (
                <div class="analysis-section-item flex flex-col sm:flex-row gap-3 bg-surface-container/40 rounded-xl p-4 border border-outline-variant/15" data-section-idx={idx}>
                  <div class="flex-1 flex flex-col gap-2">
                    <div class="flex items-center gap-2">
                      <span class="text-xs font-mono text-on-surface-variant/40 bg-surface-container px-2 py-0.5 rounded">{idx + 1}</span>
                      <input type="text" name={`section_title_vi_${idx}`} value={sec.title_vi ?? ''} placeholder="Tiêu đề mục (VI) *" class="flex-1 bg-surface-container border border-outline-variant rounded-lg px-3 py-2 text-sm text-on-surface focus:outline-none focus:border-primary transition-all" />
                    </div>
                    <input type="text" name={`section_title_en_${idx}`} value={sec.title_en ?? ''} placeholder="Title (EN) — tùy chọn" class="w-full bg-surface-container border border-outline-variant rounded-lg px-3 py-2 text-sm text-on-surface focus:outline-none focus:border-primary transition-all" />
                  </div>
                  <input type="hidden" name={`section_id_${idx}`} value={sec.id ?? ''} />
                  <button type="button" class="btn-remove-section self-start sm:self-center p-2 rounded-lg hover:bg-red-500/20 text-on-surface-variant hover:text-red-400 transition-all" title="Xóa mục này">
                    <span class="material-symbols-outlined text-[18px]">delete</span>
                  </button>
                </div>
              ))}
            </div>

            <button type="button" id="btn-add-analysis-section" class="w-full sm:w-auto sm:self-start px-4 py-2.5 rounded-xl bg-surface-container border border-dashed border-outline-variant/50 text-on-surface-variant hover:text-primary hover:border-primary/50 text-sm font-semibold transition-all flex items-center gap-2">
              <span class="material-symbols-outlined text-[18px]">add</span>
              Thêm mục phân tích
            </button>

            {(aiConfig.analysis_sections?.length ?? 0) === 0 && (
              <p id="ai-sections-empty" class="text-sm text-on-surface-variant/40 italic text-center py-4">Chưa có mục nào. Nhấn "Thêm mục phân tích" để tạo.</p>
            )}
          </div>
        </div>

        <p id="ai-error" class="text-sm text-red-400 hidden bg-red-500/10 border border-red-500/30 rounded-lg p-2"></p>
        <div class="flex justify-end pt-2 border-t border-outline-variant/10">
          <button type="submit" id="btn-ai-submit" class="bg-primary-container text-white px-5 py-2.5 rounded-xl font-bold text-sm cyan-glow hover:opacity-90 active:scale-95 transition-all flex items-center gap-2">
            <span class="material-symbols-outlined text-[18px]">save</span>
            Lưu AI Config
          </button>
        </div>
      </form>

      <!-- Scoring Rules (Visual UI) -->
      <form id="form-scoring" class="glass-card rounded-2xl p-6 flex flex-col gap-6">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-[20px]">speed</span>
            <h2 class="text-lg font-bold text-on-surface">Scoring Rules</h2>
          </div>
          <div class="flex items-center gap-2">
            <button type="button" id="btn-scoring-json-toggle" class="text-xs font-mono px-2.5 py-1 rounded-lg bg-surface-container border border-outline-variant/30 text-on-surface-variant hover:text-on-surface hover:border-primary/40 transition-all">
              <span id="scoring-json-toggle-label">JSON thô</span>
            </button>
          </div>
        </div>
        <p class="text-xs text-on-surface-variant/60">
          Định nghĩa các chiều đo (dimensions) và cách tính điểm. Chỉ câu <code class="bg-surface-container px-1 py-0.5 rounded font-mono">select</code> và <code class="bg-surface-container px-1 py-0.5 rounded font-mono">yesno</code> mới có thể gán vào dimension để tính điểm.
        </p>

        <!-- JSON raw view -->
        <div id="scoring-panel-json" class="hidden">
          <textarea name="scoring_rules_json" id="scoring-rules-json-ta" rows="16" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-3 text-on-surface font-mono text-xs focus:outline-none focus:border-primary">{scoringRulesJson}</textarea>
          <p class="text-[11px] text-on-surface-variant/50 mt-1.5">Có thể paste JSON hợp lệ vào đây, hoặc edit form bên dưới rồi chuyển về form.</p>
        </div>

        <!-- Structured view -->
        <div id="scoring-panel-structured" class="flex flex-col gap-5">

          <!-- Dimensions list -->
          <div>
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-sm font-semibold text-on-surface">Chiều đo (Dimensions)</h3>
              <button type="button" id="btn-add-dimension" class="flex items-center gap-1.5 text-xs font-semibold text-primary hover:text-primary/80 transition-colors">
                <span class="material-symbols-outlined text-[16px]">add</span>
                Thêm dimension
              </button>
            </div>

            <div id="dimensions-list" class="flex flex-col gap-3">
              <!-- Dimension cards injected by JS -->
            </div>

            <div id="dimensions-empty" class="text-sm text-on-surface-variant/40 italic text-center py-6 rounded-xl bg-surface-container/20 border border-dashed border-outline-variant/30">
              Chưa có dimension nào. Nhấn "Thêm dimension" để bắt đầu.
            </div>
          </div>

          <!-- Total formula -->
          <div class="p-4 bg-surface-container/30 rounded-xl border border-outline-variant/15">
            <h3 class="text-sm font-semibold text-on-surface mb-3">Tổng điểm (Total Score)</h3>
            <div class="flex gap-4 flex-wrap">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="total_formula" value="average" class="accent-primary" />
                <span class="text-sm text-on-surface">Average — trung bình các chiều</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="total_formula" value="weighted_average" class="accent-primary" />
                <span class="text-sm text-on-surface">Weighted — theo trọng số từng chiều</span>
              </label>
            </div>
          </div>

          <!-- Thresholds -->
          <div class="p-4 bg-surface-container/30 rounded-xl border border-outline-variant/15">
            <h3 class="text-sm font-semibold text-on-surface mb-3">Ngưỡng đánh giá (Thresholds)</h3>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
              <div>
                <label class="text-xs text-on-surface-variant block mb-1.5 flex items-center gap-1.5">
                  <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 shrink-0"></span>
                  Vững mạnh (≥)
                </label>
                <input type="number" name="threshold_excellent" min="0" max="100" class="w-full bg-surface-container border border-outline-variant rounded-lg px-3 py-2 text-sm text-on-surface font-mono focus:outline-none focus:border-primary" />
              </div>
              <div>
                <label class="text-xs text-on-surface-variant block mb-1.5 flex items-center gap-1.5">
                  <span class="w-2.5 h-2.5 rounded-full bg-blue-500 shrink-0"></span>
                  Đang phát triển (≥)
                </label>
                <input type="number" name="threshold_good" min="0" max="100" class="w-full bg-surface-container border border-outline-variant rounded-lg px-3 py-2 text-sm text-on-surface font-mono focus:outline-none focus:border-primary" />
              </div>
              <div>
                <label class="text-xs text-on-surface-variant block mb-1.5 flex items-center gap-1.5">
                  <span class="w-2.5 h-2.5 rounded-full bg-amber-500 shrink-0"></span>
                  Cần chú ý (≥)
                </label>
                <input type="number" name="threshold_needs_work" min="0" max="100" class="w-full bg-surface-container border border-outline-variant rounded-lg px-3 py-2 text-sm text-on-surface font-mono focus:outline-none focus:border-primary" />
              </div>
              <div>
                <label class="text-xs text-on-surface-variant block mb-1.5 flex items-center gap-1.5">
                  <span class="w-2.5 h-2.5 rounded-full bg-red-500 shrink-0"></span>
                  Cần soi chiếu (&lt;)
                </label>
                <input type="number" name="threshold_critical" min="0" max="100" class="w-full bg-surface-container border border-outline-variant rounded-lg px-3 py-2 text-sm text-on-surface font-mono focus:outline-none focus:border-primary" />
              </div>
            </div>
            <!-- Visual threshold bar preview -->
            <div class="mt-3">
              <div class="relative h-3 rounded-full overflow-hidden flex" id="threshold-bar">
                <div class="bg-red-500/80 h-full" id="bar-critical" style="width:0%"></div>
                <div class="bg-amber-500/80 h-full" id="bar-needs-work" style="width:0%"></div>
                <div class="bg-blue-500/80 h-full" id="bar-good" style="width:0%"></div>
                <div class="bg-emerald-500/80 h-full" id="bar-excellent" style="width:100%"></div>
              </div>
              <div class="flex justify-between text-[10px] text-on-surface-variant/50 mt-1 font-mono">
                <span>0</span><span>25</span><span>50</span><span>75</span><span>100</span>
              </div>
            </div>
          </div>

          <!-- Preview score card -->
          <div id="scoring-preview" class="hidden p-4 rounded-xl border border-primary/30 bg-primary/5">
            <p class="text-xs font-semibold text-primary mb-3 flex items-center gap-1.5">
              <span class="material-symbols-outlined text-[14px]">preview</span>
              Preview — điểm mẫu
            </p>
            <div class="flex gap-3 flex-wrap" id="scoring-preview-content"></div>
          </div>
        </div>

        <p id="scoring-error" class="text-sm text-red-400 hidden"></p>
        <div class="flex justify-end pt-3 border-t border-outline-variant/10">
          <button type="submit" id="btn-scoring-submit" class="bg-primary-container text-white px-5 py-2.5 rounded-xl font-bold text-sm cyan-glow hover:opacity-90 active:scale-95 transition-all flex items-center gap-2">
            <span class="material-symbols-outlined text-[18px]">save</span>
            Lưu Scoring Rules
          </button>
        </div>
      </form>
    </>
  )}

  <!-- Section modal -->
  <div id="section-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4">
    <div id="section-modal-backdrop" class="absolute inset-0 bg-black/0 transition-colors"></div>
    <div id="section-modal-panel" class="relative glass-card rounded-2xl p-6 w-full max-w-lg max-h-[90vh] overflow-y-auto scrollbar-hide scale-95 opacity-0 transition-all">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-xl font-bold text-on-surface" id="section-modal-title">Thêm section</h3>
        <button type="button" id="section-modal-close" class="p-2 rounded-lg hover:bg-surface-container text-on-surface-variant">
          <span class="material-symbols-outlined text-[20px]">close</span>
        </button>
      </div>
      <form id="section-form" class="flex flex-col gap-4">
        <input type="hidden" name="id" id="section-form-id" />
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Tiêu đề (VI) *</label>
          <input type="text" name="title_vi" required class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Tiêu đề (EN)</label>
          <input type="text" name="title_en" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Subtitle (VI)</label>
          <input type="text" name="subtitle_vi" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Reference (vd: Ch.26 — ROOTS)</label>
          <input type="text" name="ref" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface font-mono focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Icon (Material Symbol)</label>
          <input type="text" name="icon" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface font-mono focus:outline-none focus:border-primary" placeholder="park" />
        </div>
        <p id="section-form-error" class="text-sm text-red-400 hidden"></p>
        <div class="flex justify-end gap-2 pt-2">
          <button type="button" id="section-modal-cancel" class="px-4 py-2.5 rounded-xl text-sm font-semibold text-on-surface-variant hover:bg-surface-container">Huỷ</button>
          <button type="submit" class="bg-primary-container text-white px-5 py-2.5 rounded-xl font-bold text-sm cyan-glow hover:opacity-90 active:scale-95 transition-all">Lưu</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Question modal -->
  <div id="question-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4">
    <div id="question-modal-backdrop" class="absolute inset-0 bg-black/0 transition-colors"></div>
    <div id="question-modal-panel" class="relative glass-card rounded-2xl p-6 w-full max-w-5xl max-h-[90vh] overflow-y-auto scrollbar-hide scale-95 opacity-0 transition-all">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-xl font-bold text-on-surface" id="question-modal-title">Thêm câu hỏi</h3>
        <button type="button" id="question-modal-close" class="p-2 rounded-lg hover:bg-surface-container text-on-surface-variant">
          <span class="material-symbols-outlined text-[20px]">close</span>
        </button>
      </div>
      <form id="question-form" class="flex flex-col lg:flex-row gap-6">
        <!-- Left: Form fields -->
        <div class="flex-1 flex flex-col gap-4 min-w-0">
          <input type="hidden" name="id" id="question-form-id" />
          <input type="hidden" name="section_id" id="question-form-section-id" />

          <!-- ID + Type + Dimension row -->
          <div class="grid grid-cols-1 sm:grid-cols-12 gap-3">
            <div class="sm:col-span-5">
              <label class="text-xs font-semibold text-on-surface-variant block mb-1">question_id *</label>
              <input type="text" name="question_id" required pattern="[a-z0-9_]+" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface font-mono text-sm focus:outline-none focus:border-primary transition-shadow" placeholder="hr_q1" />
              <p class="text-[10px] text-on-surface-variant/70 mt-1">Tự sinh từ Label VI — chỉ chữ thường, số, gạch dưới</p>
            </div>
            <div class="sm:col-span-4">
              <label class="text-xs font-semibold text-on-surface-variant block mb-1">Loại *</label>
              <select name="type" required class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary">
                <option value="select" selected>select (1-5 scale)</option>
                <option value="textarea">textarea (mở)</option>
                <option value="radio">radio (chọn 1)</option>
                <option value="yesno">yesno (Có/Không)</option>
              </select>
            </div>
            <div class="sm:col-span-3">
              <label class="text-xs font-semibold text-on-surface-variant block mb-1">Dimension</label>
              <input type="text" name="dimension" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface font-mono text-sm focus:outline-none focus:border-primary" placeholder="operations" />
            </div>
          </div>

          <!-- Language tabs -->
          <div class="flex gap-1 border-b border-outline-variant/15 -mb-px">
            <button type="button" class="q-tab-btn px-3 py-2 text-xs font-semibold border-b-2 border-primary text-primary transition-colors" data-q-tab="vi">🇻🇳 Tiếng Việt</button>
            <button type="button" class="q-tab-btn px-3 py-2 text-xs font-semibold border-b-2 border-transparent text-on-surface-variant hover:text-on-surface transition-colors" data-q-tab="en">🇬🇧 English</button>
          </div>

          <!-- VI tab -->
          <div data-q-tab-panel="vi" class="q-tab-panel flex flex-col gap-3">
            <div>
              <label class="text-xs font-semibold text-on-surface-variant block mb-1">Label (VI) *</label>
              <textarea name="label_vi" required rows="2" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary" placeholder="Câu hỏi của bạn..."></textarea>
            </div>
            <div>
              <label class="text-xs font-semibold text-on-surface-variant block mb-1">Placeholder (VI)</label>
              <input type="text" name="placeholder_vi" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface text-sm focus:outline-none focus:border-primary" />
            </div>
            <div id="q-field-options" class="hidden">
              <label class="text-xs font-semibold text-on-surface-variant block mb-1">Options (VI) — mỗi dòng 1 option</label>
              <textarea name="options_vi_text" rows="4" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface text-sm focus:outline-none focus:border-primary" placeholder="Lựa chọn A&#10;Lựa chọn B&#10;Lựa chọn C"></textarea>
              <p class="text-[10px] text-on-surface-variant/70 mt-1">Dành cho câu hỏi <strong>radio</strong></p>
            </div>
            <div id="q-field-scale">
              <div class="flex items-center justify-between mb-2">
                <label class="text-xs font-semibold text-on-surface-variant">Scale labels (VI)</label>
                <div class="flex gap-1">
                  <button type="button" class="q-scale-template text-[10px] px-2 py-0.5 rounded bg-surface-container border border-outline-variant hover:border-primary text-on-surface" data-template='{"1":"Chưa có","2":"Đang bắt đầu","3":"Đã có","4":"Ổn định","5":"Đầu tàu"}'>Mặc định</button>
                  <button type="button" class="q-scale-template text-[10px] px-2 py-0.5 rounded bg-surface-container border border-outline-variant hover:border-primary text-on-surface" data-template='{"1":"Hoàn toàn không","5":"Hoàn toàn đồng ý"}'>Likert</button>
                  <button type="button" class="q-scale-template text-[10px] px-2 py-0.5 rounded bg-surface-container border border-outline-variant hover:border-primary text-on-surface" data-template='{"1":"Yếu","2":"Trung bình","3":"Khá","4":"Tốt","5":"Xuất sắc"}'>Năng lực</button>
                </div>
              </div>
              <div class="flex gap-2">
                <div class="flex flex-col items-center gap-1 flex-1 min-w-0">
                  <span class="text-[10px] font-bold text-on-surface-variant bg-surface-container-high px-1.5 py-0.5 rounded">1</span>
                  <input type="text" name="scale_1" class="w-full bg-surface-container border border-outline-variant rounded-lg px-2 py-1.5 text-on-surface text-xs text-center focus:outline-none focus:border-primary placeholder:text-on-surface-variant/40 placeholder:text-[10px]" placeholder="Mức 1" />
                </div>
                <div class="flex flex-col items-center gap-1 flex-1 min-w-0">
                  <span class="text-[10px] font-bold text-on-surface-variant bg-surface-container-high px-1.5 py-0.5 rounded">2</span>
                  <input type="text" name="scale_2" class="w-full bg-surface-container border border-outline-variant rounded-lg px-2 py-1.5 text-on-surface text-xs text-center focus:outline-none focus:border-primary placeholder:text-on-surface-variant/40 placeholder:text-[10px]" placeholder="Mức 2" />
                </div>
                <div class="flex flex-col items-center gap-1 flex-1 min-w-0">
                  <span class="text-[10px] font-bold text-on-surface-variant bg-surface-container-high px-1.5 py-0.5 rounded">3</span>
                  <input type="text" name="scale_3" class="w-full bg-surface-container border border-outline-variant rounded-lg px-2 py-1.5 text-on-surface text-xs text-center focus:outline-none focus:border-primary placeholder:text-on-surface-variant/40 placeholder:text-[10px]" placeholder="Mức 3" />
                </div>
                <div class="flex flex-col items-center gap-1 flex-1 min-w-0">
                  <span class="text-[10px] font-bold text-on-surface-variant bg-surface-container-high px-1.5 py-0.5 rounded">4</span>
                  <input type="text" name="scale_4" class="w-full bg-surface-container border border-outline-variant rounded-lg px-2 py-1.5 text-on-surface text-xs text-center focus:outline-none focus:border-primary placeholder:text-on-surface-variant/40 placeholder:text-[10px]" placeholder="Mức 4" />
                </div>
                <div class="flex flex-col items-center gap-1 flex-1 min-w-0">
                  <span class="text-[10px] font-bold text-on-surface-variant bg-surface-container-high px-1.5 py-0.5 rounded">5</span>
                  <input type="text" name="scale_5" class="w-full bg-surface-container border border-outline-variant rounded-lg px-2 py-1.5 text-on-surface text-xs text-center focus:outline-none focus:border-primary placeholder:text-on-surface-variant/40 placeholder:text-[10px]" placeholder="Mức 5" />
                </div>
              </div>
              <input type="hidden" name="scale_labels_vi_text" />
              <p class="text-[10px] text-on-surface-variant/70 mt-1">Dành cho câu hỏi <strong>select</strong> (scale 1-5)</p>
            </div>
          </div>

          <!-- EN tab -->
          <div data-q-tab-panel="en" class="q-tab-panel hidden flex flex-col gap-3">
            <div>
              <label class="text-xs font-semibold text-on-surface-variant block mb-1">Label (EN)</label>
              <textarea name="label_en" rows="2" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary" placeholder="Your question..."></textarea>
            </div>
            <div>
              <label class="text-xs font-semibold text-on-surface-variant block mb-1">Placeholder (EN)</label>
              <input type="text" name="placeholder_en" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface text-sm focus:outline-none focus:border-primary" />
            </div>
          </div>

          <!-- Flags -->
          <div class="flex items-center gap-6 pt-2 border-t border-outline-variant/10">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="required" value="1" class="w-4 h-4 rounded accent-primary" />
              <span class="text-sm text-on-surface">Required</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="anchor" value="1" class="w-4 h-4 rounded accent-amber-500" />
              <span class="text-sm text-on-surface">⭐ Anchor (câu neo)</span>
            </label>
          </div>

          <p id="question-form-error" class="text-sm text-red-400 hidden bg-red-500/10 border border-red-500/30 rounded-lg p-2"></p>
          <div class="flex justify-end gap-2 pt-2">
            <button type="button" id="question-modal-cancel" class="px-4 py-2.5 rounded-xl text-sm font-semibold text-on-surface-variant hover:bg-surface-container">Huỷ</button>
            <button type="submit" class="bg-primary-container text-white px-5 py-2.5 rounded-xl font-bold text-sm cyan-glow hover:opacity-90 active:scale-95 transition-all flex items-center gap-2">
              <span class="material-symbols-outlined text-[16px]">save</span>
              Lưu câu hỏi
            </button>
          </div>
        </div>

        <!-- Right: Live preview -->
        <div class="lg:w-80 shrink-0">
          <div class="sticky top-4">
            <p class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-2">Live Preview</p>
            <div id="q-preview"></div>
            <p class="text-[10px] text-on-surface-variant/70 mt-3 leading-relaxed">
              Preview hiển thị câu hỏi như user sẽ thấy trên form thực tế. Chuyển tab VI/EN để xem preview ngôn ngữ tương ứng.
            </p>
          </div>
        </div>
      </form>
    </div>
  </div>
  </div>
</AdminLayout>

