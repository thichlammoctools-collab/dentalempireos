---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';
import { getSurveyDefinitionFull, parseScoringRules, parseAiConfig } from '../../../lib/survey-config-db';

export const prerender = false;

const idParam = Astro.params.id;
const id = idParam ?? '';

let full = null;
let loadError = '';

try {
  full = await getSurveyDefinitionFull(env.DB, id);
} catch (err) {
  loadError = err instanceof Error ? err.message : 'Lỗi tải dữ liệu';
}

if (!full && !loadError) {
  return Astro.redirect('/admin/scanners');
}

const def = full.definition;
const sections = full.sections;

const scoringRules = parseScoringRules(def.scoring_rules);
const aiConfig = parseAiConfig(def.ai_config);

let chapterRefsList = [];
try { chapterRefsList = def.chapter_refs ? JSON.parse(def.chapter_refs) : []; } catch {}

const statusLabels = { draft: 'Bản nháp', active: 'Đang hoạt động', archived: 'Lưu trữ' };
const typeLabels = { mini: 'Mini', full: 'Full', checklist: 'Checklist' };

const aiConfigJson = JSON.stringify(aiConfig, null, 2);
const scoringRulesJson = JSON.stringify(scoringRules, null, 2);
const chapterRefsValue = chapterRefsList.join(',');
---

<AdminLayout title={`${def ? def.title_vi : 'Scanner'} | Admin`}>
  <div data-def-id={def ? def.id : ''}>
  {loadError && (
    <div class="glass-card rounded-2xl p-6 border border-red-500/30">
      <p class="text-red-300 font-semibold">Lỗi tải dữ liệu</p>
      <p class="text-sm text-on-surface-variant mt-1">{loadError}</p>
    </div>
  )}

  {def && (
    <>
      <header class="flex flex-wrap items-start justify-between gap-4">
        <div class="flex items-start gap-4 min-w-0">
          <a href="/admin/scanners" class="p-2 rounded-lg hover:bg-surface-container text-on-surface-variant hover:text-on-surface transition-colors shrink-0">
            <span class="material-symbols-outlined">arrow_back</span>
          </a>
          <div class="min-w-0">
            <div class="flex items-center gap-2 mb-1 flex-wrap">
              <span class="text-xs uppercase tracking-wider text-on-surface-variant/70 font-bold">Scanner</span>
              <span class="text-xs px-2 py-0.5 rounded-md bg-purple-500/20 text-purple-300 font-semibold">{typeLabels[def.survey_type] || def.survey_type}</span>
              <span class="text-xs px-2 py-0.5 rounded-md bg-surface-container border border-outline-variant/30 text-on-surface-variant font-semibold">{statusLabels[def.status] || def.status}</span>
            </div>
            <h1 class="text-2xl font-bold text-on-surface truncate">{def.title_vi}</h1>
            <p class="text-sm text-on-surface-variant truncate font-mono mt-0.5">{def.id}</p>
          </div>
        </div>
        <div class="flex gap-2 flex-wrap shrink-0">
          <a href={`/scanner/${def.slug}`} target="_blank" class="bg-surface-container border border-outline-variant/30 text-on-surface px-4 py-2 rounded-xl font-semibold text-sm hover:bg-surface-container-high transition-colors flex items-center gap-2">
            <span class="material-symbols-outlined text-[18px]">visibility</span>
            Xem trang
          </a>
          <a href={`/admin/scanners/${def.id}/responses`} class="bg-primary-container text-white px-4 py-2 rounded-xl font-bold text-sm cyan-glow hover:opacity-90 active:scale-95 transition-all flex items-center gap-2">
            <span class="material-symbols-outlined text-[18px]">list_alt</span>
            Responses
          </a>
        </div>
      </header>

      <div class="flex gap-2 border-b border-outline-variant/15 -mb-px overflow-x-auto scrollbar-hide">
        <a href="#info" class="px-4 py-2.5 text-sm font-semibold border-b-2 border-primary text-primary whitespace-nowrap">Thông tin cơ bản</a>
        <a href="#sections" class="px-4 py-2.5 text-sm font-semibold border-b-2 border-transparent text-on-surface-variant hover:text-on-surface whitespace-nowrap">Sections & Questions ({sections.length})</a>
        <a href="#ai" class="px-4 py-2.5 text-sm font-semibold border-b-2 border-transparent text-on-surface-variant hover:text-on-surface whitespace-nowrap">AI Config</a>
        <a href="#scoring" class="px-4 py-2.5 text-sm font-semibold border-b-2 border-transparent text-on-surface-variant hover:text-on-surface whitespace-nowrap">Scoring Rules</a>
      </div>

      <!-- Basic Info -->
      <form id="form-info" class="glass-card rounded-2xl p-6 flex flex-col gap-4">
        <h2 class="text-lg font-bold text-on-surface">Thông tin cơ bản</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="text-xs font-semibold text-on-surface-variant block mb-1">Tiêu đề (VI) *</label>
            <input type="text" name="title_vi" required value={def.title_vi} class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="text-xs font-semibold text-on-surface-variant block mb-1">Tiêu đề (EN)</label>
            <input type="text" name="title_en" value={def.title_en || ''} class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="text-xs font-semibold text-on-surface-variant block mb-1">Slug</label>
            <input type="text" name="slug" value={def.slug} class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface font-mono focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="text-xs font-semibold text-on-surface-variant block mb-1">Trạng thái</label>
            <select name="status" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary">
              <option value="draft" selected={def.status === 'draft'}>Bản nháp</option>
              <option value="active" selected={def.status === 'active'}>Đang hoạt động</option>
              <option value="archived" selected={def.status === 'archived'}>Lưu trữ</option>
            </select>
          </div>
          <div>
            <label class="text-xs font-semibold text-on-surface-variant block mb-1">Loại</label>
            <select name="survey_type" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary">
              <option value="full" selected={def.survey_type === 'full'}>Full</option>
              <option value="mini" selected={def.survey_type === 'mini'}>Mini</option>
              <option value="checklist" selected={def.survey_type === 'checklist'}>Checklist</option>
            </select>
          </div>
          <div>
            <label class="text-xs font-semibold text-on-surface-variant block mb-1">AI free?</label>
            <label class="flex items-center gap-2 mt-2 cursor-pointer">
              <input type="checkbox" name="is_free" checked={def.is_free === 1} value="1" class="w-4 h-4 rounded" />
              <span class="text-sm text-on-surface">Không cần trả phí để xem AI analysis</span>
            </label>
          </div>
        </div>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Mô tả (VI)</label>
          <textarea name="description_vi" rows="3" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary">{def.description_vi || ''}</textarea>
        </div>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Mô tả (EN)</label>
          <textarea name="description_en" rows="3" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary">{def.description_en || ''}</textarea>
        </div>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Chapter refs (vd: Ch.22, Ch.24)</label>
          <input type="text" name="chapter_refs" value={chapterRefsValue} class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface font-mono focus:outline-none focus:border-primary" />
        </div>
        <p id="info-error" class="text-sm text-red-400 hidden"></p>
        <div class="flex justify-end pt-2 border-t border-outline-variant/10">
          <button type="submit" class="bg-primary-container text-white px-5 py-2.5 rounded-xl font-bold text-sm cyan-glow hover:opacity-90 active:scale-95 transition-all">Lưu thông tin</button>
        </div>
      </form>

      <!-- Sections & Questions -->
      <div id="sections" class="glass-card rounded-2xl p-6 flex flex-col gap-3">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-bold text-on-surface">Sections & Questions</h2>
          <button type="button" id="btn-add-section" class="bg-primary-container text-white px-4 py-2 rounded-xl font-bold text-sm cyan-glow hover:opacity-90 active:scale-95 transition-all flex items-center gap-2">
            <span class="material-symbols-outlined text-[18px]">add</span>
            Thêm section
          </button>
        </div>
        {sections.length === 0 ? (
          <p class="text-sm text-on-surface-variant text-center py-4">Chưa có section nào.</p>
        ) : (
          sections.map((section, idx) => (
            <div class="bg-surface-container/40 rounded-xl p-4 border border-outline-variant/15">
              <div class="flex items-center gap-3 mb-2">
                <span class="text-xs text-on-surface-variant/70 font-mono">#{idx + 1}</span>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-semibold text-on-surface truncate">{section.title_vi}</p>
                  {section.ref && <p class="text-xs text-amber-400 font-mono">{section.ref}</p>}
                </div>
                <span class="text-xs text-on-surface-variant">{section.questions.length} câu</span>
                <button type="button" class="btn-edit-section p-1.5 rounded-lg hover:bg-surface-container text-on-surface-variant hover:text-on-surface" data-section-id={section.id} data-name={section.title_vi}>
                  <span class="material-symbols-outlined text-[18px]">edit</span>
                </button>
                <button type="button" class="btn-delete-section p-1.5 rounded-lg hover:bg-red-500/20 text-on-surface-variant hover:text-red-400" data-section-id={section.id} data-name={section.title_vi}>
                  <span class="material-symbols-outlined text-[18px]">delete</span>
                </button>
              </div>
              {section.questions.length > 0 && (
                <ol class="list-decimal list-inside ml-4 flex flex-col gap-1.5 mt-2">
                  {section.questions.map((q) => (
                    <li class="text-sm text-on-surface group">
                      <div class="flex items-start gap-2">
                        <div class="flex-1 min-w-0">
                          <p>{q.label_vi}</p>
                          <p class="text-xs text-on-surface-variant font-mono">
                            {q.question_id} · {q.type}
                            {q.dimension ? ` · dim=${q.dimension}` : ''}
                            {q.required ? ' · required' : ''}
                            {q.anchor ? ' · ⭐' : ''}
                          </p>
                        </div>
                        <button type="button" class="btn-edit-question opacity-0 group-hover:opacity-100 p-1 rounded hover:bg-surface-container text-on-surface-variant" data-question-id={q.id} data-section-id={section.id} data-label={q.label_vi}>
                          <span class="material-symbols-outlined text-[14px]">edit</span>
                        </button>
                        <button type="button" class="btn-delete-question opacity-0 group-hover:opacity-100 p-1 rounded hover:bg-red-500/20 text-on-surface-variant hover:text-red-400" data-question-id={q.id} data-label={q.label_vi}>
                          <span class="material-symbols-outlined text-[14px]">delete</span>
                        </button>
                      </div>
                    </li>
                  ))}
                </ol>
              )}
              <button type="button" class="btn-add-question w-full mt-2 px-3 py-1.5 bg-surface-container border border-outline-variant/30 hover:border-primary rounded-lg text-sm font-semibold flex items-center justify-center gap-1.5" data-section-id={section.id}>
                <span class="material-symbols-outlined text-[16px]">add</span>
                Thêm câu hỏi
              </button>
            </div>
          ))
        )}
      </div>

      <!-- AI Config -->
      <form id="form-ai" class="glass-card rounded-2xl p-6 flex flex-col gap-4">
        <h2 class="text-lg font-bold text-on-surface">AI Config</h2>
        <p class="text-sm text-on-surface-variant">JSON lưu trong <code class="bg-surface-container px-1.5 py-0.5 rounded font-mono text-xs">ai_config</code>. Model mặc định: claude-sonnet-4-6.</p>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">AI Config (JSON)</label>
          <textarea name="ai_config" rows="20" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-3 text-on-surface font-mono text-xs focus:outline-none focus:border-primary">{aiConfigJson}</textarea>
        </div>
        <p id="ai-error" class="text-sm text-red-400 hidden"></p>
        <div class="flex justify-end">
          <button type="submit" class="bg-primary-container text-white px-5 py-2.5 rounded-xl font-bold text-sm cyan-glow hover:opacity-90 active:scale-95 transition-all">Lưu AI Config</button>
        </div>
      </form>

      <!-- Scoring Rules -->
      <form id="form-scoring" class="glass-card rounded-2xl p-6 flex flex-col gap-4">
        <h2 class="text-lg font-bold text-on-surface">Scoring Rules</h2>
        <p class="text-sm text-on-surface-variant">
          Định nghĩa các dimensions và cách tính điểm. Mỗi dimension liệt kê các <code class="bg-surface-container px-1.5 py-0.5 rounded font-mono text-xs">question_id</code> thuộc về nó (chỉ câu select/yesno mới tính điểm).
        </p>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Scoring Rules (JSON)</label>
          <textarea name="scoring_rules" rows="14" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-3 text-on-surface font-mono text-xs focus:outline-none focus:border-primary">{scoringRulesJson}</textarea>
        </div>
        <p id="scoring-error" class="text-sm text-red-400 hidden"></p>
        <div class="flex justify-end">
          <button type="submit" class="bg-primary-container text-white px-5 py-2.5 rounded-xl font-bold text-sm cyan-glow hover:opacity-90 active:scale-95 transition-all">Lưu Scoring Rules</button>
        </div>
      </form>
    </>
  )}

  <!-- Section modal -->
  <div id="section-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4">
    <div id="section-modal-backdrop" class="absolute inset-0 bg-black/0 transition-colors"></div>
    <div id="section-modal-panel" class="relative glass-card rounded-2xl p-6 w-full max-w-lg max-h-[90vh] overflow-y-auto scrollbar-hide scale-95 opacity-0 transition-all">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-xl font-bold text-on-surface" id="section-modal-title">Thêm section</h3>
        <button type="button" id="section-modal-close" class="p-2 rounded-lg hover:bg-surface-container text-on-surface-variant">
          <span class="material-symbols-outlined text-[20px]">close</span>
        </button>
      </div>
      <form id="section-form" class="flex flex-col gap-4">
        <input type="hidden" name="id" id="section-form-id" />
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Tiêu đề (VI) *</label>
          <input type="text" name="title_vi" required class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Tiêu đề (EN)</label>
          <input type="text" name="title_en" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Subtitle (VI)</label>
          <input type="text" name="subtitle_vi" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Reference (vd: Ch.26 — ROOTS)</label>
          <input type="text" name="ref" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface font-mono focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Icon (Material Symbol)</label>
          <input type="text" name="icon" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface font-mono focus:outline-none focus:border-primary" placeholder="park" />
        </div>
        <p id="section-form-error" class="text-sm text-red-400 hidden"></p>
        <div class="flex justify-end gap-2 pt-2">
          <button type="button" id="section-modal-cancel" class="px-4 py-2.5 rounded-xl text-sm font-semibold text-on-surface-variant hover:bg-surface-container">Huỷ</button>
          <button type="submit" class="bg-primary-container text-white px-5 py-2.5 rounded-xl font-bold text-sm cyan-glow hover:opacity-90 active:scale-95 transition-all">Lưu</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Question modal -->
  <div id="question-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4">
    <div id="question-modal-backdrop" class="absolute inset-0 bg-black/0 transition-colors"></div>
    <div id="question-modal-panel" class="relative glass-card rounded-2xl p-6 w-full max-w-2xl max-h-[90vh] overflow-y-auto scrollbar-hide scale-95 opacity-0 transition-all">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-xl font-bold text-on-surface" id="question-modal-title">Thêm câu hỏi</h3>
        <button type="button" id="question-modal-close" class="p-2 rounded-lg hover:bg-surface-container text-on-surface-variant">
          <span class="material-symbols-outlined text-[20px]">close</span>
        </button>
      </div>
      <form id="question-form" class="flex flex-col gap-4">
        <input type="hidden" name="id" id="question-form-id" />
        <input type="hidden" name="section_id" id="question-form-section-id" />
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div>
            <label class="text-xs font-semibold text-on-surface-variant block mb-1">question_id *</label>
            <input type="text" name="question_id" required pattern="[a-z0-9_]+" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface font-mono focus:outline-none focus:border-primary" placeholder="hr_q1" />
          </div>
          <div>
            <label class="text-xs font-semibold text-on-surface-variant block mb-1">Loại *</label>
            <select name="type" required class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary">
              <option value="textarea">textarea</option>
              <option value="select" selected>select (1-5)</option>
              <option value="radio">radio</option>
              <option value="yesno">yesno</option>
            </select>
          </div>
          <div>
            <label class="text-xs font-semibold text-on-surface-variant block mb-1">Dimension</label>
            <input type="text" name="dimension" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface font-mono focus:outline-none focus:border-primary" placeholder="operations" />
          </div>
        </div>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Label (VI) *</label>
          <textarea name="label_vi" required rows="2" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary"></textarea>
        </div>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Label (EN)</label>
          <textarea name="label_en" rows="2" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary"></textarea>
        </div>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Placeholder (VI)</label>
          <input type="text" name="placeholder_vi" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Options (VI) — mỗi dòng 1 option (chỉ cho radio)</label>
          <textarea name="options_vi_text" rows="3" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary" placeholder="Đứng vững giá trị&#10;Cân bằng lợi ích&#10;Đang học cách cân bằng"></textarea>
        </div>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Scale labels (VI) — JSON (chỉ cho select)</label>
          <textarea name="scale_labels_vi_text" rows="3" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface font-mono text-xs focus:outline-none focus:border-primary" placeholder='{"1":"Chưa có","5":"Đầu tàu"}'></textarea>
        </div>
        <div class="flex items-center gap-6">
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" name="required" value="1" class="w-4 h-4 rounded" />
            <span class="text-sm text-on-surface">Required</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" name="anchor" value="1" class="w-4 h-4 rounded" />
            <span class="text-sm text-on-surface">⭐ Anchor</span>
          </label>
        </div>
        <p id="question-form-error" class="text-sm text-red-400 hidden"></p>
        <div class="flex justify-end gap-2 pt-2">
          <button type="button" id="question-modal-cancel" class="px-4 py-2.5 rounded-xl text-sm font-semibold text-on-surface-variant hover:bg-surface-container">Huỷ</button>
          <button type="submit" class="bg-primary-container text-white px-5 py-2.5 rounded-xl font-bold text-sm cyan-glow hover:opacity-90 active:scale-95 transition-all">Lưu</button>
        </div>
      </form>
    </div>
  </div>
  </div>
</AdminLayout>

<script src="/scripts/scanner-edit-client.js" is:inline></script>