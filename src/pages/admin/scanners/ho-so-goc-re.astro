---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';
import { getSurveyDefinitionFull, parseScoringRules, parseAiConfig } from '../../../lib/survey-config-db';

export const prerender = false;

let full = null;
let loadError = '';

try {
  full = await getSurveyDefinitionFull(env.DB, 'ho-so-goc-re');
} catch (err) {
  loadError = err instanceof Error ? err.message : 'Lỗi tải dữ liệu';
}

if (!full && !loadError) {
  return Astro.redirect('/admin/scanners');
}

const def = full.definition;
const sections = full.sections;
const scoringRules = parseScoringRules(def.scoring_rules);
const aiConfig = parseAiConfig(def.ai_config);

// Build dimension map from sections
const dimMap: Record<string, { name: string; color: string; bgColor: string; icon: string; ref: string; qCount: number; scored: number }> = {
  roots:  { name: 'ROOTS',        color: 'text-amber-400',   bgColor: 'bg-amber-500/10',   borderColor: 'border-amber-500/30',   icon: 'park',     ref: 'Ch.26 — R.O.A.D.M.A.P', qCount: 0, scored: 0 },
  sky:    { name: 'SKY',          color: 'text-sky-400',    bgColor: 'bg-sky-500/10',    borderColor: 'border-sky-500/30',    icon: 'wb_sunny', ref: 'Ch.24 — TO BE SKY',      qCount: 0, scored: 0 },
  stars:  { name: 'S.T.A.R.S',    color: 'text-purple-400', bgColor: 'bg-purple-500/10', borderColor: 'border-purple-500/30', icon: 'stars',    ref: 'Ch.25 — S.T.A.R.S',       qCount: 0, scored: 0 },
  living: { name: 'Hệ thống sống', color: 'text-emerald-400', bgColor: 'bg-emerald-500/10', borderColor: 'border-emerald-500/30', icon: 'eco',      ref: 'Ch.22 — Hệ Thống Sống',  qCount: 0, scored: 0 },
};

for (const section of sections) {
  // Derive dimension from section ref (sections don't have a dimension field)
  const ref = section.ref || '';
  const dim = ref.includes('26') || ref.includes('ROOTS') || ref.includes('R.O.A.D') ? 'roots'
    : ref.includes('24') || ref.includes('SKY') ? 'sky'
    : ref.includes('25') || ref.includes('S.T.A.R.S') || ref.includes('STARS') ? 'stars'
    : ref.includes('22') || ref.includes('Hệ Thống') || ref.includes('Sống') ? 'living'
    : null;
  if (dim && dimMap[dim]) {
    dimMap[dim].qCount += section.questions.length;
    dimMap[dim].scored += section.questions.filter((q: any) => q.type === 'select' || q.type === 'yesno').length;
  }
}

const totalQuestions = sections.reduce((acc, s) => acc + s.questions.length, 0);
const totalAnchors = sections.reduce((acc, s) => acc + s.questions.filter(q => q.anchor === 1).length, 0);

const aiConfigJson = JSON.stringify(aiConfig, null, 2);
const scoringRulesJson = JSON.stringify(scoringRules, null, 2);
const thresholdEntries = Object.entries(scoringRules.thresholds as Record<string, number>);

const statusConfig: Record<string, { label: string; cls: string }> = {
  draft:   { label: 'Bản nháp',     cls: 'bg-surface-container border border-outline-variant/30 text-on-surface-variant' },
  active:  { label: 'Đang hoạt động', cls: 'bg-emerald-500/15 border border-emerald-500/30 text-emerald-400' },
  archived: { label: 'Lưu trữ',     cls: 'bg-surface-container border border-outline-variant/30 text-on-surface-variant/60' },
};
const status = statusConfig[def.status] || statusConfig.draft;
---

<AdminLayout title="Hồ Sơ Gốc Rễ | Admin">
  <div data-def-id="ho-so-goc-re">

  {loadError && (
    <div class="glass-card rounded-2xl p-6 border border-red-500/30">
      <p class="text-red-300 font-semibold">Lỗi tải dữ liệu</p>
      <p class="text-sm text-on-surface-variant mt-1">{loadError}</p>
    </div>
  )}

  {def && (
    <>

    <!-- ═══════════════════════════════════════
         HERO HEADER — Scanner Identity
    ═══════════════════════════════════════ -->
    <header class="relative overflow-hidden">
      <!-- Background texture -->
      <div class="absolute inset-0 opacity-5">
        <div class="absolute inset-0" style="background-image: repeating-linear-gradient(45deg, transparent, transparent 35px, rgba(146,204,255,0.1) 35px, rgba(146,204,255,0.1) 70px);"></div>
      </div>
      <!-- Gradient overlay -->
      <div class="absolute inset-0 bg-gradient-to-br from-amber-900/20 via-transparent to-sky-900/20"></div>

      <div class="relative glass-card rounded-2xl p-6 md:p-8 mb-6">
        <div class="flex flex-col md:flex-row md:items-start gap-4 md:gap-6">
          <!-- Left: Identity -->
          <div class="flex items-start gap-4 flex-1 min-w-0">
            <a href="/admin/scanners" class="p-2 rounded-lg hover:bg-surface-container text-on-surface-variant hover:text-on-surface transition-colors shrink-0 mt-0.5" title="Quay lại">
              <span class="material-symbols-outlined text-xl">arrow_back</span>
            </a>
            <div class="min-w-0 flex-1">
              <!-- Tags row -->
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="inline-flex items-center gap-1.5 text-xs font-bold px-2.5 py-1 rounded-full bg-amber-500/20 text-amber-300 border border-amber-500/30">
                  <span class="material-symbols-outlined text-[14px]">park</span>
                  Hồ Sơ Gốc Rễ
                </span>
                <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${status.cls}`}>{status.label}</span>
                <span class="text-xs font-mono text-on-surface-variant/60 px-1">ho-so-goc-re</span>
              </div>

              <!-- Title -->
              <h1 class="text-2xl md:text-3xl font-bold text-on-surface mb-1">
                {def.title_vi}
              </h1>
              <p class="text-sm text-on-surface-variant mb-3">{def.subtitle_vi || def.title_en}</p>

              <!-- Chapter refs -->
              <div class="flex flex-wrap gap-2">
                {['Ch.22', 'Ch.24', 'Ch.25', 'Ch.26'].map(ch => (
                  <span class="text-[11px] font-mono px-2 py-0.5 rounded-md bg-surface-container border border-outline-variant/20 text-on-surface-variant/70">
                    {ch}
                  </span>
                ))}
              </div>
            </div>
          </div>

          <!-- Right: Quick stats + actions -->
          <div class="flex flex-row md:flex-col gap-2 shrink-0 md:items-end">
            <div class="flex gap-2 md:justify-end">
              <a href={`/scanner/${def.slug}`} target="_blank" class="flex items-center gap-1.5 bg-surface-container border border-outline-variant/30 text-on-surface px-3 py-2 rounded-xl text-sm font-semibold hover:bg-surface-container-high transition-colors">
                <span class="material-symbols-outlined text-[16px]">visibility</span>
                <span class="hidden sm:inline">Xem</span>
              </a>
              <a href="/admin/scanners/ho-so-goc-re/edit" class="flex items-center gap-1.5 bg-surface-container border border-outline-variant/30 text-on-surface px-3 py-2 rounded-xl text-sm font-semibold hover:bg-surface-container-high transition-colors">
                <span class="material-symbols-outlined text-[16px]">edit</span>
                <span class="hidden sm:inline">Edit</span>
              </a>
              <a href={`/admin/scanners/ho-so-goc-re/responses`} class="flex items-center gap-1.5 bg-primary-container text-white px-3 py-2 rounded-xl text-sm font-bold cyan-glow hover:opacity-90 active:scale-95 transition-all">
                <span class="material-symbols-outlined text-[16px]">list_alt</span>
                Responses
              </a>
            </div>
          </div>
        </div>

        <!-- Stats bar -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mt-5 pt-5 border-t border-outline-variant/15">
          <div class="flex items-center gap-2.5">
            <div class="w-8 h-8 rounded-lg bg-amber-500/15 flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-[16px] text-amber-400">layers</span>
            </div>
            <div>
              <p class="text-xs text-on-surface-variant">Sections</p>
              <p class="text-base font-bold text-on-surface">{sections.length}</p>
            </div>
          </div>
          <div class="flex items-center gap-2.5">
            <div class="w-8 h-8 rounded-lg bg-sky-500/15 flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-[16px] text-sky-400">help</span>
            </div>
            <div>
              <p class="text-xs text-on-surface-variant">Questions</p>
              <p class="text-base font-bold text-on-surface">{totalQuestions}</p>
            </div>
          </div>
          <div class="flex items-center gap-2.5">
            <div class="w-8 h-8 rounded-lg bg-amber-500/15 flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-[16px] text-amber-400">star</span>
            </div>
            <div>
              <p class="text-xs text-on-surface-variant">Anchor</p>
              <p class="text-base font-bold text-on-surface">{totalAnchors}</p>
            </div>
          </div>
          <div class="flex items-center gap-2.5">
            <div class="w-8 h-8 rounded-lg bg-purple-500/15 flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-[16px] text-purple-400">auto_awesome</span>
            </div>
            <div>
              <p class="text-xs text-on-surface-variant">AI Sections</p>
              <p class="text-base font-bold text-on-surface">{aiConfig.analysis_sections?.length || 9}</p>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- ═══════════════════════════════════════
         DIMENSIONS GRID
    ═══════════════════════════════════════ -->
    <section class="mb-6">
      <h2 class="text-sm font-bold uppercase tracking-wider text-on-surface-variant mb-3 flex items-center gap-2">
        <span class="material-symbols-outlined text-[16px]">hub</span>
        4 Dimensions — Scoring Framework
      </h2>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
        {Object.entries(dimMap).map(([dimId, dim]) => (
          <div class={`glass-card rounded-xl p-4 border ${dim.borderColor} ${dim.bgColor} transition-all hover:scale-[1.02] cursor-default`}>
            <div class="flex items-center gap-2 mb-3">
              <div class={`w-7 h-7 rounded-lg bg-black/20 flex items-center justify-center`}>
                <span class={`material-symbols-outlined text-[14px] ${dim.color}`}>{dim.icon}</span>
              </div>
              <span class={`text-sm font-bold ${dim.color}`}>{dim.name}</span>
            </div>
            <p class="text-[11px] font-mono text-on-surface-variant/70 mb-3">{dim.ref}</p>
            <div class="flex items-center justify-between text-xs text-on-surface-variant">
              <span>{dim.scored}/{dim.qCount} scored</span>
              <span class="font-semibold">{((dim.scored / dim.qCount) * 100).toFixed(0) || 0}%</span>
            </div>
            <div class="mt-1.5 h-1 rounded-full bg-surface-container overflow-hidden">
              <div class={`h-full rounded-full ${dim.color.replace('text-', 'bg-')}`} style={`width: ${(dim.scored / dim.qCount) * 100 || 0}%`}></div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         SECTIONS — Visual Card Layout
    ═══════════════════════════════════════ -->
    <section class="mb-6">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-bold uppercase tracking-wider text-on-surface-variant flex items-center gap-2">
          <span class="material-symbols-outlined text-[16px]">quiz</span>
          6 Sections &amp; Questions
        </h2>
        <button type="button" id="btn-add-section" class="bg-primary-container text-white px-3 py-1.5 rounded-lg text-xs font-bold cyan-glow hover:opacity-90 active:scale-95 transition-all flex items-center gap-1.5">
          <span class="material-symbols-outlined text-[14px]">add</span>
          Thêm section
        </button>
      </div>

      <div class="flex flex-col gap-4">
        {sections.map((section, idx) => {
          const dim = section.dimension;
          const dimInfo = dim && dimMap[dim];
          const anchorCount = section.questions.filter(q => q.anchor === 1).length;
          const scoredCount = section.questions.filter(q => q.type === 'select' || q.type === 'yesno').length;
          return (
            <div class="glass-card rounded-2xl border border-outline-variant/15 overflow-hidden group/section">
              <!-- Section header -->
              <div class={`flex items-center gap-3 p-4 border-b border-outline-variant/10 ${dimInfo ? dimInfo.bgColor : 'bg-surface-container/40'}`}>
                <!-- Section number -->
                <div class={`w-8 h-8 rounded-lg font-bold text-sm flex items-center justify-center shrink-0 ${
                  idx === 0 ? 'bg-amber-500/20 text-amber-400' :
                  idx === 1 ? 'bg-sky-500/20 text-sky-400' :
                  idx === 2 ? 'bg-purple-500/20 text-purple-400' :
                  idx === 3 ? 'bg-emerald-500/20 text-emerald-400' :
                  'bg-surface-container text-on-surface-variant'
                }`}>
                  {idx + 1}
                </div>

                <!-- Title & ref -->
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 flex-wrap">
                    <h3 class="text-sm font-bold text-on-surface truncate">{section.title_vi}</h3>
                    {section.ref && (
                      <span class="text-[11px] font-mono px-1.5 py-0.5 rounded bg-surface-container border border-outline-variant/20 text-on-surface-variant/70 shrink-0">
                        {section.ref}
                      </span>
                    )}
                    {dimInfo && (
                      <span class={`text-[11px] font-bold px-1.5 py-0.5 rounded shrink-0 ${dimInfo.bgColor} ${dimInfo.color}`}>
                        {dimInfo.name}
                      </span>
                    )}
                  </div>
                  {section.subtitle_vi && (
                    <p class="text-xs text-on-surface-variant mt-0.5 line-clamp-1">{section.subtitle_vi}</p>
                  )}
                </div>

                <!-- Stats -->
                <div class="flex items-center gap-3 shrink-0">
                  <div class="text-right hidden sm:block">
                    <p class="text-[11px] text-on-surface-variant">{section.questions.length} câu</p>
                    <p class="text-[11px] text-on-surface-variant/60">{scoredCount} scored · {anchorCount} ⭐</p>
                  </div>

                  <!-- Action buttons -->
                  <button type="button" class="btn-edit-section p-1.5 rounded-lg hover:bg-surface-container text-on-surface-variant hover:text-on-surface opacity-0 group-hover/section:opacity-100 transition-all" data-section-id={section.id} title="Sửa section">
                    <span class="material-symbols-outlined text-[16px]">edit</span>
                  </button>
                  <button type="button" class="btn-delete-section p-1.5 rounded-lg hover:bg-red-500/20 text-on-surface-variant hover:text-red-400 opacity-0 group-hover/section:opacity-100 transition-all" data-section-id={section.id} data-name={section.title_vi} title="Xóa section">
                    <span class="material-symbols-outlined text-[16px]">delete</span>
                  </button>
                </div>
              </div>

              <!-- Questions list -->
              {section.questions.length > 0 ? (
                <div class="p-3 flex flex-col gap-1.5">
                  {section.questions.map((q, qIdx) => (
                    <div class="flex items-start gap-3 p-2 rounded-lg hover:bg-surface-container/50 transition-colors group/question">
                      <span class="text-[11px] font-mono text-on-surface-variant/50 w-4 pt-1 shrink-0 text-right">{qIdx + 1}</span>

                      <!-- Type badge -->
                      <div class={`shrink-0 mt-0.5 ${
                        q.type === 'select' ? 'text-sky-400' :
                        q.type === 'textarea' ? 'text-amber-400' :
                        q.type === 'radio' ? 'text-purple-400' :
                        'text-emerald-400'
                      }`}>
                        <span class="material-symbols-outlined text-[14px]">{
                          q.type === 'select' ? 'radio_button_checked' :
                          q.type === 'textarea' ? 'notes' :
                          q.type === 'radio' ? 'check_circle' :
                          'toggle_on'
                        }</span>
                      </div>

                      <!-- Question content -->
                      <div class="flex-1 min-w-0">
                        <p class="text-xs text-on-surface leading-snug">{q.label_vi}</p>
                        <p class="text-[10px] font-mono text-on-surface-variant/60 mt-0.5 flex flex-wrap gap-x-3 gap-y-0.5">
                          <span>{q.question_id}</span>
                          <span class={q.dimension && dimInfo ? dimInfo.color : ''}>{q.dimension ? `dim=${q.dimension}` : 'no-dim'}</span>
                          {q.required === 1 && <span class="text-red-400/70">required</span>}
                          {q.anchor === 1 && <span class="text-amber-400/70">⭐ anchor</span>}
                        </p>
                      </div>

                      <!-- Question actions -->
                      <div class="flex items-center gap-0.5 shrink-0 opacity-0 group-hover/question:opacity-100 transition-all">
                        <button type="button" class="btn-edit-question p-1 rounded hover:bg-surface-container text-on-surface-variant hover:text-on-surface" data-question-id={q.id} data-section-id={section.id} title="Sửa">
                          <span class="material-symbols-outlined text-[14px]">edit</span>
                        </button>
                        <button type="button" class="btn-delete-question p-1 rounded hover:bg-red-500/20 text-on-surface-variant hover:text-red-400" data-question-id={q.id} data-label={q.label_vi} title="Xóa">
                          <span class="material-symbols-outlined text-[14px]">delete</span>
                        </button>
                      </div>
                    </div>
                  ))}

                  <!-- Add question button -->
                  <button type="button" class="btn-add-question w-full mt-1 px-3 py-2 bg-surface-container/50 border border-dashed border-outline-variant/30 hover:border-primary rounded-lg text-xs font-semibold text-on-surface-variant hover:text-primary flex items-center justify-center gap-1.5 transition-colors" data-section-id={section.id}>
                    <span class="material-symbols-outlined text-[14px]">add</span>
                    Thêm câu hỏi
                  </button>
                </div>
              ) : (
                <div class="p-4 text-center">
                  <button type="button" class="btn-add-question px-4 py-2 bg-surface-container border border-outline-variant/30 hover:border-primary rounded-lg text-sm font-semibold text-on-surface-variant hover:text-primary flex items-center gap-1.5 mx-auto transition-colors" data-section-id={section.id}>
                    <span class="material-symbols-outlined text-[14px]">add</span>
                    Thêm câu hỏi đầu tiên
                  </button>
                </div>
              )}
            </div>
          );
        })}
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         AI CONFIG — Structured Editor
    ═══════════════════════════════════════ -->
    <section class="mb-6">
      <h2 class="text-sm font-bold uppercase tracking-wider text-on-surface-variant mb-3 flex items-center gap-2">
        <span class="material-symbols-outlined text-[16px]">psychology</span>
        AI Configuration — Dr. Vinh Persona
      </h2>

      <div class="glass-card rounded-2xl border border-outline-variant/15 overflow-hidden">
        <!-- AI sections preview -->
        <div class="p-4 border-b border-outline-variant/10 bg-surface-container/20">
          <p class="text-xs text-on-surface-variant mb-3">Analysis Sections — {scoringRules.dimensions.length} Dimensions</p>
          <div class="flex flex-wrap gap-2">
            {scoringRules.dimensions.map((dim: any) => (
              <div class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[11px] font-semibold border ${
                dim.id === 'roots' ? 'bg-amber-500/10 border-amber-500/30 text-amber-300' :
                dim.id === 'sky' ? 'bg-sky-500/10 border-sky-500/30 text-sky-300' :
                dim.id === 'stars' ? 'bg-purple-500/10 border-purple-500/30 text-purple-300' :
                'bg-emerald-500/10 border-emerald-500/30 text-emerald-300'
              }`}>
                <span class="material-symbols-outlined text-[10px]">circle</span>
                {dim.name_vi}
                <span class="opacity-60">({dim.question_ids.length}q)</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Tabs -->
        <div class="flex border-b border-outline-variant/10">
          <button type="button" class="ai-tab-btn px-4 py-2.5 text-xs font-bold border-b-2 border-primary text-primary transition-colors" data-tab="overview">Tổng quan</button>
          <button type="button" class="ai-tab-btn px-4 py-2.5 text-xs font-bold border-b-2 border-transparent text-on-surface-variant hover:text-on-surface transition-colors" data-tab="prompts">Prompts VI/EN</button>
          <button type="button" class="ai-tab-btn px-4 py-2.5 text-xs font-bold border-b-2 border-transparent text-on-surface-variant hover:text-on-surface transition-colors" data-tab="raw">Raw JSON</button>
        </div>

        <!-- Tab: Overview -->
        <div data-ai-tab="overview" class="ai-tab-panel p-4">
          <div class="grid grid-cols-2 gap-3">
            <div class="bg-surface-container/40 rounded-xl p-3 border border-outline-variant/10">
              <p class="text-[11px] text-on-surface-variant mb-1">Model</p>
              <p class="text-sm font-mono text-on-surface">{aiConfig.model_override || 'claude-sonnet-4-6'}</p>
            </div>
            <div class="bg-surface-container/40 rounded-xl p-3 border border-outline-variant/10">
              <p class="text-[11px] text-on-surface-variant mb-1">Max Tokens</p>
              <p class="text-sm font-mono text-on-surface">{aiConfig.max_tokens_override || 4096}</p>
            </div>
          </div>
          {aiConfig.analysis_sections && (
            <div class="mt-3">
              <p class="text-[11px] text-on-surface-variant mb-2">Analysis Output Structure</p>
              <div class="flex flex-col gap-1.5">
                {aiConfig.analysis_sections.map((s, i) => (
                  <div class="flex items-center gap-3 p-2 rounded-lg bg-surface-container/30 border border-outline-variant/10">
                    <span class="text-[10px] font-mono text-on-surface-variant/50 w-4 text-right">{i + 1}</span>
                    <span class="text-xs font-semibold text-on-surface">{s.title_vi}</span>
                    <span class="text-[10px] font-mono text-on-surface-variant/60 ml-auto">{s.id}</span>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- Tab: Prompts -->
        <div data-ai-tab="prompts" class="ai-tab-panel hidden p-4">
          <div class="mb-3">
            <label class="text-[11px] font-semibold text-on-surface-variant block mb-1">System Prompt (VI) — first 500 chars</label>
            <div class="bg-surface-container/40 rounded-xl p-3 border border-outline-variant/10">
              <p class="text-xs font-mono text-on-surface-variant/80 leading-relaxed whitespace-pre-wrap line-clamp-6">{aiConfig.prompt_vi?.slice(0, 500)}...</p>
            </div>
          </div>
          <div>
            <label class="text-[11px] font-semibold text-on-surface-variant block mb-1">System Prompt (EN) — first 500 chars</label>
            <div class="bg-surface-container/40 rounded-xl p-3 border border-outline-variant/10">
              <p class="text-xs font-mono text-on-surface-variant/80 leading-relaxed whitespace-pre-wrap line-clamp-6">{aiConfig.prompt_en?.slice(0, 500)}...</p>
            </div>
          </div>
        </div>

        <!-- Tab: Raw JSON -->
        <div data-ai-tab="raw" class="ai-tab-panel hidden">
          <form id="form-ai" class="p-4 flex flex-col gap-3">
            <div>
              <label class="text-xs font-semibold text-on-surface-variant block mb-1">AI Config JSON</label>
              <textarea name="ai_config" rows="20" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-3 text-on-surface font-mono text-xs focus:outline-none focus:border-primary">{aiConfigJson}</textarea>
            </div>
            <p id="ai-error" class="text-sm text-red-400 hidden"></p>
            <div class="flex justify-end">
              <button type="submit" class="bg-primary-container text-white px-5 py-2.5 rounded-xl font-bold text-sm cyan-glow hover:opacity-90 active:scale-95 transition-all">Lưu AI Config</button>
            </div>
          </form>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         SCORING RULES — Structured
    ═══════════════════════════════════════ -->
    <section class="mb-6">
      <h2 class="text-sm font-bold uppercase tracking-wider text-on-surface-variant mb-3 flex items-center gap-2">
        <span class="material-symbols-outlined text-[16px]">speed</span>
        Scoring Rules
      </h2>

      <div class="glass-card rounded-2xl border border-outline-variant/15 overflow-hidden">
        <!-- Thresholds -->
        <div class="p-4 border-b border-outline-variant/10 bg-surface-container/20">
          <p class="text-[11px] text-on-surface-variant mb-2">Score Thresholds</p>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
            {thresholdEntries.map(([key, val]) => (
              <div class="bg-surface-container/40 rounded-lg p-2 border border-outline-variant/10">
                <p class="text-[10px] text-on-surface-variant/70 capitalize">{key}</p>
                <p class="text-sm font-bold text-on-surface">{val}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Tabs -->
        <div class="flex border-b border-outline-variant/10">
          <button type="button" class="scoring-tab-btn px-4 py-2.5 text-xs font-bold border-b-2 border-primary text-primary transition-colors" data-tab="overview">Dimensions</button>
          <button type="button" class="scoring-tab-btn px-4 py-2.5 text-xs font-bold border-b-2 border-transparent text-on-surface-variant hover:text-on-surface transition-colors" data-tab="raw">Raw JSON</button>
        </div>

        <!-- Tab: Dimensions overview -->
        <div data-scoring-tab="overview" class="scoring-tab-panel p-4">
          <div class="flex flex-col gap-3">
            {scoringRules.dimensions.map((dim: any) => {
              const dimColor = dim.id === 'roots' ? 'text-amber-400' : dim.id === 'sky' ? 'text-sky-400' : dim.id === 'stars' ? 'text-purple-400' : 'text-emerald-400';
              return (
                <div class="bg-surface-container/30 rounded-xl p-3 border border-outline-variant/10">
                  <div class="flex items-center gap-2 mb-2">
                    <span class={`text-sm font-bold ${dimColor}`}>{dim.name_vi}</span>
                    <span class="text-[11px] font-mono text-on-surface-variant/60">({dim.formula})</span>
                    <span class="text-[11px] px-1.5 py-0.5 rounded bg-surface-container text-on-surface-variant/70 ml-auto">{dim.question_ids.length} questions</span>
                  </div>
                  <div class="flex flex-wrap gap-1.5">
                    {dim.question_ids.map((qid: string) => (
                      <span class="text-[10px] font-mono px-1.5 py-0.5 rounded bg-surface-container border border-outline-variant/20 text-on-surface-variant/80">{qid}</span>
                    ))}
                  </div>
                </div>
              );
            })}
          </div>
        </div>

        <!-- Tab: Raw JSON -->
        <div data-scoring-tab="raw" class="scoring-tab-panel hidden">
          <form id="form-scoring" class="p-4 flex flex-col gap-3">
            <div>
              <label class="text-xs font-semibold text-on-surface-variant block mb-1">Scoring Rules JSON</label>
              <textarea name="scoring_rules" rows="14" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-3 text-on-surface font-mono text-xs focus:outline-none focus:border-primary">{scoringRulesJson}</textarea>
            </div>
            <p id="scoring-error" class="text-sm text-red-400 hidden"></p>
            <div class="flex justify-end">
              <button type="submit" class="bg-primary-container text-white px-5 py-2.5 rounded-xl font-bold text-sm cyan-glow hover:opacity-90 active:scale-95 transition-all">Lưu Scoring Rules</button>
            </div>
          </form>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         BASIC INFO — Collapsed
    ═══════════════════════════════════════ -->
    <section class="mb-6">
      <h2 class="text-sm font-bold uppercase tracking-wider text-on-surface-variant mb-3 flex items-center gap-2">
        <span class="material-symbols-outlined text-[16px]">settings</span>
        Basic Info
      </h2>
      <div class="glass-card rounded-2xl border border-outline-variant/15 overflow-hidden">
        <div class="flex border-b border-outline-variant/10">
          <button type="button" class="info-tab-btn px-4 py-2.5 text-xs font-bold border-b-2 border-primary text-primary transition-colors" data-tab="view">View</button>
          <button type="button" class="info-tab-btn px-4 py-2.5 text-xs font-bold border-b-2 border-transparent text-on-surface-variant hover:text-on-surface transition-colors" data-tab="edit">Edit</button>
        </div>

        <div data-info-tab="view" class="info-tab-panel p-4">
          <div class="grid grid-cols-2 gap-3 text-xs">
            <div><span class="text-on-surface-variant/60">Slug:</span> <span class="font-mono text-on-surface">{def.slug}</span></div>
            <div><span class="text-on-surface-variant/60">Type:</span> <span class="text-on-surface">{def.survey_type}</span></div>
            <div><span class="text-on-surface-variant/60">Status:</span> <span class={`px-1.5 py-0.5 rounded text-[10px] font-bold ${status.cls}`}>{status.label}</span></div>
            <div><span class="text-on-surface-variant/60">AI Free:</span> <span class="text-on-surface">{def.is_free === 1 ? 'Yes' : 'No'}</span></div>
          </div>
          {def.description_vi && <p class="text-xs text-on-surface-variant mt-3 leading-relaxed">{def.description_vi}</p>}
        </div>

        <div data-info-tab="edit" class="info-tab-panel hidden">
          <form id="form-info" class="p-4 flex flex-col gap-3">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div>
                <label class="text-xs font-semibold text-on-surface-variant block mb-1">Tiêu đề (VI) *</label>
                <input type="text" name="title_vi" required value={def.title_vi} class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface text-sm focus:outline-none focus:border-primary" />
              </div>
              <div>
                <label class="text-xs font-semibold text-on-surface-variant block mb-1">Tiêu đề (EN)</label>
                <input type="text" name="title_en" value={def.title_en || ''} class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface text-sm focus:outline-none focus:border-primary" />
              </div>
              <div>
                <label class="text-xs font-semibold text-on-surface-variant block mb-1">Slug</label>
                <input type="text" name="slug" value={def.slug} class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface font-mono text-sm focus:outline-none focus:border-primary" />
              </div>
              <div>
                <label class="text-xs font-semibold text-on-surface-variant block mb-1">Status</label>
                <select name="status" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface text-sm focus:outline-none focus:border-primary">
                  <option value="draft" selected={def.status === 'draft'}>Bản nháp</option>
                  <option value="active" selected={def.status === 'active'}>Đang hoạt động</option>
                  <option value="archived" selected={def.status === 'archived'}>Lưu trữ</option>
                </select>
              </div>
              <div>
                <label class="text-xs font-semibold text-on-surface-variant block mb-1">Loại</label>
                <select name="survey_type" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface text-sm focus:outline-none focus:border-primary">
                  <option value="full" selected={def.survey_type === 'full'}>Full</option>
                  <option value="mini" selected={def.survey_type === 'mini'}>Mini</option>
                  <option value="checklist" selected={def.survey_type === 'checklist'}>Checklist</option>
                </select>
              </div>
              <div class="flex items-center gap-2 pt-5">
                <input type="checkbox" name="is_free" id="is_free_check" value="1" checked={def.is_free === 1} class="w-4 h-4 rounded" />
                <label for="is_free_check" class="text-sm text-on-surface">AI free (không cần trả phí)</label>
              </div>
            </div>
            <div>
              <label class="text-xs font-semibold text-on-surface-variant block mb-1">Mô tả (VI)</label>
              <textarea name="description_vi" rows="2" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface text-sm focus:outline-none focus:border-primary">{def.description_vi || ''}</textarea>
            </div>
            <p id="info-error" class="text-sm text-red-400 hidden"></p>
            <div class="flex justify-end">
              <button type="submit" class="bg-primary-container text-white px-5 py-2.5 rounded-xl font-bold text-sm cyan-glow hover:opacity-90 active:scale-95 transition-all">Lưu thông tin</button>
            </div>
          </form>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         MODALS (reuse existing markup)
    ═══════════════════════════════════════ -->

    <!-- Section modal -->
    <div id="section-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4">
      <div id="section-modal-backdrop" class="absolute inset-0 bg-black/0 transition-colors"></div>
      <div id="section-modal-panel" class="relative glass-card rounded-2xl p-6 w-full max-w-lg max-h-[90vh] overflow-y-auto scrollbar-hide scale-95 opacity-0 transition-all">
        <div class="flex items-center justify-between mb-6">
          <h3 class="text-xl font-bold text-on-surface" id="section-modal-title">Thêm section</h3>
          <button type="button" id="section-modal-close" class="p-2 rounded-lg hover:bg-surface-container text-on-surface-variant">
            <span class="material-symbols-outlined text-[20px]">close</span>
          </button>
        </div>
        <form id="section-form" class="flex flex-col gap-4">
          <input type="hidden" name="id" id="section-form-id" />
          <div>
            <label class="text-xs font-semibold text-on-surface-variant block mb-1">Tiêu đề (VI) *</label>
            <input type="text" name="title_vi" required class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="text-xs font-semibold text-on-surface-variant block mb-1">Tiêu đề (EN)</label>
            <input type="text" name="title_en" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="text-xs font-semibold text-on-surface-variant block mb-1">Subtitle (VI)</label>
            <input type="text" name="subtitle_vi" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="text-xs font-semibold text-on-surface-variant block mb-1">Reference (vd: Ch.26 — ROOTS)</label>
            <input type="text" name="ref" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface font-mono focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="text-xs font-semibold text-on-surface-variant block mb-1">Icon (Material Symbol)</label>
            <input type="text" name="icon" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface font-mono focus:outline-none focus:border-primary" placeholder="park" />
          </div>
          <p id="section-form-error" class="text-sm text-red-400 hidden"></p>
          <div class="flex justify-end gap-2 pt-2">
            <button type="button" id="section-modal-cancel" class="px-4 py-2.5 rounded-xl text-sm font-semibold text-on-surface-variant hover:bg-surface-container">Huỷ</button>
            <button type="submit" class="bg-primary-container text-white px-5 py-2.5 rounded-xl font-bold text-sm cyan-glow hover:opacity-90 active:scale-95 transition-all">Lưu</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Question modal -->
    <div id="question-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4">
      <div id="question-modal-backdrop" class="absolute inset-0 bg-black/0 transition-colors"></div>
      <div id="question-modal-panel" class="relative glass-card rounded-2xl p-6 w-full max-w-5xl max-h-[90vh] overflow-y-auto scrollbar-hide scale-95 opacity-0 transition-all">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-xl font-bold text-on-surface" id="question-modal-title">Thêm câu hỏi</h3>
          <button type="button" id="question-modal-close" class="p-2 rounded-lg hover:bg-surface-container text-on-surface-variant">
            <span class="material-symbols-outlined text-[20px]">close</span>
          </button>
        </div>
        <form id="question-form" class="flex flex-col lg:flex-row gap-6">
          <div class="flex-1 flex flex-col gap-4 min-w-0">
            <input type="hidden" name="id" id="question-form-id" />
            <input type="hidden" name="section_id" id="question-form-section-id" />

            <div class="grid grid-cols-1 sm:grid-cols-12 gap-3">
              <div class="sm:col-span-5">
                <label class="text-xs font-semibold text-on-surface-variant block mb-1">question_id *</label>
                <input type="text" name="question_id" required pattern="[a-z0-9_]+" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface font-mono text-sm focus:outline-none focus:border-primary transition-shadow" placeholder="hr_q1" />
                <p class="text-[10px] text-on-surface-variant/70 mt-1">Tự sinh từ Label VI — chỉ chữ thường, số, gạch dưới</p>
              </div>
              <div class="sm:col-span-4">
                <label class="text-xs font-semibold text-on-surface-variant block mb-1">Loại *</label>
                <select name="type" required class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary">
                  <option value="select" selected>select (1-5 scale)</option>
                  <option value="textarea">textarea (mở)</option>
                  <option value="radio">radio (chọn 1)</option>
                  <option value="yesno">yesno (Có/Không)</option>
                </select>
              </div>
              <div class="sm:col-span-3">
                <label class="text-xs font-semibold text-on-surface-variant block mb-1">Dimension</label>
                <input type="text" name="dimension" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface font-mono text-sm focus:outline-none focus:border-primary" placeholder="roots" />
              </div>
            </div>

            <div class="flex gap-1 border-b border-outline-variant/15 -mb-px">
              <button type="button" class="q-tab-btn px-3 py-2 text-xs font-semibold border-b-2 border-primary text-primary transition-colors" data-q-tab="vi">VI</button>
              <button type="button" class="q-tab-btn px-3 py-2 text-xs font-semibold border-b-2 border-transparent text-on-surface-variant hover:text-on-surface transition-colors" data-q-tab="en">EN</button>
            </div>

            <div data-q-tab-panel="vi" class="q-tab-panel flex flex-col gap-3">
              <div>
                <label class="text-xs font-semibold text-on-surface-variant block mb-1">Label (VI) *</label>
                <textarea name="label_vi" required rows="2" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary" placeholder="Câu hỏi của bạn..."></textarea>
              </div>
              <div>
                <label class="text-xs font-semibold text-on-surface-variant block mb-1">Placeholder (VI)</label>
                <input type="text" name="placeholder_vi" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface text-sm focus:outline-none focus:border-primary" />
              </div>
              <div id="q-field-options" class="hidden">
                <label class="text-xs font-semibold text-on-surface-variant block mb-1">Options (VI)</label>
                <textarea name="options_vi_text" rows="4" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface text-sm focus:outline-none focus:border-primary" placeholder="Lựa chọn A&#10;Lựa chọn B&#10;Lựa chọn C"></textarea>
              </div>
              <div id="q-field-scale">
                <div class="flex items-center justify-between mb-2">
                  <label class="text-xs font-semibold text-on-surface-variant">Scale labels (VI)</label>
                  <div class="flex gap-1">
                    <button type="button" class="q-scale-template text-[10px] px-2 py-0.5 rounded bg-surface-container border border-outline-variant hover:border-primary text-on-surface" data-template='{"1":"Chưa có","2":"Đang bắt đầu","3":"Đã có","4":"Ổn định","5":"Đầu tàu"}'>Mặc định</button>
                    <button type="button" class="q-scale-template text-[10px] px-2 py-0.5 rounded bg-surface-container border border-outline-variant hover:border-primary text-on-surface" data-template='{"1":"Hoàn toàn không","5":"Hoàn toàn đồng ý"}'>Likert</button>
                  </div>
                </div>
                <div class="flex gap-2">
                  <div class="flex flex-col items-center gap-1 flex-1 min-w-0">
                    <span class="text-[10px] font-bold text-on-surface-variant bg-surface-container-high px-1.5 py-0.5 rounded">1</span>
                    <input type="text" name="scale_1" class="w-full bg-surface-container border border-outline-variant rounded-lg px-2 py-1.5 text-on-surface text-xs text-center focus:outline-none focus:border-primary placeholder:text-on-surface-variant/40 placeholder:text-[10px]" placeholder="Mức 1" />
                  </div>
                  <div class="flex flex-col items-center gap-1 flex-1 min-w-0">
                    <span class="text-[10px] font-bold text-on-surface-variant bg-surface-container-high px-1.5 py-0.5 rounded">2</span>
                    <input type="text" name="scale_2" class="w-full bg-surface-container border border-outline-variant rounded-lg px-2 py-1.5 text-on-surface text-xs text-center focus:outline-none focus:border-primary placeholder:text-on-surface-variant/40 placeholder:text-[10px]" placeholder="Mức 2" />
                  </div>
                  <div class="flex flex-col items-center gap-1 flex-1 min-w-0">
                    <span class="text-[10px] font-bold text-on-surface-variant bg-surface-container-high px-1.5 py-0.5 rounded">3</span>
                    <input type="text" name="scale_3" class="w-full bg-surface-container border border-outline-variant rounded-lg px-2 py-1.5 text-on-surface text-xs text-center focus:outline-none focus:border-primary placeholder:text-on-surface-variant/40 placeholder:text-[10px]" placeholder="Mức 3" />
                  </div>
                  <div class="flex flex-col items-center gap-1 flex-1 min-w-0">
                    <span class="text-[10px] font-bold text-on-surface-variant bg-surface-container-high px-1.5 py-0.5 rounded">4</span>
                    <input type="text" name="scale_4" class="w-full bg-surface-container border border-outline-variant rounded-lg px-2 py-1.5 text-on-surface text-xs text-center focus:outline-none focus:border-primary placeholder:text-on-surface-variant/40 placeholder:text-[10px]" placeholder="Mức 4" />
                  </div>
                  <div class="flex flex-col items-center gap-1 flex-1 min-w-0">
                    <span class="text-[10px] font-bold text-on-surface-variant bg-surface-container-high px-1.5 py-0.5 rounded">5</span>
                    <input type="text" name="scale_5" class="w-full bg-surface-container border border-outline-variant rounded-lg px-2 py-1.5 text-on-surface text-xs text-center focus:outline-none focus:border-primary placeholder:text-on-surface-variant/40 placeholder:text-[10px]" placeholder="Mức 5" />
                  </div>
                </div>
                <input type="hidden" name="scale_labels_vi_text" />
              </div>
            </div>

            <div data-q-tab-panel="en" class="q-tab-panel hidden flex flex-col gap-3">
              <div>
                <label class="text-xs font-semibold text-on-surface-variant block mb-1">Label (EN)</label>
                <textarea name="label_en" rows="2" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary" placeholder="Your question..."></textarea>
              </div>
              <div>
                <label class="text-xs font-semibold text-on-surface-variant block mb-1">Placeholder (EN)</label>
                <input type="text" name="placeholder_en" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface text-sm focus:outline-none focus:border-primary" />
              </div>
            </div>

            <div class="flex items-center gap-6 pt-2 border-t border-outline-variant/10">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" name="required" value="1" class="w-4 h-4 rounded accent-primary" />
                <span class="text-sm text-on-surface">Required</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" name="anchor" value="1" class="w-4 h-4 rounded accent-amber-500" />
                <span class="text-sm text-on-surface">⭐ Anchor</span>
              </label>
            </div>

            <p id="question-form-error" class="text-sm text-red-400 hidden bg-red-500/10 border border-red-500/30 rounded-lg p-2"></p>
            <div class="flex justify-end gap-2 pt-2">
              <button type="button" id="question-modal-cancel" class="px-4 py-2.5 rounded-xl text-sm font-semibold text-on-surface-variant hover:bg-surface-container">Huỷ</button>
              <button type="submit" class="bg-primary-container text-white px-5 py-2.5 rounded-xl font-bold text-sm cyan-glow hover:opacity-90 active:scale-95 transition-all flex items-center gap-2">
                <span class="material-symbols-outlined text-[16px]">save</span>
                Lưu câu hỏi
              </button>
            </div>
          </div>

          <div class="lg:w-80 shrink-0">
            <div class="sticky top-4">
              <p class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-2">Live Preview</p>
              <div id="q-preview"></div>
            </div>
          </div>
        </form>
      </div>
    </div>

    </>
  )}
  </div>
</AdminLayout>

<script>
  import '../../../scripts/scanner-edit-client.js';
</script>

<style>
  .line-clamp-1 {
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
  }
  .line-clamp-6 {
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 6;
    -webkit-box-orient: vertical;
  }
</style>
