---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';
import {
  listSurveyDefinitions,
  countResponsesBySurvey,
} from '../../../lib/survey-config-db';
import { SEED_REGISTRY } from '../../../data/seeds/registry';

export const prerender = false;

let definitions: Awaited<ReturnType<typeof listSurveyDefinitions>> = [];
try {
  definitions = await listSurveyDefinitions(env.DB);
} catch {
  definitions = [];
}

const existingIds = new Set(definitions.map((d) => d.id));

// Count responses per survey (best effort)
const responseCounts = new Map<string, number>();
for (const def of definitions) {
  try {
    responseCounts.set(def.id, await countResponsesBySurvey(env.DB, def.id));
  } catch {
    responseCounts.set(def.id, 0);
  }
}

// Available bundled seeds (those not yet in DB)
const bundledSeeds = Object.values(SEED_REGISTRY).map((s) => ({
  id: s.id,
  slug: s.slug,
  title_vi: s.title_vi,
  type: s.survey_type ?? 'full',
  is_free: s.is_free ?? 0,
  sections: s.sections.length,
  questions: s.sections.reduce((sum, sec) => sum + sec.questions.length, 0),
  inDb: existingIds.has(s.id),
}));

const statusLabels: Record<string, string> = {
  draft: 'Bản nháp',
  active: 'Đang hoạt động',
  archived: 'Lưu trữ',
};

const statusColors: Record<string, string> = {
  draft: 'bg-gray-500/20 text-gray-400',
  active: 'bg-green-500/20 text-green-300',
  archived: 'bg-red-500/20 text-red-300',
};

const statusDotColors: Record<string, string> = {
  draft: 'bg-gray-400',
  active: 'bg-green-400',
  archived: 'bg-red-400',
};

const typeLabels: Record<string, string> = {
  mini: 'Mini',
  full: 'Full',
  checklist: 'Checklist',
};

const typeColors: Record<string, string> = {
  mini: 'bg-blue-500/20 text-blue-300',
  full: 'bg-purple-500/20 text-purple-300',
  checklist: 'bg-amber-500/20 text-amber-300',
};

function formatDate(s: string) {
  return new Date(s).toLocaleDateString('vi-VN', {
    day: '2-digit', month: '2-digit', year: 'numeric',
  });
}

function getInitials(name: string) {
  return name.split(' ').slice(0, 2).map(w => w[0]).join('').toUpperCase().slice(0, 2);
}

const avatarColors = [
  'from-blue-600 to-cyan-600',
  'from-purple-600 to-pink-600',
  'from-emerald-600 to-teal-600',
  'from-amber-600 to-orange-600',
  'from-rose-600 to-red-600',
];

// Stats
const totalDefs = definitions.length;
const activeDefs = definitions.filter(d => d.status === 'active').length;
const draftDefs = definitions.filter(d => d.status === 'draft').length;
const archivedDefs = definitions.filter(d => d.status === 'archived').length;
---

<AdminLayout title="Scanners" searchPlaceholder="Tìm scanner...">
  <!-- Header -->
  <header class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <p class="text-xs uppercase tracking-wider text-on-surface-variant/70 font-bold mb-1">
        Công cụ chẩn đoán
      </p>
      <h1 class="text-3xl font-bold text-on-surface">Scanners</h1>
      <p class="text-sm text-on-surface-variant mt-1">
        Quản lý các máy quét / khảo sát tự chẩn đoán cho chủ phòng khám. Mỗi scanner là một bộ câu hỏi + AI analysis theo framework từ sách.
      </p>
    </div>
    <div class="flex gap-2 flex-wrap">
      <button
        type="button"
        id="btn-create"
        class="bg-primary-container text-white px-5 py-2.5 rounded-xl font-bold text-sm cyan-glow hover:opacity-90 active:scale-95 transition-all flex items-center gap-2"
      >
        <span class="material-symbols-outlined text-[20px]">add</span>
        Tạo scanner mới
      </button>
    </div>
  </header>

  <!-- Bundled seeds panel -->
  {bundledSeeds.length > 0 && (
    <div class="glass-card rounded-2xl p-6 border border-primary/20">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h2 class="text-lg font-bold text-on-surface flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">inventory_2</span>
            Seed từ thư viện
          </h2>
          <p class="text-sm text-on-surface-variant mt-1">
            Import nhanh các scanner mẫu có sẵn. Những scanner đã tồn tại có thể re-import (sẽ ghi đè).
          </p>
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {bundledSeeds.map((seed) => (
          <div class={`rounded-xl p-4 border ${seed.inDb ? 'bg-surface-container border-outline-variant/30' : 'bg-surface border-primary/20'}`}>
            <div class="flex items-start justify-between mb-2">
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-on-surface truncate">{seed.title_vi}</p>
                <p class="text-xs text-on-surface-variant font-mono mt-0.5">{seed.id}</p>
              </div>
              {seed.inDb ? (
                <span class="inline-flex items-center gap-1 text-xs font-semibold text-green-400 shrink-0 ml-2">
                  <span class="material-symbols-outlined text-[14px]">check_circle</span>
                  Đã có
                </span>
              ) : (
                <span class="inline-flex items-center gap-1 text-xs font-semibold text-amber-400 shrink-0 ml-2">
                  <span class="material-symbols-outlined text-[14px]">new_releases</span>
                  Mới
                </span>
              )}
            </div>
            <div class="flex items-center gap-2 text-xs text-on-surface-variant mb-3">
              <span>{seed.type}</span>
              <span>·</span>
              <span>{seed.sections} phần</span>
              <span>·</span>
              <span>{seed.questions} câu</span>
              {seed.is_free === 1 && (
                <>
                  <span>·</span>
                  <span class="text-green-400 font-semibold">Free</span>
                </>
              )}
            </div>
            <button
              type="button"
              class={`btn-seed w-full px-3 py-2 rounded-lg font-semibold text-sm transition-colors flex items-center justify-center gap-1.5 ${
                seed.inDb
                  ? 'bg-surface-container border border-outline-variant/30 text-on-surface hover:bg-surface-container-high'
                  : 'bg-primary-container text-white cyan-glow hover:opacity-90 active:scale-95'
              }`}
              data-seed-id={seed.id}
              data-seed-name={seed.title_vi}
              data-reimport={seed.inDb ? '1' : '0'}
            >
              <span class="material-symbols-outlined text-[16px]">{seed.inDb ? 'refresh' : 'download'}</span>
              {seed.inDb ? 'Re-import' : 'Import'}
            </button>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Stats -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
    <div class="glass-card rounded-xl p-4">
      <p class="text-xs uppercase tracking-wider text-on-surface-variant/70 font-bold mb-1">Tổng</p>
      <p class="text-2xl font-bold text-on-surface">{totalDefs}</p>
    </div>
    <div class="glass-card rounded-xl p-4">
      <p class="text-xs uppercase tracking-wider text-on-surface-variant/70 font-bold mb-1">Đang hoạt động</p>
      <p class="text-2xl font-bold text-green-300">{activeDefs}</p>
    </div>
    <div class="glass-card rounded-xl p-4">
      <p class="text-xs uppercase tracking-wider text-on-surface-variant/70 font-bold mb-1">Bản nháp</p>
      <p class="text-2xl font-bold text-gray-300">{draftDefs}</p>
    </div>
    <div class="glass-card rounded-xl p-4">
      <p class="text-xs uppercase tracking-wider text-on-surface-variant/70 font-bold mb-1">Lưu trữ</p>
      <p class="text-2xl font-bold text-red-300">{archivedDefs}</p>
    </div>
  </div>

  <!-- Empty state -->
  {definitions.length === 0 && (
    <div class="glass-card rounded-2xl p-12 text-center">
      <span class="material-symbols-outlined text-6xl text-on-surface-variant/30">fact_check</span>
      <p class="text-on-surface font-semibold mt-4">Chưa có scanner nào</p>
      <p class="text-sm text-on-surface-variant mt-2">
        Bắt đầu bằng cách seed bộ câu hỏi mặc định "Hồ Sơ Gốc Rễ" hoặc tạo mới.
      </p>
      <div class="flex gap-2 justify-center mt-6">
        <button
          type="button"
          id="btn-seed-default-2"
          class="bg-primary-container text-white px-5 py-2.5 rounded-xl font-bold text-sm cyan-glow hover:opacity-90 transition-all flex items-center gap-2"
        >
          <span class="material-symbols-outlined text-[18px]">download</span>
          Seed "Hồ Sơ Gốc Rễ"
        </button>
        <button
          type="button"
          id="btn-create-2"
          class="bg-surface-container border border-outline-variant/30 text-on-surface px-5 py-2.5 rounded-xl font-semibold text-sm hover:bg-surface-container-high transition-colors"
        >
          Tạo mới
        </button>
      </div>
    </div>
  )}

  <!-- List -->
  {definitions.length > 0 && (
    <div class="glass-card rounded-2xl border border-outline-variant/20 overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="border-b border-outline-variant/15">
            <th class="text-left px-4 py-3 text-xs uppercase tracking-wider text-on-surface-variant/70 font-semibold">Scanner</th>
            <th class="text-left px-4 py-3 text-xs uppercase tracking-wider text-on-surface-variant/70 font-semibold hidden md:table-cell">Loại</th>
            <th class="text-left px-4 py-3 text-xs uppercase tracking-wider text-on-surface-variant/70 font-semibold hidden sm:table-cell">Trạng thái</th>
            <th class="text-left px-4 py-3 text-xs uppercase tracking-wider text-on-surface-variant/70 font-semibold hidden lg:table-cell">Responses</th>
            <th class="text-left px-4 py-3 text-xs uppercase tracking-wider text-on-surface-variant/70 font-semibold hidden lg:table-cell">Cập nhật</th>
            <th class="text-right px-4 py-3 text-xs uppercase tracking-wider text-on-surface-variant/70 font-semibold">Hành động</th>
          </tr>
        </thead>
        <tbody>
          {definitions.map((def, idx) => {
            const initials = getInitials(def.title_vi);
            const avatar = avatarColors[idx % avatarColors.length];
            const responseCount = responseCounts.get(def.id) ?? 0;
            return (
              <tr class="border-b border-outline-variant/10 hover:bg-surface-container-high/50 transition-colors">
                <td class="px-4 py-3">
                  <a href={`/admin/scanners/${def.id}`} class="flex items-center gap-3 group">
                    <div class={`w-10 h-10 rounded-lg bg-gradient-to-br ${avatar} flex items-center justify-center text-white font-bold text-sm shrink-0`}>
                      {initials}
                    </div>
                    <div class="min-w-0">
                      <p class="text-sm font-semibold text-on-surface group-hover:text-primary transition-colors truncate">
                        {def.title_vi}
                      </p>
                      <p class="text-xs text-on-surface-variant truncate font-mono">{def.id}</p>
                    </div>
                  </a>
                </td>
                <td class="px-4 py-3 hidden md:table-cell">
                  <span class={`px-2 py-0.5 rounded-md text-xs font-semibold ${typeColors[def.survey_type] ?? 'bg-gray-500/20 text-gray-300'}`}>
                    {typeLabels[def.survey_type] ?? def.survey_type}
                  </span>
                </td>
                <td class="px-4 py-3 hidden sm:table-cell">
                  <span class={`inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md text-xs font-semibold ${statusColors[def.status] ?? 'bg-gray-500/20 text-gray-300'}`}>
                    <span class={`w-1.5 h-1.5 rounded-full ${statusDotColors[def.status] ?? 'bg-gray-400'}`}></span>
                    {statusLabels[def.status] ?? def.status}
                  </span>
                </td>
                <td class="px-4 py-3 hidden lg:table-cell text-sm text-on-surface-variant font-semibold">
                  {responseCount}
                </td>
                <td class="px-4 py-3 hidden lg:table-cell text-sm text-on-surface-variant">
                  {formatDate(def.updated_at)}
                </td>
                <td class="px-4 py-3 text-right">
                  <div class="flex items-center justify-end gap-1">
                    <a
                      href={`/admin/scanners/${def.id}/responses`}
                      class="p-2 rounded-lg hover:bg-surface-container text-on-surface-variant hover:text-on-surface transition-colors"
                      title="Xem responses"
                    >
                      <span class="material-symbols-outlined text-[18px]">list_alt</span>
                    </a>
                    <a
                      href={`/admin/scanners/${def.id}`}
                      class="p-2 rounded-lg hover:bg-surface-container text-on-surface-variant hover:text-on-surface transition-colors"
                      title="Chỉnh sửa"
                    >
                      <span class="material-symbols-outlined text-[18px]">edit</span>
                    </a>
                    <button
                      type="button"
                      class="btn-delete p-2 rounded-lg hover:bg-red-500/20 text-on-surface-variant hover:text-red-400 transition-colors"
                      data-id={def.id}
                      data-name={def.title_vi}
                      title="Xóa"
                    >
                      <span class="material-symbols-outlined text-[18px]">delete</span>
                    </button>
                  </div>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  )}

  <!-- Create modal -->
  <div id="create-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4">
    <div id="create-modal-backdrop" class="absolute inset-0 bg-black/0 transition-colors"></div>
    <div id="create-modal-panel" class="relative glass-card rounded-2xl p-6 w-full max-w-lg max-h-[90vh] overflow-y-auto scrollbar-hide scale-95 opacity-0 transition-all">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-xl font-bold text-on-surface">Tạo scanner mới</h3>
        <button id="modal-close" type="button" class="p-2 rounded-lg hover:bg-surface-container text-on-surface-variant hover:text-on-surface transition-colors">
          <span class="material-symbols-outlined text-[20px]">close</span>
        </button>
      </div>
      <form id="create-form" class="flex flex-col gap-4">
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Tiêu đề (VI) <span class="text-red-400">*</span></label>
          <input type="text" name="title_vi" required class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary" placeholder="Hệ Thống Check" />
        </div>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Tiêu đề (EN)</label>
          <input type="text" name="title_en" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary" placeholder="Systems Check" />
        </div>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Slug (URL)</label>
          <input type="text" name="slug" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary font-mono" placeholder="he-thong-check (tự sinh nếu trống)" />
        </div>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Loại</label>
          <select name="survey_type" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary">
            <option value="full" selected>Full — Bản đầy đủ</option>
            <option value="mini">Mini — Phiên bản ngắn</option>
            <option value="checklist">Checklist — Chỉ yes/no</option>
          </select>
        </div>
        <div>
          <label class="text-xs font-semibold text-on-surface-variant block mb-1">Trạng thái</label>
          <select name="status" class="w-full bg-surface-container border border-outline-variant rounded-xl px-4 py-2.5 text-on-surface focus:outline-none focus:border-primary">
            <option value="draft" selected>Bản nháp</option>
            <option value="active">Đang hoạt động</option>
            <option value="archived">Lưu trữ</option>
          </select>
        </div>
        <p id="form-error" class="text-sm text-red-400 hidden"></p>
        <div class="flex justify-end gap-2 pt-2">
          <button type="button" id="modal-cancel" class="px-4 py-2.5 rounded-xl text-sm font-semibold text-on-surface-variant hover:bg-surface-container transition-colors">Huỷ</button>
          <button type="submit" class="bg-primary-container text-white px-5 py-2.5 rounded-xl font-bold text-sm cyan-glow hover:opacity-90 active:scale-95 transition-all">Tạo scanner</button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  // Modal logic
  const modal = document.getElementById('create-modal');
  const backdrop = document.getElementById('create-modal-backdrop');
  const panel = document.getElementById('create-modal-panel');
  const form = document.getElementById('create-form');
  const formError = document.getElementById('form-error');

  function openModal() {
    modal.classList.remove('hidden');
    requestAnimationFrame(() => {
      backdrop.classList.replace('bg-black/0', 'bg-black/60');
      panel.classList.remove('scale-95', 'opacity-0');
      panel.classList.add('scale-100', 'opacity-100');
    });
  }

  function closeModal() {
    backdrop.classList.replace('bg-black/60', 'bg-black/0');
    panel.classList.remove('scale-100', 'opacity-100');
    panel.classList.add('scale-95', 'opacity-0');
    setTimeout(() => {
      modal.classList.add('hidden');
      form.reset();
      formError.classList.add('hidden');
    }, 300);
  }

  document.getElementById('btn-create')?.addEventListener('click', openModal);
  document.getElementById('btn-create-2')?.addEventListener('click', openModal);
  document.getElementById('modal-close')?.addEventListener('click', closeModal);
  document.getElementById('modal-cancel')?.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);

  // Submit create
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    formError.classList.add('hidden');

    const fd = new FormData(form);
    const body = {
      title_vi: String(fd.get('title_vi') ?? '').trim(),
      title_en: String(fd.get('title_en') ?? '').trim(),
      slug: String(fd.get('slug') ?? '').trim() || undefined,
      survey_type: String(fd.get('survey_type') ?? 'full'),
      status: String(fd.get('status') ?? 'draft'),
    };

    try {
      const res = await fetch('/api/admin/scanner-definitions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const data = await res.json();
      if (!res.ok || !data.id) {
        throw new Error(data.error || 'Tạo thất bại');
      }
      (window).showToast?.('Tạo scanner thành công!', 'success');
      setTimeout(() => {
        window.location.href = `/admin/scanners/${data.id}`;
      }, 600);
    } catch (err) {
      formError.textContent = err instanceof Error ? err.message : 'Tạo thất bại';
      formError.classList.remove('hidden');
    }
  });

  // Delete handlers
  document.querySelectorAll('.btn-delete').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.id;
      const name = btn.dataset.name;
      if (!id) return;
      if (!confirm(`Xóa scanner "${name}"?\n\nToàn bộ sections, questions và responses sẽ bị xoá vĩnh viễn.`)) {
        return;
      }
      try {
        const res = await fetch(`/api/admin/scanner-definitions/${id}`, { method: 'DELETE' });
        if (!res.ok) {
          const data = await res.json();
          throw new Error(data.error || 'Xóa thất bại');
        }
        (window).showToast?.('Đã xóa scanner', 'success');
        setTimeout(() => window.location.reload(), 400);
      } catch (err) {
        alert(err instanceof Error ? err.message : 'Xóa thất bại');
      }
    });
  });

  // Seed handlers
  document.querySelectorAll('.btn-seed').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.seedId;
      const name = btn.dataset.seedName;
      const isReimport = btn.dataset.reimport === '1';
      if (!id) return;
      const confirmMsg = isReimport
        ? `Re-import "${name}"?\n\nDữ liệu hiện tại sẽ bị ghi đè.`
        : `Import "${name}" vào database?`;
      if (!confirm(confirmMsg)) return;

      btn.setAttribute('disabled', 'true');
      (window).showToast?.('Đang import...', 'info', 2000);

      try {
        const res = await fetch(`/api/admin/seed-scanner/${id}`, { method: 'POST' });
        const data = await res.json();
        if (!res.ok || !data.success) {
          throw new Error(data.error || 'Import thất bại');
        }
        (window).showToast?.(
          `Đã import ${data.sections_added} phần, ${data.questions_added} câu hỏi`,
          'success',
          3000,
        );
        setTimeout(() => window.location.reload(), 800);
      } catch (err) {
        alert(err instanceof Error ? err.message : 'Import thất bại');
        btn.removeAttribute('disabled');
      }
    });
  });
</script>