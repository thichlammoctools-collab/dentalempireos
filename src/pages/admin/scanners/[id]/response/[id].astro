---
import AdminLayout from '../../../../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';
import {
  getSurveyDefinitionFull,
  parseScaleLabels,
  parseOptions,
} from '../../../../../lib/survey-config-db';
import {
  getScannerResponse,
  parseResponses,
  parseScores,
  buildAiContext,
  maskEmail,
} from '../../../../../lib/scanner-response-db';
import { marked } from 'marked';

export const prerender = false;

// Extract both surveyId and responseId from URL path to avoid Astro param conflicts.
// URL: /admin/scanners/<surveyId>/response/<responseId>
const url = new URL(Astro.request.url);
const pathParts = url.pathname.split('/').filter(Boolean);
// pathParts example: ['admin', 'scanners', '<surveyId>', 'response', '<responseId>']
const surveyId = pathParts[2] ?? '';
const responseId = parseInt(pathParts[4] ?? '0', 10);

let full: Awaited<ReturnType<typeof getSurveyDefinitionFull>> = null;
let response: Awaited<ReturnType<typeof getScannerResponse>> = null;

try {
  full = await getSurveyDefinitionFull(env.DB, surveyId);
  response = await getScannerResponse(env.DB, responseId);
} catch {
  // ignore
}

if (!full || !response) {
  return Astro.redirect('/admin/scanners');
}

const def = full.definition;
const scores = parseScores(response.scores_json);
const responses = parseResponses(response.responses_json);

function scoreLevel(score: number) {
  if (score >= 75) return { label: 'Vững mạnh', color: 'text-green-400', hex: '#10b981' };
  if (score >= 55) return { label: 'Đang phát triển', color: 'text-blue-400', hex: '#3b82f6' };
  if (score >= 35) return { label: 'Cần chú ý', color: 'text-amber-400', hex: '#f59e0b' };
  return { label: 'Cần soi chiếu', color: 'text-red-400', hex: '#ef4444' };
}

function formatDate(s: string) {
  return new Date(s).toLocaleString('vi-VN', {
    day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit',
  });
}

marked.setOptions({ gfm: true, breaks: true });
const analysisHtml = response.ai_analysis ? (marked.parse(response.ai_analysis) as string) : '';
---

<AdminLayout title={`Response #${response.id} | ${def.title_vi}`}>
  <header class="flex flex-wrap items-start justify-between gap-4">
    <div class="flex items-start gap-4 min-w-0">
      <a href={`/admin/scanners/${def.id}/responses`} class="p-2 rounded-lg hover:bg-surface-container text-on-surface-variant hover:text-on-surface transition-colors shrink-0">
        <span class="material-symbols-outlined">arrow_back</span>
      </a>
      <div class="min-w-0">
        <p class="text-xs uppercase tracking-wider text-on-surface-variant/70 font-bold mb-1">Response #{response.id}</p>
        <h1 class="text-2xl font-bold text-on-surface truncate">{response.clinic_name ?? '—'}</h1>
        <p class="text-sm text-on-surface-variant mt-0.5">{response.owner_name ?? ''} · {formatDate(response.created_at)}</p>
      </div>
    </div>
    <div class="flex gap-2 flex-wrap shrink-0">
      <a
        href={`/scanner/result/${response.id}`}
        target="_blank"
        class="bg-surface-container border border-outline-variant/30 text-on-surface px-4 py-2 rounded-xl font-semibold text-sm hover:bg-surface-container-high transition-colors flex items-center gap-2"
      >
        <span class="material-symbols-outlined text-[18px]">open_in_new</span>
        Xem trang công khai
      </a>
      <button
        type="button"
        id="btn-reanalyze"
        class="bg-primary-container text-white px-4 py-2 rounded-xl font-bold text-sm cyan-glow hover:opacity-90 active:scale-95 transition-all flex items-center gap-2"
        data-response-id={response.id}
      >
        <span class="material-symbols-outlined text-[18px]">auto_awesome</span>
        Re-analyze AI
      </button>
    </div>
  </header>

  <!-- Scores + meta -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="glass-card rounded-2xl p-6">
      <p class="text-xs uppercase tracking-wider text-on-surface-variant/70 font-bold mb-1">Tổng điểm</p>
      <div class="flex items-baseline gap-1">
        <span class={`text-5xl font-extrabold ${scoreLevel(scores.total ?? 0).color}`}>{scores.total ?? 0}</span>
        <span class="text-lg text-on-surface-variant">/100</span>
      </div>
      <p class={`text-sm font-semibold mt-1 ${scoreLevel(scores.total ?? 0).color}`}>{scoreLevel(scores.total ?? 0).label}</p>
    </div>
    <div class="glass-card rounded-2xl p-6 lg:col-span-2">
      <p class="text-xs uppercase tracking-wider text-on-surface-variant/70 font-bold mb-3">Điểm từng dimension</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        {Object.entries(scores).filter(([k]) => k !== 'total').map(([dimId, score]) => {
          const dim = full?.sections.flatMap(s => []).find(() => false);
          // Find dimension name from scoring_rules
          let dimName = dimId;
          if (def.scoring_rules) {
            try {
              const rules = JSON.parse(def.scoring_rules);
              const found = rules.dimensions?.find((d: any) => d.id === dimId);
              if (found) dimName = found.name_vi ?? dimId;
            } catch {}
          }
          const level = scoreLevel(score as number);
          return (
            <div>
              <p class="text-xs text-on-surface-variant mb-1">{dimName}</p>
              <p class={`text-2xl font-bold ${level.color}`}>{score as number}</p>
            </div>
          );
        })}
      </div>
    </div>
  </div>

  <!-- Meta -->
  <div class="glass-card rounded-2xl p-6">
    <h2 class="text-lg font-bold text-on-surface mb-3">Thông tin liên hệ</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 text-sm">
      <div>
        <p class="text-xs text-on-surface-variant">Email</p>
        <p class="text-on-surface font-semibold font-mono">{maskEmail(response.email)}</p>
      </div>
      <div>
        <p class="text-xs text-on-surface-variant">Số năm hoạt động</p>
        <p class="text-on-surface font-semibold">{response.years_in_operation ?? '—'}</p>
      </div>
      <div>
        <p class="text-xs text-on-surface-variant">Số nhân sự</p>
        <p class="text-on-surface font-semibold">{response.staff_count ?? '—'}</p>
      </div>
      <div class="sm:col-span-3">
        <p class="text-xs text-on-surface-variant">Địa chỉ</p>
        <p class="text-on-surface">{response.clinic_address ?? '—'}</p>
      </div>
    </div>
  </div>

  <!-- AI Analysis -->
  <div class="glass-card rounded-2xl p-6">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-lg font-bold text-on-surface">Phân tích AI</h2>
      <p id="ai-status" class="text-xs text-on-surface-variant">
        {response.ai_analysis ? `Đã phân tích ${formatDate(response.ai_analyzed_at ?? '')}` : 'Chưa có'}
      </p>
    </div>
    {analysisHtml ? (
      <article class="prose prose-invert max-w-none">
        <div set:html={analysisHtml}></div>
      </article>
    ) : (
      <div class="text-center py-8 text-on-surface-variant">
        <p>Chưa có AI analysis. Bấm "Re-analyze AI" để tạo.</p>
      </div>
    )}
  </div>

  <!-- All answers (collapsible) -->
  <details class="glass-card rounded-2xl overflow-hidden">
    <summary class="p-6 cursor-pointer font-bold text-on-surface hover:bg-surface-container-high/50 transition-colors list-none flex items-center gap-2">
      <span class="material-symbols-outlined">expand_more</span>
      Tất cả câu trả lời ({Object.keys(responses).length})
    </summary>
    <div class="p-6 pt-0 flex flex-col gap-4 border-t border-outline-variant/10">
      {full.sections.map((section) => (
        <div>
          <h3 class="font-bold text-on-surface mb-2 text-sm">{section.title_vi}</h3>
          <div class="flex flex-col gap-2">
            {section.questions.map((q) => {
              const val = responses[q.question_id];
              const labels = parseScaleLabels(q.scale_labels_vi);
              const options = parseOptions(q.options_vi);
              return (
                <div class="bg-surface-container/40 rounded-lg p-3 text-sm">
                  <p class="text-on-surface font-medium mb-1">{q.label_vi}</p>
                  <p class="text-xs text-on-surface-variant font-mono mb-2">{q.question_id} · {q.type}</p>
                  {val === undefined || val === null || val === '' ? (
                    <p class="text-on-surface-variant italic text-xs">— không trả lời —</p>
                  ) : q.type === 'select' || q.type === 'yesno' ? (
                    <p class="text-on-surface">
                      <span class="font-bold">{val}</span>
                      {labels[String(val)] ? ` — ${labels[String(val)]}` : ''}
                    </p>
                  ) : q.type === 'radio' ? (
                    <p class="text-on-surface">{String(val)}</p>
                  ) : (
                    <p class="text-on-surface whitespace-pre-wrap">{String(val)}</p>
                  )}
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </details>
</AdminLayout>

<script>
  document.getElementById('btn-reanalyze')?.addEventListener('click', async (e) => {
    const btn = e.currentTarget;
    const responseId = btn.dataset.responseId;
    if (!responseId) return;
    if (!confirm('Re-run AI analysis cho response này?')) return;

    btn.setAttribute('disabled', 'true');
    btn.innerHTML = '<span>Đang phân tích...</span>';
    window.showToast?.('Đang gọi AI...', 'info');

    try {
      // Use the AI endpoint if it exists, otherwise just trigger via fetch
      const res = await fetch(`/api/admin/scanner/regenerate-ai?id=${responseId}`, { method: 'POST' });
      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        throw new Error(data.error || 'Re-analyze thất bại');
      }
      window.showToast?.('Đã tạo AI analysis mới', 'success');
      setTimeout(() => window.location.reload(), 800);
    } catch (err) {
      alert(err instanceof Error ? err.message : 'Re-analyze thất bại');
      btn.removeAttribute('disabled');
      btn.innerHTML = '<span class="material-symbols-outlined text-[18px]">auto_awesome</span> Re-analyze AI';
    }
  });
</script>