---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { env } from 'cloudflare:workers';

export const prerender = false;

const orderId = Astro.url.searchParams.get('order') || '';

// Fetch order details to show which product was purchased
let orderInfo: { product_name: string; product_id: string } | null = null;
if (orderId) {
  try {
    const result = await env.DB
      .prepare(
        `SELECT p.name as product_name, o.product_id
         FROM "order" o
         JOIN "product" p ON o.product_id = p.id
         WHERE o.id = ? LIMIT 1`
      )
      .bind(orderId)
      .first<{ product_name: string; product_id: string }>();
    if (result) {
      orderInfo = result;
    }
  } catch {
    // ignore
  }
}

const productName = orderInfo?.product_name ?? 'nội dung của bạn';
---

<BaseLayout title="Kết quả thanh toán | Dental Empire OS" noindex={true}>
  <section class="max-w-[480px] mx-auto px-6 py-16 text-center">
    <div id="payment-result" class="glass-card rounded-2xl p-8 border border-outline-variant/20">
      <!-- Loading state -->
      <div id="state-loading" class="flex flex-col items-center gap-4">
        <div class="w-12 h-12 border-4 border-primary/30 border-t-primary rounded-full animate-spin"></div>
        <p class="text-on-surface-variant text-sm">Đang xác nhận thanh toán...</p>
        <p class="text-white/30 text-xs">Vui lòng không tắt trang này</p>
      </div>

      <!-- Success state -->
      <div id="state-success" class="hidden flex flex-col items-center gap-4">
        <div class="w-16 h-16 rounded-full bg-emerald-500/20 flex items-center justify-center">
          <svg class="w-8 h-8 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h2 class="text-xl font-bold text-white">Thanh toán thành công!</h2>
        <p class="text-on-surface-variant text-sm" id="success-message">
          <strong>{productName}</strong> đã được mở khóa. Bạn có thể truy cập ngay.
        </p>
        <div class="flex flex-col sm:flex-row gap-2 mt-2 w-full">
          <a href="/" class="flex-1 px-6 py-2.5 btn-primary-metallic font-bold rounded-xl text-sm">
            Về trang chủ
          </a>
          {orderInfo?.product_id === 'prod-scanner-pack' && (
            <a href="/scanner" class="flex-1 px-6 py-2.5 bg-emerald-500/20 hover:bg-emerald-500/30 text-emerald-300 font-bold rounded-xl text-sm flex items-center justify-center gap-2 transition-all">
              <span class="material-symbols-outlined text-base">fact_check</span>
              Khám phá Scanner
            </a>
          )}
        </div>
      </div>

      <!-- Failed/cancelled state -->
      <div id="state-failed" class="hidden flex flex-col items-center gap-4">
        <div class="w-16 h-16 rounded-full bg-rose-500/20 flex items-center justify-center">
          <svg class="w-8 h-8 text-rose-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </div>
        <h2 class="text-xl font-bold text-white">Thanh toán chưa hoàn tất</h2>
        <p class="text-on-surface-variant text-sm">
          Đơn hàng đang được xử lý hoặc đã bị hủy. Vui lòng quay lại và thử lại nếu cần.
        </p>
        <a href="/" class="mt-2 px-6 py-2.5 btn-primary-metallic font-bold rounded-xl text-sm">
          Về trang chủ
        </a>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ orderId }}>
    const ORDER_ID = orderId;
    let attempts = 0;
    const MAX_ATTEMPTS = 12;

    const loading = document.getElementById('state-loading');
    const success = document.getElementById('state-success');
    const failed = document.getElementById('state-failed');

    async function checkStatus() {
      if (attempts >= MAX_ATTEMPTS) {
        loading?.classList.add('hidden');
        failed?.classList.remove('hidden');
        return;
      }
      attempts++;

      try {
        // Check order status
        const res = await fetch('/api/payos/check-access?order_id=' + ORDER_ID);
        if (res.ok) {
          const data = await res.json();
          if (data.status === 'paid') {
            loading?.classList.add('hidden');
            success?.classList.remove('hidden');
            return;
          }
        }
      } catch {
        // Network error, keep polling
      }

      setTimeout(checkStatus, 2000);
    }

    // Start polling after 2 seconds (webhook needs time to process)
    setTimeout(checkStatus, 2000);

    // Also try to get order status directly
    async function getOrderStatus() {
      if (!ORDER_ID) {
        loading?.classList.add('hidden');
        failed?.classList.remove('hidden');
        return;
      }

      try {
        const res = await fetch(`/api/payos/check-access?order_id=${ORDER_ID}`);
        if (res.ok) {
          const data = await res.json();
          if (data.status === 'paid') {
            loading?.classList.add('hidden');
            success?.classList.remove('hidden');
            return;
          }
        }
      } catch {}

      // Give a final delay then check actual status before showing result
      setTimeout(async () => {
        loading?.classList.add('hidden');
        try {
          const res = await fetch('/api/payos/check-access?order_id=' + ORDER_ID);
          if (res.ok) {
            const data = await res.json();
            if (data.status === 'paid') {
              success?.classList.remove('hidden');
              return;
            }
          }
        } catch {}
        failed?.classList.remove('hidden');
      }, 4000);
    }

    // Fallback: show success after timeout
    setTimeout(getOrderStatus, 1000);
  </script>
</BaseLayout>
