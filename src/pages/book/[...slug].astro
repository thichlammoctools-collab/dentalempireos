---
import { marked } from 'marked';
import { env } from 'cloudflare:workers';
import { getChapterTree, listPublishedChapters, getSupportSettings, type SectionNode } from '../../lib/book-db';
import { getTierLabel } from '../../lib/collection-helpers';
import BookLayout from '../../layouts/BookLayout.astro';
import BookHeader from '../../components/book/BookHeader.astro';
import ChapterNav from '../../components/book/ChapterNav.astro';
import ModuleNav from '../../components/book/ModuleNav.astro';
import KeywordAutoLink from '../../components/book/KeywordAutoLink.astro';
import DonateWidget from '../../components/book/DonateWidget.astro';

export const prerender = false;

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/book');

const db = env.DB;
const tree = await getChapterTree(db, slug);
if (!tree) {
  return new Response('Không tìm thấy chương', { status: 404 });
}

const { chapter: ch, sections } = tree;

const allPublished = await listPublishedChapters(db);
const groupedByTier = [1, 2, 3].map((tier) => ({
  tier,
  label: getTierLabel(tier),
  chapters: allPublished
    .filter((c) => c.tier === tier)
    .map((c) => ({
      id: c.id,
      data: { title: c.title, tier: c.tier, chapter: c.chapter_no },
    })),
}));

const flatIds = allPublished.map((c) => c.id);
const currentIdx = flatIds.indexOf(slug);
const prevCh = currentIdx > 0 ? allPublished[currentIdx - 1] : null;
const nextCh = currentIdx < flatIds.length - 1 ? allPublished[currentIdx + 1] : null;
const prev = prevCh ? { id: prevCh.id, data: { title: prevCh.title, tier: prevCh.tier } } : null;
const next = nextCh ? { id: nextCh.id, data: { title: nextCh.title, tier: nextCh.tier } } : null;

const modules = sections.map((s) => ({
  title: s.title,
  slug: s.slug,
}));

marked.use({ breaks: true });

function renderMarkdown(text: string): string {
  let html = marked.parse(text) as string;
  // Rewrite <img> src: if it's an R2 key (no protocol), prepend /media/
  // Also add onerror to hide broken images gracefully
  html = html.replace(
    /<img\b([^>]*)>/gi,
    (match, attrs: string) => {
      // Fix src: bare keys like "book/xxx/file.jpg" → "/media/book/xxx/file.jpg"
      let fixed = attrs.replace(
        /\bsrc="([^"]*)"/i,
        (_: string, src: string) => {
          if (/^https?:\/\//.test(src)) return `src="${src}"`;
          if (src.startsWith('/media/')) return `src="${src}"`;
          return `src="/media/${src}"`;
        }
      );
      // Add onerror fallback
      if (!/onerror/i.test(fixed)) {
        fixed += ' onerror="this.style.display=\'none\'"';
      }
      return `<img${fixed}>`;
    }
  );
  return html;
}

function renderSection(s: SectionNode): string {
  const tag = s.level === 2 ? 'h2' : 'h3';
  let html = `<${tag} id="${s.slug}" class="section-heading">${s.title}</${tag}>`;

  for (const block of s.blocks) {
    if (block.type === 'text' && block.text_md) {
      html += renderMarkdown(block.text_md);
    } else if (block.type === 'image' && block.r2_key) {
      html += `<figure class="my-6">
        <img src="/media/${block.r2_key}" alt="${block.alt ?? ''}" class="rounded-xl w-full" loading="lazy" />
        ${block.caption ? `<figcaption class="text-center text-sm text-on-surface-variant mt-2">${block.caption}</figcaption>` : ''}
      </figure>`;
    } else if (block.type === 'file' && block.r2_key) {
      const icon = getFileIcon(block.mime);
      html += `<div class="my-4 p-4 bg-surface-container-low border border-outline-variant/40 rounded-xl flex items-center gap-4">
        <span class="material-symbols-outlined text-primary text-3xl">${icon}</span>
        <div class="flex-1">
          <p class="text-sm text-white font-semibold">${block.filename ?? 'Tải file'}</p>
          ${block.caption ? `<p class="text-xs text-on-surface-variant mt-0.5">${block.caption}</p>` : ''}
        </div>
        <a href="/media/${block.r2_key}" target="_blank" class="px-3 py-1.5 text-xs font-bold text-primary border border-primary/30 rounded-lg hover:bg-primary/5 transition-all">
          Tải
        </a>
      </div>`;
    }
  }

  for (const child of s.children) {
    html += renderSection(child);
  }

  return html;
}

function getFileIcon(mime: string | null): string {
  if (!mime) return 'description';
  if (mime.includes('pdf')) return 'picture_as_pdf';
  if (mime.includes('word') || mime.includes('document')) return 'article';
  if (mime.includes('sheet') || mime.includes('excel')) return 'table_chart';
  if (mime.includes('image')) return 'image';
  return 'description';
}

// Render sections, stripping first h2 (chapter title is shown by BookHeader)
const sectionsHtml = sections.map(renderSection).join('');
// Strip the first h2/h3 since BookHeader shows the chapter title
const strippedContent = sectionsHtml.replace(/<\/?(?:h2|h3)[^>]*>.*?<\/(?:h2|h3)>/i, '', 1);

// Support widget settings
const supportSettings = (await getSupportSettings(db)) ?? {
  enabled: 0,
  title: 'Ủng Hộ Tác Giả',
  message: '',
  qr_url: '',
  payment_methods: '',
};
---

<BookLayout
  title={ch.title}
  description={ch.description ?? ''}
  groupedChapters={groupedByTier}
  currentSlug={slug}
  currentModules={modules}
  tier={ch.tier}
  tierLabel={getTierLabel(ch.tier)}
  chapterNo={ch.chapter_no}
>
  <!-- Mobile-optimized Book Header -->
  <BookHeader
    title={ch.title}
    description={ch.description ?? ''}
    tier={ch.tier}
    tierLabel={getTierLabel(ch.tier)}
    chapterNo={ch.chapter_no}
  />

  <!-- Module Navigation Pills (desktop) -->
  <div class="hidden lg:block">
    <ModuleNav modules={modules} />
  </div>

  <!-- Chapter Content -->
  <div class="prose prose-invert prose-headings:text-white prose-p:text-on-surface-variant prose-a:text-primary prose-strong:text-white prose-li:text-on-surface-variant prose-figure:my-6 max-w-none reader-content" id="reader-content" set:html={strippedContent} />

  <!-- Donate Widget -->
  <DonateWidget settings={supportSettings} />

  <!-- Chapter Navigation -->
  <ChapterNav prev={prev} next={next} />

  <!-- Keyword Auto-Linking -->
  <KeywordAutoLink />
</BookLayout>
