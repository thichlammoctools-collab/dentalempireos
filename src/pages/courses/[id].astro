---
import BaseLayout from '../../layouts/BaseLayout.astro';
import VideoPlayer from '../../components/courses/VideoPlayer.astro';
import VideoList from '../../components/courses/VideoList.astro';
import { env } from 'cloudflare:workers';
import { getCourse, getCourseVideos } from '../../lib/course-db';

export const prerender = false;

const db = env.DB;
const courseId = Astro.params.id!;

const [course, user] = await Promise.all([
  getCourse(db, courseId),
  Promise.resolve(Astro.locals.user),
]);

if (!course || !course.is_published) {
  return Astro.redirect('/courses');
}

const isActivated = (user as any)?.is_active === 1;
const isLoggedIn = !!user;
const videos = await getCourseVideos(db, courseId, { publishedOnly: true });
const firstVideo = videos[0];
---

<BaseLayout title={`${course.title} | Dental Empire OS`}>
  <!-- Access gate -->
  {!isLoggedIn ? (
    <div class="max-w-6xl mx-auto px-6 py-20 text-center">
      <div class="glass-card rounded-2xl p-10 max-w-lg mx-auto">
        <span class="material-symbols-outlined text-5xl text-on-surface-variant mb-4 block">lock</span>
        <h2 class="text-2xl font-bold text-white mb-3">Đăng nhập để xem</h2>
        <a href="/login" class="inline-flex items-center gap-2 bg-primary-container text-white px-6 py-3 rounded-xl font-bold mt-4">
          <span class="material-symbols-outlined text-[20px]">login</span>
          Đăng nhập
        </a>
      </div>
    </div>
  ) : !isActivated ? (
    <div class="max-w-6xl mx-auto px-6 py-20 text-center">
      <div class="glass-card rounded-2xl p-10 max-w-lg mx-auto">
        <span class="material-symbols-outlined text-5xl text-tertiary mb-4 block">hourglass_empty</span>
        <h2 class="text-2xl font-bold text-white mb-3">Tài khoản chưa được kích hoạt</h2>
        <p class="text-on-surface-variant">Tài khoản của bạn đang chờ kích hoạt.</p>
      </div>
    </div>
  ) : (
    <div class="max-w-7xl mx-auto px-4 sm:px-6 pb-16 pt-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-on-surface-variant mb-6">
        <a href="/courses" class="hover:text-primary transition-colors flex items-center gap-1">
          <span class="material-symbols-outlined text-[16px]">home</span>
          Khóa học
        </a>
        <span class="material-symbols-outlined text-[16px]">chevron_right</span>
        <span class="text-white">{course.title}</span>
      </nav>

      <!-- Page header -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold text-white mb-2">{course.title}</h1>
        {course.description && (
          <p class="text-on-surface-variant">{course.description}</p>
        )}
        <div class="flex items-center gap-3 mt-3">
          <span class="inline-flex items-center gap-1.5 text-sm text-on-surface-variant">
            <span class="material-symbols-outlined text-[16px]">play_circle</span>
            {videos.length} video{videos.length !== 1 ? 's' : ''}
          </span>
        </div>
      </div>

      <!-- Main content: 2 columns -->
      <div class="flex flex-col lg:flex-row gap-6">
        <!-- Video Player -->
        <div class="flex-1 min-w-0">
          <div id="player-container">
            {firstVideo ? (
              <VideoPlayer
                youtubeId={firstVideo.youtube_id}
                title={firstVideo.title}
              />
            ) : (
              <div class="aspect-video bg-surface-container rounded-xl flex items-center justify-center">
                <div class="text-center">
                  <span class="material-symbols-outlined text-6xl text-on-surface-variant/30">video_library</span>
                  <p class="text-on-surface-variant mt-3">Khóa học chưa có video nào</p>
                </div>
              </div>
            )}
          </div>
          <!-- Current video title -->
          <div id="current-info" class="mt-4 p-4 bg-surface-container rounded-xl">
            <h2 id="current-title" class="text-lg font-bold text-white">
              {firstVideo?.title ?? 'Chọn một video để xem'}
            </h2>
            {firstVideo?.description && (
              <p id="current-desc" class="text-sm text-on-surface-variant mt-2">{firstVideo.description}</p>
            )}
          </div>
        </div>

        <!-- Video List Sidebar -->
        <div class="lg:w-96 shrink-0">
          <div class="bg-surface-container rounded-xl p-4 max-h-[70vh] overflow-y-auto scrollbar-hide">
            <div class="flex items-center justify-between mb-4">
              <h3 class="font-bold text-white text-sm uppercase tracking-wider">Danh sách bài</h3>
              <span class="text-xs text-on-surface-variant">{videos.length} video</span>
            </div>
            <VideoList
              videos={videos}
              activeVideoId={firstVideo?.id}
              onSelect="selectVideo"
            />
          </div>
        </div>
      </div>
    </div>
  )}
</BaseLayout>

<script>
  function selectVideo(btn: HTMLButtonElement) {
    const ytId = btn.dataset.videoId!;
    const title = btn.dataset.videoTitle!;

    // Update player
    const container = document.getElementById('player-container')!;
    container.innerHTML = `<div class="video-player-wrapper relative w-full" style="padding-top: 56.25%;">
      <iframe
        class="absolute inset-0 w-full h-full rounded-xl"
        src="https://www.youtube.com/embed/${ytId}?rel=0&modestbranding=1&autoplay=1"
        title="${title.replace(/"/g, '&quot;')}"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      ></iframe>
    </div>`;

    // Update title
    const titleEl = document.getElementById('current-title');
    const descEl = document.getElementById('current-desc');
    if (titleEl) titleEl.textContent = title;

    const videoObj = btn.dataset.videoObj ? JSON.parse(btn.dataset.videoObj) : null;
    if (descEl) descEl.textContent = videoObj?.description ?? '';

    // Update active state
    document.querySelectorAll('.video-item').forEach((el) => {
      el.classList.remove('bg-primary/10', 'border-primary/30');
      el.classList.add('bg-surface-container', 'border-transparent');
    });
    btn.classList.add('bg-primary/10', 'border-primary/30');
    btn.classList.remove('bg-surface-container', 'border-transparent');
  }

  (window as any).selectVideo = selectVideo;
</script>
