---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { env } from 'cloudflare:workers';
import { createAuth } from '../../lib/auth';
import { getClinicProfile } from '../../lib/clinic-profile-db';

export const prerender = false;

const auth = createAuth(env);
const session = await auth.api.getSession({ headers: Astro.request.headers });
if (!session?.user) {
  return Astro.redirect('/login?redirect=/account/clinic');
}

const profile = await getClinicProfile(env.DB, session.user.id);
const initial = {
  name: profile?.name ?? session.user.name ?? '',
  clinic_name: profile?.clinic_name ?? '',
  clinic_address: profile?.clinic_address ?? '',
  phone: profile?.phone ?? '',
  logo_url: profile?.logo_url ?? null,
  updated_at: profile?.updated_at ?? null,
};
---

<BaseLayout title="Hồ Sơ Phòng Khám | Dental Empire OS" description="Quản lý thông tin phòng khám." noindex={true}>
  <div class="min-h-screen bg-surface pt-24 pb-16">
    <div class="max-w-[860px] mx-auto px-4 md:px-6">

      <!-- Page Header -->
      <div class="flex items-center justify-between mb-6 md:mb-8">
        <div>
          <h1 class="text-xl md:text-2xl font-bold text-white">Hồ sơ phòng khám</h1>
          <p class="text-xs md:text-sm text-on-surface-variant mt-1 hidden sm:block">Thông tin phòng khám dùng để prefill khi làm scanner.</p>
        </div>
        <a
          href="/account/profile"
          class="flex items-center gap-1.5 px-3 py-2 rounded-xl bg-white/5 hover:bg-white/10 border border-outline-variant/20 text-sm text-on-surface-variant hover:text-white transition-all"
        >
          <span class="material-symbols-outlined text-base">arrow_back</span>
          <span class="hidden sm:inline">Quay lại</span>
        </a>
      </div>

      <div class="flex flex-col gap-4 md:gap-6">

        <!-- Logo Upload Card -->
        <div class="glass-card rounded-2xl p-5 md:p-6 border border-outline-variant/20">
          <h2 class="text-sm font-bold text-white mb-1">Logo phòng khám</h2>
          <p class="text-xs text-on-surface-variant mb-5">Logo sẽ hiển thị khi xuất kết quả scanner.</p>

          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-5">
            <!-- Logo preview -->
            <div class="relative group" id="logo-container">
              {initial.logo_url ? (
                <img
                  id="logo-preview"
                  src={initial.logo_url}
                  alt="Clinic logo"
                  class="w-24 h-24 rounded-2xl object-contain bg-white/5 border border-outline-variant/30"
                />
              ) : (
                <div
                  id="logo-preview"
                  class="w-24 h-24 rounded-2xl bg-white/5 border border-dashed border-outline-variant/40 flex items-center justify-center"
                >
                  <span class="material-symbols-outlined text-4xl text-on-surface-variant/30">image</span>
                </div>
              )}

              <!-- Overlay actions -->
              <div class="absolute inset-0 flex items-center justify-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity" id="logo-actions-overlay">
                <button
                  id="logo-change-btn"
                  type="button"
                  class="w-9 h-9 rounded-full bg-black/70 flex items-center justify-center hover:bg-black/80 transition-colors"
                  title="Thay đổi logo"
                >
                  <span class="material-symbols-outlined text-base text-white">edit</span>
                </button>
                {initial.logo_url && (
                  <button
                    id="logo-delete-btn"
                    type="button"
                    class="w-9 h-9 rounded-full bg-rose-500/80 flex items-center justify-center hover:bg-rose-500 transition-colors"
                    title="Xóa logo"
                  >
                    <span class="material-symbols-outlined text-base text-white">delete</span>
                  </button>
                )}
              </div>
            </div>

            <div class="flex-1">
              <p class="text-xs text-on-surface-variant mb-2">Hỗ trợ JPEG, PNG, WebP, SVG. Tối đa 2MB.</p>
              <button
                id="logo-upload-btn"
                type="button"
                class="px-4 py-2 rounded-xl bg-primary text-white text-sm font-bold hover:bg-primary/90 transition-all active:scale-95"
              >
                <span class="flex items-center gap-2">
                  <span class="material-symbols-outlined text-base">cloud_upload</span>
                  Tải lên logo
                </span>
              </button>
              <input id="logo-input" type="file" accept="image/jpeg,image/png,image/webp,image/svg+xml" class="hidden" />
              <p id="logo-error" class="hidden text-xs text-rose-400 mt-2"></p>
            </div>
          </div>
        </div>

        <!-- Clinic Info Form -->
        <div class="glass-card rounded-2xl p-5 md:p-6 border border-outline-variant/20">
          <h2 class="text-sm font-bold text-white mb-5">Thông tin phòng khám</h2>

          <div class="flex flex-col gap-4">
            <!-- Owner name -->
            <div>
              <label class="block text-xs font-semibold text-on-surface-variant mb-1.5" for="name-input">
                Tên người đại diện
              </label>
              <input
                id="name-input"
                type="text"
                value={initial.name}
                maxlength="100"
                placeholder="Nguyễn Văn A"
                class="w-full px-3 py-2.5 bg-white/5 border border-outline-variant rounded-lg text-white placeholder:text-white/30 focus:ring-2 focus:ring-primary focus:outline-none text-sm"
              />
            </div>

            <!-- Clinic name -->
            <div>
              <label class="block text-xs font-semibold text-on-surface-variant mb-1.5" for="clinic-name-input">
                Tên phòng khám <span class="text-rose-400">*</span>
              </label>
              <input
                id="clinic-name-input"
                type="text"
                value={initial.clinic_name}
                maxlength="200"
                placeholder="Nha Khoa Thẩm Mỹ Quốc Tế"
                class="w-full px-3 py-2.5 bg-white/5 border border-outline-variant rounded-lg text-white placeholder:text-white/30 focus:ring-2 focus:ring-primary focus:outline-none text-sm"
              />
            </div>

            <!-- Clinic address -->
            <div>
              <label class="block text-xs font-semibold text-on-surface-variant mb-1.5" for="clinic-address-input">
                Địa chỉ phòng khám
              </label>
              <input
                id="clinic-address-input"
                type="text"
                value={initial.clinic_address}
                maxlength="300"
                placeholder="123 Đường ABC, Quận 1, TP. Hồ Chí Minh"
                class="w-full px-3 py-2.5 bg-white/5 border border-outline-variant rounded-lg text-white placeholder:text-white/30 focus:ring-2 focus:ring-primary focus:outline-none text-sm"
              />
            </div>

            <!-- Phone -->
            <div>
              <label class="block text-xs font-semibold text-on-surface-variant mb-1.5" for="phone-input">
                Số điện thoại
              </label>
              <input
                id="phone-input"
                type="tel"
                value={initial.phone}
                maxlength="20"
                placeholder="0901 234 567"
                class="w-full px-3 py-2.5 bg-white/5 border border-outline-variant rounded-lg text-white placeholder:text-white/30 focus:ring-2 focus:ring-primary focus:outline-none text-sm"
              />
            </div>

            <div class="pt-2">
              <button
                id="save-btn"
                type="button"
                class="w-full sm:w-auto px-6 py-2.5 rounded-xl bg-primary text-white font-bold text-sm hover:bg-primary/90 transition-all active:scale-95 disabled:opacity-40 disabled:cursor-not-allowed"
              >
                <span id="save-btn-text">Lưu thông tin</span>
              </button>
              <p id="save-error" class="hidden text-xs text-rose-400 mt-2"></p>
              <p id="save-success" class="hidden text-xs text-emerald-400 mt-2"></p>
            </div>
          </div>
        </div>

        <!-- Info card -->
        <div class="glass-card rounded-2xl p-4 border border-outline-variant/20 bg-gradient-to-r from-primary/5 to-transparent">
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary text-xl flex-shrink-0 mt-0.5">info</span>
            <div>
              <p class="text-sm font-semibold text-white">Thông tin được sử dụng thế nào?</p>
              <p class="text-xs text-on-surface-variant mt-1">
                Khi bạn làm scanner, thông tin phòng khám sẽ được tự động điền vào form — bạn không cần nhập lại mỗi lần.
                Logo phòng khám sẽ xuất hiện trên kết quả scanner khi bạn chia sẻ.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  // ── Logo Upload ──
  const logoInput = document.getElementById('logo-input') as HTMLInputElement;
  const logoUploadBtn = document.getElementById('logo-upload-btn') as HTMLButtonElement;
  const logoChangeBtn = document.getElementById('logo-change-btn') as HTMLButtonElement;
  const logoDeleteBtn = document.getElementById('logo-delete-btn') as HTMLButtonElement;
  const logoPreview = document.getElementById('logo-preview') as HTMLElement;
  const logoContainer = document.getElementById('logo-container') as HTMLElement;
  const logoError = document.getElementById('logo-error') as HTMLElement;
  const logoActionsOverlay = document.getElementById('logo-actions-overlay') as HTMLElement;

  let currentLogoUrl = logoPreview.tagName === 'IMG'
    ? (logoPreview as HTMLImageElement).src
    : null;

  logoUploadBtn?.addEventListener('click', () => logoInput.click());
  logoChangeBtn?.addEventListener('click', () => logoInput.click());

  logoInput?.addEventListener('change', async () => {
    const file = logoInput.files?.[0];
    if (!file) return;
    logoError.classList.add('hidden');

    if (file.size > 2 * 1024 * 1024) {
      logoError.textContent = 'File quá lớn (tối đa 2MB).';
      logoError.classList.remove('hidden');
      logoInput.value = '';
      return;
    }

    const allowedTypes = ['image/jpeg', 'image/png', 'image/webp', 'image/svg+xml'];
    if (!allowedTypes.includes(file.type)) {
      logoError.textContent = 'Chỉ hỗ trợ JPEG, PNG, WebP, SVG.';
      logoError.classList.remove('hidden');
      logoInput.value = '';
      return;
    }

    // Optimistic preview
    const previewUrl = URL.createObjectURL(file);
    if (logoPreview.tagName === 'IMG') {
      (logoPreview as HTMLImageElement).src = previewUrl;
    } else {
      const img = document.createElement('img');
      img.id = 'logo-preview';
      img.src = previewUrl;
      img.alt = 'Clinic logo';
      img.className = 'w-24 h-24 rounded-2xl object-contain bg-white/5 border border-outline-variant/30';
      logoPreview.parentNode?.replaceChild(img, logoPreview);
    }

    // Show overlay on new image
    if (!logoActionsOverlay) {
      const newOverlay = document.createElement('div');
      newOverlay.id = 'logo-actions-overlay';
      newOverlay.className = 'absolute inset-0 flex items-center justify-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity';
      logoContainer?.querySelector('img')?.parentNode?.insertBefore(newOverlay, logoContainer.querySelector('img')?.nextSibling ?? null);
      const delBtn = document.createElement('button');
      delBtn.id = 'logo-delete-btn';
      delBtn.type = 'button';
      delBtn.className = 'w-9 h-9 rounded-full bg-rose-500/80 flex items-center justify-center hover:bg-rose-500 transition-colors';
      delBtn.title = 'Xóa logo';
      delBtn.innerHTML = '<span class="material-symbols-outlined text-base text-white">delete</span>';
      delBtn.addEventListener('click', deleteLogo);
      newOverlay.appendChild(delBtn);
    }

    try {
      const fd = new FormData();
      fd.append('file', file);
      const res = await fetch('/api/account/logo-upload', { method: 'POST', body: fd });
      if (!res.ok) {
        const body = await res.json().catch(() => ({}));
        throw new Error(body.error || 'Upload failed');
      }
      currentLogoUrl = previewUrl;
    } catch (err: any) {
      // Revert preview
      if (currentLogoUrl) {
        (logoPreview as HTMLImageElement).src = currentLogoUrl;
      }
      logoError.textContent = err?.message || 'Có lỗi xảy ra.';
      logoError.classList.remove('hidden');
    }
    logoInput.value = '';
  });

  async function deleteLogo() {
    try {
      const res = await fetch('/api/account/logo-upload', { method: 'DELETE' });
      if (!res.ok) throw new Error('Delete failed');

      const placeholder = document.createElement('div');
      placeholder.id = 'logo-preview';
      placeholder.className = 'w-24 h-24 rounded-2xl bg-white/5 border border-dashed border-outline-variant/40 flex items-center justify-center';
      placeholder.innerHTML = '<span class="material-symbols-outlined text-4xl text-on-surface-variant/30">image</span>';
      logoPreview.parentNode?.replaceChild(placeholder, logoPreview);
      currentLogoUrl = null;

      if (logoActionsOverlay) logoActionsOverlay.remove();
    } catch (_) {
      window.showToast('Xóa logo thất bại', 'error');
    }
  }

  logoDeleteBtn?.addEventListener('click', deleteLogo);

  // ── Form Save ──
  const nameInput = document.getElementById('name-input') as HTMLInputElement;
  const clinicNameInput = document.getElementById('clinic-name-input') as HTMLInputElement;
  const clinicAddressInput = document.getElementById('clinic-address-input') as HTMLInputElement;
  const phoneInput = document.getElementById('phone-input') as HTMLInputElement;
  const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
  const saveBtnText = document.getElementById('save-btn-text') as HTMLElement;
  const saveError = document.getElementById('save-error') as HTMLElement;
  const saveSuccess = document.getElementById('save-success') as HTMLElement;

  function checkDirty() {
    const orig = {
      name: nameInput.dataset.orig ?? '',
      clinic_name: clinicNameInput.dataset.orig ?? '',
      clinic_address: clinicAddressInput.dataset.orig ?? '',
      phone: phoneInput.dataset.orig ?? '',
    };
    const curr = {
      name: nameInput.value,
      clinic_name: clinicNameInput.value,
      clinic_address: clinicAddressInput.value,
      phone: phoneInput.value,
    };
    return JSON.stringify(orig) !== JSON.stringify(curr);
  }

  // Store originals
  nameInput.dataset.orig = nameInput.value;
  clinicNameInput.dataset.orig = clinicNameInput.value;
  clinicAddressInput.dataset.orig = clinicAddressInput.value;
  phoneInput.dataset.orig = phoneInput.value;

  saveBtn?.addEventListener('click', async () => {
    const clinic_name = clinicNameInput.value.trim();
    if (!clinic_name) {
      saveError.textContent = 'Vui lòng nhập tên phòng khám.';
      saveError.classList.remove('hidden');
      saveSuccess.classList.add('hidden');
      return;
    }

    saveError.classList.add('hidden');
    saveSuccess.classList.add('hidden');
    saveBtn.disabled = true;
    saveBtnText.textContent = 'Đang lưu...';

    try {
      const res = await fetch('/api/account/clinic-profile', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: nameInput.value.trim() || null,
          clinic_name,
          clinic_address: clinicAddressInput.value.trim() || null,
          phone: phoneInput.value.trim() || null,
        }),
      });

      if (!res.ok) {
        const body = await res.json().catch(() => ({}));
        throw new Error(body.error || 'Save failed');
      }

      // Update originals
      nameInput.dataset.orig = nameInput.value;
      clinicNameInput.dataset.orig = clinicNameInput.value;
      clinicAddressInput.dataset.orig = clinicAddressInput.value;
      phoneInput.dataset.orig = phoneInput.value;

      saveSuccess.textContent = 'Đã lưu thông tin phòng khám.';
      saveSuccess.classList.remove('hidden');
      window.showToast('Lưu thông tin thành công', 'success');
    } catch (err: any) {
      saveError.textContent = err?.message || 'Có lỗi xảy ra.';
      saveError.classList.remove('hidden');
      window.showToast('Lưu thông tin thất bại', 'error');
    } finally {
      saveBtn.disabled = false;
      saveBtnText.textContent = 'Lưu thông tin';
    }
  });

  // Track dirty state
  [nameInput, clinicNameInput, clinicAddressInput, phoneInput].forEach(el => {
    el?.addEventListener('input', () => {
      saveBtn.disabled = !checkDirty();
    });
  });
  saveBtn.disabled = true;
</script>
