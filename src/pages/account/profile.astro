---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NotificationBell from '../../components/layout/NotificationBell.astro';
import { env } from 'cloudflare:workers';
import { createAuth } from '../../lib/auth';
import { listQuestionsByUser } from '../../lib/question-db';
import { listChapters } from '../../lib/book-db';

export const prerender = false;

const auth = createAuth(env);
const result = await auth.api.getSession({ headers: Astro.request.headers });
if (!result?.user) {
  return Astro.redirect('/login?redirect=/account/profile');
}

const user = Astro.locals.user;

const questions = await listQuestionsByUser(env.DB, result.user.id);
const chapters = await listChapters(env.DB);
const chapterMap = new Map(chapters.map(c => [c.id, { title: c.title, tier: c.tier, chapter_no: c.chapter_no }]));

// Purchased products (active access)
const now = new Date().toISOString();
const { results: purchases } = await env.DB
  .prepare(
    `SELECT
       a."granted_at",
       a."expires_at",
       a."is_active"  as "access_active",
       p."id"         as "product_id",
       p."name"       as "product_name",
       p."type"       as "product_type",
       p."price"      as "product_price",
       p."reference_id",
       o."amount"     as "paid_amount",
       o."paid_at"
     FROM "access" a
     JOIN "product" p ON a."product_id" = p."id"
     JOIN "order"   o ON a."order_id"   = o."id"
     WHERE a."user_id" = ? AND a."is_active" = 1
       AND (a."expires_at" IS NULL OR a."expires_at" > ?)
     ORDER BY a."granted_at" DESC`
  )
  .bind(result.user.id, now)
  .all<{
    granted_at: string;
    expires_at: string | null;
    access_active: number;
    product_id: string;
    product_name: string;
    product_type: string;
    product_price: number;
    reference_id: string | null;
    paid_amount: number;
    paid_at: string | null;
  }>();

const productTypeMap: Record<string, { label: string; icon: string }> = {
  course_unlock:      { label: 'Khóa học',       icon: 'school' },
  document_unlock:    { label: 'Tài liệu',       icon: 'description' },
  booking:           { label: 'Đặt lịch',        icon: 'event' },
  event_ticket:      { label: 'Vé sự kiện',      icon: 'confirmation_number' },
  survey_unlock:     { label: 'Khảo sát',        icon: 'analytics' },
};

function productLink(p: typeof purchases[0]): string {
  if (p.product_type === 'course_unlock' && p.reference_id) return `/courses/${p.reference_id}`;
  if (p.product_type === 'document_unlock') return '/resources';
  return '#';
}

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' });
}

function formatPrice(vnd: number): string {
  return vnd.toLocaleString('vi-VN') + 'đ';
}

function timeAgo(dateStr: string): string {
  const diff = Date.now() - new Date(dateStr).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'vừa xong';
  if (mins < 60) return `${mins} phút trước`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return `${hrs} giờ trước`;
  const days = Math.floor(hrs / 24);
  return `${days} ngày trước`;
}

function statusInfo(status: string) {
  if (status === 'open') return { label: 'Chờ trả lời', icon: 'pending', color: 'text-error bg-error/10' };
  if (status === 'answered') return { label: 'Đã trả lời', icon: 'check_circle', color: 'text-primary bg-primary/10' };
  return { label: 'Đã đóng', icon: 'archive', color: 'text-on-surface-variant bg-surface-container-high' };
}
---

<BaseLayout title="Hồ Sơ Cá Nhân | Dental Empire OS" description="Quản lý thông tin hồ sơ cá nhân." noindex={true}>
  <div class="min-h-screen bg-surface pt-24 pb-16">
    <div class="max-w-[640px] mx-auto px-6">

      <!-- Page Header -->
      <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-white">Hồ sơ cá nhân</h1>
        <NotificationBell />
      </div>

      <!-- Section 1: Avatar -->
      <div class="glass-card rounded-2xl p-6 border border-outline-variant/20 mb-4">
        <div class="flex flex-col items-center gap-4">
          <div class="relative group">
            {user?.image ? (
              <img
                id="avatar-preview"
                src={user.image}
                alt="Avatar"
                class="w-32 h-32 rounded-full object-cover border-2 border-outline-variant/30"
              />
            ) : (
              <div
                id="avatar-preview"
                class="w-32 h-32 rounded-full bg-primary/10 flex items-center justify-center border-2 border-outline-variant/30"
              >
                <span class="material-symbols-outlined text-6xl text-primary/40">person</span>
              </div>
            )}
            <button
              id="avatar-trigger"
              type="button"
              class="absolute inset-0 flex items-center justify-center bg-black/50 rounded-full opacity-0 group-hover:opacity-100 transition-opacity"
              aria-label="Thay đổi ảnh"
            >
              <span class="material-symbols-outlined text-white text-2xl">photo_camera</span>
            </button>
          </div>

          <input id="avatar-input" type="file" accept="image/jpeg,image/png,image/webp" class="hidden" />
          <p class="text-xs text-on-surface-variant">JPEG, PNG hoặc WebP · Tối đa 5 MB</p>

          <p id="avatar-error" class="hidden text-sm text-rose-400"></p>
        </div>
      </div>

      <!-- Section 2: Display Name -->
      <div class="glass-card rounded-2xl p-6 border border-outline-variant/20 mb-4">
        <label class="block text-sm font-semibold text-on-surface-variant mb-1.5" for="name-input">Tên hiển thị</label>
        <input
          id="name-input"
          type="text"
          value={user?.name ?? ''}
          maxlength="100"
          class="w-full px-4 py-3 bg-white/5 border border-outline-variant rounded-xl text-white placeholder:text-white/30 focus:ring-2 focus:ring-primary focus:outline-none text-sm"
        />

        <p id="name-error" class="hidden text-sm text-rose-400 mt-2"></p>

        <button
          id="name-save-btn"
          type="button"
          disabled
          class="mt-4 px-6 py-2.5 btn-primary-metallic font-bold rounded-xl text-sm active:scale-95 transition-all disabled:opacity-40 disabled:cursor-not-allowed"
        >
          Lưu thay đổi
        </button>
      </div>

      <!-- Section 3: Email (read-only) -->
      <div class="glass-card rounded-2xl p-6 border border-outline-variant/20 mb-4">
        <label class="block text-sm font-semibold text-on-surface-variant mb-1.5">Email</label>
        <p class="text-white text-sm">{user?.email}</p>
        <p class="text-xs text-on-surface-variant mt-2">Email không thể thay đổi vì lý do bảo mật.</p>
      </div>

      <!-- Section 4: Purchased Products -->
      <div class="glass-card rounded-2xl p-6 border border-outline-variant/20 mb-4">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-semibold text-on-surface-variant uppercase tracking-wider">Sản phẩm đã mua</h2>
          <span class="text-xs text-on-surface-variant">{purchases.length}</span>
        </div>

        {purchases.length === 0 ? (
          <div class="text-center py-8">
            <span class="material-symbols-outlined text-5xl text-on-surface-variant/20 block mb-3">shopping_bag</span>
            <p class="text-sm text-on-surface-variant mb-1">Chưa có sản phẩm nào</p>
            <p class="text-xs text-on-surface-variant/70 mb-4">Khám phá các khóa học và tài liệu của chúng tôi.</p>
            <a
              href="/#courses"
              class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-primary text-on-primary font-bold text-xs hover:opacity-90 transition-all"
            >
              <span class="material-symbols-outlined text-sm">school</span>
              Khám phá khóa học
            </a>
          </div>
        ) : (
          <div class="flex flex-col gap-2">
            {purchases.map(p => {
              const typeInfo = productTypeMap[p.product_type] || { label: p.product_type, icon: 'inventory_2' };
              const link = productLink(p);
              const expiry = p.expires_at ? formatDate(p.expires_at) : null;
              return (
                <a
                  href={link}
                  class="flex items-center gap-3 p-3 rounded-xl bg-white/5 hover:bg-white/10 transition-colors group"
                >
                  <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0">
                    <span class="material-symbols-outlined text-base text-primary">{typeInfo.icon}</span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <h3 class="text-sm font-semibold text-white truncate group-hover:text-primary transition-colors">{p.product_name}</h3>
                    <div class="flex items-center gap-2 mt-1 text-[11px] text-on-surface-variant">
                      <span class="px-1.5 py-0.5 rounded bg-surface-container-high text-on-surface-variant">{typeInfo.label}</span>
                      <span>{formatPrice(p.paid_amount)}</span>
                      {p.paid_at && <span>· {formatDate(p.paid_at)}</span>}
                    </div>
                  </div>
                  <div class="text-right flex-shrink-0">
                    <div class="flex items-center gap-1 text-[11px]">
                      <span class="material-symbols-outlined text-xs text-primary">verified</span>
                      <span class="text-primary font-bold">Đã mua</span>
                    </div>
                    {expiry ? (
                      <p class="text-[10px] text-on-surface-variant/60 mt-0.5">HSD: {expiry}</p>
                    ) : (
                      <p class="text-[10px] text-primary/60 mt-0.5">Vĩnh viễn</p>
                    )}
                  </div>
                </a>
              );
            })}
          </div>
        )}
      </div>

      <!-- Section 5: My Questions -->
      <div class="glass-card rounded-2xl p-6 border border-outline-variant/20">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-semibold text-on-surface-variant uppercase tracking-wider">Câu hỏi của tôi</h2>
          <span class="text-xs text-on-surface-variant">{questions.length}</span>
        </div>

        {questions.length === 0 ? (
          <div class="text-center py-8">
            <span class="material-symbols-outlined text-5xl text-on-surface-variant/20 block mb-3">question_answer</span>
            <p class="text-sm text-on-surface-variant mb-1">Chưa có câu hỏi nào</p>
            <p class="text-xs text-on-surface-variant/70 mb-4">Hãy đọc sách và nhấn nút "Hỏi Tác Giả" để đặt câu hỏi.</p>
            <a
              href="/book"
              class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-primary text-on-primary font-bold text-xs hover:opacity-90 transition-all"
            >
              <span class="material-symbols-outlined text-sm">menu_book</span>
              Đọc sách
            </a>
          </div>
        ) : (
          <div class="flex flex-col gap-2">
            {questions.slice(0, 5).map(q => {
              const ch = chapterMap.get(q.chapter_id);
              const st = statusInfo(q.status);
              return (
                <a
                  href={`/my-questions/${q.id}`}
                  class="flex items-start gap-3 p-3 rounded-xl bg-white/5 hover:bg-white/10 transition-colors group"
                >
                  <div class:list={['w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0', st.color]}>
                    <span class="material-symbols-outlined text-sm">{st.icon}</span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <h3 class="text-sm font-semibold text-white truncate group-hover:text-primary transition-colors">{q.title}</h3>
                    <div class="flex items-center gap-2 mt-1 text-[11px] text-on-surface-variant">
                      {ch && <span>Tier {ch.tier} · Ch{String(ch.chapter_no).padStart(2, '0')}</span>}
                      <span>·</span>
                      <span>{timeAgo(q.createdAt)}</span>
                    </div>
                  </div>
                  <span class="material-symbols-outlined text-on-surface-variant/30 group-hover:text-primary transition-colors self-center">chevron_right</span>
                </a>
              );
            })}
            {questions.length > 5 && (
              <p class="text-xs text-center text-on-surface-variant mt-2">
                Và {questions.length - 5} câu hỏi khác...
              </p>
            )}
          </div>
        )}
      </div>

    </div>
  </div>

  <script>
    import { authClient } from '../../lib/auth-client';

    declare function showToast(msg: string, type?: string, duration?: number): void;

    const originalName = (document.getElementById('name-input') as HTMLInputElement).value;
    const originalImageSrc = document.getElementById('avatar-preview')?.getAttribute('src') ?? '';

    // ── Avatar upload ──
    const avatarInput = document.getElementById('avatar-input') as HTMLInputElement;
    const avatarTrigger = document.getElementById('avatar-trigger') as HTMLButtonElement;
    const avatarPreview = document.getElementById('avatar-preview') as HTMLElement;
    const avatarError = document.getElementById('avatar-error') as HTMLElement;
    let isUploading = false;

    avatarTrigger?.addEventListener('click', () => avatarInput.click());

    avatarInput?.addEventListener('change', async () => {
      const file = avatarInput.files?.[0];
      if (!file) return;

      avatarError.classList.add('hidden');

      if (file.size > 5 * 1024 * 1024) {
        avatarError.textContent = 'File quá lớn. Vui lòng chọn file dưới 5 MB.';
        avatarError.classList.remove('hidden');
        avatarInput.value = '';
        return;
      }

      const allowedTypes = ['image/jpeg', 'image/png', 'image/webp'];
      if (!allowedTypes.includes(file.type)) {
        avatarError.textContent = 'Định dạng không hỗ trợ. Chỉ chấp nhận JPEG, PNG hoặc WebP.';
        avatarError.classList.remove('hidden');
        avatarInput.value = '';
        return;
      }

      const previewUrl = URL.createObjectURL(file);
      if (avatarPreview.tagName === 'IMG') {
        (avatarPreview as HTMLImageElement).src = previewUrl;
      } else {
        const img = document.createElement('img');
        img.id = 'avatar-preview';
        img.src = previewUrl;
        img.alt = 'Avatar';
        img.className = 'w-32 h-32 rounded-full object-cover border-2 border-outline-variant/30';
        avatarPreview.parentNode?.replaceChild(img, avatarPreview);
      }

      if (isUploading) return;
      isUploading = true;

      try {
        const fd = new FormData();
        fd.append('file', file);
        const res = await fetch('/api/account/avatar', { method: 'POST', body: fd });

        if (!res.ok) {
          const body = await res.json().catch(() => ({}));
          throw new Error(body.error || 'Upload failed');
        }

        const { url } = await res.json();

        const { error } = await authClient.updateUser({ image: url });
        if (error) throw new Error(error.message || 'Failed to update user');

        window.showToast('Cập nhật ảnh thành công', 'success');
      } catch (err: any) {
        if (originalImageSrc && avatarPreview.tagName === 'IMG') {
          (avatarPreview as HTMLImageElement).src = originalImageSrc;
        }
        avatarError.textContent = err?.message || 'Có lỗi xảy ra. Vui lòng thử lại.';
        avatarError.classList.remove('hidden');
        window.showToast('Cập nhật ảnh thất bại', 'error');
      } finally {
        isUploading = false;
        avatarInput.value = '';
      }
    });

    // ── Name save ──
    const nameInput = document.getElementById('name-input') as HTMLInputElement;
    const nameSaveBtn = document.getElementById('name-save-btn') as HTMLButtonElement;
    const nameError = document.getElementById('name-error') as HTMLElement;

    nameInput?.addEventListener('input', () => {
      const dirty = nameInput.value.trim() !== originalName.trim();
      nameSaveBtn.disabled = !dirty || nameInput.value.trim() === '';
    });

    nameSaveBtn?.addEventListener('click', async () => {
      const newName = nameInput.value.trim();
      if (!newName || newName === originalName.trim()) return;

      nameSaveBtn.disabled = true;
      nameSaveBtn.textContent = 'Đang lưu...';
      nameError.classList.add('hidden');

      try {
        const { error } = await authClient.updateUser({ name: newName });
        if (error) throw new Error(error.message || 'Failed to update');

        window.showToast('Cập nhật tên thành công', 'success');
        nameSaveBtn.textContent = 'Lưu thay đổi';
      } catch (err: any) {
        nameError.textContent = err?.message || 'Có lỗi xảy ra.';
        nameError.classList.remove('hidden');
        window.showToast('Cập nhật tên thất bại', 'error');
        nameSaveBtn.disabled = false;
        nameSaveBtn.textContent = 'Lưu thay đổi';
      }
    });
  </script>
</BaseLayout>
