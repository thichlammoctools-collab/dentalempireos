---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { env } from 'cloudflare:workers';
import { getSurveyDefinitionFullBySlug } from '../../lib/survey-config-db';

export const prerender = false;

const slug = Astro.params.slug ?? '';
const full = await getSurveyDefinitionFullBySlug(env.DB, slug);
---

<BaseLayout title="Test" noindex={true}>
  <div class="min-h-screen bg-surface text-white pt-24 p-8">
    <h1>Test: {slug}</h1>
    {full ? (
      <div>
        <p>Found: {full.definition.title_vi}</p>
        <p>Sections: {full.sections.length}</p>
      </div>
    ) : (
      <p>Not found</p>
    )}
  </div>
</BaseLayout>
