---
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = false;
---

<BaseLayout title="Scanner Pack | Dental Empire OS" description="Bộ 5 Mini Scanner + AI Analysis — chỉ 499K">
  <div class="min-h-screen bg-surface pt-20 pb-12">
    <div class="max-w-3xl mx-auto px-4 text-center">

      <!-- Header -->
      <div class="mb-2">
        <span class="inline-block px-3 py-1 text-xs font-bold uppercase tracking-widest text-amber-400 bg-amber-400/10 rounded-full mb-4">Bundle Deal</span>
        <h1 class="text-3xl md:text-4xl font-bold text-white mb-3">Scanner Pack</h1>
        <p class="text-on-surface-variant text-lg mb-2">Bộ 5 Mini Scanner + AI Analysis</p>
        <p class="text-on-surface-variant text-sm">Mua 1 lần — mở khóa AI Analysis cho cả 5 scanner. Dùng mãi mãi.</p>
      </div>

      <!-- Price -->
      <div class="my-8">
        <div class="inline-flex items-baseline gap-1">
          <span class="text-5xl font-black text-white">499K</span>
          <span class="text-xl text-on-surface-variant">/ lần</span>
        </div>
        <p class="text-xs text-emerald-400 mt-2">Tiết kiệm 95% so với mua lẻ từng scanner</p>
      </div>

      <!-- Scanner list -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 text-left mb-8">
        <div class="glass-card rounded-xl p-4 border border-blue-500/30 bg-gradient-to-br from-blue-600/10 to-transparent">
          <span class="material-symbols-outlined text-blue-400 text-xl mb-2 block">settings</span>
          <h3 class="text-sm font-bold text-white mb-1">Hệ Thống Check</h3>
          <p class="text-xs text-on-surface-variant">Triển Khai Hệ Thống</p>
        </div>
        <div class="glass-card rounded-xl p-4 border border-emerald-500/30 bg-gradient-to-br from-emerald-600/10 to-transparent">
          <span class="material-symbols-outlined text-emerald-400 text-xl mb-2 block">groups</span>
          <h3 class="text-sm font-bold text-white mb-1">Nhân Sự Check</h3>
          <p class="text-xs text-on-surface-variant">Quản Trị Nhân Sự</p>
        </div>
        <div class="glass-card rounded-xl p-4 border border-amber-500/30 bg-gradient-to-br from-amber-600/10 to-transparent">
          <span class="material-symbols-outlined text-amber-400 text-xl mb-2 block">account_tree</span>
          <h3 class="text-sm font-bold text-white mb-1">Quy Trình Check</h3>
          <p class="text-xs text-on-surface-variant">Triển Khai Quy Trình</p>
        </div>
        <div class="glass-card rounded-xl p-4 border border-pink-500/30 bg-gradient-to-br from-pink-600/10 to-transparent">
          <span class="material-symbols-outlined text-pink-400 text-xl mb-2 block">sentiment_satisfied</span>
          <h3 class="text-sm font-bold text-white mb-1">Tiếp Đón Check</h3>
          <p class="text-xs text-on-surface-variant">Trải Nghiệm Bệnh Nhân</p>
        </div>
        <div class="glass-card rounded-xl p-4 border border-violet-500/30 bg-gradient-to-br from-violet-600/10 to-transparent">
          <span class="material-symbols-outlined text-violet-400 text-xl mb-2 block">payments</span>
          <h3 class="text-sm font-bold text-white mb-1">Tài Chính Check</h3>
          <p class="text-xs text-on-surface-variant">Quản Trị Tài Chính</p>
        </div>
        <div class="glass-card rounded-xl p-4 border border-surface-container bg-surface-container-high flex flex-col items-center justify-center gap-2">
          <span class="material-symbols-outlined text-primary text-2xl">auto_awesome</span>
          <p class="text-xs text-primary font-bold text-center">+ AI Analysis<br/>cho mỗi scanner</p>
        </div>
      </div>

      <!-- CTA -->
      <button
        id="buy-pack-btn"
        class="w-full sm:w-auto px-10 py-4 rounded-2xl bg-primary text-white font-bold text-lg hover:bg-primary/90 transition-all shadow-lg shadow-primary/20 mb-4"
      >
        Mua Scanner Pack — 499.000đ
      </button>
      <p class="text-xs text-on-surface-variant/60">Thanh toán qua PayOS · Mua 1 lần dùng mãi mãi</p>

      <!-- Note -->
      <div class="mt-8 p-4 rounded-xl bg-surface-container-low border border-outline-variant/20 text-left">
        <p class="text-xs text-on-surface-variant">
          <strong class="text-white">Bao gồm:</strong> AI Analysis cá nhân hóa cho mỗi scanner, dựa trên kết quả của riêng bạn. Không giới hạn số lần sử dụng.
        </p>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('buy-pack-btn')?.addEventListener('click', async () => {
      const btn = document.getElementById('buy-pack-btn') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Đang chuyển...';
      try {
        const res = await fetch('/api/payos/create-payment', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ product_id: 'prod-scanner-pack' }),
        });
        const data = await res.json() as { checkoutUrl?: string; error?: string };
        if (data.checkoutUrl) {
          window.location.href = data.checkoutUrl;
        } else {
          alert(data.error ?? 'Có lỗi xảy ra');
          btn.disabled = false;
          btn.textContent = 'Mua Scanner Pack — 499.000đ';
        }
      } catch {
        alert('Có lỗi xảy ra');
        btn.disabled = false;
        btn.textContent = 'Mua Scanner Pack — 499.000đ';
      }
    });
  </script>
</BaseLayout>
