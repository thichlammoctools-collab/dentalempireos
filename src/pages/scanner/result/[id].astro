  }
  .insight-section-label.success { color: #22c55e; }
  .insight-section-label.warning { color: #f59e0b; }
  .insight-items { display: flex; flex-direction: column; gap: 0.6rem; }
  .insight-item {
    background: var(--surface-container);
    border-radius: 0.6rem;
    padding: 0.75rem 1rem;
  }
  .insight-item-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }
  .insight-question {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--on-surface);
    flex: 1;
    min-width: 0;
  }
  .insight-badge {
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.2rem 0.5rem;
    border-radius: 0.3rem;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .success-badge { background: rgba(34,197,94,0.15); color: #22c55e; }
  .warning-badge { background: rgba(245,158,11,0.15); color: #f59e0b; }
  .insight-bar-track {
    height: 6px;
    background: rgba(255,255,255,0.05);
    border-radius: 999px;
    overflow: hidden;
  }
  .insight-bar-fill {
    height: 100%;
    border-radius: 999px;
    transition: width 1s ease;
  }

  /* ── Section 2: Reading card ── */
  .reading-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .reading-item {
