---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { env } from 'cloudflare:workers';
import { marked } from 'marked';
import {
  getSurveyDefinitionFull,
  parseScoringRules,
  parseAiConfig,
  parseScaleLabels,
} from '../../../lib/survey-config-db';
import {
  getScannerResponse,
  parseScores,
  parseResponses,
} from '../../../lib/scanner-response-db';
import { getScoreLevel } from '../../../lib/scoring-engine';
import { getChaptersByRefs, getChapterExcerpt } from '../../../lib/book-db';
import { createAuth } from '../../../lib/auth';
import { isResponseOwnedByUser } from '../../../lib/scanner-history-db';
import { getUserByEmail } from '../../../lib/user-db';

export const prerender = false;

const idParam = Astro.params.id;
const id = idParam ? parseInt(idParam, 10) : 0;

if (!id || Number.isNaN(id)) {
  return Astro.redirect('/');
}

const response = await getScannerResponse(env.DB, id);
if (!response) {
  return new Response('Response not found', { status: 404 });
}

// Auth check — require login
const auth = createAuth(env);
const session = await auth.api.getSession({ headers: Astro.request.headers });
if (!session?.user) {
  return Astro.redirect(`/login?redirect=/scanner/result/${id}`);
}

// Ownership check — must own this response (via scanner_history or email match)
const owned = await isResponseOwnedByUser(env.DB, session.user.id, id);
const ownsByEmail = response.email
  ? (await getUserByEmail(env.DB, response.email))?.id === session.user.id
  : false;

if (!owned && !ownsByEmail) {
  return new Response(
    'Bạn không có quyền xem kết quả này.',
    { status: 403 },
  );
}

const full = await getSurveyDefinitionFull(env.DB, response.survey_id);
if (!full) {
  return new Response('Survey not found', { status: 404 });
}

const { definition } = full;
const lang = (response.lang === 'en' ? 'en' : 'vi') as 'vi' | 'en';
const scoringRules = parseScoringRules(definition.scoring_rules);
const aiConfig = parseAiConfig(definition.ai_config);

const scores = parseScores(response.scores_json);
const totalScore = scores.total ?? 0;

// Build dimension list with names
type DimRow = { id: string; name: string; score: number; level: ReturnType<typeof getScoreLevel> };
const dimensions: DimRow[] = [];
if (scoringRules) {
  for (const dim of scoringRules.dimensions) {
    const score = scores[dim.id] ?? 0;
    dimensions.push({
      id: dim.id,
      name: lang === 'vi' ? (dim.name_vi ?? dim.id) : (dim.name_en ?? dim.name_vi ?? dim.id),
      score,
      level: getScoreLevel(score, scoringRules, lang),
    });
  }
}

const totalLevel = getScoreLevel(totalScore, scoringRules ?? { dimensions: [], total_formula: 'average', thresholds: { excellent: 75, good: 55, needs_work: 35, critical: 0 } }, lang);

// Pre-render analysis and plan
marked.setOptions({ gfm: true, breaks: true });
const analysisHtml = response.ai_analysis ? (marked.parse(response.ai_analysis) as string) : '';
const hasAnalysis = !!analysisHtml;
const hasPlan = !!response.ai_plan;
const planHtml = response.ai_plan ? (marked.parse(response.ai_plan) as string) : '';

// ── Section 1: Strengths & Needs Work (computed server-side) ──────────────────
type InsightItem = { question: string; value: number; label: string; score: number };
const insights: { strengths: InsightItem[]; needsWork: InsightItem[] } = { strengths: [], needsWork: [] };

const parsedResponses = parseResponses(response.responses_json);
for (const section of full.sections) {
  for (const q of section.questions) {
    if (q.type === 'select') {
      const v = parsedResponses[q.question_id];
      if (typeof v === 'number') {
        const labels = parseScaleLabels(q.scale_labels_vi);
        const label = labels[String(v)] ?? String(v);
        const rawScore = (v / 5) * 100;
        if (v >= 4) {
          insights.strengths.push({ question: lang === 'vi' ? q.label_vi : (q.label_en ?? q.label_vi), value: v, label, score: rawScore });
        } else {
          insights.needsWork.push({ question: lang === 'vi' ? q.label_vi : (q.label_en ?? q.label_vi), value: v, label, score: rawScore });
        }
      }
    }
  }
}

// ── Section 2: Reading recommendations ───────────────────────────────────────
type ChapterRef = { chapter_no: number; title: string; id: string; excerpt: string | null };
const chapterRefs: ChapterRef[] = [];
if (definition.chapter_refs) {
  try {
    const refs: string[] = JSON.parse(definition.chapter_refs);
    const chapters = await getChaptersByRefs(env.DB, refs);
    for (const ch of chapters) {
      const excerpt = await getChapterExcerpt(env.DB, ch.id);
      chapterRefs.push({ chapter_no: ch.chapter_no, title: ch.title, id: ch.id, excerpt });
    }
  } catch { /* ignore */ }
}

// Resolve linked product (for paywall)
let linkedProduct: { id: string; name: string; price: number } | null = null;
try {
  // Try: ai_application → product (for scanners with AI app)
  const app = await env.DB
    .prepare('SELECT id FROM "ai_application" WHERE "slug" = ? OR "id" = ?')
    .bind(definition.slug, `survey-${definition.id}`)
    .first<{ id: string }>();
  if (app) {
    linkedProduct = await env.DB
      .prepare('SELECT id, name, price FROM "product" WHERE "app_id" = ? AND "is_active" = 1 ORDER BY "price" DESC LIMIT 1')
      .bind(app.id)
      .first<{ id: string; name: string; price: number }>();
  }
  // Try: product.reference_id = survey id (for scanners without AI app)
  if (!linkedProduct) {
    linkedProduct = await env.DB
      .prepare('SELECT id, name, price FROM "product" WHERE "reference_id" = ? AND "is_active" = 1 ORDER BY "price" DESC LIMIT 1')
      .bind(definition.id)
      .first<{ id: string; name: string; price: number }>();
  }
  // Try: scanner pack — always grant access
  if (!linkedProduct) {
    const packProduct = await env.DB
      .prepare('SELECT id, name, price FROM "product" WHERE "id" = \'prod-scanner-pack\' AND "is_active" = 1 LIMIT 1')
      .first<{ id: string; name: string; price: number }>();
    if (packProduct) linkedProduct = packProduct;
  }
} catch {
  // ignore
}

const productId = linkedProduct?.id ?? `survey-${definition.id}`;
const priceFormatted = linkedProduct
  ? new Intl.NumberFormat('vi-VN').format(linkedProduct.price)
  : linkedProduct === null && definition.is_free === 1 ? '0' : '199.000';

const surveyTitle = lang === 'vi' ? definition.title_vi : (definition.title_en || definition.title_vi);

// AI analysis sections from ai_config (optional, used for header)
const analysisSections = aiConfig.analysis_sections ?? [];

// Cross-sell suggestions: pick 2 other active surveys
let crossSells: Array<{ id: string; slug: string; title_vi: string; title_en: string; description_vi: string | null }> = [];
try {
  const result = await env.DB
    .prepare(
      `SELECT id, slug, title_vi, title_en, description_vi
       FROM "survey_definition"
       WHERE status = 'active' AND id != ?
       ORDER BY order_index ASC
       LIMIT 3`,
    )
    .bind(definition.id)
    .all<any>();
  crossSells = (result.results ?? []).map((r) => ({
    id: r.id,
    slug: r.slug,
    title_vi: r.title_vi,
    title_en: r.title_en || r.title_vi,
    description_vi: r.description_vi,
  }));
} catch {}
---

<BaseLayout
  title={`${surveyTitle} #${id} | Dental Empire OS`}
  description={lang === 'vi' ? 'Bản phân tích hệ thống quản trị phòng khám' : 'Clinic management analysis'}
  noindex={true}
>
  <section class="result-wrap" data-response-id={id} data-survey-id={id} data-product-id={productId} data-lang={lang} data-survey-slug={definition.slug} data-is-free={definition.is_free}>
    <!-- Header -->
    <div class="result-header">
      <div>
        <p class="text-xs uppercase tracking-wider text-amber-500 font-bold mb-1">
          {surveyTitle}
        </p>
        <h1 class="result-title">
          {response.clinic_name ?? (lang === 'vi' ? 'Phòng khám' : 'Clinic')}
        </h1>
        <p class="text-sm text-on-surface-variant mt-1">
          {response.owner_name ? `${response.owner_name} · ` : ''}
          {new Date(response.created_at).toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' })}
        </p>
      </div>
      <div class="flex gap-2 flex-wrap">
        <a href={`/scanner/${definition.slug}`} class="btn btn-ghost">
          {lang === 'vi' ? 'Làm khảo sát mới' : 'New survey'}
        </a>
      </div>
    </div>

    <!-- Score Overview Card — ALWAYS FREE -->
    <div class="card score-card">
      <div class="score-header">
        <div>
          <p class="text-xs uppercase tracking-wider text-on-surface-variant font-bold">
            {lang === 'vi' ? 'Điểm tổng hợp' : 'Overall Score'}
          </p>
          <div class="score-total">
            <span class="score-num" style={`color: ${totalLevel.color}`}>{totalScore}</span>
            <span class="score-suffix">/100</span>
          </div>
          <p class="text-sm font-semibold" style={`color: ${totalLevel.color}`}>{totalLevel.label_vi}</p>
        </div>
        <div class="score-summary">
          {lang === 'vi' ? (
            <p>
              {totalScore < 40
                ? 'Phòng khám đang ở giai đoạn sơ khai — đây là thời điểm tốt để soi chiếu.'
                : totalScore < 70
                ? 'Phòng khám đang hình thành — tiếp tục đào sâu để vững mạnh.'
                : 'Phòng khám đang trưởng thành — giữ vững momentum và lan tỏa giá trị.'}
            </p>
          ) : (
            <p>
              {totalScore < 40
                ? 'Your clinic is in the early stage — this is a good time to illuminate and deepen.'
                : totalScore < 70
                ? 'Your clinic is forming — keep deepening to grow strong.'
                : 'Your clinic is maturing — keep the momentum and spread the value.'}
            </p>
          )}
        </div>
      </div>

      <div class="score-bars">
        {dimensions.map((p) => (
          <div class="bar-item">
            <div class="bar-label">
              <span class="bar-name">{p.name}</span>
              <span class="bar-value" style={`color: ${p.level.color}`}>
                {p.score} <span class="bar-level">· {lang === 'vi' ? p.level.label_vi : p.level.label_en}</span>
              </span>
            </div>
            <div class="bar-track">
              <div class="bar-fill" style={`width: ${p.score}%; background: ${p.level.color}`}></div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Section 1: What does this score mean? — ALWAYS FREE -->
    {insights.strengths.length > 0 || insights.needsWork.length > 0 ? (
      <div class="card insight-card">
        <div class="insight-header">
          <span class="material-symbols-outlined text-amber-400 text-xl">lightbulb</span>
          <h2 class="insight-title">
            {lang === 'vi' ? 'Điểm này có ý nghĩa gì?' : 'What does this score mean?'}
          </h2>
        </div>
        {insights.strengths.length > 0 && (
          <div class="insight-section">
            <p class="insight-section-label success">
              <span class="material-symbols-outlined text-sm">thumb_up</span>
              {lang === 'vi' ? 'Điểm mạnh' : 'Strengths'}
            </p>
            <div class="insight-items">
              {insights.strengths.map((item) => (
                <div class="insight-item insight-item--success">
                  <div class="insight-item-header">
                    <span class="insight-question">{item.question}</span>
                    <span class="insight-badge success-badge">
                      {item.value}/5 — {item.label}
                    </span>
                  </div>
                  <div class="insight-bar-track">
                    <div class="insight-bar-fill" style={`width:${item.score}%;background:#22c55e`}></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
        {insights.needsWork.length > 0 && (
          <div class="insight-section">
            <p class="insight-section-label warning">
              <span class="material-symbols-outlined text-sm">construction</span>
              {lang === 'vi' ? 'Cần cải thiện' : 'Needs improvement'}
            </p>
            <div class="insight-items">
              {insights.needsWork.map((item) => (
                <div class="insight-item insight-item--warning">
                  <div class="insight-item-header">
                    <span class="insight-question">{item.question}</span>
                    <span class="insight-badge warning-badge">
                      {item.value}/5 — {item.label}
                    </span>
                  </div>
                  <div class="insight-bar-track">
                    <div class="insight-bar-fill" style={`width:${item.score}%;background:#f59e0b`}></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    ) : null}

    <!-- Section 2: Nên đọc thêm — ALWAYS FREE -->
    {chapterRefs.length > 0 && (
      <div class="card reading-card">
        <div class="insight-header">
          <span class="material-symbols-outlined text-amber-400 text-xl">menu_book</span>
          <h2 class="insight-title">
            {lang === 'vi' ? 'Nên đọc thêm' : 'Recommended reading'}
          </h2>
        </div>
        <div class="reading-list">
          {chapterRefs.map((ch) => (
            <a href={`/book/${ch.id}`} class="reading-item">
              <div class="reading-meta">
                <span class="reading-tag">Ch.{ch.chapter_no}</span>
                <h3 class="reading-title">{ch.title}</h3>
              </div>
              {ch.excerpt && <p class="reading-excerpt">{ch.excerpt}</p>}
              <div class="reading-cta">
                <span class="reading-link">
                  {lang === 'vi' ? 'Đọc chương này' : 'Read this chapter'}
                  <span class="material-symbols-outlined text-base">arrow_forward</span>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Section 3: 30-day plan — FREE (AI-generated, polled) -->
    <div class="card plan-card" id="plan-section">
      <div class="insight-header">
        <span class="material-symbols-outlined text-amber-400 text-xl">calendar_month</span>
        <h2 class="insight-title">
          {lang === 'vi' ? 'Kế hoạch 30 ngày' : '30-day action plan'}
        </h2>
      </div>
      {hasPlan ? (
        <article class="prose-content" set:html={planHtml}></article>
      ) : (
        <div class="text-center py-6 text-on-surface-variant" id="plan-loading">
          <div class="spinner mb-3"></div>
          <p class="text-sm">{lang === 'vi' ? 'Đang tạo kế hoạch cá nhân hóa...' : 'Creating your personalized plan...'}</p>
        </div>
      )}
    </div>

    <!-- AI Analysis — LOCKED behind paywall (unless is_free=1) -->
    <div class="card analysis-card" id="analysis-section">
      <div class="analysis-header">
        <div>
          <p class="text-xs uppercase tracking-wider text-amber-500 font-bold">
            {lang === 'vi' ? 'Phân tích AI' : 'AI Analysis'}
          </p>
          <h2 class="analysis-title">
            {lang === 'vi' ? 'Bản soi chiếu hệ thống' : 'System Illumination'}
          </h2>
        </div>
      </div>

      <div id="analysis-unlocked" class="hidden">
        {hasAnalysis ? (
          <article class="prose-content" set:html={analysisHtml}></article>
        ) : (
          <div class="text-center py-8 text-on-surface-variant">
            <div class="spinner mb-4"></div>
            <p>{lang === 'vi' ? 'Bản phân tích AI đang được tạo...' : 'AI analysis is being generated...'}</p>
          </div>
        )}
      </div>

      <div id="analysis-locked">
        {definition.is_free === 1 ? (
          <div class="text-center py-6 text-on-surface-variant">
            <p>{lang === 'vi' ? 'Bản phân tích đang được tạo...' : 'Analysis is being generated...'}</p>
          </div>
        ) : (
          <div class="paywall-overlay">
            <div class="paywall-icon">
              <span class="material-symbols-outlined" style="font-size:3rem;color:#f59e0b;">lock</span>
            </div>
            <h3 class="paywall-title">
              {lang === 'vi' ? 'Mở khóa Bản Phân Tích AI' : 'Unlock AI Analysis'}
            </h3>
            <p class="paywall-desc">
              {lang === 'vi'
                ? `Bản phân tích chi tiết theo framework — bao gồm gợi ý hành động ưu tiên và lời nhắn từ chuyên gia.`
                : `Detailed framework-based analysis — including priority actions and a personal note from the expert.`}
            </p>
            <div class="paywall-price">
              <span class="paywall-amount">{priceFormatted}</span>
              <span class="paywall-currency">VND</span>
            </div>
            <button id="btn-unlock" class="btn btn-primary paywall-btn">
              <span class="material-symbols-outlined text-base">lock_open</span>
              {lang === 'vi' ? 'Mở khóa ngay' : 'Unlock now'}
            </button>
            <p class="paywall-note">
              {lang === 'vi' ? 'Thanh toán qua PayOS • Truy cập vĩnh viễn' : 'Pay via PayOS • Lifetime access'}
            </p>
          </div>
        )}
      </div>
    </div>

    <!-- Cross-sell (other scanners) -->
    {crossSells.length > 0 && (
      <div class="card cross-sell-card">
        <h3 class="cross-sell-title">
          {lang === 'vi' ? 'Khám phá thêm các máy quét khác' : 'Explore other scanners'}
        </h3>
        <div class="cross-sell-grid">
          {crossSells.map((s) => (
            <a href={`/scanner/${s.slug}`} class="cross-sell-item">
              <span class="material-symbols-outlined text-primary text-2xl">fact_check</span>
              <div>
                <p class="text-sm font-semibold text-on-surface">{lang === 'vi' ? s.title_vi : s.title_en}</p>
                {s.description_vi && <p class="text-xs text-on-surface-variant line-clamp-2 mt-0.5">{s.description_vi}</p>}
              </div>
              <span class="material-symbols-outlined text-on-surface-variant/50">arrow_forward</span>
            </a>
          ))}
        </div>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .result-wrap {
    max-width: 880px;
    margin: 0 auto;
    padding: 2rem 1rem 5rem;
  }
  .result-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .result-title {
    font-size: 1.875rem;
    font-weight: 700;
    margin: 0;
    color: var(--on-surface);
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    padding: 1.75rem;
    margin-bottom: 1.25rem;
  }

  .score-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .score-total {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    margin: 0.25rem 0;
  }
  .score-num {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1;
  }
  .score-suffix {
    font-size: 1.25rem;
    color: var(--on-surface-variant);
    font-weight: 500;
  }
  .score-summary {
    flex: 1;
    min-width: 280px;
    color: var(--on-surface-variant);
    line-height: 1.6;
    font-size: 0.95rem;
    max-width: 480px;
  }

  .score-bars {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .bar-label {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.4rem;
    font-size: 0.9rem;
  }
  .bar-name { font-weight: 600; color: var(--on-surface); }
  .bar-value { font-weight: 700; }
  .bar-level { font-weight: 400; color: var(--on-surface-variant); font-size: 0.85rem; }
  .bar-track {
    height: 10px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 999px;
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    border-radius: 999px;
    transition: width 1s ease;
  }

  .analysis-header { margin-bottom: 1.5rem; }
  .analysis-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--on-surface);
    margin: 0.25rem 0 0;
  }

  .prose-content {
    color: var(--on-surface);
    line-height: 1.75;
  }
  .prose-content :global(h1),
  .prose-content :global(h2),
  .prose-content :global(h3) {
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
    font-weight: 700;
    line-height: 1.3;
  }
  .prose-content :global(h1) { font-size: 1.5rem; color: var(--on-surface); }
  .prose-content :global(h2) { font-size: 1.25rem; color: var(--on-surface); }
  .prose-content :global(h3) { font-size: 1.05rem; color: var(--on-surface); }
  .prose-content :global(p) { margin: 0 0 1rem; }
  .prose-content :global(ul),
  .prose-content :global(ol) {
    margin: 0 0 1rem;
    padding-left: 1.5rem;
  }
  .prose-content :global(li) { margin-bottom: 0.4rem; }
  .prose-content :global(strong) { color: #f59e0b; }
  .prose-content :global(em) { color: var(--on-surface-variant); font-style: italic; }
  .prose-content :global(blockquote) {
    border-left: 3px solid #f59e0b;
    padding: 0.25rem 0 0.25rem 1rem;
    margin: 1rem 0;
    color: var(--on-surface-variant);
    font-style: italic;
  }
  .prose-content :global(code) {
    background: rgba(255, 255, 255, 0.06);
    padding: 0.1rem 0.35rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }
  .prose-content :global(hr) {
    border: 0;
    border-top: 1px solid var(--outline-variant);
    margin: 2rem 0;
  }

  .paywall-overlay {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2.5rem 1rem;
    text-align: center;
    border-top: 1px solid var(--outline-variant);
    margin-top: 1rem;
  }
  .paywall-icon { margin-bottom: 1rem; }
  .paywall-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--on-surface);
    margin: 0 0 0.5rem;
  }
  .paywall-desc {
    color: var(--on-surface-variant);
    font-size: 0.9rem;
    line-height: 1.55;
    max-width: 480px;
    margin: 0 0 1.25rem;
  }
  .paywall-price {
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
    margin-bottom: 1rem;
  }
  .paywall-amount {
    font-size: 2rem;
    font-weight: 800;
    color: var(--on-surface);
  }
  .paywall-currency {
    font-size: 1rem;
    color: var(--on-surface-variant);
    font-weight: 500;
  }
  .paywall-btn {
    padding: 0.75rem 2rem;
    font-size: 1rem;
  }
