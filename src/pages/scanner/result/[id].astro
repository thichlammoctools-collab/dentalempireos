---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { env } from 'cloudflare:workers';
import { marked } from 'marked';
import {
  getSurveyDefinitionFull,
  parseScoringRules,
  parseAiConfig,
} from '../../../lib/survey-config-db';
import {
  getScannerResponse,
  parseScores,
} from '../../../lib/scanner-response-db';
import { getScoreLevel } from '../../../lib/scoring-engine';

export const prerender = false;

const idParam = Astro.params.id;
const id = idParam ? parseInt(idParam, 10) : 0;

if (!id || Number.isNaN(id)) {
  return Astro.redirect('/');
}

const response = await getScannerResponse(env.DB, id);
if (!response) {
  return new Response('Response not found', { status: 404 });
}

const full = await getSurveyDefinitionFull(env.DB, response.survey_id);
if (!full) {
  return new Response('Survey not found', { status: 404 });
}

const { definition } = full;
const lang = (response.lang === 'en' ? 'en' : 'vi') as 'vi' | 'en';
const scoringRules = parseScoringRules(definition.scoring_rules);
const aiConfig = parseAiConfig(definition.ai_config);

const scores = parseScores(response.scores_json);
const totalScore = scores.total ?? 0;

// Build dimension list with names
type DimRow = { id: string; name: string; score: number; level: ReturnType<typeof getScoreLevel> };
const dimensions: DimRow[] = [];
if (scoringRules) {
  for (const dim of scoringRules.dimensions) {
    const score = scores[dim.id] ?? 0;
    dimensions.push({
      id: dim.id,
      name: lang === 'vi' ? (dim.name_vi ?? dim.id) : (dim.name_en ?? dim.name_vi ?? dim.id),
      score,
      level: getScoreLevel(score, scoringRules, lang),
    });
  }
}

const totalLevel = getScoreLevel(totalScore, scoringRules ?? { dimensions: [], total_formula: 'average', thresholds: { excellent: 75, good: 55, needs_work: 35, critical: 0 } }, lang);

// Pre-render analysis
marked.setOptions({ gfm: true, breaks: true });
const analysisHtml = response.ai_analysis ? (marked.parse(response.ai_analysis) as string) : '';
const hasAnalysis = !!analysisHtml;

// Resolve linked product (for paywall)
let linkedProduct: { id: string; name: string; price: number } | null = null;
try {
  // Find ai_application row matching this survey
  const app = await env.DB
    .prepare('SELECT id FROM "ai_application" WHERE "slug" = ? OR "id" = ?')
    .bind(definition.slug, `survey-${definition.id}`)
    .first<{ id: string }>();
  if (app) {
    linkedProduct = await env.DB
      .prepare('SELECT id, name, price FROM "product" WHERE "app_id" = ? AND "is_active" = 1 ORDER BY "price" DESC LIMIT 1')
      .bind(app.id)
      .first<{ id: string; name: string; price: number }>();
  }
} catch {
  // ignore
}

const productId = linkedProduct?.id ?? `survey-${definition.id}`;
const priceFormatted = linkedProduct
  ? new Intl.NumberFormat('vi-VN').format(linkedProduct.price)
  : '199.000';

const surveyTitle = lang === 'vi' ? definition.title_vi : (definition.title_en || definition.title_vi);

// AI analysis sections from ai_config (optional, used for header)
const analysisSections = aiConfig.analysis_sections ?? [];

// Cross-sell suggestions: pick 2 other active surveys
let crossSells: Array<{ id: string; slug: string; title_vi: string; title_en: string; description_vi: string | null }> = [];
try {
  const result = await env.DB
    .prepare(
      `SELECT id, slug, title_vi, title_en, description_vi
       FROM "survey_definition"
       WHERE status = 'active' AND id != ?
       ORDER BY order_index ASC
       LIMIT 3`,
    )
    .bind(definition.id)
    .all<any>();
  crossSells = (result.results ?? []).map((r) => ({
    id: r.id,
    slug: r.slug,
    title_vi: r.title_vi,
    title_en: r.title_en || r.title_vi,
    description_vi: r.description_vi,
  }));
} catch {}
---

<BaseLayout
  title={`${surveyTitle} #${id} | Dental Empire OS`}
  description={lang === 'vi' ? 'Bản phân tích hệ thống quản trị phòng khám' : 'Clinic management analysis'}
  noindex={true}
>
  <section class="result-wrap" data-survey-id={id} data-product-id={productId} data-lang={lang} data-survey-slug={definition.slug} data-is-free={definition.is_free}>
    <!-- Header -->
    <div class="result-header">
      <div>
        <p class="text-xs uppercase tracking-wider text-amber-500 font-bold mb-1">
          {surveyTitle}
        </p>
        <h1 class="result-title">
          {response.clinic_name ?? (lang === 'vi' ? 'Phòng khám' : 'Clinic')}
        </h1>
        <p class="text-sm text-on-surface-variant mt-1">
          {response.owner_name ? `${response.owner_name} · ` : ''}
          {new Date(response.created_at).toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' })}
        </p>
      </div>
      <div class="flex gap-2 flex-wrap">
        <a href={`/scanner/${definition.slug}`} class="btn btn-ghost">
          {lang === 'vi' ? 'Làm khảo sát mới' : 'New survey'}
        </a>
      </div>
    </div>

    <!-- Score Overview Card — ALWAYS FREE -->
    <div class="card score-card">
      <div class="score-header">
        <div>
          <p class="text-xs uppercase tracking-wider text-on-surface-variant font-bold">
            {lang === 'vi' ? 'Điểm tổng hợp' : 'Overall Score'}
          </p>
          <div class="score-total">
            <span class="score-num" style={`color: ${totalLevel.color}`}>{totalScore}</span>
            <span class="score-suffix">/100</span>
          </div>
          <p class="text-sm font-semibold" style={`color: ${totalLevel.color}`}>{totalLevel.label_vi}</p>
        </div>
        <div class="score-summary">
          {lang === 'vi' ? (
            <p>
              {totalScore < 40
                ? 'Phòng khám đang ở giai đoạn sơ khai — đây là thời điểm tốt để soi chiếu.'
                : totalScore < 70
                ? 'Phòng khám đang hình thành — tiếp tục đào sâu để vững mạnh.'
                : 'Phòng khám đang trưởng thành — giữ vững momentum và lan tỏa giá trị.'}
            </p>
          ) : (
            <p>
              {totalScore < 40
                ? 'Your clinic is in the early stage — this is a good time to illuminate and deepen.'
                : totalScore < 70
                ? 'Your clinic is forming — keep deepening to grow strong.'
                : 'Your clinic is maturing — keep the momentum and spread the value.'}
            </p>
          )}
        </div>
      </div>

      <div class="score-bars">
        {dimensions.map((p) => (
          <div class="bar-item">
            <div class="bar-label">
              <span class="bar-name">{p.name}</span>
              <span class="bar-value" style={`color: ${p.level.color}`}>
                {p.score} <span class="bar-level">· {lang === 'vi' ? p.level.label_vi : p.level.label_en}</span>
              </span>
            </div>
            <div class="bar-track">
              <div class="bar-fill" style={`width: ${p.score}%; background: ${p.level.color}`}></div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- AI Analysis — LOCKED behind paywall (unless is_free=1) -->
    <div class="card analysis-card" id="analysis-section">
      <div class="analysis-header">
        <div>
          <p class="text-xs uppercase tracking-wider text-amber-500 font-bold">
            {lang === 'vi' ? 'Phân tích AI' : 'AI Analysis'}
          </p>
          <h2 class="analysis-title">
            {lang === 'vi' ? 'Bản soi chiếu hệ thống' : 'System Illumination'}
          </h2>
        </div>
      </div>

      <div id="analysis-unlocked" class="hidden">
        {hasAnalysis ? (
          <article class="prose-content" set:html={analysisHtml}></article>
        ) : (
          <div class="text-center py-8 text-on-surface-variant">
            <div class="spinner mb-4"></div>
            <p>{lang === 'vi' ? 'Bản phân tích AI đang được tạo...' : 'AI analysis is being generated...'}</p>
          </div>
        )}
      </div>

      <div id="analysis-locked">
        {definition.is_free === 1 ? (
          <div class="text-center py-6 text-on-surface-variant">
            <p>{lang === 'vi' ? 'Bản phân tích đang được tạo...' : 'Analysis is being generated...'}</p>
          </div>
        ) : (
          <div class="paywall-overlay">
            <div class="paywall-icon">
              <span class="material-symbols-outlined" style="font-size:3rem;color:#f59e0b;">lock</span>
            </div>
            <h3 class="paywall-title">
              {lang === 'vi' ? 'Mở khóa Bản Phân Tích AI' : 'Unlock AI Analysis'}
            </h3>
            <p class="paywall-desc">
              {lang === 'vi'
                ? `Bản phân tích chi tiết theo framework — bao gồm gợi ý hành động ưu tiên và lời nhắn từ chuyên gia.`
                : `Detailed framework-based analysis — including priority actions and a personal note from the expert.`}
            </p>
            <div class="paywall-price">
              <span class="paywall-amount">{priceFormatted}</span>
              <span class="paywall-currency">VND</span>
            </div>
            <button id="btn-unlock" class="btn btn-primary paywall-btn">
              <span class="material-symbols-outlined text-base">lock_open</span>
              {lang === 'vi' ? 'Mở khóa ngay' : 'Unlock now'}
            </button>
            <p class="paywall-note">
              {lang === 'vi' ? 'Thanh toán qua PayOS • Truy cập vĩnh viễn' : 'Pay via PayOS • Lifetime access'}
            </p>
          </div>
        )}
      </div>
    </div>

    <!-- Cross-sell (other scanners) -->
    {crossSells.length > 0 && (
      <div class="card cross-sell-card">
        <h3 class="cross-sell-title">
          {lang === 'vi' ? 'Khám phá thêm các máy quét khác' : 'Explore other scanners'}
        </h3>
        <div class="cross-sell-grid">
          {crossSells.map((s) => (
            <a href={`/scanner/${s.slug}`} class="cross-sell-item">
              <span class="material-symbols-outlined text-primary text-2xl">fact_check</span>
              <div>
                <p class="text-sm font-semibold text-on-surface">{lang === 'vi' ? s.title_vi : s.title_en}</p>
                {s.description_vi && <p class="text-xs text-on-surface-variant line-clamp-2 mt-0.5">{s.description_vi}</p>}
              </div>
              <span class="material-symbols-outlined text-on-surface-variant/50">arrow_forward</span>
            </a>
          ))}
        </div>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .result-wrap {
    max-width: 880px;
    margin: 0 auto;
    padding: 2rem 1rem 5rem;
  }
  .result-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .result-title {
    font-size: 1.875rem;
    font-weight: 700;
    margin: 0;
    color: var(--on-surface);
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    padding: 1.75rem;
    margin-bottom: 1.25rem;
  }

  .score-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .score-total {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    margin: 0.25rem 0;
  }
  .score-num {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1;
  }
  .score-suffix {
    font-size: 1.25rem;
    color: var(--on-surface-variant);
    font-weight: 500;
  }
  .score-summary {
    flex: 1;
    min-width: 280px;
    color: var(--on-surface-variant);
    line-height: 1.6;
    font-size: 0.95rem;
    max-width: 480px;
  }

  .score-bars {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .bar-label {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.4rem;
    font-size: 0.9rem;
  }
  .bar-name { font-weight: 600; color: var(--on-surface); }
  .bar-value { font-weight: 700; }
  .bar-level { font-weight: 400; color: var(--on-surface-variant); font-size: 0.85rem; }
  .bar-track {
    height: 10px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 999px;
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    border-radius: 999px;
    transition: width 1s ease;
  }

  .analysis-header { margin-bottom: 1.5rem; }
  .analysis-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--on-surface);
    margin: 0.25rem 0 0;
  }

  .prose-content {
    color: var(--on-surface);
    line-height: 1.75;
  }
  .prose-content :global(h1),
  .prose-content :global(h2),
  .prose-content :global(h3) {
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
    font-weight: 700;
    line-height: 1.3;
  }
  .prose-content :global(h1) { font-size: 1.5rem; color: var(--on-surface); }
  .prose-content :global(h2) { font-size: 1.25rem; color: var(--on-surface); }
  .prose-content :global(h3) { font-size: 1.05rem; color: var(--on-surface); }
  .prose-content :global(p) { margin: 0 0 1rem; }
  .prose-content :global(ul),
  .prose-content :global(ol) {
    margin: 0 0 1rem;
    padding-left: 1.5rem;
  }
  .prose-content :global(li) { margin-bottom: 0.4rem; }
  .prose-content :global(strong) { color: #f59e0b; }
  .prose-content :global(em) { color: var(--on-surface-variant); font-style: italic; }
  .prose-content :global(blockquote) {
    border-left: 3px solid #f59e0b;
    padding: 0.25rem 0 0.25rem 1rem;
    margin: 1rem 0;
    color: var(--on-surface-variant);
    font-style: italic;
  }
  .prose-content :global(code) {
    background: rgba(255, 255, 255, 0.06);
    padding: 0.1rem 0.35rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }
  .prose-content :global(hr) {
    border: 0;
    border-top: 1px solid var(--outline-variant);
    margin: 2rem 0;
  }

  .paywall-overlay {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2.5rem 1rem;
    text-align: center;
    border-top: 1px solid var(--outline-variant);
    margin-top: 1rem;
  }
  .paywall-icon { margin-bottom: 1rem; }
  .paywall-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--on-surface);
    margin: 0 0 0.5rem;
  }
  .paywall-desc {
    color: var(--on-surface-variant);
    font-size: 0.9rem;
    line-height: 1.55;
    max-width: 480px;
    margin: 0 0 1.25rem;
  }
  .paywall-price {
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
    margin-bottom: 1rem;
  }
  .paywall-amount {
    font-size: 2rem;
    font-weight: 800;
    color: var(--on-surface);
  }
  .paywall-currency {
    font-size: 1rem;
    color: var(--on-surface-variant);
    font-weight: 500;
  }
  .paywall-btn {
    padding: 0.75rem 2rem;
    font-size: 1rem;
  }
  .paywall-note {
    color: var(--on-surface-variant);
    font-size: 0.75rem;
    margin-top: 0.75rem;
    opacity: 0.7;
  }

  .spinner {
    width: 36px;
    height: 36px;
    border: 3px solid rgba(245, 158, 11, 0.2);
    border-top-color: #f59e0b;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: 0 auto;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .cross-sell-card { padding: 1.5rem; }
  .cross-sell-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--on-surface);
    margin: 0 0 1rem;
  }
  .cross-sell-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
  }
  .cross-sell-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    background: var(--surface-container);
    border: 1px solid var(--outline-variant);
    border-radius: 0.6rem;
    text-decoration: none;
    transition: all 0.2s;
  }
  .cross-sell-item:hover {
    border-color: var(--primary);
    transform: translateY(-1px);
  }

  .btn {
    padding: 0.6rem 1.25rem;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    border: 0;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .btn-primary {
    background: linear-gradient(135deg, #3b82f6, #1d4ed8);
    color: white;
  }
  .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3); }
  .btn-ghost {
    background: transparent;
    color: var(--on-surface-variant);
    border: 1px solid var(--outline-variant);
  }
  .btn-ghost:hover { color: var(--on-surface); }

  .hidden { display: none !important; }

  @media (max-width: 640px) {
    .result-wrap { padding: 1rem 0.5rem 3rem; }
    .card { padding: 1.25rem; }
    .score-num { font-size: 2.75rem; }
    .paywall-overlay { padding: 1.5rem 0.5rem; }
    .paywall-amount { font-size: 1.5rem; }
  }
</style>

<script>
  const wrap = document.querySelector('.result-wrap') as HTMLElement;
  const surveyId = wrap?.dataset.surveyId;
  const productId = wrap?.dataset.productId;
  const lang = (wrap?.dataset.lang ?? 'vi') as 'vi' | 'en';
  const isFree = wrap?.dataset.isFree === '1';
  const btnUnlock = document.getElementById('btn-unlock');
  const locked = document.getElementById('analysis-locked');
  const unlocked = document.getElementById('analysis-unlocked');

  async function checkAccess() {
    if (!surveyId || !productId) return false;
    try {
      const res = await fetch(`/api/scanner/check-access?id=${surveyId}&product_id=${productId}`);
      const data = await res.json() as { hasAccess?: boolean };
      return data.hasAccess === true;
    } catch {
      return false;
    }
  }

  function showUnlocked() {
    if (locked) locked.style.display = 'none';
    if (unlocked) unlocked.classList.remove('hidden');
  }

  function showLocked() {
    if (locked) locked.style.display = '';
    if (unlocked) unlocked.classList.add('hidden');
  }

  function startPolling() {
    let attempts = 0;
    const interval = setInterval(async () => {
      attempts++;
      try {
        const res = await fetch(`/api/scanner/${surveyId}`);
        const data = await res.json() as { ai_analysis?: string };
        if (data.ai_analysis) {
          clearInterval(interval);
          window.location.reload();
        }
      } catch {}
      if (attempts >= 15) clearInterval(interval);
    }, 4000);
  }

  // Init: if is_free → no paywall, just check if analysis exists
  if (isFree) {
    showUnlocked();
    const analysisEl = document.querySelector('.spinner');
    if (analysisEl) startPolling();
  } else {
    checkAccess().then((hasAccess) => {
      if (hasAccess) {
        showUnlocked();
        const analysisEl = document.querySelector('.spinner');
        if (analysisEl) startPolling();
      } else {
        showLocked();
      }
    });
  }

  btnUnlock?.addEventListener('click', async () => {
    btnUnlock.innerHTML = `<span>${lang === 'vi' ? 'Đang chuyển...' : 'Redirecting...'}</span>`;
    btnUnlock.setAttribute('disabled', 'true');

    try {
      const res = await fetch('/api/payos/create-payment', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ product_id: productId }),
      });
      const data = await res.json() as { checkoutUrl?: string; error?: string };
      if (data.checkoutUrl) {
        window.location.href = data.checkoutUrl;
      } else {
        alert(data.error || 'Payment failed');
        btnUnlock.innerHTML = `<span class="material-symbols-outlined text-base">lock_open</span> ${lang === 'vi' ? 'Mở khóa ngay' : 'Unlock now'}`;
        btnUnlock.removeAttribute('disabled');
      }
    } catch {
      alert(lang === 'vi' ? 'Không thể kết nối thanh toán' : 'Payment connection failed');
      btnUnlock.innerHTML = `<span class="material-symbols-outlined text-base">lock_open</span> ${lang === 'vi' ? 'Mở khóa ngay' : 'Unlock now'}`;
      btnUnlock.removeAttribute('disabled');
    }
  });
</script>