---
import BaseLayout from '../layouts/BaseLayout.astro';
import { chapters, tiers } from '../data/modules';

export const prerender = true;
---

<BaseLayout title="Admin - Thêm Nội Dung" description="Trang quản trị nội dung sách Dental Empire OS">

  <section class="py-12">
    <div class="px-6 max-w-[900px] mx-auto">
      <h1 class="text-headline-lg text-white mb-2">📝 Thêm Nội Dung Mới</h1>
      <p class="text-on-surface-variant mb-8">Điền thông tin và paste nội dung, hệ thống sẽ tự generate file MDX cho bạn.</p>

      <!-- Form -->
      <div class="space-y-6">
        <!-- Row: Chapter + Tier + Order -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-semibold text-on-surface-variant mb-1">Chương số</label>
            <select id="admin-chapter" class="w-full px-4 py-3 bg-surface-container border border-outline-variant rounded-xl text-white focus:ring-2 focus:ring-primary focus:outline-none">
              {chapters.map((ch) => (
                <option value={ch.chapter}>
                  Ch {String(ch.chapter).padStart(2, '0')}: {ch.title} {ch.draft ? '' : '✓'}
                </option>
              ))}
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold text-on-surface-variant mb-1">Tầng</label>
            <select id="admin-tier" class="w-full px-4 py-3 bg-surface-container border border-outline-variant rounded-xl text-white focus:ring-2 focus:ring-primary focus:outline-none">
              {tiers.map((t) => (
                <option value={t.tier}>Tầng {t.tier}: {t.name}</option>
              ))}
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold text-on-surface-variant mb-1">Thứ tự</label>
            <input type="number" id="admin-order" value="1" min="1" class="w-full px-4 py-3 bg-surface-container border border-outline-variant rounded-xl text-white focus:ring-2 focus:ring-primary focus:outline-none" />
          </div>
        </div>

        <!-- Title -->
        <div>
          <label class="block text-sm font-semibold text-on-surface-variant mb-1">Tên chương</label>
          <input type="text" id="admin-title" placeholder="VD: Tổng Quan Hệ Thống" class="w-full px-4 py-3 bg-surface-container border border-outline-variant rounded-xl text-white placeholder:text-white/30 focus:ring-2 focus:ring-primary focus:outline-none" />
        </div>

        <!-- Description -->
        <div>
          <label class="block text-sm font-semibold text-on-surface-variant mb-1">Mô tả ngắn</label>
          <input type="text" id="admin-description" placeholder="1-2 dòng mô tả nội dung chương" class="w-full px-4 py-3 bg-surface-container border border-outline-variant rounded-xl text-white placeholder:text-white/30 focus:ring-2 focus:ring-primary focus:outline-none" />
        </div>

        <!-- Content -->
        <div>
          <div class="flex items-center justify-between mb-1">
            <label class="text-sm font-semibold text-on-surface-variant">Nội dung (Markdown)</label>
            <div class="flex gap-2">
              <button id="btn-write" class="text-xs px-3 py-1 rounded-lg bg-primary/10 text-primary font-semibold">Viết</button>
              <button id="btn-preview" class="text-xs px-3 py-1 rounded-lg bg-surface-container text-on-surface-variant font-semibold">Xem trước</button>
            </div>
          </div>
          <textarea id="admin-content" rows="20" placeholder={"## Tên Module 1\n\nNội dung module ở đây...\n\n## Tên Module 2\n\nNội dung module tiếp theo..."} class="w-full px-4 py-3 bg-surface-container border border-outline-variant rounded-xl text-white placeholder:text-white/30 focus:ring-2 focus:ring-primary focus:outline-none font-mono text-sm leading-relaxed resize-y"></textarea>
          <div id="admin-preview" class="hidden w-full min-h-[300px] px-4 py-3 bg-surface-container border border-outline-variant rounded-xl text-on-surface-variant prose prose-invert prose-headings:text-white prose-p:text-on-surface-variant max-w-none"></div>
        </div>

        <!-- Auto-fill from current chapter data -->
        <div class="bg-surface-container-low border border-outline-variant rounded-xl p-4">
          <p class="text-xs text-on-surface-variant mb-2">💡 <strong>Mẹo:</strong> Chọn chương ở trên để tự động điền tên và mô tả (nếu đã có trong hệ thống).</p>
          <button id="btn-autofill" type="button" class="text-xs px-4 py-2 bg-white/5 border border-outline-variant text-on-surface-variant rounded-lg hover:text-primary hover:border-primary transition-all">
            Tự động điền từ chương đã chọn
          </button>
        </div>

        <!-- Action buttons -->
        <div class="flex flex-col sm:flex-row gap-3">
          <button id="btn-copy" class="flex-1 px-6 py-3 btn-primary-metallic font-bold rounded-xl active:scale-95 transition-all flex items-center justify-center gap-2">
            <span class="material-symbols-outlined text-[18px]">content_copy</span>
            Copy MDX
          </button>
          <button id="btn-download" class="flex-1 px-6 py-3 border-2 border-outline text-on-surface-variant font-bold rounded-xl hover:border-primary hover:text-primary active:scale-95 transition-all flex items-center justify-center gap-2">
            <span class="material-symbols-outlined text-[18px]">download</span>
            Tải file .mdx
          </button>
        </div>

        <!-- Generated MDX output -->
        <div>
          <label class="block text-sm font-semibold text-on-surface-variant mb-1">MDX Output</label>
          <pre id="mdx-output" class="w-full min-h-[200px] px-4 py-3 bg-surface-container-low border border-outline-variant rounded-xl text-sm text-on-surface-variant overflow-x-auto whitespace-pre-wrap break-words"></pre>
          <div id="copy-toast" class="hidden fixed bottom-6 left-1/2 -translate-x-1/2 bg-emerald-600 text-white px-4 py-2 rounded-xl text-sm font-semibold shadow-lg z-50">
            ✅ Đã copy vào clipboard!
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  // Chapter data for auto-fill
  const chapterData: Record<number, { title: string; description: string; tier: number }> = {
    1: { title: 'Triển Khai Hệ Thống', description: 'Các nguyên tắc cốt lõi để xây dựng hệ thống quản trị phòng khám từ ngày đầu.', tier: 1 },
    2: { title: 'Quản Trị Nhân Sự', description: 'Xây dựng cấu trúc phòng ban, tuyển dụng và đào tạo nhân sự nha khoa.', tier: 1 },
    21: { title: 'Tổng Quan Hệ Thống', description: 'Giới thiệu tổng quan về hệ điều hành quản trị Dental Empire OS.', tier: 3 },
    22: { title: 'Hệ Thống Sống', description: 'Tổ chức không phải là cỗ máy, mà là một hệ thống sống.', tier: 3 },
    23: { title: 'Con Người Là Chủ Thể', description: 'Con người không phải là nguồn lực, mà là chủ thể trưởng thành.', tier: 3 },
    24: { title: 'TO BE SKY', description: 'Bầu trời đạo đức phía trên tổ chức — Sincerity, Kindness, Yielding.', tier: 3 },
    25: { title: 'S.T.A.R.S', description: 'Bản đồ năng lực của con người — Skills, Traits, Actions, Results, Synergy.', tier: 3 },
    26: { title: 'R.O.A.D.M.A.P', description: 'Con đường biến văn hóa thành hệ thống.', tier: 3 },
    27: { title: 'Đào Tạo', description: 'Đào tạo là hạ tầng của sự trưởng thành.', tier: 3 },
    28: { title: 'Đo Lường', description: 'Đo lường không phải để kiểm soát, mà để nhìn thấy sự thật.', tier: 3 },
    29: { title: 'Linh Hồn Phòng Khám', description: 'Phòng khám có thể lớn lên mà không đánh mất linh hồn.', tier: 3 },
  };

  const chapterSelect = document.getElementById('admin-chapter') as HTMLSelectElement;
  const tierSelect = document.getElementById('admin-tier') as HTMLSelectElement;
  const titleInput = document.getElementById('admin-title') as HTMLInputElement;
  const descInput = document.getElementById('admin-description') as HTMLInputElement;
  const contentArea = document.getElementById('admin-content') as HTMLTextAreaElement;
  const orderInput = document.getElementById('admin-order') as HTMLInputElement;
  const mdxOutput = document.getElementById('mdx-output') as HTMLElement;
  const preview = document.getElementById('admin-preview') as HTMLElement;

  function generateMDX(): string {
    const ch = parseInt(chapterSelect.value);
    const tier = parseInt(tierSelect.value);
    const title = titleInput.value;
    const desc = descInput.value;
    const order = orderInput.value;
    const content = contentArea.value;

    return `---
title: "${title}"
tier: ${tier}
chapter: ${ch}
description: "${desc}"
order: ${order}
draft: false
---

${content}`;
  }

  function updateOutput() {
    mdxOutput.textContent = generateMDX();
  }

  // Auto-fill
  document.getElementById('btn-autofill')?.addEventListener('click', () => {
    const ch = parseInt(chapterSelect.value);
    const data = chapterData[ch];
    if (data) {
      titleInput.value = data.title;
      descInput.value = data.description;
      tierSelect.value = String(data.tier);
      updateOutput();
    }
  });

  // Auto-update tier when chapter changes
  chapterSelect.addEventListener('change', () => {
    const ch = parseInt(chapterSelect.value);
    const data = chapterData[ch];
    if (data) {
      tierSelect.value = String(data.tier);
    }
    updateOutput();
  });

  // Live update
  [chapterSelect, tierSelect, titleInput, descInput, orderInput, contentArea].forEach(el => {
    el.addEventListener('input', updateOutput);
  });

  // Preview toggle
  document.getElementById('btn-write')?.addEventListener('click', () => {
    contentArea.classList.remove('hidden');
    preview.classList.add('hidden');
    document.getElementById('btn-write')?.classList.add('bg-primary/10', 'text-primary');
    document.getElementById('btn-write')?.classList.remove('text-on-surface-variant');
    document.getElementById('btn-preview')?.classList.remove('bg-primary/10', 'text-primary');
    document.getElementById('btn-preview')?.classList.add('text-on-surface-variant');
  });

  document.getElementById('btn-preview')?.addEventListener('click', () => {
    // Simple markdown preview (basic conversion)
    let md = contentArea.value;
    md = md.replace(/^### (.+)$/gm, '<h3>$1</h3>');
    md = md.replace(/^## (.+)$/gm, '<h2>$1</h2>');
    md = md.replace(/^# (.+)$/gm, '<h1>$1</h1>');
    md = md.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
    md = md.replace(/\*(.+?)\*/g, '<em>$1</em>');
    md = md.replace(/^- (.+)$/gm, '<li>$1</li>');
    md = md.replace(/(<li>.*<\/li>)/s, '<ul>$1</ul>');
    md = md.replace(/\n\n/g, '</p><p>');
    md = '<p>' + md + '</p>';

    preview.innerHTML = md;
    contentArea.classList.add('hidden');
    preview.classList.remove('hidden');
    document.getElementById('btn-preview')?.classList.add('bg-primary/10', 'text-primary');
    document.getElementById('btn-preview')?.classList.remove('text-on-surface-variant');
    document.getElementById('btn-write')?.classList.remove('bg-primary/10', 'text-primary');
    document.getElementById('btn-write')?.classList.add('text-on-surface-variant');
  });

  // Copy to clipboard
  document.getElementById('btn-copy')?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(generateMDX());
      const toast = document.getElementById('copy-toast');
      toast?.classList.remove('hidden');
      setTimeout(() => toast?.classList.add('hidden'), 2000);
    } catch {
      // Fallback
      const ta = document.createElement('textarea');
      ta.value = generateMDX();
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
    }
  });

  // Download .mdx file
  document.getElementById('btn-download')?.addEventListener('click', () => {
    const ch = parseInt(chapterSelect.value);
    const data = chapterData[ch];
    const slug = data ? data.title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '') : `chapter-${ch}`;
    const filename = `${String(ch).padStart(2, '0')}-${slug}.mdx`;

    const blob = new Blob([generateMDX()], { type: 'text/markdown' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    a.click();
    URL.revokeObjectURL(url);
  });

  // Init
  updateOutput();
</script>
