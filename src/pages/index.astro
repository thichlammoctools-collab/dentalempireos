---
import BaseLayout from '../layouts/BaseLayout.astro';
import { tiers, chapters, testimonials, type ChapterMeta } from '../data/modules';
---

<BaseLayout title="Dental Empire OS - Hệ Điều Hành Quản Trị Nha Khoa Toàn Diện">

  <!-- Hero Section -->
  <section class="relative min-h-[870px] flex items-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-r from-surface-container-lowest via-surface-container-lowest/90 to-transparent"></div>
    </div>
    <div class="relative z-10 w-full px-6 max-w-[1200px] mx-auto grid md:grid-cols-2 gap-12 items-center">
      <div class="space-y-8">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary-container/20 border border-primary/30 text-primary">
          <span class="material-symbols-outlined text-[18px]">verified</span>
          <span class="font-semibold text-sm tracking-wider">THE ULTIMATE KNOWLEDGE HUB</span>
        </div>
        <h1 class="text-headline-xl leading-tight text-white">
          Dental Empire OS:<br />
          <span class="text-primary">Hệ Điều Hành</span> Quản Trị Nha Khoa Toàn Diện
        </h1>
        <p class="text-on-surface-variant max-w-lg leading-relaxed">
          Xây dựng đế chế nha khoa bền vững với hệ thống quản trị chuẩn mực, tối ưu hóa quy trình từ vận hành, nhân sự đến trải nghiệm khách hàng.
        </p>
        <div class="flex flex-wrap gap-4 pt-4">
          <a href="/book" class="px-8 py-4 btn-primary-metallic font-bold rounded-xl text-lg hover:-translate-y-1 active:scale-95 transition-all">
            Đọc sách miễn phí ngay
          </a>
          <a href="/about" class="px-8 py-4 border-2 border-outline text-on-surface-variant font-bold rounded-xl text-lg hover:border-primary hover:text-primary active:scale-95 transition-all">
            Tìm hiểu mô hình
          </a>
        </div>
        <div class="flex items-center gap-6 pt-6 border-t border-outline-variant">
          <p class="text-on-surface-variant font-semibold">+500 Chủ phòng khám đã tin dùng</p>
        </div>
      </div>
      <div class="hidden md:block relative">
        <div class="absolute inset-0 bg-primary-container/10 rounded-[2rem] -rotate-3 blur-2xl"></div>
        <img
          src="/images/book/cover.jpg"
          alt="Dental Empire OS - Bìa sách"
          class="relative z-10 w-full rounded-[2rem] shadow-2xl border-4 border-surface-container-high object-cover"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Core Modules (Bento Grid) -->
  <section class="py-20 bg-surface-container-low">
    <div class="px-6 max-w-[1200px] mx-auto">
      <div class="text-center mb-16 space-y-4">
        <h2 class="text-headline-lg text-white">3 Tầng Cốt Lõi Của Dental Empire</h2>
        <p class="text-on-surface-variant max-w-2xl mx-auto">
          Lộ trình chuyển đổi từ chuyên môn thuần túy đến hệ thống quản trị nha khoa toàn diện.
        </p>
      </div>
      <div class="flex flex-col gap-8 max-w-4xl mx-auto">
        {tiers.map((mod, index) => (
          <div class:list={[
            'group relative p-8 rounded-[2rem] border transition-all duration-500',
            index === 0
              ? 'bg-surface-container border-primary/30 hover:border-primary shadow-[0_0_30px_rgba(146,204,255,0.1)]'
              : 'bg-surface-container border-outline-variant hover:border-primary/50',
          ]}>
            <div class:list={[
              'absolute top-0 right-0 p-6 transition-opacity',
              index === 0 ? 'opacity-20 group-hover:opacity-100' : 'opacity-10 group-hover:opacity-50',
            ]}>
              <span class="material-symbols-outlined text-6xl text-primary">{mod.icon}</span>
            </div>
            <div class="relative z-10">
              <div class:list={[
                'inline-block px-4 py-1 rounded-full font-semibold text-sm tracking-wider mb-4',
                index === 0 ? 'bg-primary/10 text-primary' : 'bg-white/5 text-on-surface-variant',
              ]}>
                TẦNG {mod.tier}
              </div>
              <h3 class="text-headline-md text-white mb-4">{mod.name}</h3>
              <p class="text-on-surface-variant leading-relaxed max-w-2xl">
                {mod.subtitle}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Social Proof / Testimonials -->
  <section class="py-20 overflow-hidden bg-surface">
    <div class="px-6 max-w-[1200px] mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-end gap-6 mb-16">
        <div class="max-w-xl">
          <h2 class="text-headline-lg text-white mb-4">Chia Sẻ Từ Đồng Nghiệp</h2>
          <p class="text-on-surface-variant">Hơn 500 bác sĩ và chủ phòng khám đã thay đổi tư duy quản trị từ những kiến thức tại Dental Empire.</p>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {testimonials.map((t) => (
          <div class="bg-surface-container-low p-8 rounded-2xl border border-outline-variant shadow-sm relative">
            <span class="absolute top-6 right-8 text-6xl text-primary/10">&ldquo;</span>
            <div class="flex items-center gap-1 text-primary mb-4">
              {[1, 2, 3, 4, 5].map(() => (
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
              ))}
            </div>
            <p class="text-on-surface-variant mb-8 italic leading-relaxed">
              &ldquo;{t.quote}&rdquo;
            </p>
            <div class="flex items-center gap-4">
              <img
                class="w-12 h-12 rounded-full object-cover"
                src={t.avatar}
                alt={t.name}
                loading="lazy"
              />
              <div>
                <p class="font-bold text-white">{t.name}</p>
                <p class="text-xs text-on-surface-variant">{t.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Authority / Founder Section -->
  <section class="py-20 bg-surface-container-lowest text-on-surface overflow-hidden">
    <div class="px-6 max-w-[1200px] mx-auto grid md:grid-cols-2 gap-16 items-center">
      <div class="relative group">
        <div class="absolute -inset-4 bg-primary-container/10 rounded-3xl blur-3xl opacity-0 group-hover:opacity-100 transition-all duration-500"></div>
        <div class="relative z-10 w-full aspect-[3/4] rounded-3xl shadow-2xl border-2 border-outline-variant bg-gradient-to-br from-surface-container to-surface-container-high flex items-center justify-center overflow-hidden">
          <div class="text-center space-y-4 p-8">
            <span class="material-symbols-outlined text-9xl text-primary/30">person</span>
            <div class="text-headline-md font-bold text-white">Dr. Vinh</div>
            <div class="text-on-surface-variant text-sm">Founder &amp; Author</div>
          </div>
        </div>
      </div>
      <div class="space-y-8">
        <div class="inline-block px-4 py-1 rounded-full border border-outline bg-white/5 font-semibold text-sm tracking-wider">VỀ NGƯỜI SÁNG LẬP</div>
        <h2 class="text-headline-lg text-white">Dr. Vinh &ndash; Sứ Mệnh Chuyên Nghiệp Hóa Ngành Nha</h2>
        <p class="text-on-surface-variant leading-relaxed">
          Với hơn 15 năm kinh nghiệm trong cả hai vai trò: Bác sĩ điều trị và Nhà quản trị hệ thống, Dr. Vinh đã đúc kết lộ trình &ldquo;Dental Empire OS&rdquo; để giúp các đồng nghiệp tránh khỏi những sai lầm đắt giá trong vận hành phòng khám.
        </p>
        <div class="grid grid-cols-2 gap-8 py-4">
          <div>
            <div class="text-4xl font-bold text-primary mb-2">15+</div>
            <div class="text-sm text-on-surface-variant">Năm kinh nghiệm thực chiến</div>
          </div>
          <div>
            <div class="text-4xl font-bold text-primary mb-2">500+</div>
            <div class="text-sm text-on-surface-variant">Học viên là chủ phòng khám</div>
          </div>
        </div>
        <a class="inline-flex items-center gap-2 group font-bold text-primary hover:text-white transition-colors" href="/about">
          Xem chi tiết hành trình
          <span class="material-symbols-outlined group-hover:translate-x-2 transition-transform">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Secondary CTA Section -->
  <section class="py-20 bg-surface">
    <div class="px-6 max-w-[1200px] mx-auto">
      <div class="bg-surface-container-low border border-outline-variant rounded-[3rem] p-12 md:p-20 relative overflow-hidden text-center">
        <div class="absolute top-0 right-0 w-64 h-64 bg-primary/5 rounded-full -translate-y-1/2 translate-x-1/2 blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-primary/5 rounded-full translate-y-1/2 -translate-x-1/2 blur-3xl"></div>
        <div class="relative z-10 max-w-3xl mx-auto space-y-8">
          <h2 class="text-headline-xl text-white">Sẵn sàng để bắt đầu hành trình nâng tầm?</h2>
          <p class="text-on-surface-variant">Tham gia cộng đồng 10.000+ bác sĩ hoặc tải ngay bộ Toolkit quản trị miễn phí của chúng tôi.</p>
          <div class="flex flex-col sm:flex-row gap-6 justify-center pt-4">
            <a href="#" class="px-10 py-5 btn-primary-metallic font-bold rounded-2xl shadow-lg active:scale-95 transition-all flex items-center justify-center gap-3">
              <span class="material-symbols-outlined">groups</span>
              Tham gia Community
            </a>
            <a href="/resources" class="px-10 py-5 border-2 border-outline text-on-surface-variant font-bold rounded-2xl hover:border-primary hover:text-primary shadow-lg active:scale-95 transition-all flex items-center justify-center gap-3">
              <span class="material-symbols-outlined">download</span>
              Tải miễn phí Toolkit
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
