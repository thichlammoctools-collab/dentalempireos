---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { env } from 'cloudflare:workers';
import { getSurveyResponse } from '../../../lib/survey-db';
import { marked } from 'marked';

export const prerender = false;

const idParam = Astro.params.id;
const id = idParam ? parseInt(idParam, 10) : 0;

if (!id || Number.isNaN(id)) {
  return Astro.redirect('/survey');
}

const row = await getSurveyResponse(env.DB, id);
if (!row) {
  return new Response('Survey not found', { status: 404 });
}

const lang = row.lang === 'en' ? 'en' : 'vi';

const scoreRoots = row.score_roots ?? 0;
const scoreSky = row.score_sky ?? 0;
const scoreStars = row.score_stars ?? 0;
const scoreLiving = row.score_living ?? 0;
const scoreTotal = row.score_total ?? 0;

function scoreLevel(s: number): { label: string; color: string } {
  if (s >= 75) return { label: lang === 'vi' ? 'Vững mạnh' : 'Strong', color: '#10b981' };
  if (s >= 55) return { label: lang === 'vi' ? 'Đang phát triển' : 'Growing', color: '#3b82f6' };
  if (s >= 35) return { label: lang === 'vi' ? 'Cần chú ý' : 'Needs attention', color: '#f59e0b' };
  return { label: lang === 'vi' ? 'Cần soi chiếu' : 'Needs illumination', color: '#ef4444' };
}

const totalLevel = scoreLevel(scoreTotal);
const parts = [
  { key: 'roots', name: 'ROOTS', score: scoreRoots, ...scoreLevel(scoreRoots) },
  { key: 'sky', name: 'SKY', score: scoreSky, ...scoreLevel(scoreSky) },
  { key: 'stars', name: 'S.T.A.R.S', score: scoreStars, ...scoreLevel(scoreStars) },
  { key: 'living', name: lang === 'vi' ? 'Hệ thống sống' : 'Living System', score: scoreLiving, ...scoreLevel(scoreLiving) },
];

// Pre-render the analysis HTML for unlocked state
marked.setOptions({ gfm: true, breaks: true });
const analysisHtml = row.ai_analysis ? (marked.parse(row.ai_analysis) as string) : '';
const hasAnalysis = !!analysisHtml;

// Dynamic product resolution from ai_application registry
const SURVEY_APP_ID = 'survey-rootsgoc-1-app';
const SURVEY_PRODUCT_FALLBACK = 'survey-rootsgoc-1';

let linkedProduct: { id: string; name: string; price: number; description: string } | null = null;
try {
  linkedProduct = await env.DB
    .prepare('SELECT * FROM "product" WHERE "app_id" = ? AND "is_active" = 1 ORDER BY "price" DESC LIMIT 1')
    .bind(SURVEY_APP_ID)
    .first<{ id: string; name: string; price: number; description: string }>();
} catch {
  // Table may not have app_id column yet — use fallback
}

const productId = linkedProduct?.id ?? SURVEY_PRODUCT_FALLBACK;
const priceFormatted = linkedProduct
  ? new Intl.NumberFormat('vi-VN').format(linkedProduct.price)
  : '199.000';
---

<BaseLayout
  title={`Hồ Sơ Gốc Rễ #${id} | Dental Empire OS`}
  description="Bản phân tích hệ thống quản trị phòng khám"
  noindex={true}
>
  <section class="result-wrap" data-survey-id={id} data-product-id={productId} data-lang={lang}>
    <!-- Header -->
    <div class="result-header">
      <div>
        <p class="text-xs uppercase tracking-wider text-amber-500 font-bold mb-1">
          {lang === 'vi' ? 'Hồ Sơ Gốc Rễ' : 'Roots Profile'}
        </p>
        <h1 class="result-title">
          {row.clinic_name ?? (lang === 'vi' ? 'Phòng khám' : 'Clinic')}
        </h1>
        <p class="text-sm text-[var(--on-surface-variant)] mt-1">
          {row.owner_name ? `${row.owner_name} · ` : ''}
          {row.created_at}
        </p>
      </div>
      <div class="flex gap-2 flex-wrap">
        <a href="/survey" class="btn btn-ghost">
          {lang === 'vi' ? 'Làm khảo sát mới' : 'New survey'}
        </a>
      </div>
    </div>

    <!-- Score Overview Card — ALWAYS FREE -->
    <div class="card score-card">
      <div class="score-header">
        <div>
          <p class="text-xs uppercase tracking-wider text-[var(--on-surface-variant)] font-bold">
            {lang === 'vi' ? 'Điểm tổng hợp' : 'Overall Score'}
          </p>
          <div class="score-total">
            <span class="score-num" style={`color: ${totalLevel.color}`}>{scoreTotal}</span>
            <span class="score-suffix">/100</span>
          </div>
          <p class="text-sm font-semibold" style={`color: ${totalLevel.color}`}>{totalLevel.label}</p>
        </div>
        <div class="score-summary">
          {lang === 'vi' ? (
            <p>
              Phòng khám đang ở giai đoạn <strong>{scoreTotal < 40 ? 'sơ khai' : scoreTotal < 70 ? 'đang hình thành' : 'trưởng thành'}</strong>.
              {scoreTotal >= 70 ? ' Hệ thống đang sinh trưởng đúng hướng.' : ' Đây là thời điểm tốt để soi chiếu và đào sâu.'}
            </p>
          ) : (
            <p>
              Your clinic is in the <strong>{scoreTotal < 40 ? 'early' : scoreTotal < 70 ? 'forming' : 'maturing'}</strong> stage.
              {scoreTotal >= 70 ? ' The system is growing in the right direction.' : ' This is a good time to illuminate and deepen.'}
            </p>
          )}
        </div>
      </div>

      <div class="score-bars">
        {parts.map((p) => (
          <div class="bar-item">
            <div class="bar-label">
              <span class="bar-name">{p.name}</span>
              <span class="bar-value" style={`color: ${p.color}`}>{p.score} <span class="bar-level">· {p.label}</span></span>
            </div>
            <div class="bar-track">
              <div class="bar-fill" style={`width: ${p.score}%; background: ${p.color}`}></div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- AI Analysis — LOCKED behind paywall -->
    <div class="card analysis-card" id="analysis-section">
      <div class="analysis-header">
        <div>
          <p class="text-xs uppercase tracking-wider text-amber-500 font-bold">
            {lang === 'vi' ? 'Phân tích AI' : 'AI Analysis'}
          </p>
          <h2 class="analysis-title">
            {lang === 'vi' ? 'Bản soi chiếu hệ thống' : 'System Illumination'}
          </h2>
        </div>
      </div>

      <!-- Unlocked content (hidden by default, shown by JS if access granted) -->
      <div id="analysis-unlocked" class="hidden">
        {hasAnalysis ? (
          <article class="prose-content" set:html={analysisHtml}></article>
        ) : (
          <div class="text-center py-8 text-[var(--on-surface-variant)]">
            <div class="spinner mb-4"></div>
            <p>{lang === 'vi' ? 'Bản phân tích AI đang được tạo...' : 'AI analysis is being generated...'}</p>
          </div>
        )}
      </div>

      <!-- Paywall overlay (shown by default, hidden by JS if access granted) -->
      <div id="analysis-locked">
        <div class="paywall-overlay">
          <div class="paywall-icon">
            <span class="material-symbols-outlined" style="font-size:3rem;color:#f59e0b;">lock</span>
          </div>
          <h3 class="paywall-title">
            {lang === 'vi' ? 'Mở khóa Bản Phân Tích AI' : 'Unlock AI Analysis'}
          </h3>
          <p class="paywall-desc">
            {lang === 'vi'
              ? `Bản phân tích chi tiết 9 phần theo framework ROOTS, SKY, S.T.A.R.S — bao gồm gợi ý hành động ưu tiên và lời nhắn từ BS. Vinh.`
              : `Detailed 9-part analysis using the ROOTS, SKY, S.T.A.R.S framework — including priority actions and a personal note from Dr. Vinh.`}
          </p>
          <div class="paywall-price">
            <span class="paywall-amount">{priceFormatted}</span>
            <span class="paywall-currency">VND</span>
          </div>
          <button id="btn-unlock" class="btn btn-primary paywall-btn">
            <span class="material-symbols-outlined text-base">lock_open</span>
            {lang === 'vi' ? 'Mở khóa ngay' : 'Unlock now'}
          </button>
          <p class="paywall-note">
            {lang === 'vi' ? 'Thanh toán qua PayOS • Truy cập vĩnh viễn • Tải PDF không giới hạn' : 'Pay via PayOS • Lifetime access • Unlimited PDF downloads'}
          </p>
        </div>
      </div>
    </div>

    <!-- Footer CTA — always visible -->
    <div class="card cta-card">
      <h3 class="cta-title">
        {lang === 'vi' ? 'Bước tiếp theo' : 'Next steps'}
      </h3>
      <p class="text-sm text-[var(--on-surface-variant)] mb-4">
        {lang === 'vi'
          ? 'Bản phân tích này là điểm khởi đầu. Trong buổi tư vấn "Khám Phục" (Giai đoạn 1 R.O.A.D.M.A.P), chúng ta sẽ cùng nhau đi sâu vào từng chiều — xác định gốc rễ, soi lại đạo đức và chuẩn hóa năng lực đội ngũ.'
          : 'This analysis is a starting point. In the "Awakening" consulting session (Phase 1 of R.O.A.D.M.A.P), we\'ll dive deep into each dimension — define the roots, re-illuminate ethics, and standardize team capability.'}
      </p>
      <div class="flex gap-3 flex-wrap">
        <a href="/about" class="btn btn-primary">
          {lang === 'vi' ? 'Về BS. Vinh' : 'About Dr. Vinh'}
        </a>
        <a href="/book" class="btn btn-ghost">
          {lang === 'vi' ? 'Đọc sách miễn phí' : 'Read the free book'}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .result-wrap {
    max-width: 880px;
    margin: 0 auto;
    padding: 2rem 1rem 5rem;
  }
  .result-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .result-title {
    font-size: 1.875rem;
    font-weight: 700;
    margin: 0;
    color: var(--on-surface);
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    padding: 1.75rem;
    margin-bottom: 1.25rem;
  }

  /* Score card */
  .score-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .score-total {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    margin: 0.25rem 0;
  }
  .score-num {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1;
  }
  .score-suffix {
    font-size: 1.25rem;
    color: var(--on-surface-variant);
    font-weight: 500;
  }
  .score-summary {
    flex: 1;
    min-width: 280px;
    color: var(--on-surface-variant);
    line-height: 1.6;
    font-size: 0.95rem;
    max-width: 480px;
  }

  .score-bars {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .bar-label {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.4rem;
    font-size: 0.9rem;
  }
  .bar-name { font-weight: 600; color: var(--on-surface); }
  .bar-value { font-weight: 700; }
  .bar-level { font-weight: 400; color: var(--on-surface-variant); font-size: 0.85rem; }
  .bar-track {
    height: 10px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 999px;
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    border-radius: 999px;
    transition: width 1s ease;
  }

  /* Analysis card */
  .analysis-header {
    margin-bottom: 1.5rem;
  }
  .analysis-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--on-surface);
    margin: 0.25rem 0 0;
  }

  .prose-content {
    color: var(--on-surface);
    line-height: 1.75;
  }
  .prose-content :global(h1),
  .prose-content :global(h2),
  .prose-content :global(h3) {
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
    font-weight: 700;
    line-height: 1.3;
  }
  .prose-content :global(h1) { font-size: 1.5rem; color: var(--on-surface); }
  .prose-content :global(h2) { font-size: 1.25rem; color: var(--on-surface); }
  .prose-content :global(h3) { font-size: 1.05rem; color: var(--on-surface); }
  .prose-content :global(p) { margin: 0 0 1rem; }
  .prose-content :global(ul),
  .prose-content :global(ol) {
    margin: 0 0 1rem;
    padding-left: 1.5rem;
  }
  .prose-content :global(li) { margin-bottom: 0.4rem; }
  .prose-content :global(strong) { color: #f59e0b; }
  .prose-content :global(em) { color: var(--on-surface-variant); font-style: italic; }
  .prose-content :global(blockquote) {
    border-left: 3px solid #f59e0b;
    padding: 0.25rem 0 0.25rem 1rem;
    margin: 1rem 0;
    color: var(--on-surface-variant);
    font-style: italic;
  }
  .prose-content :global(code) {
    background: rgba(255, 255, 255, 0.06);
    padding: 0.1rem 0.35rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }
  .prose-content :global(hr) {
    border: 0;
    border-top: 1px solid var(--outline-variant);
    margin: 2rem 0;
  }

  /* Paywall overlay */
  .paywall-overlay {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2.5rem 1rem;
    text-align: center;
    border-top: 1px solid var(--outline-variant);
    margin-top: 1rem;
  }
  .paywall-icon { margin-bottom: 1rem; }
  .paywall-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--on-surface);
    margin: 0 0 0.5rem;
  }
  .paywall-desc {
    color: var(--on-surface-variant);
    font-size: 0.9rem;
    line-height: 1.55;
    max-width: 480px;
    margin: 0 0 1.25rem;
  }
  .paywall-price {
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
    margin-bottom: 1rem;
  }
  .paywall-amount {
    font-size: 2rem;
    font-weight: 800;
    color: var(--on-surface);
  }
  .paywall-currency {
    font-size: 1rem;
    color: var(--on-surface-variant);
    font-weight: 500;
  }
  .paywall-btn {
    padding: 0.75rem 2rem;
    font-size: 1rem;
  }
  .paywall-note {
    color: var(--on-surface-variant);
    font-size: 0.75rem;
    margin-top: 0.75rem;
    opacity: 0.7;
  }

  /* Pending spinner */
  .spinner {
    width: 36px;
    height: 36px;
    border: 3px solid rgba(245, 158, 11, 0.2);
    border-top-color: #f59e0b;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: 0 auto;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* CTA */
  .cta-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--on-surface);
    margin: 0 0 0.5rem;
  }

  /* Buttons */
  .btn {
    padding: 0.6rem 1.25rem;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    border: 0;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .btn-primary {
    background: linear-gradient(135deg, #3b82f6, #1d4ed8);
    color: white;
  }
  .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3); }
  .btn-ghost {
    background: transparent;
    color: var(--on-surface-variant);
    border: 1px solid var(--outline-variant);
  }
  .btn-ghost:hover { color: var(--on-surface); }

  .hidden { display: none !important; }

  @media (max-width: 640px) {
    .result-wrap { padding: 1rem 0.5rem 3rem; }
    .card { padding: 1.25rem; }
    .score-num { font-size: 2.75rem; }
    .paywall-overlay { padding: 1.5rem 0.5rem; }
    .paywall-amount { font-size: 1.5rem; }
  }
</style>

<script>
  const wrap = document.querySelector('.result-wrap') as HTMLElement;
  const surveyId = wrap?.dataset.surveyId;
  const productId = wrap?.dataset.productId;
  const lang = wrap?.dataset.lang ?? 'vi';
  const btnUnlock = document.getElementById('btn-unlock');
  const locked = document.getElementById('analysis-locked');
  const unlocked = document.getElementById('analysis-unlocked');

  async function checkAccess() {
    if (!surveyId || !productId) return false;
    try {
      const res = await fetch(`/api/survey/check-access?id=${surveyId}&product_id=${productId}`);
      const data = await res.json() as { hasAccess?: boolean };
      return data.hasAccess === true;
    } catch {
      return false;
    }
  }

  function showUnlocked() {
    if (locked) locked.style.display = 'none';
    if (unlocked) unlocked.classList.remove('hidden');
  }

  function showLocked() {
    if (locked) locked.style.display = '';
    if (unlocked) unlocked.classList.add('hidden');
  }

  // Auto-refresh for pending analysis (only if unlocked)
  function startPolling() {
    let attempts = 0;
    const interval = setInterval(async () => {
      attempts++;
      try {
        const res = await fetch(`/api/survey?id=${surveyId}`);
        const data = await res.json() as { ai_analysis?: string };
        if (data.ai_analysis) {
          clearInterval(interval);
          window.location.reload();
        }
      } catch {}
      if (attempts >= 15) clearInterval(interval);
    }, 4000);
  }

  // Init
  checkAccess().then((hasAccess) => {
    if (hasAccess) {
      showUnlocked();
      // Poll for analysis if not yet generated
      const analysisEl = document.querySelector('.spinner');
      if (analysisEl) startPolling();
    } else {
      showLocked();
    }
  });

  // Unlock button — redirect to payment
  btnUnlock?.addEventListener('click', async () => {
    btnUnlock.textContent = lang === 'vi' ? 'Đang chuyển...' : 'Redirecting...';
    btnUnlock.setAttribute('disabled', 'true');

    try {
      const res = await fetch('/api/payos/create-payment', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ product_id: productId }),
      });
      const data = await res.json() as { checkoutUrl?: string; error?: string };
      if (data.checkoutUrl) {
        window.location.href = data.checkoutUrl;
      } else {
        alert(data.error || 'Payment failed');
        btnUnlock.textContent = lang === 'vi' ? 'Mở khóa ngay' : 'Unlock now';
        btnUnlock.removeAttribute('disabled');
      }
    } catch {
      alert(lang === 'vi' ? 'Không thể kết nối thanh toán' : 'Payment connection failed');
      btnUnlock.textContent = lang === 'vi' ? 'Mở khóa ngay' : 'Unlock now';
      btnUnlock.removeAttribute('disabled');
    }
  });
</script>
