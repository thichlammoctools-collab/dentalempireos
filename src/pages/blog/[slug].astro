---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogSectionNav from '../../components/blog/BlogSectionNav.astro';
import AuthorBio from '../../components/blog/AuthorBio.astro';
import StructuredData from '../../components/seo/StructuredData.astro';
import { marked } from 'marked';
import { env } from 'cloudflare:workers';
import { getPost, getRelatedPosts, getPopularPosts, listCategories, incrementViewCount, getBlocksByPostId, type BlogPostWithMeta, type BlogCategory, type BlogBlock } from '../../lib/blog-db';
import { sanitizeRichHtml } from '../../lib/sanitize';
import WebsiteChatWidget from '../../components/chat/WebsiteChatWidget.astro';

export const prerender = false;

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/blog');

const db = env.DB;

let post: BlogPostWithMeta | null = null;
let popular: BlogPostWithMeta[] = [];
let categories: BlogCategory[] = [];

try {
  [post, popular, categories] = await Promise.all([
    getPost(db, slug),
    getPopularPosts(db, 5),
    listCategories(db),
  ]);
} catch {
  // If main queries fail, try just the post
  try {
    post = await getPost(db, slug);
  } catch {
    post = null;
  }
}

if (!post) {
  return new Response('Không tìm thấy bài viết', { status: 404 });
}

let blocks: BlogBlock[] = [];
try {
  blocks = await getBlocksByPostId(db, post.id);
} catch {
  // blog_block table may not exist yet — gracefully degrade
  blocks = [];
}

// Thêm id vào heading để TOC links hoạt động
function addHeadingIds(html: string): string {
  return html.replace(/<h([234])([^>]*)>([\s\S]*?)<\/h[234]>/gi, (_match, level, attrs, inner) => {
    if (attrs.includes('id=')) return _match;
    const text = inner.replace(/<[^>]+>/g, '').trim();
    const id = text.toLowerCase().replace(/[^a-z0-9À-ɏ]+/gu, '-').replace(/^-|-$/g, '');
    return `<h${level}${attrs} id="${id}">${inner}</h${level}>`;
  });
}

// Increment view count (fire and forget)
incrementViewCount(db, post.id).catch(() => {});

let related: BlogPostWithMeta[] = [];
try {
  related = await getRelatedPosts(db, post.id, post.category_id, 4);
} catch {
  related = [];
}

// Fetch linked chapter and scanner
let linkedChapter: { id: string; title: string; chapter_no: number; slug: string } | null = null;
let linkedScanner: { id: string; title_vi: string; description_vi: string } | null = null;

if (post.chapter_id) {
  try {
    const ch = await env.DB.prepare('SELECT id, title, chapter_no, slug FROM "chapter" WHERE id = ?').bind(post.chapter_id).first<{ id: string; title: string; chapter_no: number; slug: string }>();
    if (ch) linkedChapter = ch;
  } catch { /* column may not exist yet */ }
}

if (post.scanner_id) {
  try {
    const sc = await db.prepare('SELECT id, title_vi, description_vi FROM "survey_definition" WHERE id = ?').bind(post.scanner_id).first<{ id: string; title_vi: string; description_vi: string }>();
    if (sc) linkedScanner = sc;
  } catch { /* table may not exist yet */ }
}

const htmlContent = marked(post.content_md);

function formatDate(iso: string | null): string {
  if (!iso) return '';
  return new Date(iso).toLocaleDateString('vi-VN', { day: '2-digit', month: 'long', year: 'numeric' });
}

// Build TOC from rendered (sanitized) HTML — extracts actual IDs and decodes entities
const tocItems = (() => {
  const items: { level: number; text: string; id: string }[] = [];

  // Build source from sanitized rich blocks
  const source = blocks.length > 0
    ? blocks.map(b => b.type === 'rich' ? b.content : '').join('\n')
    : post.content_md ?? '';

  // Extract from HTML headings: captures existing id="" attribute and text content
  // Handles: <h2 id="foo">Text</h2> AND <h2>Text</h2> (no id)
  const htmlHeadingRegex = /<h([23])(?:\s[^>]*)?>(.*?)<\/h[23]>/gi;
  let match;
  while ((match = htmlHeadingRegex.exec(source)) !== null) {
    const level = parseInt(match[1]);
    const tagOuter = match[0]; // full tag e.g. <h2> or <h2 id="foo" class="bar">
    const inner = match[2].replace(/<[^>]+>/g, '').trim();
    // Decode common HTML entities
    const text = inner
      .replace(/&amp;/g, '&')
      .replace(/&lt;/g, '<')
      .replace(/&gt;/g, '>')
      .replace(/&quot;/g, '"')
      .replace(/&#39;/g, "'")
      .replace(/&nbsp;/g, ' ');
    // Extract existing id attribute if present
    const idMatch = /id="([^"]*)"/.exec(tagOuter);
    const id = idMatch
      ? idMatch[1]
      : text.toLowerCase().replace(/[^a-z0-9À-ɏ]+/gu, '-').replace(/^-|-$/g, '');
    items.push({ level, text, id });
  }

  // Fallback: markdown headings
  if (items.length === 0 && post.content_md) {
    const mdHeadingRegex = /^(#{2,3})\s+(.+)$/gm;
    while ((match = mdHeadingRegex.exec(post.content_md)) !== null) {
      const text = match[2].replace(/[*_`&amp;]/g, s => s === '&amp;' ? '&' : s).trim();
      const id = text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
      items.push({ level: match[1].length, text, id });
    }
  }

  // Deduplicate by id
  const seen = new Set<string>();
  return items.filter(item => {
    if (seen.has(item.id)) return false;
    seen.add(item.id);
    return true;
  });
})();

// ogImage: ưu tiên cover_url, fallback vào ảnh đầu tiên trong content blocks
const ogImage = (() => {
  if (post.cover_url) return post.cover_url;
  for (const block of blocks) {
    if (block.type === 'rich') {
      const imgMatch = /<img[^>]+src=["']([^"']+)["'][^>]*>/i.exec(block.content);
      if (imgMatch) return imgMatch[1];
    }
  }
  return '/images/og-image.png';
})();

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: post.description,
  image: post.cover_url ? [post.cover_url] : undefined,
  datePublished: post.published_at,
  dateModified: post.updated_at ?? post.published_at,
  author: {
    '@type': 'Person',
    name: post.author_name,
    url: 'https://dentalempireos.com/about',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Dental Empire OS',
    logo: {
      '@type': 'ImageObject',
      url: 'https://dentalempireos.com/icons/icon-512.png',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': new URL(`/blog/${post.slug}`, Astro.site ?? 'https://dentalempireos.com').toString(),
  },
  articleSection: post.category?.name,
  keywords: post.tags.map(t => t.name).join(', '),
  inLanguage: 'vi',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Trang chủ',
      item: 'https://dentalempireos.com/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Blog',
      item: 'https://dentalempireos.com/blog',
    },
    ...(post.category
      ? [
          {
            '@type': 'ListItem',
            position: 3,
            name: post.category.name,
            item: `https://dentalempireos.com/blog?cat=${post.category.slug}`,
          },
          {
            '@type': 'ListItem',
            position: 4,
            name: post.title,
            item: new URL(`/blog/${post.slug}`, Astro.site ?? 'https://dentalempireos.com').toString(),
          },
        ]
      : [
          {
            '@type': 'ListItem',
            position: 3,
            name: post.title,
            item: new URL(`/blog/${post.slug}`, Astro.site ?? 'https://dentalempireos.com').toString(),
          },
        ]),
  ],
};
---

<BaseLayout
  title={`${post.title} | Blog Dental Empire`}
  description={post.description}
  ogImage={ogImage}
  ogImageAlt={post.title}
  ogType="article"
>
  <StructuredData type="article" data={articleSchema} />
  <StructuredData type="breadcrumb" data={breadcrumbSchema} />

  <!-- Reading progress bar -->
  <div id="read-progress" class="fixed top-[72px] left-0 h-0.5 bg-primary/40 z-50 transition-all duration-100" style="width: 0"></div>

  <!-- Article Header -->
  <section class="relative py-10 sm:py-16 overflow-hidden">
    <!-- Subtle background gradient -->
    <div class="absolute inset-0 bg-gradient-to-b from-surface-container-lowest via-surface to-surface"></div>
    {post.cover_url && (
      <div class="absolute inset-0 opacity-5">
        <img src={post.cover_url} alt="" class="w-full h-full object-cover" />
      </div>
    )}

    <div class="relative z-10 px-6 mx-auto max-w-[680px]">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-1.5 text-xs text-on-surface-variant mb-8">
        <a href="/" class="hover:text-primary transition-colors">Trang chủ</a>
        <span class="opacity-40">/</span>
        <a href="/blog" class="hover:text-primary transition-colors">Blog</a>
        {post.category && (
          <>
            <span class="opacity-40">/</span>
            <a
              href={`/blog?cat=${post.category.slug}`}
              class="hover:text-primary transition-colors"
              style={`color: ${post.category.color}`}
            >
              {post.category.name}
            </a>
          </>
        )}
      </nav>

      <!-- Category badge -->
      {post.category && (
        <a href={`/blog?cat=${post.category.slug}`} class="inline-block mb-5">
          <span
            class="px-3 py-1 text-[11px] font-bold uppercase tracking-wider rounded-full"
            style={`background: ${post.category.color}18; color: ${post.category.color}; border: 1px solid ${post.category.color}30`}
          >
            {post.category.name}
          </span>
        </a>
      )}

      <!-- Title -->
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4 leading-tight">
        {post.title}
      </h1>

      <!-- Description -->
      <p class="text-base sm:text-lg text-on-surface-variant mb-6 leading-relaxed">{post.description}</p>

      <!-- Meta -->
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-on-surface-variant">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-full bg-primary/15 flex items-center justify-center shrink-0">
            <span class="text-[11px] font-bold text-primary">{post.author_name.charAt(0)}</span>
          </div>
          <span class="font-semibold text-white">{post.author_name}</span>
        </div>
        <span class="opacity-30">·</span>
        <time datetime={post.published_at ?? ''}>{formatDate(post.published_at)}</time>
        <span class="opacity-30">·</span>
        <span>{post.read_time_minutes} phút đọc</span>
        {post.updated_at && post.published_at && new Date(post.updated_at) > new Date(post.published_at) && (
          <>
            <span class="opacity-30">·</span>
            <span class="text-primary/80 text-xs">Cập nhật {formatDate(post.updated_at)}</span>
          </>
        )}
        <span class="opacity-30">·</span>
        <span class="flex items-center gap-1">
          <span class="material-symbols-outlined text-[14px]">visibility</span>
          {post.view_count.toLocaleString()} lượt xem
        </span>
      </div>
    </div>
  </section>

  <!-- Article Body -->
  <section class="px-6 pb-20">
    <div class="mx-auto max-w-[1200px] grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-10 xl:gap-14">

      <!-- Main Content Column -->
      <div class="min-w-0">

      <!-- Featured image -->
      {post.cover_url && (
        <div class="mb-8 -mx-6 sm:mx-0">
          <img
            src={post.cover_url}
            alt={post.cover_alt}
            class="w-full sm:rounded-2xl object-cover max-h-[460px]"
            loading="lazy"
          />
        </div>
      )}

      <!-- Content -->
      <article>
        <div class="reader-content" id="article-content">
          {blocks.length > 0 ? (
            <div class="blocks-render flex flex-col gap-6" id="blocks-container" data-post-id={post.id}>
              {blocks.map((block: BlogBlock) => {
                if (block.type === 'text') {
                  return <div class="block-text" set:html={marked(block.content)}></div>;
                } else if (block.type === 'image') {
                  const parsed = (() => { try { return JSON.parse(block.content); } catch { return { url: block.content, alt: '' }; } })();
                  return parsed.url ? (
                    <figure class="block-image my-6">
                      <img src={parsed.url} alt={parsed.alt || ''} class="w-full rounded-xl object-cover" loading="lazy" />
                      {parsed.alt && <figcaption class="text-center text-xs text-on-surface-variant mt-2 px-4">{parsed.alt}</figcaption>}
                    </figure>
                  ) : null;
                } else if (block.type === 'form') {
                  const cfg = (() => { try { return JSON.parse(block.content); } catch { return { title: '', fields: [] }; } })();
                  return (
                    <div class="block-form my-6 p-6 rounded-2xl border border-outline-variant bg-surface-container-low">
                      {cfg.title && <h3 class="text-base font-bold text-white mb-4">{cfg.title}</h3>}
                      <form class="form-render flex flex-col gap-3" data-action="/api/contact">
                        {cfg.fields.map((field: { id: string; type: string; label: string; placeholder?: string; required?: boolean }) => (
                          <div class="flex flex-col gap-1">
                            <label class="text-xs font-semibold text-on-surface-variant">{field.label}{field.required && <span class="text-red-400 ml-1">*</span>}</label>
                            {field.type === 'textarea' ? (
                              <textarea name={field.id} placeholder={field.placeholder || ''} required={field.required} rows="4" class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-xl text-white text-sm placeholder:text-white/20 focus:outline-none focus:border-primary resize-none"></textarea>
                            ) : (
                              <input type={(field.type === 'phone' ? 'tel' : field.type) as any} name={field.id} placeholder={field.placeholder || ''} required={field.required} class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-xl text-white text-sm placeholder:text-white/20 focus:outline-none focus:border-primary" />
                            )}
                          </div>
                        ))}
                        <button type="submit" class="mt-2 px-6 py-2.5 bg-primary text-white rounded-xl text-sm font-bold hover:opacity-90 transition-opacity">Gửi</button>
                      </form>
                    </div>
                  );
                } else if (block.type === 'rich') {
                  const richHtml = addHeadingIds(sanitizeRichHtml(block.content));
                  return <div class="block-rich" set:html={richHtml}></div>;
                }
                return null;
              })}
            </div>
          ) : (
            <div set:html={htmlContent}></div>
          )}
        </div>
      </article>

      <!-- Tags -->
      {post.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-10 pt-8 border-t border-outline-variant">
          {post.tags.map((tag) => (
            <a
              href={`/blog?tag=${tag.slug}`}
              class="px-3 py-1 text-xs font-medium rounded-full bg-surface-container-high text-on-surface-variant border border-outline-variant hover:border-primary/50 hover:text-primary transition-all"
            >
              #{tag.name}
            </a>
          ))}
        </div>
      )}

      <!-- Share -->
      <div class="flex items-center justify-between mt-6 p-4 rounded-2xl border border-outline-variant bg-surface-container-low">
        <div>
          <p class="text-xs font-semibold text-on-surface-variant mb-2">Chia sẻ bài viết</p>
          <div class="flex gap-2">
            <a
              href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Facebook"
              class="w-9 h-9 flex items-center justify-center rounded-lg bg-surface-container-high border border-outline-variant text-on-surface-variant hover:text-primary hover:border-primary/50 transition-all"
            >
              <svg class="w-[16px] h-[16px]" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn"
              class="w-9 h-9 flex items-center justify-center rounded-lg bg-surface-container-high border border-outline-variant text-on-surface-variant hover:text-primary hover:border-primary/50 transition-all"
            >
              <svg class="w-[16px] h-[16px]" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a
              href={`https://sp.zalo.me/share_inline?url=${encodeURIComponent(Astro.url.href)}&title=${encodeURIComponent(post.title)}`}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Zalo"
              class="w-9 h-9 flex items-center justify-center rounded-lg bg-surface-container-high border border-outline-variant text-on-surface-variant hover:text-primary hover:border-primary/50 transition-all"
            >
              <svg class="w-[16px] h-[16px]" fill="currentColor" viewBox="0 0 48 48"><path d="M24 4C12.954 4 4 11.611 4 21.24c0 5.802 3.061 10.945 7.852 14.31-.284 1.078-1.045 3.389-1.232 4.146-.18.728.255.733.563.508.247-.18 2.886-1.802 4.236-2.61C18.6 38.51 21.236 39 24 39c11.046 0 20-7.611 20-17.76C44 11.611 35.046 4 24 4z"/></svg>
            </a>
            <button
              type="button"
              id="copy-link-btn"
              aria-label="Sao chép liên kết"
              class="w-9 h-9 flex items-center justify-center rounded-lg bg-surface-container-high border border-outline-variant text-on-surface-variant hover:text-primary hover:border-primary/50 transition-all"
              data-url={Astro.url.href}
            >
              <span class="material-symbols-outlined text-[16px]">link</span>
            </button>
          </div>
        </div>
        <a href="/blog" class="flex items-center gap-1.5 text-xs text-on-surface-variant hover:text-primary transition-colors">
          <span class="material-symbols-outlined text-[16px]">arrow_back</span>
          Tất cả bài viết
        </a>
      </div>

      <!-- Author Bio -->
      <AuthorBio name={post.author_name} />

      <!-- Linked Content CTAs -->
      {(linkedChapter || linkedScanner) && (
        <div class="mt-6 space-y-4">
          {linkedChapter && (
            <a href={`/book/${linkedChapter.slug}`} class="block rounded-2xl p-5 border border-primary/20 hover:border-primary/40 transition-all group bg-surface-container-low">
              <div class="flex items-start gap-4">
                <div class="w-11 h-11 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center shrink-0">
                  <span class="material-symbols-outlined text-xl text-primary">menu_book</span>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    <span class="px-2 py-0.5 text-[10px] font-bold rounded-full bg-primary/10 border border-primary/20 text-primary">SÁCH</span>
                    <span class="text-[10px] text-on-surface-variant">Chương {linkedChapter.chapter_no}</span>
                  </div>
                  <h3 class="font-bold text-white group-hover:text-primary transition-colors">{linkedChapter.title}</h3>
                  <p class="text-xs text-on-surface-variant mt-1 line-clamp-2">Tìm hiểu đầy đủ chủ đề này trong chương sách chi tiết của chúng tôi, cùng hàng chục chiến lược vận hành phòng khám được đúc kết từ thực tế.</p>
                  <div class="flex items-center gap-1 mt-2 text-primary text-xs font-bold">
                    <span>Đọc chương sách</span>
                    <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
                  </div>
                </div>
              </div>
            </a>
          )}
          {linkedScanner && (
            <a href={`/app/${linkedScanner.id}`} class="block rounded-2xl p-5 border border-tertiary/20 hover:border-tertiary/40 transition-all group bg-surface-container-low">
              <div class="flex items-start gap-4">
                <div class="w-11 h-11 rounded-xl bg-tertiary/10 border border-tertiary/20 flex items-center justify-center shrink-0">
                  <span class="material-symbols-outlined text-xl text-tertiary">quiz</span>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    <span class="px-2 py-0.5 text-[10px] font-bold rounded-full bg-tertiary/10 border border-tertiary/20 text-tertiary">BÀI TEST</span>
                  </div>
                  <h3 class="font-bold text-white group-hover:text-tertiary transition-colors">{linkedScanner.title_vi}</h3>
                  <p class="text-xs text-on-surface-variant mt-1 line-clamp-2">{linkedScanner.description_vi || 'Làm bài test để đánh giá kiến thức và nhận kết quả chi tiết.'}</p>
                  <div class="flex items-center gap-1 mt-2 text-tertiary text-xs font-bold">
                    <span>Làm bài test</span>
                    <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
                  </div>
                </div>
              </div>
            </a>
          )}
        </div>
      )}

      <!-- Related Posts -->
      {related.length > 0 && (
        <div class="mt-12 pt-8 border-t border-outline-variant">
          <h2 class="text-base font-bold text-white mb-6 flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-[18px]">auto_awesome</span>
            Bài viết liên quan
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {related.map((r) => (
              <a href={`/blog/${r.slug}`} class="group">
                <article class="rounded-2xl overflow-hidden border border-outline-variant hover:border-primary/30 transition-all duration-300 h-full">
                  {r.cover_url ? (
                    <img
                      src={r.cover_url}
                      alt={r.cover_alt}
                      class="w-full h-36 object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-36 bg-gradient-to-br from-primary/20 to-tertiary/20"></div>
                  )}
                  <div class="p-4">
                    {r.category && (
                      <span class="text-[10px] font-bold uppercase tracking-wider" style={`color: ${r.category.color}`}>
                        {r.category.name}
                      </span>
                    )}
                    <h3 class="text-sm font-bold text-white line-clamp-2 group-hover:text-primary transition-colors leading-snug mt-1.5">
                      {r.title}
                    </h3>
                    <div class="flex items-center gap-2 mt-2 text-[11px] text-on-surface-variant">
                      <span>{r.read_time_minutes} phút</span>
                      <span>·</span>
                      <span>{r.view_count.toLocaleString()} xem</span>
                    </div>
                  </div>
                </article>
              </a>
            ))}
          </div>
        </div>
      )}

      </div><!-- /main content -->

      <!-- Sidebar -->
      <aside class="hidden lg:block space-y-6 self-start sticky top-24">

        <!-- Điểm nổi bật -->
        {tocItems.length > 2 && (
          <details class="group rounded-2xl border border-outline-variant bg-white dark:bg-surface-container-low [&::-webkit-details-marker]:hidden" open>
            <summary class="flex items-center gap-2.5 px-4 py-3.5 cursor-pointer select-none list-none">
              <div class="w-7 h-7 rounded-lg bg-[#B45309] flex items-center justify-center shrink-0">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="white"/>
                </svg>
              </div>
              <div class="flex-1">
                <p class="text-sm font-bold text-gray-900 dark:text-white leading-none">Điểm nổi bật</p>
                <p class="text-[11px] text-gray-500 dark:text-on-surface-variant mt-0.5">Nhấn để đến mục tương ứng</p>
              </div>
              <span class="material-symbols-outlined text-[18px] text-gray-400 dark:text-on-surface-variant/40 transition-transform group-open:rotate-180">expand_more</span>
            </summary>
            <div class="border-t border-gray-100 dark:border-outline-variant"></div>
            <ol class="toc-list ol-reset px-4 py-3 space-y-2" style="counter-reset: toc-counter">
              {tocItems.map((item) => (
                <li class={`toc-list-item ${item.level === 3 ? 'toc-list-h3' : ''}`}>
                  <a
                    href={`#${item.id}`}
                    class="flex items-start gap-2.5 group/toc toc-item"
                    data-id={item.id}
                    data-level={item.level}
                  >
                    <span class="toc-badge w-5 h-5 rounded-full bg-[#B45309] dark:bg-primary text-white text-[10px] font-bold flex items-center justify-center shrink-0 mt-0.5 transition-transform group-hover/toc:scale-110"></span>
                    <span class="text-xs text-gray-700 dark:text-on-surface-variant group-hover/toc:text-[#B45309] dark:group-hover/toc:text-primary transition-colors leading-snug">{item.text}</span>
                  </a>
                </li>
              ))}
            </ol>
          </details>
        )}

        <!-- Bài viết xem nhiều nhất -->
        {popular.length > 0 && (
          <div class="rounded-2xl border border-outline-variant bg-white dark:bg-surface-container-low overflow-hidden">
            <div class="flex items-center gap-2.5 px-4 py-3.5">
              <div class="w-7 h-7 rounded-lg bg-[#B45309] flex items-center justify-center shrink-0">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z" fill="white"/>
                </svg>
              </div>
              <p class="text-sm font-bold text-gray-900 dark:text-white leading-none">Bài viết xem nhiều nhất</p>
            </div>
            <div class="border-t border-gray-100 dark:border-outline-variant"></div>
            <ol class="divide-y divide-gray-50 dark:divide-outline-variant">
              {popular.slice(0, 5).map((p, i) => (
                <li>
                  <a href={`/blog/${p.slug}`} class="flex items-start gap-3 px-4 py-3 hover:bg-gray-50 dark:hover:bg-white/5 transition-colors group/pop">
                    <span class="w-6 h-6 rounded bg-[#B45309]/10 dark:bg-primary/10 text-[#B45309] dark:text-primary text-[11px] font-bold flex items-center justify-center shrink-0 mt-0.5">{i + 1}</span>
                    <div class="flex-1 min-w-0">
                      <p class="text-xs font-semibold text-gray-800 dark:text-white/90 group-hover/pop:text-[#B45309] dark:group-hover/pop:text-primary transition-colors leading-snug line-clamp-2">{p.title}</p>
                      <p class="text-[10px] text-gray-400 dark:text-on-surface-variant/60 mt-1">{p.view_count.toLocaleString()} lượt xem</p>
                    </div>
                  </a>
                </li>
              ))}
            </ol>
          </div>
        )}

      </aside>

    </div>
  </section>

  <!-- Mobile section navigation (FAB + bottom sheet) -->
  {tocItems.length > 2 && (
    <BlogSectionNav items={tocItems} postTitle={post.title} />
  )}

  <!-- AI Chat Widget -->
  <WebsiteChatWidget pageType="blog" pageSlug={post.slug} />
</BaseLayout>

<script>
  // Reading progress bar
  const progressBar = document.getElementById('read-progress');
  const article = document.getElementById('article-content');

  if (progressBar && article) {
    function updateProgress() {
      const rect = article!.getBoundingClientRect();
      const total = rect.height;
      const scrolled = Math.max(0, -rect.top);
      const progress = Math.min(100, (scrolled / total) * 100);
      progressBar!.style.width = `${progress}%`;
    }
    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();
  }

  // TOC active state
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-item');
  if (tocLinks.length) {
    const headingEls: HTMLElement[] = [];
    tocLinks.forEach((link) => {
      const id = link.dataset.id;
      if (id) {
        const el = document.getElementById(id);
        if (el) headingEls.push(el);
      }
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const id = entry.target.id;
          const link = document.querySelector(`.toc-item[data-id="${id}"]`);
          if (link) {
            if (entry.isIntersecting) {
              document.querySelectorAll('.toc-item').forEach((l) => l.classList.remove('toc-item-active'));
              link.classList.add('toc-item-active');
            }
          }
        });
      },
      { rootMargin: '-20% 0px -70% 0px' },
    );

    headingEls.forEach((el) => observer.observe(el));
  }

  // Add IDs to headings in rendered content
  const content = document.getElementById('article-content');
  if (content) {
    content.querySelectorAll('h2, h3').forEach((heading) => {
      if (!heading.id) {
        const text = heading.textContent ?? '';
        const id = text.toLowerCase().replace(/[^a-z0-9À-ɏ]+/gu, '-').replace(/^-|-$/g, '');
        heading.id = id;
      }
    });
  }

  // Copy Link handler
  const copyBtn = document.getElementById('copy-link-btn') as HTMLButtonElement | null;
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      const url = copyBtn.dataset.url ?? window.location.href;
      try {
        await navigator.clipboard.writeText(url);
        const original = copyBtn.innerHTML;
        copyBtn.innerHTML = '<span class="material-symbols-outlined text-[18px]">check</span>';
        copyBtn.classList.add('border-green-400', 'text-green-400');
        setTimeout(() => {
          copyBtn.innerHTML = original;
          copyBtn.classList.remove('border-green-400', 'text-green-400');
        }, 1500);
      } catch {
        // Fallback: select-and-copy via temp input
        const input = document.createElement('input');
        input.value = url;
        document.body.appendChild(input);
        input.select();
        document.execCommand('copy');
        document.body.removeChild(input);
      }
    });
  }

  // Blog form submissions (form blocks)
  document.querySelectorAll<HTMLFormElement>('.form-render').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalText = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Đang gửi...';

      try {
        const formData = new FormData(form);
        const fields: Record<string, string> = {};
        formData.forEach((val, key) => { fields[key] = String(val); });

        const postId = document.getElementById('blocks-container')?.getAttribute('data-post-id') || '';

        const res = await fetch('/api/blog-form', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            post_id: postId,
            fields,
          }),
        });

        if (!res.ok) throw new Error();

        btn.textContent = '✓ Đã gửi!';
        btn.classList.add('bg-green-600');
        form.reset();
        setTimeout(() => {
          btn.textContent = originalText;
          btn.disabled = false;
          btn.classList.remove('bg-green-600');
        }, 3000);
      } catch {
        btn.textContent = 'Lỗi — thử lại';
        btn.disabled = false;
        setTimeout(() => { btn.textContent = originalText; }, 2000);
      }
    });
  });
</script>
