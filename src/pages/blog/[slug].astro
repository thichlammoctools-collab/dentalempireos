---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogSectionNav from '../../components/blog/BlogSectionNav.astro';
import StructuredData from '../../components/seo/StructuredData.astro';
import { marked } from 'marked';
import { env } from 'cloudflare:workers';
import { getPost, getRelatedPosts, getPopularPosts, listCategories, incrementViewCount, getBlocksByPostId, type BlogPostWithMeta, type BlogCategory, type BlogBlock } from '../../lib/blog-db';
import { sanitizeRichHtml } from '../../lib/sanitize';

export const prerender = false;

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/blog');

const db = env.DB;

let post: BlogPostWithMeta | null = null;
let popular: BlogPostWithMeta[] = [];
let categories: BlogCategory[] = [];

try {
  [post, popular, categories] = await Promise.all([
    getPost(db, slug),
    getPopularPosts(db, 5),
    listCategories(db),
  ]);
} catch {
  // If main queries fail, try just the post
  try {
    post = await getPost(db, slug);
  } catch {
    post = null;
  }
}

if (!post) {
  return new Response('Không tìm thấy bài viết', { status: 404 });
}

let blocks: BlogBlock[] = [];
try {
  blocks = await getBlocksByPostId(db, post.id);
} catch {
  // blog_block table may not exist yet — gracefully degrade
  blocks = [];
}

// Increment view count (fire and forget)
incrementViewCount(db, post.id).catch(() => {});

let related: BlogPostWithMeta[] = [];
try {
  related = await getRelatedPosts(db, post.id, post.category_id, 4);
} catch {
  related = [];
}

const htmlContent = marked(post.content_md);

function formatDate(iso: string | null): string {
  if (!iso) return '';
  return new Date(iso).toLocaleDateString('vi-VN', { day: '2-digit', month: 'long', year: 'numeric' });
}

// Build TOC from h2/h3 headings in content (blocks or markdown)
const tocItems = (() => {
  const headingRegex = /^(#{2,3})\s+(.+)$/gm;
  const items: { level: number; text: string; id: string }[] = [];
  const source = blocks.length > 0
    ? blocks.map(b => {
        if (b.type === 'rich') {
          // Convert HTML headings to Markdown-style so the headingRegex can match them.
          return b.content
            .replace(/<h2[^>]*>(.*?)<\/h2>/gi, (_, t) => `## ${t.replace(/<[^>]+>/g, '')}`)
            .replace(/<h3[^>]*>(.*?)<\/h3>/gi, (_, t) => `### ${t.replace(/<[^>]+>/g, '')}`);
        }
        return b.type === 'text' ? b.content : '';
      }).join('\n')
    : post.content_md;
  let match;
  while ((match = headingRegex.exec(source)) !== null) {
    const text = match[2].replace(/[*_`]/g, '').trim();
    const id = text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    items.push({ level: match[1].length, text, id });
  }
  return items;
})();

const ogImage = post.cover_url || '/images/og-image.svg';

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: post.description,
  image: post.cover_url ? [post.cover_url] : undefined,
  datePublished: post.published_at,
  dateModified: post.updated_at ?? post.published_at,
  author: {
    '@type': 'Person',
    name: post.author_name,
    url: 'https://dentalempireos.com/about',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Dental Empire OS',
    logo: {
      '@type': 'ImageObject',
      url: 'https://dentalempireos.com/favicon.svg',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': new URL(`/blog/${post.slug}`, Astro.site ?? 'https://dentalempireos.com').toString(),
  },
  articleSection: post.category?.name,
  keywords: post.tags.map(t => t.name).join(', '),
  inLanguage: 'vi',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Trang chủ',
      item: 'https://dentalempireos.com/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Blog',
      item: 'https://dentalempireos.com/blog',
    },
    ...(post.category
      ? [
          {
            '@type': 'ListItem',
            position: 3,
            name: post.category.name,
            item: `https://dentalempireos.com/blog?cat=${post.category.slug}`,
          },
          {
            '@type': 'ListItem',
            position: 4,
            name: post.title,
            item: new URL(`/blog/${post.slug}`, Astro.site ?? 'https://dentalempireos.com').toString(),
          },
        ]
      : [
          {
            '@type': 'ListItem',
            position: 3,
            name: post.title,
            item: new URL(`/blog/${post.slug}`, Astro.site ?? 'https://dentalempireos.com').toString(),
          },
        ]),
  ],
};
---

<BaseLayout
  title={`${post.title} | Blog Dental Empire`}
  description={post.description}
  ogImage={ogImage}
  ogType="article"
>
  <StructuredData type="article" data={articleSchema} />
  <StructuredData type="breadcrumb" data={breadcrumbSchema} />

  <!-- Reading progress bar -->
  <div id="read-progress" class="fixed top-20 left-0 h-0.5 read-progress z-50" style="width: 0"></div>

  <!-- Article Header -->
  <section class="relative py-8 sm:py-12 overflow-hidden">
    {post.cover_url && (
      <div class="absolute inset-0">
        <img src={post.cover_url} alt={post.cover_alt} class="w-full h-full object-cover opacity-20" />
        <div class="absolute inset-0 bg-gradient-to-b from-surface via-surface/80 to-surface"></div>
      </div>
    )}
    {!post.cover_url && <div class="absolute inset-0 bg-gradient-to-b from-surface-container-lowest to-surface"></div>}

    <div class="relative z-10 px-6 max-w-[800px] mx-auto text-center">
      <!-- Breadcrumb -->
      <div class="flex items-center justify-center gap-2 text-xs text-on-surface-variant mb-6">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span class="material-symbols-outlined text-[12px]">chevron_right</span>
        <a href="/blog" class="hover:text-primary transition-colors">Blog</a>
        {post.category && (
          <>
            <span class="material-symbols-outlined text-[12px]">chevron_right</span>
            <a
              href={`/blog?cat=${post.category.slug}`}
              class="hover:text-primary transition-colors"
              style={`color: ${post.category.color}`}
            >
              {post.category.name}
            </a>
          </>
        )}
      </div>

      <!-- Category badge -->
      {post.category && (
        <a href={`/blog?cat=${post.category.slug}`} class="inline-block mb-4">
          <span
            class="px-3 py-1.5 text-xs font-bold uppercase tracking-wider rounded-full"
            style={`background: ${post.category.color}22; color: ${post.category.color}; border: 1px solid ${post.category.color}44`}
          >
            {post.category.name}
          </span>
        </a>
      )}

      <h1 class="text-headline-medium font-bold text-white mb-4 leading-tight">
        {post.title}
      </h1>
      <p class="text-on-surface-variant text-base mb-6">{post.description}</p>

      <!-- Meta -->
      <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-sm text-on-surface-variant">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center">
            <span class="text-xs font-bold text-primary">{post.author_name.charAt(0)}</span>
          </div>
          <span class="font-semibold text-white">{post.author_name}</span>
        </div>
        <span class="opacity-40 hidden sm:inline">·</span>
        <span class="flex items-center gap-1">
          <span class="material-symbols-outlined text-[16px]">calendar_today</span>
          <time datetime={post.published_at ?? ''}>{formatDate(post.published_at)}</time>
        </span>
        <span class="opacity-40 hidden sm:inline">·</span>
        <span class="flex items-center gap-1">
          <span class="material-symbols-outlined text-[16px]">schedule</span>
          {post.read_time_minutes} phút đọc
        </span>
        <span class="opacity-40 hidden sm:inline">·</span>
        <span class="flex items-center gap-1">
          <span class="material-symbols-outlined text-[16px]">visibility</span>
          {post.view_count.toLocaleString()}
        </span>
      </div>

      {post.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4 justify-center">
          {post.tags.map((tag) => (
            <a
              href={`/blog?tag=${tag.slug}`}
              class="px-2.5 py-1 text-xs font-semibold rounded-full bg-surface-container-high text-on-surface-variant border border-outline-variant hover:border-primary transition-all"
            >
              #{tag.name}
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Article Body -->
  <section class="px-6 max-w-[1200px] mx-auto pb-16">
    <div class="flex flex-col lg:flex-row gap-10">

      <!-- TOC (desktop sidebar) -->
      {tocItems.length > 2 && (
        <aside class="hidden lg:block w-64 shrink-0">
          <div class="sticky top-28">
            <div class="glass-card rounded-2xl p-4">
              <h3 class="text-sm font-bold uppercase tracking-wider text-on-surface-variant mb-3 flex items-center gap-2">
                <span class="material-symbols-outlined text-[16px]">list</span>
                Mục lục
              </h3>
              <nav class="space-y-1">
                {tocItems.map((item) => (
                  <a
                    href={`#${item.id}`}
                    class="block text-sm py-2 border-l-2 border-outline-variant text-on-surface-variant hover:text-primary hover:border-primary hover:bg-primary/5 transition-all duration-200 toc-item"
                    style={item.level === 3 ? 'padding-left: 1.5rem' : 'padding-left: 0.75rem'}
                    data-id={item.id}
                  >
                    {item.text}
                  </a>
                ))}
              </nav>
            </div>
          </div>
        </aside>
      )}

      <!-- Content -->
      <article class="flex-1 min-w-0 max-w-[760px]">
        <div class="glass-card rounded-2xl px-5 sm:px-8 lg:px-10 py-6 sm:py-8 lg:py-10">
          <div class="reader-content" id="article-content">
            {blocks.length > 0 ? (
              <div class="blocks-render flex flex-col gap-6" id="blocks-container" data-post-id={post.id}>
                {blocks.map((block: BlogBlock) => {
                  if (block.type === 'text') {
                    return <div class="block-text" set:html={marked(block.content)}></div>;
                  } else if (block.type === 'image') {
                    const parsed = (() => { try { return JSON.parse(block.content); } catch { return { url: block.content, alt: '' }; } })();
                    return parsed.url ? (
                      <figure class="block-image my-4">
                        <img src={parsed.url} alt={parsed.alt || ''} class="w-full rounded-xl object-cover" loading="lazy" />
                        {parsed.alt && <figcaption class="text-center text-xs text-on-surface-variant mt-2">{parsed.alt}</figcaption>}
                      </figure>
                    ) : null;
                  } else if (block.type === 'form') {
                    const cfg = (() => { try { return JSON.parse(block.content); } catch { return { title: '', fields: [] }; } })();
                    return (
                      <div class="block-form my-4 p-6 bg-surface-container rounded-2xl border border-outline-variant">
                        {cfg.title && <h3 class="text-base font-bold text-white mb-4">{cfg.title}</h3>}
                        <form class="form-render flex flex-col gap-3" data-action="/api/contact">
                          {cfg.fields.map((field: { id: string; type: string; label: string; placeholder?: string; required?: boolean }) => (
                            <div class="flex flex-col gap-1">
                              <label class="text-xs font-semibold text-on-surface-variant">{field.label}{field.required && <span class="text-red-400 ml-1">*</span>}</label>
                              {field.type === 'textarea' ? (
                                <textarea name={field.id} placeholder={field.placeholder || ''} required={field.required} rows="4" class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-xl text-white text-sm placeholder:text-white/20 focus:outline-none focus:border-primary resize-none"></textarea>
                              ) : (
                                <input type={field.type === 'phone' ? 'tel' : field.type} name={field.id} placeholder={field.placeholder || ''} required={field.required} class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-xl text-white text-sm placeholder:text-white/20 focus:outline-none focus:border-primary" />
                              )}
                            </div>
                          ))}
                          <button type="submit" class="mt-2 px-6 py-2.5 bg-primary text-white rounded-xl text-sm font-bold hover:opacity-90 transition-opacity">Gửi</button>
                        </form>
                      </div>
                    );
                  } else if (block.type === 'rich') {
                    return <div class="block-rich" set:html={sanitizeRichHtml(block.content)}></div>;
                  }
                  return null;
                })}
              </div>
            ) : (
              <div set:html={htmlContent}></div>
            )}
          </div>
        </div>

        <!-- Share -->
        <div class="flex items-center justify-between mt-6 glass-card rounded-2xl p-5">
          <div>
            <p class="text-sm font-semibold text-white mb-1">Chia sẻ bài viết</p>
            <div class="flex gap-3 mt-2">
              <a
                href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`}
                target="_blank"
                rel="noopener"
                class="w-9 h-9 flex items-center justify-center rounded-lg bg-surface-container-high border border-outline-variant text-on-surface-variant hover:text-primary hover:border-primary transition-all"
              >
                <span class="material-symbols-outlined text-[18px]">share</span>
              </a>
              <a
                href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(Astro.url.href)}&text=${encodeURIComponent(post.title)}`}
                target="_blank"
                rel="noopener"
                class="w-9 h-9 flex items-center justify-center rounded-lg bg-surface-container-high border border-outline-variant text-on-surface-variant hover:text-primary hover:border-primary transition-all"
              >
                <span class="material-symbols-outlined text-[18px]">link</span>
              </a>
            </div>
          </div>
          <a href="/blog" class="flex items-center gap-2 text-sm text-on-surface-variant hover:text-primary transition-colors">
            <span class="material-symbols-outlined text-[18px]">arrow_back</span>
            Quay lại blog
          </a>
        </div>

        <!-- Related Posts -->
        {related.length > 0 && (
          <div class="mt-10">
            <h2 class="text-lg font-bold text-white mb-6 flex items-center gap-2">
              <span class="material-symbols-outlined text-primary text-[20px]">auto_awesome</span>
              Bài viết liên quan
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              {related.map((r) => (
                <a href={`/blog/${r.slug}`} class="group">
                  <article class="glass-card rounded-2xl overflow-hidden flex hover:-translate-y-1 transition-all duration-300">
                    {r.cover_url ? (
                      <img
                        src={r.cover_url}
                        alt={r.cover_alt}
                        class="w-24 h-24 object-cover shrink-0 group-hover:scale-105 transition-transform duration-500"
                        loading="lazy"
                      />
                    ) : (
                      <div class="w-24 h-24 shrink-0 bg-gradient-to-br from-primary/30 to-tertiary/20"></div>
                    )}
                    <div class="p-4 flex flex-col justify-center min-w-0">
                      {r.category && (
                        <span
                          class="text-[10px] font-bold uppercase tracking-wider"
                          style={`color: ${r.category.color}`}
                        >
                          {r.category.name}
                        </span>
                      )}
                      <h3 class="text-sm font-bold text-white line-clamp-2 group-hover:text-primary transition-colors leading-snug mt-1">
                        {r.title}
                      </h3>
                      <div class="flex items-center gap-2 mt-2 text-[11px] text-on-surface-variant">
                        <span>{r.read_time_minutes} phút</span>
                        <span>·</span>
                        <span>{r.view_count.toLocaleString()} lượt xem</span>
                      </div>
                    </div>
                  </article>
                </a>
              ))}
            </div>
          </div>
        )}
      </article>

    </div>
  </section>

  <!-- Mobile section navigation (FAB + bottom sheet) -->
  {tocItems.length > 2 && (
    <BlogSectionNav items={tocItems} postTitle={post.title} />
  )}
</BaseLayout>

<script>
  // Reading progress bar
  const progressBar = document.getElementById('read-progress');
  const article = document.getElementById('article-content');

  if (progressBar && article) {
    function updateProgress() {
      const rect = article.getBoundingClientRect();
      const total = rect.height;
      const scrolled = Math.max(0, -rect.top);
      const progress = Math.min(100, (scrolled / total) * 100);
      progressBar.style.width = `${progress}%`;
    }
    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();
  }

  // TOC active state
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-item');
  if (tocLinks.length) {
    const headingEls: HTMLElement[] = [];
    tocLinks.forEach((link) => {
      const id = link.dataset.id;
      if (id) {
        const el = document.getElementById(id);
        if (el) headingEls.push(el);
      }
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const id = entry.target.id;
          const link = document.querySelector(`.toc-item[data-id="${id}"]`);
          if (link) {
            if (entry.isIntersecting) {
              document.querySelectorAll('.toc-item').forEach((l) => l.classList.remove('toc-item-active'));
              link.classList.add('toc-item-active');
            }
          }
        });
      },
      { rootMargin: '-20% 0px -70% 0px' },
    );

    headingEls.forEach((el) => observer.observe(el));
  }

  // Add IDs to headings in rendered content
  const content = document.getElementById('article-content');
  if (content) {
    content.querySelectorAll('h2, h3').forEach((heading) => {
      if (!heading.id) {
        const text = heading.textContent ?? '';
        const id = text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
        heading.id = id;
      }
    });
  }

  // Blog form submissions (form blocks)
  document.querySelectorAll<HTMLFormElement>('.form-render').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalText = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Đang gửi...';

      try {
        const formData = new FormData(form);
        const fields: Record<string, string> = {};
        formData.forEach((val, key) => { fields[key] = String(val); });

        const postId = document.getElementById('blocks-container')?.getAttribute('data-post-id') || '';

        const res = await fetch('/api/blog-form', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            post_id: postId,
            fields,
          }),
        });

        if (!res.ok) throw new Error();

        btn.textContent = '✓ Đã gửi!';
        btn.classList.add('bg-green-600');
        form.reset();
        setTimeout(() => {
          btn.textContent = originalText;
          btn.disabled = false;
          btn.classList.remove('bg-green-600');
        }, 3000);
      } catch {
        btn.textContent = 'Lỗi — thử lại';
        btn.disabled = false;
        setTimeout(() => { btn.textContent = originalText; }, 2000);
      }
    });
  });
</script>
