---
import BaseLayout from '../layouts/BaseLayout.astro';
import { tiers } from '../data/modules';

const tierIcons: Record<number, string> = {
  1: 'clinical_notes',
  2: 'groups',
  3: 'terminal',
};
const tierLetters: Record<number, string> = {
  1: 'C',
  2: 'U',
  3: 'O',
};
---

<BaseLayout
  title="Về Chúng Tôi | Dental Empire OS"
  description="Sứ mệnh chuyên nghiệp hóa ngành nha. Dental Empire OS tái định nghĩa cách phòng khám vận hành qua sự kết hợp giữa y đức truyền thống và công nghệ tự động hóa."
>

  <!-- Hero Section -->
  <section class="relative px-6 py-20 overflow-hidden min-h-[70vh] flex flex-col justify-center">
    <div class="absolute top-0 right-0 w-1/2 h-full opacity-30 pointer-events-none">
      <div class="absolute inset-0 bg-gradient-to-l from-brand-cyan/20 to-transparent"></div>
    </div>
    <div class="max-w-[1200px] mx-auto w-full">
      <div class="max-w-4xl relative z-10">
        <div class="flex items-center gap-2 mb-4">
          <span class="status-dot"></span>
          <span class="text-xs font-bold tracking-[0.2em] uppercase text-brand-cyan">System On · Next-Gen Clinical Sovereignty</span>
        </div>
        <h1 class="text-headline-xl md:text-[64px] leading-tight text-white mb-6">
          Về Chúng Tôi —<br />
          <span class="text-gradient-cyan">Sứ Mệnh Chuyên Nghiệp Hóa Ngành Nha</span>
        </h1>
        <p class="text-on-surface-variant max-w-2xl leading-relaxed">
          Dental Empire OS không chỉ là một phần mềm quản lý. Chúng tôi là một hệ tư duy mới, tái định nghĩa cách các phòng khám vận hành thông qua sự kết hợp giữa y đức truyền thống và công nghệ tự động hóa tương lai.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a href="#" class="bg-brand-cyan text-white px-8 py-4 rounded-xl font-bold cyan-glow hover:brightness-110 active:scale-95 transition-all flex items-center gap-2">
            Tham gia Cộng đồng
            <span class="material-symbols-outlined">group</span>
          </a>
          <a href="/book" class="border border-outline px-8 py-4 rounded-xl font-bold text-on-surface-variant hover:border-primary hover:text-primary active:scale-95 transition-all">
            Tìm hiểu Hệ thống
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Brand Story Section -->
  <section class="px-6 py-20 bg-surface-container-lowest">
    <div class="max-w-[1200px] mx-auto grid md:grid-cols-2 gap-12 items-center">
      <div class="relative group">
        <div class="absolute -inset-4 bg-brand-cyan/5 rounded-3xl blur-2xl group-hover:bg-brand-cyan/10 transition-all"></div>
        <img
          src="/images/book/cover.jpg"
          alt="Dental Empire OS"
          class="relative rounded-3xl border border-outline-variant/20 shadow-2xl w-full object-cover"
          loading="lazy"
        />
      </div>
      <div class="space-y-6">
        <h2 class="text-headline-lg text-white">Hành Trình Chuyển Đổi Số</h2>
        <div class="space-y-4 text-on-surface-variant leading-relaxed">
          <p>
            Khởi nguồn từ trăn trở về việc tối ưu hóa hiệu suất lâm sàng, Dental Empire OS ra đời để giải quyết những nút thắt của các phòng khám truyền thống: sự phụ thuộc vào con người, quy trình rời rạc và thiếu hụt dữ liệu thực tế.
          </p>
          <p>
            Chúng tôi tin rằng mỗi bác sĩ xứng đáng có một "Hệ điều hành" để giải phóng họ khỏi những tác vụ quản trị thủ công, giúp họ tập trung hoàn toàn vào chuyên môn và sự hài lòng của bệnh nhân.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-4 pt-4">
          <div class="p-4 glass-card rounded-xl border-l-4 border-l-brand-cyan">
            <div class="text-primary text-4xl font-bold">15+</div>
            <div class="text-xs font-bold tracking-[0.1em] uppercase text-on-surface-variant mt-1">Năm Kinh Nghiệm</div>
          </div>
          <div class="p-4 glass-card rounded-xl border-l-4 border-l-brand-cyan">
            <div class="text-primary text-4xl font-bold">500+</div>
            <div class="text-xs font-bold tracking-[0.1em] uppercase text-on-surface-variant mt-1">Phòng Khám Đối Tác</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Founder Section -->
  <section class="px-6 py-20">
    <div class="max-w-[1200px] mx-auto glass-card rounded-3xl overflow-hidden grid md:grid-cols-12 shadow-2xl">
      <div class="md:col-span-5 relative h-[500px] md:h-auto md:min-h-[520px]">
        <img
          src="/images/founder.jpg"
          alt="Dr. Nguyễn Phước Vinh — Founder & CEO"
          class="absolute inset-0 w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700"
          loading="lazy"
        />
        <div class="absolute bottom-0 left-0 w-full p-6 bg-gradient-to-t from-black to-transparent">
          <h3 class="text-headline-md text-white">Dr. Nguyễn Phước Vinh</h3>
          <p class="text-xs font-bold tracking-[0.1em] uppercase text-brand-cyan mt-1">Founder &amp; CEO</p>
        </div>
      </div>
      <div class="md:col-span-7 p-8 md:p-12 flex flex-col justify-center space-y-4">
        <h4 class="text-title-lg text-primary font-bold">Tầm Nhìn Từ Người Trong Cuộc</h4>
        <p class="text-on-surface-variant leading-relaxed">
          "Hơn 15 năm đứng ghế và quản trị, tôi nhận ra rằng sự thành công của một nha khoa không nằm ở quy mô mặt bằng, mà ở hiệu suất của 'Hệ điều hành' đằng sau nó. Dental Empire OS là tâm huyết của tôi để mang lại sự tự do thực sự cho các đồng nghiệp."
        </p>
        <div class="flex flex-wrap gap-8 border-t border-outline-variant/20 pt-6">
          <div class="flex flex-col">
            <span class="font-bold text-on-surface">Chuyên gia Quản trị</span>
            <span class="text-sm text-on-surface-variant">Chiến lược vận hành nha khoa</span>
          </div>
          <div class="flex flex-col">
            <span class="font-bold text-on-surface">Tác giả</span>
            <span class="text-sm text-on-surface-variant">Kiến trúc hệ thống Dental Empire</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3-Tier Philosophy -->
  <section class="px-6 py-20 bg-surface-container-low">
    <div class="max-w-[1200px] mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-headline-lg text-white mb-3">Triết Lý 3 Lớp Toàn Diện</h2>
        <p class="text-on-surface-variant max-w-xl mx-auto">Nền tảng vững chắc cho sự phát triển bền vững của mọi tổ chức nha khoa.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {tiers.map((tier) => (
          <div class:list={[
            'glass-card p-8 rounded-3xl relative overflow-hidden group',
            tier.tier === 3 ? 'border-2 border-brand-cyan/30' : '',
          ]}>
            <div class="absolute -right-4 -top-4 text-[120px] font-bold leading-none opacity-5 text-brand-cyan group-hover:scale-110 transition-transform">
              {tierLetters[tier.tier]}
            </div>
            <span class="material-symbols-outlined text-brand-cyan text-[48px] mb-4" style="font-variation-settings: 'FILL' 1;">
              {tierIcons[tier.tier]}
            </span>
            <h3 class="text-title-md text-white font-bold mb-2">{tier.name}</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed">{tier.subtitle}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Core Values Bento Grid -->
  <section class="px-6 py-20">
    <div class="max-w-[1200px] mx-auto">
      <h2 class="text-headline-lg text-white mb-16 text-center">Giá Trị Cốt Lõi</h2>
      <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:auto-rows-[240px]">
        <div class="md:col-span-8 md:row-span-1 glass-card p-8 rounded-3xl flex flex-col justify-end relative overflow-hidden bg-gradient-to-br from-brand-cyan/10 to-transparent">
          <div class="relative z-10">
            <h4 class="text-title-md text-primary font-bold mb-2">Clinical Excellence</h4>
            <p class="text-on-surface-variant max-w-lg">Chúng tôi không bao giờ đánh đổi chất lượng chuyên môn để lấy lợi nhuận. Mọi tính năng trong OS đều phục vụ kết quả điều trị tốt nhất.</p>
          </div>
        </div>
        <div class="md:col-span-4 glass-card p-8 rounded-3xl flex flex-col items-center justify-center text-center border-t-2 border-brand-cyan">
          <span class="material-symbols-outlined text-brand-cyan text-[64px] mb-4">verified_user</span>
          <h4 class="text-title-md text-white font-bold mb-2">Digital Sovereignty</h4>
          <p class="text-sm text-on-surface-variant">Chủ quyền số hóa, bảo mật tuyệt đối dữ liệu bệnh nhân và quyền sở hữu hệ thống của phòng khám.</p>
        </div>
        <div class="md:col-span-4 glass-card p-6 rounded-3xl flex items-center gap-4">
          <div class="bg-surface-container-highest p-3 rounded-xl shrink-0">
            <span class="material-symbols-outlined text-primary">trending_up</span>
          </div>
          <div>
            <h4 class="font-bold text-on-surface">Community Growth</h4>
            <p class="text-xs text-on-surface-variant mt-1">Phát triển cùng cộng đồng bác sĩ quản trị chuyên nghiệp.</p>
          </div>
        </div>
        <div class="md:col-span-8 glass-card p-8 rounded-3xl flex items-center justify-between gap-4 bg-gradient-to-r from-brand-cyan/10 to-transparent">
          <div class="max-w-md">
            <h4 class="text-title-md text-white font-bold mb-1">Next-Gen Authority</h4>
            <p class="text-sm text-on-surface-variant">Xây dựng vị thế dẫn đầu thông qua công nghệ và sự chuẩn mực trong quản trị.</p>
          </div>
          <span class="material-symbols-outlined text-brand-cyan text-[48px] opacity-50 shrink-0">auto_awesome</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="px-6 py-32 text-center relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-brand-cyan/10 via-transparent to-transparent"></div>
    <div class="relative z-10 max-w-2xl mx-auto">
      <h2 class="text-headline-xl text-white mb-8">
        Sẵn Sàng Để Làm Chủ<br />
        <span class="text-brand-cyan">Đế Chế Của Riêng Bạn?</span>
      </h2>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/book" class="bg-primary text-on-primary px-8 py-4 rounded-xl font-bold cyan-glow hover:scale-105 active:scale-95 transition-all text-lg">
          Bắt Đầu Ngay
        </a>
        <a href="#" class="border border-brand-cyan text-brand-cyan px-8 py-4 rounded-xl font-bold hover:bg-brand-cyan/10 active:scale-95 transition-all text-lg">
          Liên hệ Chuyên gia
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
