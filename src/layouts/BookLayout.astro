---
import BaseLayout from './BaseLayout.astro';
import SectionNav from '../components/book/SectionNav.astro';

interface ChapterItem {
  id: string;
  data: { title: string; tier: number; chapter: number };
}

interface ModuleItem {
  title: string;
  slug: string;
}

interface SectionItem {
  title: string;
  slug: string;
  level: number;
}

interface TierGroup {
  tier: number;
  label: string;
  chapters: ChapterItem[];
}

interface Props {
  title: string;
  description?: string;
  groupedChapters: TierGroup[];
  currentSlug: string;
  currentModules: ModuleItem[];
  sections?: SectionItem[];
  tier?: number;
  tierLabel?: string;
  chapterNo?: number;
}

const {
  title,
  description,
  groupedChapters,
  currentSlug,
  currentModules,
  sections = [],
  tier = 3,
  tierLabel = 'Tier 3',
  chapterNo = 1,
} = Astro.props;

const currentTierLabel = groupedChapters.find((g) =>
  g.chapters.some((c) => c.id === currentSlug)
)?.label ?? 'Tier 3';
const currentTier = groupedChapters.find((g) =>
  g.chapters.some((c) => c.id === currentSlug)
)?.tier ?? 3;
---

<BaseLayout title={`${title} - Dental Empire OS`} description={description}>
  <!-- ==========================================
       READER LAYOUT WRAPPER
       ========================================== -->
  <div id="reader-app" class="reader-app flex flex-col overflow-hidden">

    <!-- ==========================================
         READER TOOLBAR (top bar)
         ========================================== -->
    <header id="reader-toolbar" class="reader-toolbar flex items-center justify-between px-4 lg:px-6 h-12 lg:h-14 flex-shrink-0 glass-nav border-b border-white/[0.06] z-50">
      <!-- Left: Back + breadcrumb -->
      <div class="flex items-center gap-2 lg:gap-3 min-w-0">
        <a href="/book" class="flex items-center gap-1 lg:gap-2 text-on-surface-variant hover:text-primary transition-colors flex-shrink-0">
          <span class="material-symbols-outlined text-lg lg:text-xl">arrow_back</span>
          <span class="hidden sm:inline text-xs lg:text-sm font-semibold">Thư Viện</span>
        </a>
        <div class="w-px h-5 bg-outline-variant hidden sm:block"></div>
        <div class="flex items-center gap-2 min-w-0">
          <span class="text-xs lg:text-sm font-bold text-on-surface truncate max-w-[80px] sm:max-w-[160px] lg:max-w-[200px]">{title}</span>
        </div>
      </div>

      <!-- Center: Progress (desktop) -->
      <div class="hidden lg:flex items-center gap-2 flex-shrink-0">
        <span id="progress-pct" class="text-[10px] text-on-surface-variant font-bold tabular-nums" style="min-width: 2.5ch; text-align: right;">0%</span>
        <div class="w-32 h-1.5 bg-surface-container-high rounded-full overflow-hidden">
          <div id="progress-bar" class="read-progress h-full rounded-full transition-all duration-300" style="width: 0%"></div>
        </div>
      </div>

      <!-- Right: Controls -->
      <div class="flex items-center gap-1 lg:gap-2">
        <!-- Font size -->
        <div class="relative">
          <button id="font-menu-btn" class="fab-control flex items-center gap-1 px-2 lg:px-3 py-1.5 rounded-lg text-on-surface-variant hover:text-primary hover:bg-surface-container transition-all" title="Kích thước chữ">
            <span class="material-symbols-outlined text-base">text_fields</span>
            <span class="hidden lg:inline text-[11px] font-semibold">A</span>
          </button>
          <!-- Font popup -->
          <div id="font-popup" class="hidden absolute top-full right-0 mt-2 z-[60] glass-panel rounded-xl p-3 w-56 shadow-xl">
            <p class="text-[10px] font-bold uppercase tracking-wider text-on-surface-variant mb-3">Kích thước chữ</p>
            <div class="flex gap-2">
              <button data-fs="sm" class="fs-btn flex-1 py-2 rounded-lg text-center font-bold bg-surface-container-high hover:bg-primary/10 hover:text-primary transition-all" style="font-size: 14px">A</button>
              <button data-fs="md" class="fs-btn flex-1 py-2 rounded-lg text-center font-bold bg-primary text-on-primary active" id="fs-md-active" style="font-size: 16px">A</button>
              <button data-fs="lg" class="fs-btn flex-1 py-2 rounded-lg text-center font-bold bg-surface-container-high hover:bg-primary/10 hover:text-primary transition-all" style="font-size: 18px">A</button>
              <button data-fs="xl" class="fs-btn flex-1 py-2 rounded-lg text-center font-bold bg-surface-container-high hover:bg-primary/10 hover:text-primary transition-all" style="font-size: 20px">A</button>
              <button data-fs="2xl" class="fs-btn flex-1 py-2 rounded-lg text-center font-bold bg-surface-container-high hover:bg-primary/10 hover:text-primary transition-all" style="font-size: 22px">A</button>
            </div>
          </div>
        </div>

        <!-- Theme toggle -->
        <button id="theme-btn" class="fab-control flex items-center gap-1 px-2 lg:px-3 py-1.5 rounded-lg bg-primary/10 text-primary border border-primary/30 hover:bg-primary/20 transition-all" title="Chế độ đọc">
          <span class="material-symbols-outlined text-base" id="theme-icon">dark_mode</span>
          <span class="hidden lg:inline text-[11px] font-semibold">Nền</span>
        </button>

        <!-- Focus mode -->
        <button id="focus-btn" class="fab-control flex items-center gap-1 px-2 lg:px-3 py-1.5 rounded-lg text-on-surface-variant hover:text-primary hover:bg-surface-container transition-all" title="Chế độ tập trung">
          <span class="material-symbols-outlined text-base">visibility</span>
          <span class="hidden lg:inline text-[11px] font-semibold">Focus</span>
        </button>

        <!-- Search -->
        <button id="search-btn" class="fab-control flex items-center gap-1 px-2 lg:px-3 py-1.5 rounded-lg text-on-surface-variant hover:text-primary hover:bg-surface-container transition-all" title="Tìm kiếm (Ctrl+K)">
          <span class="material-symbols-outlined text-base">search</span>
          <span class="hidden lg:inline text-[11px] font-semibold">Tìm</span>
        </button>

        <!-- Bookmark -->
        <button id="bookmark-btn" class="fab-control flex items-center gap-1 px-2 lg:px-3 py-1.5 rounded-lg text-on-surface-variant hover:text-primary hover:bg-surface-container transition-all" title="Đánh dấu">
          <span class="material-symbols-outlined text-base" id="bookmark-icon">bookmark_border</span>
        </button>

        <!-- TOC toggle (desktop) -->
        <button id="toc-toggle-btn" class="hidden lg:flex fab-control items-center gap-1 px-3 py-1.5 rounded-lg text-on-surface-variant hover:text-primary hover:bg-surface-container transition-all active-toc-btn" title="Mục lục">
          <span class="material-symbols-outlined text-base">list</span>
          <span class="text-[11px] font-semibold">Mục lục</span>
        </button>
      </div>
    </header>

    <!-- Search overlay -->
    <div id="search-overlay" class="hidden fixed inset-0 z-[70] bg-black/60 backdrop-blur-sm flex items-start justify-center pt-20 px-4">
      <div class="glass-panel-dark rounded-2xl w-full max-w-xl overflow-hidden shadow-2xl">
        <div class="flex items-center gap-3 px-4 py-3 border-b border-white/[0.06]">
          <span class="material-symbols-outlined text-on-surface-variant">search</span>
          <input id="search-input" type="text" placeholder="Tìm kiếm trong chương..." class="flex-1 bg-transparent border-none outline-none text-on-surface placeholder:text-on-surface-variant/50 text-sm" autofocus/>
          <kbd class="hidden sm:inline px-2 py-1 rounded bg-surface-container-high text-[10px] text-on-surface-variant font-mono">ESC</kbd>
        </div>
        <div class="p-8 text-center text-sm text-on-surface-variant">
          <span class="material-symbols-outlined text-4xl block mb-3 opacity-50">manage_search</span>
          <p>Nhập từ khóa để tìm kiếm trong nội dung</p>
        </div>
      </div>
    </div>

    <!-- ==========================================
         MAIN BODY: Sidebar + Reader
         ========================================== -->
    <div class="flex flex-col flex-1 overflow-hidden relative">
      <!-- Horizontal content row (sidebar + reader + section nav) -->
      <div class="flex flex-1 overflow-hidden">

      <!-- Desktop Sidebar TOC -->
      <aside id="toc-sidebar" class="hidden lg:flex flex-col w-72 flex-shrink-0 h-full border-r border-white/[0.06] bg-surface-container-low/50 overflow-y-auto toc-sidebar">
        <!-- TOC Header -->
        <div class="px-4 py-4 border-b border-white/[0.06] sticky top-0 bg-surface-container-low z-10">
          <h3 class="text-sm font-bold text-on-surface mb-1">Mục lục</h3>
          <p class="text-xs text-on-surface-variant">{currentTierLabel}</p>
          <div class="mt-3">
            <div class="w-full h-1 bg-surface-container-high rounded-full overflow-hidden">
              <div id="progress-bar-sidebar" class="read-progress h-full rounded-full transition-all duration-300" style="width: 0%"></div>
            </div>
            <p id="progress-pct-sidebar" class="text-[10px] text-tertiary mt-1 font-bold">0% Hoàn thành</p>
          </div>
        </div>

        <!-- Chapter navigation -->
        <nav class="flex-1 px-3 py-3 space-y-1">
          {groupedChapters.map((group) => {
            const isCurrentTier = group.tier === currentTier;
            return (
              <div class="space-y-1">
                <div class="flex items-center gap-2 px-3 py-2">
                  <span class="material-symbols-outlined text-primary text-[16px]">folder</span>
                  <span class="text-xs font-bold text-on-surface-variant">{group.label}</span>
                  <span class="ml-auto text-[10px] text-on-surface-variant bg-surface-container-high px-1.5 py-0.5 rounded">{group.chapters.length}</span>
                </div>
                {group.chapters.map((ch) => {
                  const isCurrent = ch.id === currentSlug;
                  return (
                    <a
                      href={`/book/${ch.id}`}
                      class:list={[
                        'flex items-center gap-2 px-3 py-2 rounded-lg text-xs transition-all border-l-2',
                        isCurrent
                          ? 'toc-item-active border-primary bg-primary/10 text-primary'
                          : 'border-transparent text-on-surface-variant hover:text-on-surface hover:bg-surface-container hover:border-white/20',
                      ]}
                    >
                      <span class="shrink-0 text-[10px] text-on-surface-variant w-6">Ch{String(ch.data.chapter).padStart(2, '0')}</span>
                      <span class="truncate">{ch.data.title}</span>
                    </a>
                  );
                })}
              </div>
            );
          })}
        </nav>

        <!-- Current section -->
        <div class="px-4 py-4 border-t border-white/[0.06] sticky bottom-0 bg-surface-container-low">
          <p class="text-[10px] font-bold uppercase tracking-wider text-on-surface-variant mb-1">Đang đọc</p>
          <p class="text-sm font-bold text-on-surface leading-tight line-clamp-2">{title}</p>
        </div>
      </aside>

      <!-- Reader Scroll Area -->
      <main id="reader-scroll" class="flex-1 overflow-y-auto relative reader-main" tabindex="-1">
        <!-- Content -->
        <div
          class="max-w-[680px] mx-auto px-4 sm:px-6 lg:px-12 py-8 lg:py-12 reader-content"
          id="reader-content"
          data-chapter-title={title}
          data-chapter-tier={tier}
          data-chapter-tier-label={tierLabel}
          data-chapter-no={chapterNo}
          data-chapter-desc={description}
        >
          <slot />
        </div>
      </main>

      <!-- ==========================================
           SECTION NAV (Desktop right sidebar + Mobile drawer)
           ========================================== -->
      <SectionNav sections={sections} groupedChapters={groupedChapters} currentSlug={currentSlug} />

      </div><!-- end horizontal content row -->

      <!-- ==========================================
           STATUS BAR (Desktop)
           ========================================== -->
      <footer id="reader-status" class="hidden lg:flex items-center justify-between px-6 h-9 flex-shrink-0 glass-nav border-t border-white/[0.06] z-40">
        <div class="flex items-center gap-4">
          <div class="flex items-center gap-2">
            <span class="status-dot"></span>
            <span class="text-[10px] text-on-surface-variant font-semibold">Online</span>
          </div>
          <div class="h-4 w-px bg-outline-variant"></div>
          <span id="word-count" class="text-[10px] text-on-surface-variant">—</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-[10px] text-primary font-bold">Dental Empire OS</span>
          <button id="fullscreen-btn" class="text-on-surface-variant hover:text-primary transition-colors">
            <span class="material-symbols-outlined text-sm">fullscreen</span>
          </button>
        </div>
      </footer>

      <!-- ==========================================
           MOBILE BOTTOM BAR
           ========================================== -->
      <div class="lg:hidden flex items-center justify-around gap-1 px-2 py-2 glass-nav border-t border-white/[0.06] z-50 mobile-bottom-bar" style="padding-bottom: env(safe-area-inset-bottom, 0);">
        <!-- Đọc offline (previously Mục lục — TOC now via SectionNav floating trigger) -->
        <button id="mobile-offline-btn" class="flex flex-col items-center gap-0.5 px-3 py-1.5 rounded-lg text-on-surface-variant hover:text-primary hover:bg-surface-container transition-all">
          <span class="material-symbols-outlined text-xl">download_for_offline</span>
          <span class="text-[9px] font-bold uppercase tracking-tighter">Offline</span>
        </button>
        <button id="mobile-font-decrease" class="flex flex-col items-center gap-0.5 px-2 py-1.5 rounded-lg text-on-surface-variant hover:text-primary hover:bg-surface-container transition-all active:scale-90 transition-transform">
          <span class="material-symbols-outlined text-lg">text_decrease</span>
          <span class="text-[9px] font-bold uppercase tracking-tighter">Nhỏ</span>
        </button>
        <button id="mobile-font-display" class="flex flex-col items-center gap-0.5 px-2 py-1.5 rounded-lg text-primary transition-all">
          <span class="text-lg font-bold leading-none" id="mobile-font-label">Aa</span>
          <span class="text-[9px] font-bold uppercase tracking-tighter">Cỡ chữ</span>
        </button>
        <button id="mobile-font-increase" class="flex flex-col items-center gap-0.5 px-2 py-1.5 rounded-lg text-on-surface-variant hover:text-primary hover:bg-surface-container transition-all active:scale-90 transition-transform">
          <span class="material-symbols-outlined text-lg">text_increase</span>
          <span class="text-[9px] font-bold uppercase tracking-tighter">Lớn</span>
        </button>
        <button id="mobile-theme-btn" class="flex flex-col items-center gap-0.5 px-3 py-1.5 rounded-lg text-on-surface-variant hover:text-primary hover:bg-surface-container transition-all active:scale-90 transition-transform">
          <span class="material-symbols-outlined text-xl" id="mobile-theme-icon">dark_mode</span>
          <span class="text-[9px] font-bold uppercase tracking-tighter" id="mobile-theme-label">Tối</span>
        </button>
      </div>

      <!-- Mobile bottom padding -->
      <div class="lg:hidden h-14" style="padding-bottom: env(safe-area-inset-bottom, 0);"></div>
    </div>

    <!-- Mobile progress bar (fixed, outside flex container) -->
    <div class="lg:hidden fixed left-0 right-0 z-40 h-0.5 bg-surface-container-high pointer-events-none" style="top: 5rem;">
      <div id="progress-bar-mobile" class="read-progress h-full rounded-r-full transition-all duration-300" style="width: 0%"></div>
    </div>
  </div>

  <!-- ═══════════════ File Preview Modal ═══════════════ -->
  <div id="file-preview-modal" class="hidden fixed inset-0 z-[80] flex items-center justify-center" role="dialog" aria-modal="true">
    <div class="file-preview-backdrop absolute inset-0 bg-black/70 backdrop-blur-sm" id="preview-backdrop"></div>
    <div class="file-preview-panel relative z-10 bg-surface-container rounded-2xl border border-outline-variant/30 shadow-2xl mx-4 my-4 flex flex-col w-full h-[90vh] sm:max-w-4xl sm:max-h-[85vh]">
      <div class="flex items-center justify-between px-4 py-3 border-b border-outline-variant/30 shrink-0">
        <div class="flex items-center gap-2 min-w-0">
          <span class="material-symbols-outlined text-primary text-lg">visibility</span>
          <p id="preview-filename" class="text-sm font-bold text-on-surface truncate"></p>
        </div>
        <div class="flex items-center gap-1 shrink-0">
          <button id="preview-open-external" class="w-8 h-8 flex items-center justify-center rounded-lg text-on-surface-variant hover:text-primary hover:bg-surface-container-high transition-all" title="Mở tab mới">
            <span class="material-symbols-outlined text-[18px]">open_in_new</span>
          </button>
          <button id="preview-download" class="w-8 h-8 flex items-center justify-center rounded-lg text-on-surface-variant hover:text-primary hover:bg-surface-container-high transition-all" title="Tải file">
            <span class="material-symbols-outlined text-[18px]">download</span>
          </button>
          <button id="preview-close" class="w-8 h-8 flex items-center justify-center rounded-lg text-on-surface-variant hover:text-white hover:bg-error/20 transition-all" title="Đóng">
            <span class="material-symbols-outlined text-[18px]">close</span>
          </button>
        </div>
      </div>
      <div id="preview-body" class="flex-1 overflow-auto p-2 sm:p-4 flex items-center justify-center"></div>
    </div>
  </div>

  <!-- Reader init script -->
  <script>
    (function () {
      // ---- Reader state ----
      const themes = ['dark', 'light', 'sepia'];
      let currentThemeIdx = 0;
      let bookmarked = false;
      let tocOpen = true;
      let focusMode = false;

      const doc = document;
      const body = doc.body;
      const readerApp = doc.getElementById('reader-app');
      const readerScroll = doc.getElementById('reader-scroll');
      const tocSidebar = doc.getElementById('toc-sidebar');
      const searchOverlay = doc.getElementById('search-overlay');
      const searchInput = doc.getElementById('search-input');
      const fontPopup = doc.getElementById('font-popup');

      // ---- Theme cycling ----
      function applyTheme(idx) {
        body.classList.remove('light-mode', 'sepia-mode');
        if (idx === 1) body.classList.add('light-mode');
        if (idx === 2) body.classList.add('sepia-mode');
        const icons = ['dark_mode', 'light_mode', 'coffee'];
        const labels = ['Tối', 'Sáng', 'Sepia'];
        doc.getElementById('theme-icon')!.textContent = icons[idx];
        const mobileIcon = doc.getElementById('mobile-theme-icon');
        if (mobileIcon) mobileIcon.textContent = icons[idx];
        const mobileLabel = doc.getElementById('mobile-theme-label');
        if (mobileLabel) mobileLabel.textContent = labels[idx];
        currentThemeIdx = idx;
      }

      doc.getElementById('theme-btn')?.addEventListener('click', () => {
        applyTheme((currentThemeIdx + 1) % themes.length);
      });
      doc.getElementById('mobile-theme-btn')?.addEventListener('click', () => {
        applyTheme((currentThemeIdx + 1) % themes.length);
      });

      // ---- Font size ----
      const fontOrder = ['sm', 'md', 'lg', 'xl', '2xl'];
      const fontLabels = { sm: '12', md: '14', lg: '16', xl: '18', '2xl': '20' };
      let fontIdx = 1; // md = default

      function setFontSize(size: string) {
        const sizes = { sm: '0.875', md: '1', lg: '1.125', xl: '1.25', '2xl': '1.4' };
        const el = doc.getElementById('reader-content') as HTMLElement | null;
        if (el) el.style.setProperty('--fs', sizes[size as keyof typeof sizes] + 'rem');
        fontIdx = fontOrder.indexOf(size);
        doc.querySelectorAll('.fs-btn').forEach((btn) => {
          const isActive = btn.getAttribute('data-fs') === size;
          btn.classList.toggle('bg-primary', isActive);
          btn.classList.toggle('text-on-primary', isActive);
          btn.classList.toggle('bg-surface-container-high', !isActive);
        });
        const label = doc.getElementById('mobile-font-label');
        if (label) label.textContent = fontLabels[size as keyof typeof fontLabels];
      }

      doc.querySelectorAll('.fs-btn').forEach((btn) => {
        btn.addEventListener('click', () => setFontSize(btn.getAttribute('data-fs') || 'md'));
      });

      doc.getElementById('mobile-font-increase')?.addEventListener('click', () => {
        if (fontIdx < fontOrder.length - 1) { fontIdx++; setFontSize(fontOrder[fontIdx]); }
      });
      doc.getElementById('mobile-font-decrease')?.addEventListener('click', () => {
        if (fontIdx > 0) { fontIdx--; setFontSize(fontOrder[fontIdx]); }
      });

      // ---- Focus mode ----
      function toggleFocus() {
        focusMode = !focusMode;
        body.classList.toggle('focus-mode', focusMode);
        const btn = doc.getElementById('focus-btn');
        const mobileBtn = doc.getElementById('mobile-focus-btn');
        const icon = focusMode ? 'visibility_off' : 'visibility';
        btn?.querySelector('.material-symbols-outlined')!.setAttribute('data-icon', icon);
        btn!.querySelector('.material-symbols-outlined')!.textContent = icon;
        mobileBtn?.querySelector('.material-symbols-outlined')!.setAttribute('data-icon', icon);
        mobileBtn!.querySelector('.material-symbols-outlined')!.textContent = icon;
        btn?.classList.toggle('bg-primary/10', focusMode);
        btn?.classList.toggle('text-primary', focusMode);
        btn?.classList.toggle('border', focusMode);
        btn?.classList.toggle('border-primary/30', focusMode);
        mobileBtn?.classList.toggle('text-primary', focusMode);
      }

      doc.getElementById('focus-btn')?.addEventListener('click', toggleFocus);
      doc.getElementById('mobile-focus-btn')?.addEventListener('click', toggleFocus);

      // ---- Bookmark ----
      function toggleBookmark() {
        bookmarked = !bookmarked;
        const icon = bookmarked ? 'bookmark' : 'bookmark_border';
        doc.getElementById('bookmark-icon')!.textContent = icon;
        doc.getElementById('bookmark-btn')?.classList.toggle('text-primary', bookmarked);
        doc.getElementById('bookmark-btn')?.classList.toggle('bg-primary/10', bookmarked);
        doc.getElementById('bookmark-btn')?.classList.toggle('border', bookmarked);
        doc.getElementById('bookmark-btn')?.classList.toggle('border-primary/30', bookmarked);
      }

      doc.getElementById('bookmark-btn')?.addEventListener('click', toggleBookmark);


      // ---- TOC toggle (desktop) ----
      function toggleToc() {
        tocOpen = !tocOpen;
        if (tocSidebar) {
          tocSidebar.classList.toggle('hidden', !tocOpen);
          tocSidebar.classList.toggle('lg:flex', tocOpen);
        }
        const btn = doc.getElementById('toc-toggle-btn');
        btn?.classList.toggle('bg-primary/10', tocOpen);
        btn?.classList.toggle('text-primary', tocOpen);
        btn?.classList.toggle('border', tocOpen);
        btn?.classList.toggle('border-primary/30', tocOpen);
      }

      doc.getElementById('toc-toggle-btn')?.addEventListener('click', toggleToc);

      // ---- Search ----
      function openSearch() {
        searchOverlay?.classList.remove('hidden');
        searchInput?.focus();
      }
      function closeSearch() {
        searchOverlay?.classList.add('hidden');
        if (searchInput) searchInput.value = '';
      }

      doc.getElementById('search-btn')?.addEventListener('click', openSearch);
      doc.getElementById('search-overlay')?.addEventListener('click', (e) => {
        if (e.target === searchOverlay) closeSearch();
      });

      // Ctrl+K shortcut
      doc.addEventListener('keydown', (e) => {
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
          e.preventDefault();
          openSearch();
        }
        if (e.key === 'Escape') {
          closeSearch();
          fontPopup?.classList.add('hidden');
        }
      });

      // ---- Font popup ----
      doc.getElementById('font-menu-btn')?.addEventListener('click', (e) => {
        e.stopPropagation();
        fontPopup?.classList.toggle('hidden');
      });
      doc.addEventListener('click', () => fontPopup?.classList.add('hidden'));

      // ---- Fullscreen ----
      doc.getElementById('fullscreen-btn')?.addEventListener('click', () => {
        if (!doc.fullscreenElement) {
          doc.documentElement.requestFullscreen();
        } else {
          doc.exitFullscreen();
        }
      });

      // ---- Reading progress ----
      function updateProgress() {
        if (!readerScroll) return;
        const scrollTop = readerScroll.scrollTop;
        const scrollHeight = readerScroll.scrollHeight - readerScroll.clientHeight;
        const pct = scrollHeight > 0 ? Math.min(100, Math.round((scrollTop / scrollHeight) * 100)) : 0;
        doc.querySelectorAll('.read-progress').forEach((el) => {
          (el as HTMLElement).style.width = pct + '%';
        });
        doc.querySelectorAll('[id^="progress-pct"]').forEach((el) => {
          el.textContent = pct + '%';
        });
        doc.querySelectorAll('[id$="-pct-sidebar"]').forEach((el) => {
          el.textContent = pct + '% Hoàn thành';
        });
      }

      readerScroll?.addEventListener('scroll', updateProgress);

      // ---- Word count ----
      const article = doc.querySelector('article, .reader-content');
      if (article) {
        const text = article.textContent || '';
        const words = text.trim().split(/\s+/).filter(Boolean).length;
        doc.getElementById('word-count')!.textContent = words.toLocaleString('vi') + ' từ';
      }

      // ---- Mobile TOC (now unified via SectionNav floating trigger) ----
      // The SectionNav's own #section-nav-trigger handles this; no separate handler needed.

      // ---- Scroll to heading (smooth) ----
      const HEADER_OFFSET = 80;
      doc.querySelectorAll('a[href^="#"]').forEach((link) => {
        link.addEventListener('click', (e) => {
          const hash = link.getAttribute('href');
          if (!hash || hash === '#') return;
          e.preventDefault();
          const target = doc.getElementById(hash.slice(1));
          if (target && readerScroll) {
            const top = target.getBoundingClientRect().top + readerScroll.scrollTop - HEADER_OFFSET;
            readerScroll.scrollTo({ top, behavior: 'smooth' });
          }
          history.replaceState(null, '', hash);
          // Close mobile TOC if open
          (window as any).__closeSectionNav?.();
        });
      });

      if (location.hash) {
        requestAnimationFrame(() => {
          const target = doc.getElementById(location.hash.slice(1));
          if (target && readerScroll) {
            const top = target.getBoundingClientRect().top + readerScroll.scrollTop - HEADER_OFFSET;
            readerScroll.scrollTo({ top, behavior: 'smooth' });
          }
        });
      }

      // ---- Init ----
      setFontSize('md');
    })();
  </script>

  <!-- ═══════════════ File Download / Preview Script ═══════════════ -->
  <script>
    (function () {
      const MAX_FETCH_SIZE = 50 * 1024 * 1024; // 50 MB — above this, fallback to direct link

      // ── Helpers ──
      function formatBytes(bytes: number): string {
        if (bytes === 0) return '0 B';
        const units = ['B', 'KB', 'MB', 'GB'];
        const i = Math.floor(Math.log(bytes) / Math.log(1024));
        return (bytes / Math.pow(1024, i)).toFixed(i > 0 ? 1 : 0) + ' ' + units[i];
      }

      function escapeAttr(s: string): string {
        return s.replace(/&/g, '&amp;').replace(/"/g, '&quot;');
      }

      // ── File size cache ──
      const sizeCache = new Map<string, string>();

      async function fetchFileSize(card: HTMLElement): Promise<void> {
        const url = card.dataset.fileUrl;
        if (!url) return;
        if (sizeCache.has(url)) {
          showSize(card, sizeCache.get(url)!);
          return;
        }
        try {
          const res = await fetch(url, { method: 'GET' });
          const total = Number(res.headers.get('Content-Length'));
          if (total > 0) {
            const formatted = formatBytes(total);
            sizeCache.set(url, formatted);
            showSize(card, formatted);
          }
        } catch { /* silent — size display is non-critical */ }
      }

      function showSize(card: HTMLElement, text: string): void {
        const sizeEl = card.querySelector('.file-size-display') as HTMLElement | null;
        const mimeEl = card.querySelector('.file-mime-label') as HTMLElement | null;
        if (sizeEl && mimeEl) {
          sizeEl.textContent = text;
          sizeEl.classList.remove('hidden');
          mimeEl.classList.add('hidden');
        }
      }

      // ── Intersection Observer for lazy size fetch ──
      const sizeObserver = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              fetchFileSize(entry.target as HTMLElement);
              sizeObserver.unobserve(entry.target);
            }
          }
        },
        { rootMargin: '200px' }
      );
      document.querySelectorAll<HTMLElement>('[data-file-card]').forEach((card) => {
        sizeObserver.observe(card);
      });

      // ── Download with progress ──
      async function downloadFile(card: HTMLElement): Promise<void> {
        const url = card.dataset.fileUrl;
        const filename = card.dataset.fileName || 'download';
        if (!url) return;

        const overlay = card.querySelector('.file-progress-overlay') as HTMLElement | null;
        const progressBar = card.querySelector('.file-progress-bar') as HTMLElement | null;
        const pctText = card.querySelector('.file-progress-pct') as HTMLElement | null;
        const statusText = card.querySelector('.file-progress-status') as HTMLElement | null;
        const cancelBtn = card.querySelector('.file-cancel-btn') as HTMLElement | null;

        if (!overlay || !progressBar || !pctText || !statusText) return;

        // Check file size first — fallback to direct download for large files
        let totalSize = 0;
        if (sizeCache.has(url)) {
          // Parse cached size back to bytes (rough check)
          const cached = sizeCache.get(url)!;
          if (cached.includes('GB')) {
            directDownload(url, filename);
            return;
          }
        } else {
          try {
            const headRes = await fetch(url, { method: 'GET' });
            totalSize = Number(headRes.headers.get('Content-Length')) || 0;
            // Don't consume the body — let it GC
          } catch { /* proceed with fetch anyway */ }
          if (totalSize > MAX_FETCH_SIZE) {
            directDownload(url, filename);
            return;
          }
        }

        const controller = new AbortController();
        const onAbort = () => controller.abort();
        cancelBtn?.addEventListener('click', onAbort, { once: true });

        // Show overlay
        overlay.classList.remove('hidden');
        progressBar.style.width = '0%';
        pctText.textContent = '0';
        statusText.textContent = 'Đang tải...';
        statusText.classList.remove('text-error');
        progressBar.classList.toggle('indeterminate', totalSize === 0);

        try {
          const response = await fetch(url, { signal: controller.signal });
          if (!response.ok) throw new Error('Download failed');

          const total = totalSize || Number(response.headers.get('Content-Length')) || 0;
          const reader = response.body!.getReader();
          const chunks: Uint8Array[] = [];
          let loaded = 0;

          while (true) {
            const { done, value } = await reader.read();
            if (done) break;
            chunks.push(value);
            loaded += value.length;
            if (total > 0) {
              const pct = Math.round((loaded / total) * 100);
              progressBar.style.width = pct + '%';
              pctText.textContent = String(pct);
              statusText.textContent = `${formatBytes(loaded)} / ${formatBytes(total)}`;
            } else {
              statusText.textContent = `Đang tải... ${formatBytes(loaded)}`;
            }
          }

          // Build blob and trigger download
          const blob = new Blob(chunks);
          const blobUrl = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = blobUrl;
          a.download = filename;
          a.click();
          setTimeout(() => URL.revokeObjectURL(blobUrl), 1000);

          progressBar.classList.remove('indeterminate');
          progressBar.style.width = '100%';
          pctText.textContent = '100';
          statusText.textContent = 'Hoàn thành!';
          setTimeout(() => overlay.classList.add('hidden'), 800);
        } catch (e: any) {
          progressBar.classList.remove('indeterminate');
          if (e?.name !== 'AbortError') {
            statusText.textContent = 'Lỗi tải file';
            statusText.classList.add('text-error');
            setTimeout(() => overlay.classList.add('hidden'), 2000);
          } else {
            overlay.classList.add('hidden');
          }
        } finally {
          cancelBtn?.removeEventListener('click', onAbort);
        }
      }

      function directDownload(url: string, filename: string): void {
        const a = document.createElement('a');
        a.href = url;
        a.download = filename;
        a.target = '_blank';
        a.rel = 'noopener';
        a.click();
      }

      // ── Preview modal ──
      const previewModal = document.getElementById('file-preview-modal');
      const previewBackdrop = document.getElementById('preview-backdrop');
      const previewBody = document.getElementById('preview-body');
      const previewFilename = document.getElementById('preview-filename');
      const previewCloseBtn = document.getElementById('preview-close');
      const previewOpenExt = document.getElementById('preview-open-external');
      const previewDownloadBtn = document.getElementById('preview-download');
      let previewUrl = '';
      let previewFileName = '';

      function openPreview(url: string, filename: string, mime: string): void {
        if (!previewModal || !previewBody || !previewFilename) return;
        previewUrl = url;
        previewFileName = filename;
        previewFilename.textContent = filename;
        previewBody.innerHTML = '';

        if (mime.includes('pdf')) {
          previewBody.innerHTML = `<iframe src="${escapeAttr(url)}" class="w-full h-full rounded-xl border-none" style="min-height: 60vh" title="PDF Preview"></iframe>`;
        } else if (mime.includes('image')) {
          previewBody.innerHTML = `
            <div class="relative flex items-center justify-center w-full h-full">
              <img id="preview-img" class="max-w-full max-h-full object-contain rounded-xl" alt="${escapeAttr(filename)}" />
              <div class="absolute inset-0 flex items-center justify-center preview-loading">
                <span class="material-symbols-outlined text-4xl text-on-surface-variant" style="animation: spin 1s linear infinite;">progress_activity</span>
              </div>
            </div>`;
          const img = document.getElementById('preview-img') as HTMLImageElement | null;
          fetch(url).then(r => r.blob()).then(blob => {
            if (img) img.src = URL.createObjectURL(blob);
            previewBody?.querySelector('.preview-loading')?.remove();
          }).catch(() => {
            previewBody.innerHTML = '<p class="text-sm text-on-surface-variant text-center py-8">Không thể tải ảnh</p>';
          });
        }

        previewModal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        // Focus trap
        previewCloseBtn?.focus();
      }

      function closePreview(): void {
        if (!previewModal) return;
        previewModal.classList.add('hidden');
        if (previewBody) previewBody.innerHTML = '';
        document.body.style.overflow = '';
        previewUrl = '';
        previewFileName = '';
      }

      previewCloseBtn?.addEventListener('click', closePreview);
      previewBackdrop?.addEventListener('click', closePreview);
      previewOpenExt?.addEventListener('click', () => {
        if (previewUrl) window.open(previewUrl, '_blank', 'noopener');
      });
      previewDownloadBtn?.addEventListener('click', () => {
        if (previewUrl && previewFileName) {
          directDownload(previewUrl, previewFileName);
        }
      });

      // ── Event delegation for file card buttons ──
      document.addEventListener('click', (e) => {
        const target = (e.target as HTMLElement).closest<HTMLElement>('.file-download-btn, .file-preview-btn');
        if (!target) return;
        const card = target.closest<HTMLElement>('[data-file-card]');
        if (!card) return;

        if (target.classList.contains('file-download-btn')) {
          e.preventDefault();
          downloadFile(card);
        } else if (target.classList.contains('file-preview-btn')) {
          e.preventDefault();
          const url = card.dataset.fileUrl;
          const name = card.dataset.fileName || 'preview';
          const mime = card.dataset.fileMime || '';
          if (url) openPreview(url, name, mime);
        }
      });

      // Escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && previewModal && !previewModal.classList.contains('hidden')) {
          closePreview();
        }
      });
    })();
  </script>
  <style>
    @keyframes spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
  </style>
</BaseLayout>
