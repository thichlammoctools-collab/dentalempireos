---
import BaseLayout from './BaseLayout.astro';
import StructuredData from '../components/seo/StructuredData.astro';
import SectionNav from '../components/book/SectionNav.astro';
import SectionNavMobile from '../components/book/SectionNavMobile.astro';
import ChapterNav from '../components/book/ChapterNav.astro';
import ReviewDrawer from '../components/book/ReviewDrawer.astro';
import QuestionDrawer from '../components/book/QuestionDrawer.astro';

interface ChapterItem {
  id: string;
  data: { title: string; tier: number; chapter: number };
}

interface ModuleItem {
  title: string;
  slug: string;
}

interface SectionItem {
  title: string;
  slug: string;
  level: number;
  sectionNumber: string;
}

interface TierGroup {
  tier: number;
  label: string;
  chapters: ChapterItem[];
}

interface AttachmentItem {
  id: string;
  type: 'image' | 'file';
  title: string;
  url: string;
  caption?: string;
  filename?: string;
  mime?: string | null;
  mimeLabel?: string;
  sectionSlug: string;
  sectionTitle: string;
  ext?: string;
  previewable: boolean;
}

interface ChapterNavItem {
  id: string;
  data: { title: string; tier: number };
}

interface Props {
  title: string;
  description?: string;
  groupedChapters: TierGroup[];
  currentSlug: string;
  currentModules: ModuleItem[];
  sections?: SectionItem[];
  attachments?: AttachmentItem[];
  tier?: number;
  tierLabel?: string;
  chapterNo?: number;
  prev?: ChapterNavItem | null;
  next?: ChapterNavItem | null;
  isLoggedIn?: boolean;
  currentUserId?: string | null;
  chapterId?: string;
}

const {
  title,
  description,
  groupedChapters,
  currentSlug,
  currentModules,
  sections = [],
  attachments = [],
  tier = 3,
  tierLabel = 'Tier 3',
  chapterNo = 1,
  prev = null,
  next = null,
  isLoggedIn = false,
  currentUserId = null,
  chapterId = '',
} = Astro.props;

const currentTierLabel = groupedChapters.find((g) =>
  g.chapters.some((c) => c.id === currentSlug)
)?.label ?? 'Tier 3';
const currentTier = groupedChapters.find((g) =>
  g.chapters.some((c) => c.id === currentSlug)
)?.tier ?? 3;

const chapterURL = new URL(`/book/${currentSlug}`, 'https://dentalempireos.com').toString();

const bookSchema = {
  '@context': 'https://schema.org',
  '@type': 'Book',
  name: 'Dental Empire OS',
  alternateName: 'Hệ Điều Hành Quản Trị Nha Khoa',
  bookFormat: 'https://schema.org/EBook',
  inLanguage: 'vi',
  author: {
    '@type': 'Person',
    name: 'Bác sĩ Nguyễn Phước Vinh',
    url: 'https://dentalempireos.com/about',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Dental Empire OS',
    url: 'https://dentalempireos.com',
  },
  url: 'https://dentalempireos.com/book',
  description: 'Nền tảng chia sẻ tri thức quản trị nha khoa toàn diện — 6 tầng quản trị nha khoa theo hệ điều hành.',
};

const chapterSchema = {
  '@context': 'https://schema.org',
  '@type': 'Chapter',
  name: title,
  description: description,
  inLanguage: 'vi',
  isPartOf: {
    '@type': 'Book',
    name: 'Dental Empire OS',
    url: 'https://dentalempireos.com/book',
  },
  position: chapterNo,
  url: chapterURL,
  author: {
    '@type': 'Person',
    name: 'Bác sĩ Nguyễn Phước Vinh',
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Trang chủ',
      item: 'https://dentalempireos.com/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Thư viện sách',
      item: 'https://dentalempireos.com/book',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: title,
      item: chapterURL,
    },
  ],
};
---

<BaseLayout
  title={`${title} - Dental Empire OS`}
  description={description}
  isReading={true}
  currentSlug={currentSlug}
  groupedChapters={groupedChapters}
  ogType="book"
>
  <StructuredData type="book" data={bookSchema} />
  <StructuredData type="article" data={chapterSchema} />
  <StructuredData type="breadcrumb" data={breadcrumbSchema} />

  <!-- ==========================================
       TOOLBAR (outside reader-app so z-index is relative to root stacking context)
       ========================================== -->
  <header id="reader-toolbar" class="fixed top-0 left-0 right-0 flex items-center justify-between px-4 lg:px-6 h-12 lg:h-14 glass-nav border-b r-border z-50" style="background: var(--reader-chrome-bg);">
    <!-- Left: Back + breadcrumb -->
    <div class="flex items-center gap-2 lg:gap-3 min-w-0">
      <a href="/book" class="flex items-center gap-1 lg:gap-2 r-text-muted hover:text-primary transition-colors flex-shrink-0">
        <span class="material-symbols-outlined text-lg lg:text-xl">arrow_back</span>
        <span class="hidden sm:inline text-xs lg:text-sm font-semibold">Thư Viện</span>
      </a>
      <div class="w-px h-5 hidden sm:block" style="background: var(--reader-border);"></div>
      <!-- Mobile: "Đang đọc" label + title -->
      <div class="flex flex-col min-w-0 lg:hidden">
        <span class="text-[10px] font-bold uppercase tracking-wider r-text-muted leading-none">Đang đọc</span>
        <span class="text-sm font-bold r-text truncate max-w-[180px] leading-tight">{title}</span>
      </div>
      <!-- Desktop: title only -->
      <div class="hidden lg:flex items-center gap-2 min-w-0">
        <span class="text-sm lg:text-base font-bold r-text truncate max-w-[280px]">{title}</span>
      </div>
    </div>

    <!-- Center: Progress (desktop) -->
    <div class="hidden lg:flex items-center gap-2 flex-shrink-0">
      <span id="progress-pct" class="text-[10px] r-text-muted font-bold tabular-nums" style="min-width: 2.5ch; text-align: right;">0%</span>
      <div class="w-32 h-1.5 r-surface-high rounded-full overflow-hidden">
        <div id="progress-bar" class="read-progress h-full rounded-full transition-all duration-300" style="width: 0%"></div>
      </div>
    </div>

    <!-- Right: Mobile = progress + bookmark + theme | Desktop = controls -->
    <div class="flex lg:hidden items-center gap-1.5 flex-shrink-0">
      <div class="flex items-center gap-1">
        <div class="w-16 sm:w-20 h-1 r-surface-high rounded-full overflow-hidden">
          <div id="progress-bar-mobile" class="read-progress h-full rounded-r-full transition-all duration-300" style="width: 0%"></div>
        </div>
        <span id="progress-pct-mobile" class="text-[10px] r-text-muted font-bold tabular-nums shrink-0">0%</span>
      </div>
      <button id="mobile-bookmark-btn" class="w-8 h-8 flex items-center justify-center rounded-lg r-text-muted hover:text-primary r-hover transition-all" title="Đánh dấu">
        <span class="material-symbols-outlined text-lg" id="mobile-bookmark-icon">bookmark_border</span>
      </button>
      <button id="mobile-theme-btn" class="w-8 h-8 flex items-center justify-center rounded-lg r-text-muted hover:text-primary r-hover transition-all" title="Chế độ nền">
        <span class="material-symbols-outlined text-lg" id="mobile-theme-icon">dark_mode</span>
      </button>
    </div>

    <!-- Right: Controls (desktop) -->
    <div class="hidden lg:flex items-center gap-1 lg:gap-2">
      <button id="toolbar-review-btn" class="fab-control items-center gap-1 px-2 lg:px-3 py-1.5 rounded-lg r-text-muted hover:text-primary r-hover transition-all" title="Đánh giá">
        <span class="material-symbols-outlined text-base">reviews</span>
        <span class="text-[11px] font-semibold">Đánh giá</span>
      </button>

      <button id="toolbar-ask-btn" class="fab-control items-center gap-1 px-2 lg:px-3 py-1.5 rounded-lg r-text-muted hover:text-primary r-hover transition-all" title="Hỏi Tác Giả">
        <span class="material-symbols-outlined text-base">support_agent</span>
        <span class="text-[11px] font-semibold">Hỏi tác giả</span>
      </button>

      <button id="theme-btn" class="fab-control items-center gap-1 px-2 lg:px-3 py-1.5 rounded-lg bg-primary/10 text-primary border border-primary/30 hover:bg-primary/20 transition-all" title="Chế độ đọc">
        <span class="material-symbols-outlined text-base" id="theme-icon">dark_mode</span>
        <span class="text-[11px] font-semibold">Nền</span>
      </button>

      <button id="search-btn" class="fab-control items-center gap-1 px-2 lg:px-3 py-1.5 rounded-lg r-text-muted hover:text-primary r-hover transition-all" title="Tìm kiếm (Ctrl+K)">
        <span class="material-symbols-outlined text-base">search</span>
        <span class="hidden lg:inline text-[11px] font-semibold">Tìm</span>
      </button>

      {attachments.length > 0 && (
        <a
          href="#attachments-summary"
          id="attachments-btn"
          class="relative items-center gap-1 px-2 lg:px-3 py-1.5 rounded-lg r-text-muted hover:text-primary r-hover transition-all"
          title={`Xem ${attachments.length} tệp đính kèm`}
          aria-label={`Xem ${attachments.length} tệp đính kèm`}
        >
          <span class="material-symbols-outlined text-base">attachment</span>
          <span class="hidden lg:inline text-[11px] font-semibold">Tệp</span>
          <span class="absolute -top-1 -right-1 inline-flex h-5 min-w-[20px] items-center justify-center rounded-full bg-primary/15 text-primary text-[10px] font-bold px-2 py-0.5 border border-primary/20">{attachments.length}</span>
        </a>
      )}

      <button id="toc-toggle-btn" class="fab-control items-center gap-1 px-2 lg:px-3 py-1.5 rounded-lg r-text-muted hover:text-primary r-hover transition-all" title="Mục lục (Ctrl+Shift+L)">
        <span class="material-symbols-outlined text-base">list</span>
        <span class="hidden lg:inline text-[11px] font-semibold">Mục lục</span>
      </button>

      <button id="bookmark-btn" class="fab-control items-center gap-1 px-2 lg:px-3 py-1.5 rounded-lg r-text-muted hover:text-primary r-hover transition-all" title="Đánh dấu">
        <span class="material-symbols-outlined text-base" id="bookmark-icon">bookmark_border</span>
      </button>
    </div>
  </header>

  <!-- Search overlay (outside reader-app) -->
  <div id="search-overlay" class="hidden fixed inset-0 z-[70] bg-black/60 backdrop-blur-sm flex items-start justify-center pt-20 px-4">
    <div class="glass-panel-dark rounded-2xl w-full max-w-xl overflow-hidden shadow-2xl">
      <div class="flex items-center gap-3 px-4 py-3 border-b r-border" style="border-color: var(--reader-border);">
        <span class="material-symbols-outlined r-text-muted">search</span>
        <input id="search-input" type="text" placeholder="Tìm kiếm trong chương..." class="flex-1 bg-transparent border-none outline-none text-sm" autofocus style="color: var(--reader-chrome-text);"/>
        <kbd class="hidden sm:inline px-2 py-1 rounded r-surface-high text-[10px] r-text-muted font-mono">ESC</kbd>
      </div>
      <div class="p-8 text-center text-sm r-text-muted">
        <span class="material-symbols-outlined text-4xl block mb-3 opacity-50">manage_search</span>
        <p id="search-helper-text">Nhập từ khóa để tìm kiếm trong nội dung</p>
        <p id="search-result-count" class="mt-3 text-xs text-on-surface-variant/70"></p>
      </div>
    </div>
  </div>

  <!-- ==========================================
       READER LAYOUT WRAPPER
       ========================================== -->
  <div id="reader-app" class="reader-app flex flex-col overflow-hidden">

    <!-- ==========================================
         MAIN BODY: Sidebar + Reader
         ========================================== -->
    <div class="flex flex-col flex-1 overflow-hidden relative pt-12 lg:pt-14 min-h-0">
      <!-- Horizontal content row (sidebar + reader + section nav) -->
      <div class="flex flex-1 overflow-hidden min-h-0">

      <!-- Desktop Sidebar TOC -->
      <aside id="toc-sidebar" class="hidden lg:flex flex-col w-[26rem] flex-shrink-0 h-full border-r overflow-y-auto toc-sidebar" style="border-color: var(--reader-border); background: var(--reader-chrome-bg);">
        <!-- TOC Header -->
        <div class="px-5 py-4 border-b sticky top-0 z-10" style="border-color: var(--reader-border); background: var(--reader-chrome-bg);">
          <h3 class="text-sm font-bold r-text mb-1">Mục lục</h3>
          <p class="text-xs r-text-muted">{currentTierLabel}</p>
        </div>

        <!-- Chapter navigation -->
        <nav class="flex-1 px-4 py-4 space-y-2">
          {groupedChapters.map((group) => {
            const isCurrentTier = group.tier === currentTier;
            return (
              <div class="toc-group" data-tier={group.tier} data-current-tier={isCurrentTier ? 'true' : 'false'}>
                <!-- Group header with collapse toggle -->
                <button
                  class="toc-group-header flex items-center gap-2.5 px-4 py-2.5 w-full rounded-lg text-left transition-all r-hover"
                  aria-expanded="true"
                  data-toc-toggle
                >
                  <span class="material-symbols-outlined text-primary text-[18px] toc-group-icon transition-transform duration-200">folder_open</span>
                  <span class="text-sm font-bold r-text-muted toc-group-label flex-1 truncate">{group.label}</span>
                  <span class="text-xs r-text-muted px-2 py-0.5 rounded toc-group-count" style="background: var(--reader-chrome-surface-high);">{group.chapters.length}</span>
                  <span class="material-symbols-outlined text-[18px] text-on-surface-variant/60 toc-group-chevron transition-transform duration-200">expand_more</span>
                </button>

                <!-- Chapter list -->
                <div class="toc-group-chapters space-y-1 overflow-hidden transition-all duration-300">
                  {group.chapters.map((ch) => {
                    const isCurrent = ch.id === currentSlug;
                    return (
                      <a
                        href={`/book/${ch.id}`}
                        class:list={[
                          'flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm transition-all border-l-2',
                          isCurrent
                            ? 'toc-item-active border-primary text-primary'
                            : 'border-transparent r-text-muted toc-item-hover',
                        ]}
                        data-toc-chapter
                      >
                        <span class="shrink-0 text-xs w-6">Ch{String(ch.data.chapter).padStart(2, '0')}</span>
                        <span class="truncate leading-relaxed">{ch.data.title}</span>
                      </a>
                    );
                  })}
                </div>
              </div>
            );
          })}
        </nav>

        <!-- Current section -->
        <div class="px-4 py-4 border-t sticky bottom-0" style="border-color: var(--reader-border); background: var(--reader-chrome-bg);">
          <p class="text-xs font-bold uppercase tracking-wider r-text-muted mb-1">Đang đọc</p>
          <p class="text-base font-bold r-text leading-tight line-clamp-2">{title}</p>
        </div>
      </aside>


      <!-- Reader Scroll Area -->
      <main id="reader-scroll" class="flex-1 overflow-y-auto relative reader-main pb-20 lg:pb-0" style="background: var(--reader-bg);" tabindex="-1">
        <!-- Content -->
        <div
          class="max-w-[760px] mx-auto px-5 sm:px-8 lg:px-14 py-8 lg:py-12 reader-content"
          id="reader-content"
          data-chapter-id={currentSlug}
          data-chapter-title={title}
          data-chapter-tier={tier}
          data-chapter-tier-label={tierLabel}
          data-chapter-no={chapterNo}
          data-chapter-desc={description}
        >
          <slot />
          <!-- Spacer: push content above fixed chapter nav bar -->
          <div id="chapter-nav-spacer" style="height: 72px;"></div>
        </div>
      </main>

      <!-- ==========================================
           SECTION NAV (Desktop right sidebar + Mobile drawer)
           ========================================== -->
<SectionNav sections={sections} attachments={attachments} chapterId={chapterId} chapterTitle={title} />

      </div><!-- end horizontal content row -->

      <!-- ==========================================
           STATUS BAR (Desktop)
           ========================================== -->
      <footer id="reader-status" class="hidden lg:flex items-center justify-between px-6 h-9 flex-shrink-0 glass-nav border-t z-40" style="background: var(--reader-chrome-bg); border-color: var(--reader-border);">
        <div class="flex items-center gap-4">
          <div class="flex items-center gap-2">
            <span class="status-dot"></span>
            <span class="text-[10px] r-text-muted font-semibold">Online</span>
          </div>
          <div class="h-4 w-px" style="background: var(--reader-border);"></div>
          <span id="word-count" class="text-[10px] r-text-muted">—</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-[10px] text-primary font-bold">Dental Empire OS</span>
          <button id="fullscreen-btn" class="r-text-muted hover:text-primary transition-colors">
            <span class="material-symbols-outlined text-sm">fullscreen</span>
          </button>
        </div>
      </footer>

    </div>

  </div>


  <!-- ═══════════════ Section Nav Mobile (outside #reader-app, fixed positioned) ═══════════════ -->
  <SectionNavMobile
    sections={sections}
    groupedChapters={groupedChapters}
    currentSlug={currentSlug}
    attachments={attachments}
    chapterId={chapterId || currentSlug}
    chapterTitle={title}
  />

  <!-- ═══════════════ Chapter Nav Fixed Bottom Bar (outside #reader-app, fixed positioned) ═══════════════ -->
  <ChapterNav prev={prev} next={next} />

  <!-- ═══════════════ Review Drawer (outside #reader-app, fixed positioned) ═══════════════ -->
  <ReviewDrawer
    chapterId={currentSlug}
    chapterTitle={title}
    isLoggedIn={isLoggedIn}
    currentUserId={currentUserId}
  />

  <!-- ═══════════════ Question Drawer (outside #reader-app, fixed positioned) ═══════════════ -->
  <QuestionDrawer
    chapterId={currentSlug}
    chapterTitle={title}
  />

  <!-- ═══════════════ Image Lightbox (tap/click to zoom) ═══════════════ -->
  <div id="image-lightbox" class="hidden fixed inset-0 z-[90]" role="dialog" aria-modal="true" aria-label="Xem ảnh phóng to">
    <div class="lb-backdrop absolute inset-0 bg-black/90 backdrop-blur-md"></div>
    <div class="lb-container absolute inset-0 flex items-center justify-center overflow-hidden">
      <img class="lb-image select-none" draggable="false" alt="" />
    </div>
    <!-- Close button -->
    <button class="lb-close absolute top-4 right-4 z-10 w-10 h-10 flex items-center justify-center rounded-full bg-white/10 text-white hover:bg-white/20 transition-colors" title="Đóng (Esc)">
      <span class="material-symbols-outlined text-xl">close</span>
    </button>
    <!-- Zoom indicator -->
    <div class="lb-zoom-badge absolute bottom-6 left-1/2 -translate-x-1/2 z-10 px-3 py-1.5 rounded-full bg-white/10 text-white text-xs font-semibold backdrop-blur-sm pointer-events-none opacity-0 transition-opacity duration-300"></div>
    <!-- Hint (shown on first open) -->
    <div class="lb-hint absolute bottom-6 left-1/2 -translate-x-1/2 z-10 px-4 py-2 rounded-full bg-white/10 text-white/80 text-xs font-medium backdrop-blur-sm pointer-events-none transition-opacity duration-500">
      <span class="hidden sm:inline">Nhấn để zoom · Cuộn để phóng to · Esc để đóng</span>
      <span class="sm:hidden">Chạm để zoom · 2 ngón để phóng to · Vuốt để di chuyển</span>
    </div>
  </div>

  <!-- ═══════════════ File Preview Modal ═══════════════ -->
  <div id="file-preview-modal" class="hidden fixed inset-0 z-[80] flex items-center justify-center" role="dialog" aria-modal="true">
    <div class="file-preview-backdrop absolute inset-0 bg-black/70 backdrop-blur-sm" id="preview-backdrop"></div>
    <div class="file-preview-panel relative z-10 rounded-2xl border shadow-2xl mx-4 my-4 flex flex-col w-full h-[90vh] sm:max-w-4xl sm:max-h-[85vh]" style="background: var(--reader-chrome-surface); border-color: var(--reader-border);">
      <div class="flex items-center justify-between px-4 py-3 border-b shrink-0" style="border-color: var(--reader-border);">
        <div class="flex items-center gap-2 min-w-0">
          <span class="material-symbols-outlined text-primary text-lg">visibility</span>
          <p id="preview-filename" class="text-sm font-bold r-text truncate"></p>
        </div>
        <div class="flex items-center gap-1 shrink-0">
          <button id="preview-open-external" class="w-8 h-8 flex items-center justify-center rounded-lg r-text-muted hover:text-primary r-hover transition-all" title="Mở tab mới">
            <span class="material-symbols-outlined text-[18px]">open_in_new</span>
          </button>
          <button id="preview-download" class="w-8 h-8 flex items-center justify-center rounded-lg text-on-surface-variant hover:text-primary hover:bg-surface-container-high transition-all" title="Tải file">
            <span class="material-symbols-outlined text-[18px]">download</span>
          </button>
          <button id="preview-close" class="w-8 h-8 flex items-center justify-center rounded-lg text-on-surface-variant hover:text-white hover:bg-error/20 transition-all" title="Đóng">
            <span class="material-symbols-outlined text-[18px]">close</span>
          </button>
        </div>
      </div>
      <div id="preview-body" class="flex-1 overflow-auto p-2 sm:p-4 flex items-center justify-center"></div>
    </div>
  </div>

  <!-- Reader init script -->
  <script>
    (function () {
      // ---- Reader state ----
      const themes = ['dark', 'light', 'sepia'];
      let currentThemeIdx = 0;
      let bookmarked = false;
      let tocOpen = true;

      const doc = document;
      const body = doc.body;
      const readerApp = doc.getElementById('reader-app');
      const readerScroll = doc.getElementById('reader-scroll');
      const tocSidebar = doc.getElementById('toc-sidebar');
      const sectionNav = doc.getElementById('section-nav-desktop');
      const searchOverlay = doc.getElementById('search-overlay');
      const searchInput = doc.getElementById('search-input') as HTMLInputElement | null;

      // ---- Theme cycling ----
      function applyTheme(idx: number) {
        body.classList.remove('light-mode', 'sepia-mode');
        if (idx === 1) body.classList.add('light-mode');
        if (idx === 2) body.classList.add('sepia-mode');
        const icons = ['dark_mode', 'light_mode', 'coffee'];
        const labels = ['Tối', 'Sáng', 'Sepia'];
        doc.getElementById('theme-icon')!.textContent = icons[idx];
        const mobileIcon = doc.getElementById('mobile-theme-icon');
        if (mobileIcon) mobileIcon.textContent = icons[idx];
        const mobileLabel = doc.getElementById('mobile-theme-label');
        if (mobileLabel) mobileLabel.textContent = labels[idx];
        currentThemeIdx = idx;
      }

      doc.getElementById('theme-btn')?.addEventListener('click', () => {
        applyTheme((currentThemeIdx + 1) % themes.length);
      });
      doc.getElementById('mobile-theme-btn')?.addEventListener('click', () => {
        applyTheme((currentThemeIdx + 1) % themes.length);
      });

      // ---- Bookmark & Reading Progress ----
      const BM_KEY = 'deos_bookmarks';
      const RP_KEY = 'deos_read_progress';
      const bookmarkButton = doc.getElementById('bookmark-btn');
      const mobileBookmarkButton = doc.getElementById('mobile-bookmark-btn');
      const bookmarkIcon = doc.getElementById('bookmark-icon');
      const mobileBookmarkIcon = doc.getElementById('mobile-bookmark-icon');
      const readerContent = doc.getElementById('reader-content');
      const chapterId = readerContent?.getAttribute('data-chapter-id');
      const chapterTitleText = readerContent?.getAttribute('data-chapter-title');

      // -- Helpers --
      function getBookmarks(): any[] { try { return JSON.parse(localStorage.getItem(BM_KEY) || '[]'); } catch { return []; } }
      function setBookmarks(arr: any[]): void { localStorage.setItem(BM_KEY, JSON.stringify(arr)); }
      function getReadProgress(): Record<string, any> { try { return JSON.parse(localStorage.getItem(RP_KEY) || '{}'); } catch { return {}; } }
      function setReadProgress(obj: Record<string, any>): void { localStorage.setItem(RP_KEY, JSON.stringify(obj)); }
      function getScrollPct() {
        if (!readerScroll) return 0;
        const max = readerScroll.scrollHeight - readerScroll.clientHeight;
        return max > 0 ? Math.round((readerScroll.scrollTop / max) * 100) : 0;
      }

      // -- Manual bookmark (save position) --
      function isBookmarked() { return getBookmarks().some(b => b.id === chapterId); }

      function updateBookmarkUi(active: boolean) {
        const icon = active ? 'bookmark' : 'bookmark_border';
        if (bookmarkIcon) {
          bookmarkIcon.textContent = icon;
          bookmarkButton!.classList.toggle('text-primary', active);
          bookmarkButton!.classList.toggle('bg-primary/10', active);
          bookmarkButton!.classList.toggle('border', active);
          bookmarkButton!.classList.toggle('border-primary/30', active);
          bookmarkButton!.setAttribute('aria-pressed', active ? 'true' : 'false');
          bookmarkButton!.title = active ? 'Bỏ đánh dấu' : 'Ghi nhớ vị trí đọc';
        }
        if (mobileBookmarkIcon) {
          mobileBookmarkIcon.textContent = icon;
          mobileBookmarkButton!.classList.toggle('text-primary', active);
        }
      }

      function toggleBookmark() {
        if (!chapterId) return;
        const bookmarks = getBookmarks();
        const idx = bookmarks.findIndex(b => b.id === chapterId);
        if (idx >= 0) {
          bookmarks.splice(idx, 1); // remove
        } else {
          bookmarks.unshift({
            id: chapterId,
            title: chapterTitleText || '',
            url: location.pathname,
            scrollPct: getScrollPct(),
            savedAt: Date.now(),
          });
        }
        setBookmarks(bookmarks);
        updateBookmarkUi(isBookmarked());
      }

      if (bookmarkButton || mobileBookmarkButton) {
        updateBookmarkUi(isBookmarked());
        bookmarkButton?.addEventListener('click', toggleBookmark);
        mobileBookmarkButton?.addEventListener('click', toggleBookmark);
      }

      // -- Auto-save reading progress (every 5s) --
      if (chapterId && readerScroll) {
        let lastAutoPct = -1;
        setInterval(() => {
          const pct = getScrollPct();
          if (pct === lastAutoPct) return;
          lastAutoPct = pct;
          const rp = getReadProgress();
          rp[chapterId] = { pct, title: chapterTitleText || '', url: location.pathname, ts: Date.now() };
          // Keep only last 20 chapters
          const keys = Object.keys(rp).sort((a, b) => (rp[b].ts || 0) - (rp[a].ts || 0));
          if (keys.length > 20) keys.slice(20).forEach(k => delete rp[k]);
          setReadProgress(rp);
        }, 5000);

        // -- Restore scroll position on load --
        const rp = getReadProgress();
        const saved = rp[chapterId];
        if (saved && saved.pct > 5 && saved.pct < 95) {
          const toast = doc.createElement('div');
          toast.className = 'fixed bottom-20 left-3 right-3 sm:left-1/2 sm:right-auto sm:-translate-x-1/2 sm:w-max z-[80] flex items-center gap-2.5 px-4 py-2.5 rounded-2xl transition-all duration-300';
          toast.style.cssText = 'background: #ffffff; opacity: 0; transform: translateY(16px); box-shadow: 0 4px 24px rgba(0,0,0,0.10), 0 1px 4px rgba(0,0,0,0.06);';
          toast.innerHTML = '<span class="material-symbols-outlined text-primary text-sm shrink-0">history</span>' +
            '<span class="text-xs font-medium text-gray-600 shrink-0">Bạn đọc đến ' + saved.pct + '%</span>' +
            '<button id="bm-restore-btn" class="ml-auto px-3 py-1 rounded-lg text-white text-xs font-bold shrink-0" style="background: #0a7bab;">Đọc tiếp</button>' +
            '<button id="bm-dismiss-btn" class="material-symbols-outlined text-base text-gray-400 hover:text-gray-600 shrink-0 leading-none" style="padding: 2px 4px;">close</button>';
          doc.body.appendChild(toast);
          requestAnimationFrame(() => { toast.style.opacity = '1'; toast.style.transform = 'translateY(0)'; });

          doc.getElementById('bm-restore-btn')?.addEventListener('click', () => {
            const max = readerScroll.scrollHeight - readerScroll.clientHeight;
            readerScroll.scrollTo({ top: (saved.pct / 100) * max, behavior: 'smooth' });
            toast.style.opacity = '0'; toast.style.transform = 'translateY(20px)';
            setTimeout(() => toast.remove(), 300);
          });
          doc.getElementById('bm-dismiss-btn')?.addEventListener('click', () => {
            toast.style.opacity = '0'; toast.style.transform = 'translateY(20px)';
            setTimeout(() => toast.remove(), 300);
          });
          setTimeout(() => { if (toast.parentNode) { toast.style.opacity = '0'; toast.style.transform = 'translateY(20px)'; setTimeout(() => toast.remove(), 300); } }, 6000);
        }
      }


function toggleToc() {
        tocOpen = !tocOpen;
        if (tocSidebar) {
          tocSidebar.style.transition = 'opacity 0.25s ease';
          tocSidebar.style.opacity = tocOpen ? '1' : '0';
          tocSidebar.style.pointerEvents = tocOpen ? '' : 'none';
        }
        const btn = doc.getElementById('toc-toggle-btn');
        btn?.classList.toggle('bg-primary/10', tocOpen);
        btn?.classList.toggle('text-primary', tocOpen);
        btn?.classList.toggle('border', tocOpen);
        btn?.classList.toggle('border-primary/30', tocOpen);
      }

      function toggleSectionNav() {
        if (!sectionNav) return;
        // sectionNav is "hidden" when opacity is explicitly '0'
        const isCurrentlyHidden = sectionNav.style.opacity === '0';
        const willBeHidden = !isCurrentlyHidden;
        sectionNav.style.transition = 'opacity 0.25s ease';
        sectionNav.style.opacity = willBeHidden ? '0' : '1';
        sectionNav.style.pointerEvents = willBeHidden ? 'none' : '';
      }

      doc.getElementById('toc-toggle-btn')?.addEventListener('click', toggleToc);
      // ---- Search ----
      const searchHelperText = doc.getElementById('search-helper-text');
      const searchResultCount = doc.getElementById('search-result-count');
      let searchMatches: Element[] = [];
      let activeSearchIndex = 0;
      const originalReaderHtml = readerContent?.innerHTML;

      function escapeRegExp(string: string) {
        return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      }

      function clearSearchHighlights() {
        if (!readerContent || !originalReaderHtml) return;
        readerContent.innerHTML = originalReaderHtml;
        searchMatches = [];
        activeSearchIndex = 0;
        if (searchResultCount) searchResultCount.textContent = '';
        if (searchHelperText) searchHelperText.textContent = 'Nhập từ khóa để tìm kiếm trong nội dung';
      }

      function highlightText(node: Node, regex: RegExp) {
        const text = node.textContent || '';
        if (!regex.test(text)) return;
        const span = document.createDocumentFragment();
        let lastIndex = 0;
        regex.lastIndex = 0;
        let match;
        while ((match = regex.exec(text)) !== null) {
          const before = text.slice(lastIndex, match.index);
          if (before) span.appendChild(document.createTextNode(before));
          const mark = document.createElement('mark');
          mark.className = 'search-highlight';
          mark.textContent = match[0];
          span.appendChild(mark);
          lastIndex = regex.lastIndex;
        }
        const after = text.slice(lastIndex);
        if (after) span.appendChild(document.createTextNode(after));
        node.parentNode?.replaceChild(span, node);
      }

      function walkTextNodes(root: Node, regex: RegExp) {
        const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
          acceptNode(node) {
            if (!node.textContent?.trim()) return NodeFilter.FILTER_REJECT;
            if (node.parentElement?.closest('script,style,mark')) return NodeFilter.FILTER_REJECT;
            return NodeFilter.FILTER_ACCEPT;
          }
        });
        const textNodes = [];
        while (walker.nextNode()) {
          textNodes.push(walker.currentNode);
        }
        textNodes.forEach((node) => highlightText(node, regex));
      }

      function selectSearchMatch(index: number) {
        if (!searchMatches.length) return;
        searchMatches.forEach((el, i) => el.classList.toggle('search-highlight-active', i === index));
        const target = searchMatches[index] as HTMLElement;
        if (target) {
          if (readerScroll) {
            const top = target.offsetTop - 120;
            readerScroll.scrollTo({ top, behavior: 'smooth' });
          } else {
            const top = target.getBoundingClientRect().top + window.scrollY - 140;
            window.scrollTo({ top, behavior: 'smooth' });
          }
        }
      }

      function updateSearch(query: string) {
        clearSearchHighlights();
        const trimmed = query.trim();
        if (!trimmed || !readerContent) return;
        const regex = new RegExp(escapeRegExp(trimmed), 'gi');
        walkTextNodes(readerContent, regex);
        searchMatches = Array.from(readerContent.querySelectorAll('.search-highlight'));
        if (searchMatches.length > 0) {
          activeSearchIndex = 0;
          selectSearchMatch(activeSearchIndex);
          if (searchResultCount) searchResultCount.textContent = `${searchMatches.length} kết quả`;
          if (searchHelperText) searchHelperText.textContent = `Đã tìm thấy ${searchMatches.length} kết quả`;
        } else {
          if (searchResultCount) searchResultCount.textContent = 'Không tìm thấy kết quả';
          if (searchHelperText) searchHelperText.textContent = 'Không tìm thấy nội dung phù hợp';
        }
      }

      function openSearch() {
        searchOverlay?.classList.remove('hidden');
        searchInput?.focus();
      }
      function closeSearch() {
        searchOverlay?.classList.add('hidden');
        if (searchInput) {
          searchInput.value = '';
          updateSearch('');
        }
      }

      doc.getElementById('search-btn')?.addEventListener('click', openSearch);
      doc.getElementById('search-overlay')?.addEventListener('click', (e) => {
        if (e.target === searchOverlay) closeSearch();
      });

      searchInput?.addEventListener('input', (event) => {
        const query = (event.target as HTMLInputElement).value;
        updateSearch(query);
      });

      searchInput?.addEventListener('keydown', (event) => {
        if (event.key === 'Enter') {
          event.preventDefault();
          if (searchMatches.length > 0) {
            activeSearchIndex = (activeSearchIndex + 1) % searchMatches.length;
            selectSearchMatch(activeSearchIndex);
          }
        }
      });

      // Ctrl+K shortcut
      doc.addEventListener('keydown', (e) => {
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
          e.preventDefault();
          openSearch();
        }
        // Ctrl+Shift+L: toggle TOC sidebar
        if ((e.ctrlKey || e.metaKey) && e.shiftKey && e.key === 'L') {
          e.preventDefault();
          toggleToc();
        }
        if (e.key === 'Escape') {
          if (!searchOverlay?.classList.contains('hidden')) {
            closeSearch();
          }
        }
      });

      // ---- Fullscreen ----
      doc.getElementById('fullscreen-btn')?.addEventListener('click', () => {
        if (!doc.fullscreenElement) {
          doc.documentElement.requestFullscreen();
        } else {
          doc.exitFullscreen();
        }
      });

      // ---- Reading progress ----
      function updateProgress() {
        if (!readerScroll) return;
        const scrollTop = readerScroll.scrollTop;
        const scrollHeight = readerScroll.scrollHeight - readerScroll.clientHeight;
        const pct = scrollHeight > 0 ? Math.min(100, Math.round((scrollTop / scrollHeight) * 100)) : 0;
        doc.querySelectorAll('.read-progress').forEach((el) => {
          (el as HTMLElement).style.width = pct + '%';
        });
        doc.querySelectorAll('[id^="progress-pct"]').forEach((el) => {
          el.textContent = pct + '%';
        });
      }

      readerScroll?.addEventListener('scroll', updateProgress);
      updateProgress();

      // ---- Word count ----
      const article = doc.querySelector('article, .reader-content');
      if (article) {
        const text = article.textContent || '';
        const words = text.trim().split(/\s+/).filter(Boolean).length;
        doc.getElementById('word-count')!.textContent = words.toLocaleString('vi') + ' từ';
      }

      // ---- Mobile TOC (now unified via SectionNav floating trigger) ----
      // The SectionNav's own #section-nav-trigger handles this; no separate handler needed.

      // ---- Scroll to heading (smooth) ----
      const HEADER_OFFSET = 80;
      doc.querySelectorAll('a[href^="#"]').forEach((link) => {
        link.addEventListener('click', (e) => {
          const hash = link.getAttribute('href');
          if (!hash || hash === '#') return;
          e.preventDefault();
          const target = doc.getElementById(hash.slice(1));
          if (target && readerScroll) {
            const top = target.getBoundingClientRect().top + readerScroll.scrollTop - HEADER_OFFSET;
            readerScroll.scrollTo({ top, behavior: 'smooth' });
          }
          history.replaceState(null, '', hash);
          // Close mobile TOC if open
          (window as any).__closeSectionNav?.();
        });
      });

      if (location.hash) {
        requestAnimationFrame(() => {
          const target = doc.getElementById(location.hash.slice(1));
          if (target && readerScroll) {
            const top = target.getBoundingClientRect().top + readerScroll.scrollTop - HEADER_OFFSET;
            readerScroll.scrollTo({ top, behavior: 'smooth' });
          }
        });
      }

      // ---- TOC collapsible groups ----
      const TOC_COLLAPSE_KEY = 'toc-collapsed-tiers';
      function getCollapsedTiers(): Set<number> {
        try {
          const raw = localStorage.getItem(TOC_COLLAPSE_KEY);
          if (!raw) return new Set();
          return new Set(JSON.parse(raw) as number[]);
        } catch {
          return new Set();
        }
      }
      function saveCollapsedTiers(set: Set<number>) {
        try {
          localStorage.setItem(TOC_COLLAPSE_KEY, JSON.stringify([...set]));
        } catch { /* ignore */ }
      }
      function applyCollapsedState() {
        const collapsed = getCollapsedTiers();
        document.querySelectorAll<HTMLElement>('.toc-group').forEach((group) => {
          const tier = Number(group.dataset.tier);
          const isCollapsed = collapsed.has(tier);
          group.dataset.collapsed = isCollapsed ? 'true' : 'false';
          const header = group.querySelector<HTMLElement>('[data-toc-toggle]');
          if (header) header.setAttribute('aria-expanded', isCollapsed ? 'false' : 'true');
          const chapters = group.querySelector<HTMLElement>('.toc-group-chapters');
          if (chapters) {
            chapters.style.maxHeight = isCollapsed ? '0px' : '';
          }
        });
      }
      function toggleGroup(tier: number) {
        const collapsed = getCollapsedTiers();
        const group = document.querySelector<HTMLElement>(`.toc-group[data-tier="${tier}"]`);
        const chapters = group?.querySelector<HTMLElement>('.toc-group-chapters');

        if (collapsed.has(tier)) {
          // Expanding
          collapsed.delete(tier);
          saveCollapsedTiers(collapsed);
          group!.dataset.collapsed = 'false';
          const header = group!.querySelector<HTMLElement>('[data-toc-toggle]');
          if (header) header.setAttribute('aria-expanded', 'true');
          if (chapters) {
            chapters.style.maxHeight = chapters.scrollHeight + 'px';
            chapters.addEventListener('transitionend', function handler() {
              chapters.style.maxHeight = '';
              chapters.removeEventListener('transitionend', handler);
            });
          }
        } else {
          // Collapsing
          collapsed.add(tier);
          saveCollapsedTiers(collapsed);
          group!.dataset.collapsed = 'true';
          const header = group!.querySelector<HTMLElement>('[data-toc-toggle]');
          if (header) header.setAttribute('aria-expanded', 'false');
          if (chapters) {
            chapters.style.maxHeight = chapters.scrollHeight + 'px';
            requestAnimationFrame(() => {
              chapters.style.maxHeight = '0px';
            });
          }
        }
      }
      applyCollapsedState();
      document.querySelectorAll<HTMLElement>('[data-toc-toggle]').forEach((btn) => {
        const group = btn.closest<HTMLElement>('.toc-group');
        const tier = group ? Number(group.dataset.tier) : NaN;
        btn.addEventListener('click', () => {
          if (!isNaN(tier)) toggleGroup(tier);
        });
      });

      // ---- Init ----

    })();
  </script>

  <!-- ═══════════════ Image Lightbox Script ═══════════════ -->
  <script>
    (function () {
      const lightbox = document.getElementById('image-lightbox');
      if (!lightbox) return;
      const lbContainer = lightbox.querySelector('.lb-container') as HTMLElement;
      const lbImage = lightbox.querySelector('.lb-image') as HTMLImageElement;
      const lbClose = lightbox.querySelector('.lb-close') as HTMLElement;
      const lbBadge = lightbox.querySelector('.lb-zoom-badge') as HTMLElement;
      const lbHint = lightbox.querySelector('.lb-hint') as HTMLElement;

      let scale = 1;
      let panX = 0, panY = 0;
      let startPanX = 0, startPanY = 0;
      let lastPanX = 0, lastPanY = 0;
      let isPanning = false;
      let hintShown = false;
      let badgeTimeout: ReturnType<typeof setTimeout>;

      const ZOOM_STEP = 0.35;
      const MIN_SCALE = 1;
      const MAX_SCALE = 5;

      // Cache image dimensions to avoid getBoundingClientRect in clampPan
      let imgNaturalW = 0, imgNaturalH = 0;

      function applyTransform(animate = false) {
        lbImage.classList.toggle('lb-animating', animate);
        lbImage.style.transform = `translate(${panX}px, ${panY}px) scale(${scale})`;
      }

      function showBadge(text: string) {
        lbBadge.textContent = text;
        lbBadge.style.opacity = '1';
        clearTimeout(badgeTimeout);
        badgeTimeout = setTimeout(() => { lbBadge.style.opacity = '0'; }, 1200);
      }

      function resetZoom(animate = true) {
        scale = 1; panX = 0; panY = 0;
        applyTransform(animate);
        lbContainer.classList.remove('zoomed');
      }

      function zoomTo(newScale: number, cx?: number, cy?: number) {
        newScale = Math.max(MIN_SCALE, Math.min(MAX_SCALE, newScale));
        if (cx !== undefined && cy !== undefined && scale !== newScale) {
          // Zoom toward pointer/touch point
          const rect = lbImage.getBoundingClientRect();
          const imgCx = cx - rect.left - rect.width / 2;
          const imgCy = cy - rect.top - rect.height / 2;
          const ratio = newScale / scale;
          panX = imgCx - ratio * (imgCx - panX);
          panY = imgCy - ratio * (imgCy - panY);
        }
        scale = newScale;
        if (scale <= 1) {
          panX = 0; panY = 0;
          lbContainer.classList.remove('zoomed');
        } else {
          lbContainer.classList.add('zoomed');
        }
        applyTransform(false);
        showBadge(`${Math.round(scale * 100)}%`);
      }

      // Internal: update scale/pan without rendering (caller must applyTransform)
      // Uses cached rect from pinch start to avoid reflow during gesture
      let pinchRect: DOMRect | null = null;
      function computePinchZoom(newScale: number, cx: number, cy: number) {
        newScale = Math.max(MIN_SCALE, Math.min(MAX_SCALE, newScale));
        if (scale !== newScale && pinchRect) {
          const imgCx = cx - pinchRect.left - pinchRect.width / 2;
          const imgCy = cy - pinchRect.top - pinchRect.height / 2;
          const ratio = newScale / scale;
          panX = imgCx - ratio * (imgCx - panX);
          panY = imgCy - ratio * (imgCy - panY);
        }
        scale = newScale;
        if (scale <= 1) {
          panX = 0; panY = 0;
          lbContainer.classList.remove('zoomed');
        } else {
          lbContainer.classList.add('zoomed');
        }
      }

      function clampPan() {
        if (scale <= 1) { panX = 0; panY = 0; return; }
        // Use cached dimensions (updated on image load / open) to avoid forced reflow
        const vw = window.innerWidth;
        const vh = window.innerHeight;
        // Fit image into container like CSS max-width:90vw max-height:88vh
        const fitW = vw * 0.9;
        const fitH = vh * 0.88;
        const displayScale = Math.min(fitW / imgNaturalW, fitH / imgNaturalH, 1);
        const iw = imgNaturalW * displayScale;
        const ih = imgNaturalH * displayScale;
        const maxX = Math.max(0, (iw * scale - vw) / 2);
        const maxY = Math.max(0, (ih * scale - vh) / 2);
        panX = Math.max(-maxX, Math.min(maxX, panX));
        panY = Math.max(-maxY, Math.min(maxY, panY));
      }

      // ── Open ──
      function openLightbox(src: string, alt: string) {
        resetZoom(false);
        lbImage.src = src;
        lbImage.alt = alt;
        lbImage.classList.remove('lb-ready');
        lightbox!.classList.remove('hidden', 'lb-hidden');
        lightbox!.classList.add('lb-visible');
        document.body.style.overflow = 'hidden';

        // Wait for image to load before showing
        const onLoad = () => {
          // Cache natural dimensions for clampPan
          imgNaturalW = lbImage.naturalWidth;
          imgNaturalH = lbImage.naturalHeight;
          lbImage.classList.add('lb-ready');
          lbImage.removeEventListener('load', onLoad);
          // Show hint on first use
          if (!hintShown) {
            hintShown = true;
            lbHint.style.opacity = '1';
            setTimeout(() => { lbHint.style.opacity = '0'; }, 4000);
          }
        };
        if (lbImage.complete) onLoad();
        else lbImage.addEventListener('load', onLoad, { once: true });
      }

      function closeLightbox() {
        lightbox!.classList.add('lb-hidden');
        lightbox!.classList.remove('lb-visible');
        document.body.style.overflow = '';
        resetZoom(false);
        lbImage.classList.remove('lb-ready');
      }

      // ── Event: click images in reader ──
      document.addEventListener('click', (e) => {
        const img = (e.target as HTMLElement).closest('.reader-content img, figure img');
        if (!img || img.closest('#image-lightbox')) return;
        const htmlImg = img as HTMLImageElement;
        e.preventDefault();
        openLightbox(htmlImg.src, htmlImg.alt || '');
      });

      // ── Close ──
      lbClose.addEventListener('click', closeLightbox);
      lightbox!.addEventListener('click', (e) => {
        if (e.target === lbContainer) closeLightbox();
      });

      // ── Mouse: wheel zoom ──
      lbContainer.addEventListener('wheel', (e) => {
        e.preventDefault();
        const delta = e.deltaY > 0 ? -ZOOM_STEP : ZOOM_STEP;
        zoomTo(scale + delta, e.clientX, e.clientY);
      }, { passive: false });

      // ── Mouse: double-click toggle zoom ──
      let lastClickTime = 0;
      lbContainer.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('.lb-close')) return;
        const now = Date.now();
        if (now - lastClickTime < 350) {
          // Double click
          if (scale > 1) {
            resetZoom(true);
          } else {
            zoomTo(2.5, e.clientX, e.clientY);
          }
        }
        lastClickTime = now;
      });

      // ── Mouse: drag to pan ──
      lbContainer.addEventListener('mousedown', (e) => {
        if (scale <= 1) return;
        isPanning = true;
        lastPanX = panX; lastPanY = panY;
        startPanX = e.clientX; startPanY = e.clientY;
        e.preventDefault();
      });
      document.addEventListener('mousemove', (e) => {
        if (!isPanning) return;
        panX = lastPanX + (e.clientX - startPanX);
        panY = lastPanY + (e.clientY - startPanY);
        clampPan();
        applyTransform(false);
      });
      document.addEventListener('mouseup', () => {
        if (isPanning) {
          isPanning = false;
          // If pan didn't move much, treat as a click (not drag)
          requestAnimationFrame(() => { isPanning = false; });
        }
      });

      // ── Touch: pinch-to-zoom + pan ──
      let lastTouchDist = 0;
      let lastTouchCenter = { x: 0, y: 0 };
      let touchPanning = false;
      let touchStartPan = { x: 0, y: 0 };
      let touchStartCenter = { x: 0, y: 0 };

      function getTouchDist(t1: Touch, t2: Touch) {
        return Math.hypot(t2.clientX - t1.clientX, t2.clientY - t1.clientY);
      }
      function getTouchCenter(t1: Touch, t2: Touch) {
        return { x: (t1.clientX + t2.clientX) / 2, y: (t1.clientY + t2.clientY) / 2 };
      }

      lbContainer.addEventListener('touchstart', (e) => {
        if (e.touches.length === 2) {
          // Pinch start — cache rect once to avoid reflow during gesture
          lastTouchDist = getTouchDist(e.touches[0], e.touches[1]);
          lastTouchCenter = getTouchCenter(e.touches[0], e.touches[1]);
          pinchRect = lbImage.getBoundingClientRect();
          lbImage.classList.add('lb-pinching');
          e.preventDefault();
        } else if (e.touches.length === 1 && scale > 1) {
          // Pan start
          touchPanning = true;
          touchStartCenter = { x: e.touches[0].clientX, y: e.touches[0].clientY };
          touchStartPan = { x: panX, y: panY };
        }
      }, { passive: false });

      lbContainer.addEventListener('touchmove', (e) => {
        if (e.touches.length === 2) {
          const dist = getTouchDist(e.touches[0], e.touches[1]);
          const center = getTouchCenter(e.touches[0], e.touches[1]);
          const pinchScale = dist / lastTouchDist;
          // Compute zoom + pan in one pass, single applyTransform at the end
          computePinchZoom(scale * pinchScale, center.x, center.y);
          panX += center.x - lastTouchCenter.x;
          panY += center.y - lastTouchCenter.y;
          clampPan();
          applyTransform(false);
          lastTouchDist = dist;
          lastTouchCenter = center;
          e.preventDefault();
        } else if (e.touches.length === 1 && touchPanning && scale > 1) {
          panX = touchStartPan.x + (e.touches[0].clientX - touchStartCenter.x);
          panY = touchStartPan.y + (e.touches[0].clientY - touchStartCenter.y);
          clampPan();
          applyTransform(false);
          e.preventDefault();
        }
      }, { passive: false });

      lbContainer.addEventListener('touchend', (e) => {
        if (e.touches.length < 2) {
          lastTouchDist = 0;
          pinchRect = null;
          lbImage.classList.remove('lb-pinching');
        }
        if (e.touches.length === 0) {
          touchPanning = false;
          if (scale < 1.05) resetZoom(true);
        }
      });

      // ── Keyboard ──
      document.addEventListener('keydown', (e) => {
        if (lightbox!.classList.contains('lb-hidden') || lightbox!.classList.contains('hidden')) return;
        if (e.key === 'Escape') closeLightbox();
        if (e.key === '+' || e.key === '=') zoomTo(scale + ZOOM_STEP, window.innerWidth / 2, window.innerHeight / 2);
        if (e.key === '-') zoomTo(scale - ZOOM_STEP, window.innerWidth / 2, window.innerHeight / 2);
        if (e.key === '0') resetZoom(true);
      });
    })();
  </script>

  <!-- ═══════════════ File Download / Preview Script ═══════════════ -->
  <script>
    (function () {
      const MAX_FETCH_SIZE = 50 * 1024 * 1024; // 50 MB — above this, fallback to direct link

      // ── Helpers ──
      function formatBytes(bytes: number): string {
        if (bytes === 0) return '0 B';
        const units = ['B', 'KB', 'MB', 'GB'];
        const i = Math.floor(Math.log(bytes) / Math.log(1024));
        return (bytes / Math.pow(1024, i)).toFixed(i > 0 ? 1 : 0) + ' ' + units[i];
      }

      function escapeAttr(s: string): string {
        return s.replace(/&/g, '&amp;').replace(/"/g, '&quot;');
      }

      // ── File size cache ──
      const sizeCache = new Map<string, string>();

      async function fetchFileSize(card: HTMLElement): Promise<void> {
        const url = card.dataset.fileUrl;
        if (!url) return;
        if (sizeCache.has(url)) {
          showSize(card, sizeCache.get(url)!);
          return;
        }
        try {
          const res = await fetch(url, { method: 'GET' });
          const total = Number(res.headers.get('Content-Length'));
          if (total > 0) {
            const formatted = formatBytes(total);
            sizeCache.set(url, formatted);
            showSize(card, formatted);
          }
        } catch { /* silent — size display is non-critical */ }
      }

      function showSize(card: HTMLElement, text: string): void {
        const sizeEl = card.querySelector('.file-size-display') as HTMLElement | null;
        const mimeEl = card.querySelector('.file-mime-label') as HTMLElement | null;
        if (sizeEl && mimeEl) {
          sizeEl.textContent = text;
          sizeEl.classList.remove('hidden');
          mimeEl.classList.add('hidden');
        }
      }

      // ── Intersection Observer for lazy size fetch ──
      const sizeObserver = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              fetchFileSize(entry.target as HTMLElement);
              sizeObserver.unobserve(entry.target);
            }
          }
        },
        { rootMargin: '200px' }
      );

      // Defer observing file cards until after first paint
      function observeFileCards() {
        document.querySelectorAll<HTMLElement>('[data-file-card]').forEach((card) => {
          sizeObserver.observe(card);
        });
      }
      if ('requestIdleCallback' in window) {
        requestIdleCallback(observeFileCards, { timeout: 2000 });
      } else {
        setTimeout(observeFileCards, 300);
      }

      // ── Download with progress ──
      async function downloadFile(card: HTMLElement): Promise<void> {
        const url = card.dataset.fileUrl;
        const filename = card.dataset.fileName || 'download';
        if (!url) return;

        const overlay = card.querySelector('.file-progress-overlay') as HTMLElement | null;
        const progressBar = card.querySelector('.file-progress-bar') as HTMLElement | null;
        const pctText = card.querySelector('.file-progress-pct') as HTMLElement | null;
        const statusText = card.querySelector('.file-progress-status') as HTMLElement | null;
        const cancelBtn = card.querySelector('.file-cancel-btn') as HTMLElement | null;

        if (!overlay || !progressBar || !pctText || !statusText) return;

        // Check file size first — fallback to direct download for large files
        let totalSize = 0;
        if (sizeCache.has(url)) {
          // Parse cached size back to bytes (rough check)
          const cached = sizeCache.get(url)!;
          if (cached.includes('GB')) {
            directDownload(url, filename);
            return;
          }
        } else {
          try {
            const headRes = await fetch(url, { method: 'GET' });
            totalSize = Number(headRes.headers.get('Content-Length')) || 0;
            // Don't consume the body — let it GC
          } catch { /* proceed with fetch anyway */ }
          if (totalSize > MAX_FETCH_SIZE) {
            directDownload(url, filename);
            return;
          }
        }

        const controller = new AbortController();
        const onAbort = () => controller.abort();
        cancelBtn?.addEventListener('click', onAbort, { once: true });

        // Show overlay
        overlay.classList.remove('hidden');
        progressBar.style.width = '0%';
        pctText.textContent = '0';
        statusText.textContent = 'Đang tải...';
        statusText.classList.remove('text-error');
        progressBar.classList.toggle('indeterminate', totalSize === 0);

        try {
          const response = await fetch(url, { signal: controller.signal });
          if (!response.ok) throw new Error('Download failed');

          const total = totalSize || Number(response.headers.get('Content-Length')) || 0;
          const reader = response.body!.getReader();
          const chunks: Uint8Array[] = [];
          let loaded = 0;

          while (true) {
            const { done, value } = await reader.read();
            if (done) break;
            chunks.push(value);
            loaded += value.length;
            if (total > 0) {
              const pct = Math.round((loaded / total) * 100);
              progressBar.style.width = pct + '%';
              pctText.textContent = String(pct);
              statusText.textContent = `${formatBytes(loaded)} / ${formatBytes(total)}`;
            } else {
              statusText.textContent = `Đang tải... ${formatBytes(loaded)}`;
            }
          }

          // Build blob and trigger download
          const blob = new Blob(chunks as BlobPart[]);
          const blobUrl = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = blobUrl;
          a.download = filename;
          a.click();
          setTimeout(() => URL.revokeObjectURL(blobUrl), 1000);

          progressBar.classList.remove('indeterminate');
          progressBar.style.width = '100%';
          pctText.textContent = '100';
          statusText.textContent = 'Hoàn thành!';
          setTimeout(() => overlay.classList.add('hidden'), 800);
        } catch (e: any) {
          progressBar.classList.remove('indeterminate');
          if (e?.name !== 'AbortError') {
            statusText.textContent = 'Lỗi tải file';
            statusText.classList.add('text-error');
            setTimeout(() => overlay.classList.add('hidden'), 2000);
          } else {
            overlay.classList.add('hidden');
          }
        } finally {
          cancelBtn?.removeEventListener('click', onAbort);
        }
      }

      function directDownload(url: string, filename: string): void {
        const a = document.createElement('a');
        a.href = url;
        a.download = filename;
        a.target = '_blank';
        a.rel = 'noopener';
        a.click();
      }

      // ── Preview modal ──
      const previewModal = document.getElementById('file-preview-modal');
      const previewBackdrop = document.getElementById('preview-backdrop');
      const previewBody = document.getElementById('preview-body');
      const previewFilename = document.getElementById('preview-filename');
      const previewCloseBtn = document.getElementById('preview-close');
      const previewOpenExt = document.getElementById('preview-open-external');
      const previewDownloadBtn = document.getElementById('preview-download');
      let previewUrl = '';
      let previewFileName = '';

      function openPreview(url: string, filename: string, mime: string): void {
        if (!previewModal || !previewBody || !previewFilename) return;
        previewUrl = url;
        previewFileName = filename;
        previewFilename.textContent = filename;
        previewBody.innerHTML = '';

        if (mime.includes('pdf')) {
          previewBody.innerHTML = `<iframe src="${escapeAttr(url)}" class="w-full h-full rounded-xl border-none" style="min-height: 60vh" title="PDF Preview"></iframe>`;
        } else if (mime.includes('image')) {
          previewBody.innerHTML = `
            <div class="relative flex items-center justify-center w-full h-full">
              <img id="preview-img" class="max-w-full max-h-full object-contain rounded-xl" alt="${escapeAttr(filename)}" />
              <div class="absolute inset-0 flex items-center justify-center preview-loading">
                <span class="material-symbols-outlined text-4xl text-on-surface-variant" style="animation: spin 1s linear infinite;">progress_activity</span>
              </div>
            </div>`;
          const img = document.getElementById('preview-img') as HTMLImageElement | null;
          fetch(url).then(r => r.blob()).then(blob => {
            if (img) img.src = URL.createObjectURL(blob);
            previewBody?.querySelector('.preview-loading')?.remove();
          }).catch(() => {
            previewBody.innerHTML = '<p class="text-sm text-on-surface-variant text-center py-8">Không thể tải ảnh</p>';
          });
        }

        previewModal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        // Focus trap
        previewCloseBtn?.focus();
      }

      function closePreview(): void {
        if (!previewModal) return;
        previewModal.classList.add('hidden');
        if (previewBody) previewBody.innerHTML = '';
        document.body.style.overflow = '';
        previewUrl = '';
        previewFileName = '';
      }

      previewCloseBtn?.addEventListener('click', closePreview);
      previewBackdrop?.addEventListener('click', closePreview);
      previewOpenExt?.addEventListener('click', () => {
        if (previewUrl) window.open(previewUrl, '_blank', 'noopener');
      });
      previewDownloadBtn?.addEventListener('click', () => {
        if (previewUrl && previewFileName) {
          directDownload(previewUrl, previewFileName);
        }
      });

      // ── Event delegation for file card buttons ──
      document.addEventListener('click', (e) => {
        const target = (e.target as HTMLElement).closest<HTMLElement>('.file-download-btn, .file-preview-btn');
        if (!target) return;
        const card = target.closest<HTMLElement>('[data-file-card]');
        if (!card) return;

        if (target.classList.contains('file-download-btn')) {
          e.preventDefault();
          downloadFile(card);
        } else if (target.classList.contains('file-preview-btn')) {
          e.preventDefault();
          const url = card.dataset.fileUrl;
          const name = card.dataset.fileName || 'preview';
          const mime = card.dataset.fileMime || '';
          if (url) openPreview(url, name, mime);
        }
      });

      // Escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && previewModal && !previewModal.classList.contains('hidden')) {
          closePreview();
        }
      });
    })();
  </script>
  <style>
    /* Chapter nav fixed bottom bar */
    .chapter-nav-fixed a:hover span:last-child {
      color: var(--color-primary) !important;
    }

    /* Enhanced TOC item hover - more prominent */
    .toc-item-hover {
      transition: all 0.2s ease;
    }
    .toc-item-hover:hover {
      background: rgba(146, 204, 255, 0.08) !important;
      border-color: rgba(146, 204, 255, 0.4) !important;
      color: var(--color-on-surface) !important;
      transform: translateX(4px);
      box-shadow: 0 2px 8px rgba(146, 204, 255, 0.1);
    }

    /* Group header hover enhancement */
    .toc-group-header:hover {
      background: rgba(146, 204, 255, 0.06);
    }
    .toc-group-header:hover .toc-group-label {
      color: var(--color-on-surface);
    }

    /* TOC group collapse */
    .toc-group-chapters {

      overflow: hidden;
      transition: max-height 0.3s ease, opacity 0.2s ease;
    }
    .toc-group[data-collapsed="true"] .toc-group-chapters {
      max-height: 0;
      opacity: 0;
    }
    .toc-group[data-collapsed="true"] .toc-group-chevron {
      transform: rotate(-90deg);
    }
    .toc-group[data-collapsed="true"] .toc-group-icon {
      transform: rotate(-15deg);
    }
    .toc-group-header[aria-expanded="false"] + .toc-group-chapters {
      /* handled via data-collapsed */
    }

    /* TOC group header active tier highlight */
    .toc-group[data-current-tier="true"] .toc-group-header {
      background: rgba(146, 204, 255, 0.06);
    }
    .toc-group[data-current-tier="true"] .toc-group-label {
      color: var(--color-on-surface);
    }

    /* Enhanced current chapter highlight */
    .toc-item-active {
      background: rgba(146, 204, 255, 0.1) !important;
      border-color: var(--color-primary) !important;
      color: var(--color-primary) !important;
      position: relative;
      box-shadow: inset 0 0 0 1px rgba(146, 204, 255, 0.15), 0 0 12px rgba(146, 204, 255, 0.08);
    }
    .toc-item-active::before {
      content: '';
      position: absolute;
      left: -2px;
      top: 50%;
      transform: translateY(-50%);
      width: 3px;
      height: 60%;
      background: var(--color-primary);
      border-radius: 0 2px 2px 0;
      box-shadow: 0 0 8px var(--color-primary);
    }
    .toc-item-active .shrink-0 {
      color: var(--color-primary);
    }

    /* Scrollbar */
    .toc-sidebar::-webkit-scrollbar,
    .toc-sidebar *::-webkit-scrollbar {
      width: 3px;
    }
    .toc-sidebar::-webkit-scrollbar-thumb,
    .toc-sidebar *::-webkit-scrollbar-thumb {
      background: rgba(255, 255, 255, 0.08);
      border-radius: 99px;
    }
  </style>
  <style>
    @keyframes spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    /* ── Image Lightbox ── */
    #image-lightbox { touch-action: none; }
    #image-lightbox .lb-container { cursor: zoom-in; }
    #image-lightbox .lb-container.zoomed { cursor: grab; }
    #image-lightbox .lb-container.zoomed:active { cursor: grabbing; }
    .lb-image {
      max-width: 90vw;
      max-height: 88vh;
      object-fit: contain;
      border-radius: 0.5rem;
      transition: transform 0.25s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.2s ease;
      will-change: transform;
      opacity: 0;
    }
    .lb-image.lb-pinching {
      transition: none !important;
    }
    .lb-image.lb-ready { opacity: 1; }
    .lb-image.lb-animating { transition: transform 0.35s cubic-bezier(0.25, 1, 0.5, 1); }
    #image-lightbox.lb-hidden { display: none; }
    #image-lightbox.lb-visible { display: flex; }
  </style>

