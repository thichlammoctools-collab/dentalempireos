---
import BaseLayout from './BaseLayout.astro';
import SidebarNav from '../components/book/SidebarNav.astro';
import SidebarMobile from '../components/book/SidebarMobile.astro';

interface ChapterItem {
  id: string;
  data: { title: string; tier: number; chapter: number };
}

interface ModuleItem {
  title: string;
  slug: string;
}

interface TierGroup {
  tier: number;
  label: string;
  chapters: ChapterItem[];
}

interface Props {
  title: string;
  description?: string;
  groupedChapters: TierGroup[];
  currentSlug: string;
  currentModules: ModuleItem[];
}

const { title, description, groupedChapters, currentSlug, currentModules } = Astro.props;
---

<BaseLayout title={`${title} - Dental Empire OS`} description={description}>
  <!-- Desktop Sidebar -->
  <div class="px-6 max-w-[1200px] mx-auto">
    <div class="flex gap-8 py-12">
      <SidebarNav groupedChapters={groupedChapters} currentSlug={currentSlug} currentModules={currentModules} />
      <article class="flex-1 min-w-0 max-w-[72ch]">
        <slot />
      </article>
    </div>
  </div>

  <!-- Mobile Sidebar -->
  <SidebarMobile groupedChapters={groupedChapters} currentSlug={currentSlug} currentModules={currentModules} />
</BaseLayout>
