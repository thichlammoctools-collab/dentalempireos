---
// NotificationBell - bell icon with unread badge + dropdown panel
// Used inside /account/profile — auth is enforced by the page middleware.
---

<!-- Notification bell -->
<div class="relative">
  <button
    id="notif-bell-btn"
    class="relative flex items-center justify-center w-9 h-9 rounded-lg text-on-surface-variant hover:text-primary hover:bg-surface-container transition-all"
    title="Thông báo"
  >
    <span class="material-symbols-outlined text-xl">notifications</span>
    <span id="notif-badge" class="absolute -top-0.5 -right-0.5 min-w-[18px] h-[18px] flex items-center justify-center px-1 text-[9px] font-bold text-white bg-error rounded-full hidden">0</span>
  </button>

  <!-- Dropdown -->
  <div id="notif-dropdown" class="hidden absolute right-0 top-full mt-2 z-[70] w-[360px] max-h-[420px] glass-panel-dark rounded-xl shadow-2xl border border-outline-variant/20 overflow-hidden">
    <div class="flex items-center justify-between px-4 py-3 border-b border-outline-variant/15">
      <h4 class="text-sm font-bold text-white">Thông báo</h4>
      <button id="notif-mark-all" class="text-[11px] text-primary hover:underline font-bold">Đánh dấu tất cả đã đọc</button>
    </div>
    <div id="notif-list" class="overflow-y-auto max-h-[350px] divide-y divide-outline-variant/10">
      <div class="p-6 text-center text-sm text-on-surface-variant/50">
        <span class="material-symbols-outlined text-3xl block mb-2 opacity-50">notifications_none</span>
        Chưa có thông báo
      </div>
    </div>
  </div>
</div>

<script>
  interface Notification {
    id: string;
    title: string;
    body: string;
    link?: string;
    read: boolean;
    createdAt: string;
  }

  async function fetchUnreadCount(): Promise<number> {
    try {
      const res = await fetch('/api/notifications/unread-count', { credentials: 'include' });
      if (!res.ok) return 0;
      const data = await res.json() as { count?: number };
      return data.count ?? 0;
    } catch { return 0; }
  }

  function updateBadge(count: number) {
    const badge = document.getElementById('notif-badge');
    if (!badge) return;
    if (count > 0) {
      badge.textContent = count > 99 ? '99+' : String(count);
      badge.classList.remove('hidden');
    } else {
      badge.classList.add('hidden');
    }
  }

  async function fetchNotifications(): Promise<Notification[]> {
    try {
      const res = await fetch('/api/notifications', { credentials: 'include' });
      if (!res.ok) return [];
      return await res.json() as Notification[];
    } catch { return []; }
  }

  function renderNotificationList(notifs: any[], containerId: string) {
    const container = document.getElementById(containerId);
    if (!container) return;

    if (!notifs.length) {
      container.innerHTML = `
        <div class="p-6 text-center text-sm text-on-surface-variant/50">
          <span class="material-symbols-outlined text-3xl block mb-2 opacity-50">notifications_none</span>
          Chưa có thông báo
        </div>`;
      return;
    }

    container.innerHTML = notifs.map(n => `
      <a
        href="${n.link || '#'}"
        data-notif-id="${n.id}"
        data-notif-read="${n.read ? '1' : '0'}"
        class="notif-item flex items-start gap-3 px-4 py-2.5 hover:bg-surface-container transition-colors ${n.read ? '' : 'bg-primary/5'}"
      >
        <div class="w-8 h-8 rounded-full ${n.read ? 'bg-surface-container-high' : 'bg-primary/15'} flex items-center justify-center shrink-0 mt-0.5">
          <span class="material-symbols-outlined text-sm ${n.read ? 'text-on-surface-variant' : 'text-primary'}">chat</span>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-baseline gap-2">
            <p class="text-xs font-bold ${n.read ? 'text-on-surface-variant' : 'text-white'} leading-snug truncate">${n.title}</p>
            <span class="text-[10px] text-on-surface-variant/40 shrink-0">${new Date(n.createdAt).toLocaleDateString('vi-VN')}</span>
          </div>
          <p class="text-[11px] text-on-surface-variant/60 mt-0.5 line-clamp-2">${n.body}</p>
        </div>
        ${!n.read ? '<div class="w-2 h-2 rounded-full bg-primary shrink-0 mt-1.5"></div>' : ''}
      </a>
    `).join('');

    container.querySelectorAll('.notif-item[data-notif-read="0"]').forEach(el => {
      el.addEventListener('click', async (e) => {
        const id = el.getAttribute('data-notif-id');
        e.preventDefault();
        if (id) {
          try {
            await fetch('/api/notifications/read', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              credentials: 'include',
              body: JSON.stringify({ id }),
            });
            const badge = document.getElementById('notif-badge');
            if (badge && !badge.classList.contains('hidden')) {
              const n = parseInt(badge.textContent || '0') - 1;
              if (n <= 0) { badge.classList.add('hidden'); }
              else { badge.textContent = String(n); }
            }
            el.setAttribute('data-notif-read', '1');
            el.classList.remove('bg-primary/5');
            el.querySelector('.rounded-full.bg-primary')?.remove();
          } catch { /* non-critical */ }
        }
        const link = el.getAttribute('href');
        if (link && link !== '#') {
          setTimeout(() => { window.location.href = link; }, 50);
        }
      });
    });
  }

  async function openDropdown(dropdownId: string, listId: string) {
    const dropdown = document.getElementById(dropdownId);
    if (!dropdown) return;
    dropdown.classList.remove('hidden');
    const notifs = await fetchNotifications();
    renderNotificationList(notifs, listId);
  }

  function closeDropdown(dropdownId: string) {
    document.getElementById(dropdownId)?.classList.add('hidden');
  }

  document.getElementById('notif-bell-btn')?.addEventListener('click', (e) => {
    e.stopPropagation();
    const dd = document.getElementById('notif-dropdown');
    if (dd?.classList.contains('hidden')) {
      openDropdown('notif-dropdown', 'notif-list');
    } else {
      closeDropdown('notif-dropdown');
    }
  });

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest('#notif-dropdown') && !target.closest('#notif-bell-btn')) {
      closeDropdown('notif-dropdown');
    }
  });

  async function markAllRead() {
    await fetch('/api/notifications/read', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'include',
      body: JSON.stringify({}),
    });
    updateBadge(0);
    const notifs = await fetchNotifications();
    renderNotificationList(notifs, 'notif-list');
  }

  document.getElementById('notif-mark-all')?.addEventListener('click', markAllRead);

  async function pollUnread() {
    const count = await fetchUnreadCount();
    updateBadge(count);
  }

  pollUnread();
  setInterval(pollUnread, 30000);
</script>

