---
interface Props {
  resourceId: string;
  fileName: string;
  fileLabel: string;
}

const { resourceId, fileName, fileLabel } = Astro.props;
---

<!-- Login CTA (shown when not logged in) -->
<div id={`login-${resourceId}`} class="hidden mt-4">
  <a
    href="/login?redirect=/resources"
    class="inline-flex items-center gap-2 px-4 py-3 bg-white/5 border border-outline-variant text-on-surface-variant rounded-xl text-sm font-semibold hover:text-primary hover:border-primary transition-all"
  >
    <span class="material-symbols-outlined text-[18px]">lock</span>
    Đăng nhập để tải
  </a>
</div>

<!-- Download link (shown when logged in) -->
<div id={`link-${resourceId}`} class="hidden mt-4">
  <a
    href={`/files/${fileName}`}
    download
    class="inline-flex items-center gap-2 px-4 py-3 bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 rounded-xl text-sm font-semibold hover:bg-emerald-500/20 transition-all"
  >
    <span class="material-symbols-outlined text-[18px]">check_circle</span>
    Tải {fileLabel}
  </a>
</div>

<script>
  import { getSession } from '../../lib/auth-client';

  let isLoggedIn: boolean | null = null;
  let sessionPromise: Promise<boolean> | null = null;

  function resolveSession(): Promise<boolean> {
    if (isLoggedIn !== null) return Promise.resolve(isLoggedIn);
    if (!sessionPromise) {
      sessionPromise = getSession()
        .then(({ data }) => {
          isLoggedIn = Boolean(data?.user);
          return isLoggedIn;
        })
        .catch(() => {
          isLoggedIn = false;
          return false;
        });
    }
    return sessionPromise;
  }

  function reveal(resourceId: string, loggedIn: boolean) {
    const login = document.getElementById(`login-${resourceId}`);
    const link = document.getElementById(`link-${resourceId}`);
    if (loggedIn) {
      login?.classList.add('hidden');
      link?.classList.remove('hidden');
    } else {
      link?.classList.add('hidden');
      login?.classList.remove('hidden');
    }
  }

  function initDownloadGates() {
    document.querySelectorAll('[data-download]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const resourceId = (btn as HTMLElement).dataset.download;
        if (!resourceId) return;
        const loggedIn = await resolveSession();
        reveal(resourceId, loggedIn);
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initDownloadGates);
</script>
