---
interface Props {
  resourceId: string;
  fileName: string;
  fileLabel: string;
}

const { resourceId, fileName, fileLabel } = Astro.props;
---

<div id={`form-${resourceId}`} class="hidden mt-4">
  <form class="download-form flex flex-col gap-3" data-resource={resourceId} data-file={fileName}>
    <div class="relative">
      <input
        type="email"
        placeholder="Nhập email để tải..."
        required
        class="w-full px-4 py-3 bg-white/5 border border-outline-variant rounded-xl text-white placeholder:text-white/30 focus:ring-2 focus:ring-primary focus:outline-none text-sm"
      />
    </div>
    <div class="flex gap-2">
      <button
        type="submit"
        class="flex-1 px-4 py-3 btn-primary-metallic font-bold rounded-xl text-sm active:scale-95 transition-all flex items-center justify-center gap-2"
      >
        <span class="material-symbols-outlined text-[18px]">download</span>
        Tải ngay
      </button>
      <button
        type="button"
        data-close-form={resourceId}
        class="px-4 py-3 border border-outline-variant text-on-surface-variant rounded-xl text-sm hover:text-primary hover:border-primary transition-all"
      >
        Hủy
      </button>
    </div>
  </form>
</div>

<!-- Download link (hidden until form submitted) -->
<div id={`link-${resourceId}`} class="hidden mt-4">
  <a
    href={`/files/${fileName}`}
    download
    class="inline-flex items-center gap-2 px-4 py-3 bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 rounded-xl text-sm font-semibold hover:bg-emerald-500/20 transition-all"
  >
    <span class="material-symbols-outlined text-[18px]">check_circle</span>
    Tải {fileLabel}
  </a>
</div>

<script>
  function initDownloadForms() {
    // Get all submitted resources from localStorage
    const submitted = JSON.parse(localStorage.getItem('de_downloads') || '[]');

    // Check each form — if already submitted, show download link instead
    submitted.forEach((resourceId: string) => {
      const form = document.getElementById(`form-${resourceId}`);
      const link = document.getElementById(`link-${resourceId}`);
      if (form) form.classList.add('hidden');
      if (link) link.classList.remove('hidden');
    });

    // "Tải miễn phí" buttons
    document.querySelectorAll('[data-download]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const resourceId = (btn as HTMLElement).dataset.download;
        const form = document.getElementById(`form-${resourceId}`);
        const link = document.getElementById(`link-${resourceId}`);

        // Already downloaded? Skip form
        if (submitted.includes(resourceId)) {
          form?.classList.add('hidden');
          link?.classList.remove('hidden');
          return;
        }

        form?.classList.toggle('hidden');
      });
    });

    // Close form buttons
    document.querySelectorAll('[data-close-form]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const resourceId = (btn as HTMLElement).dataset.closeForm;
        const form = document.getElementById(`form-${resourceId}`);
        form?.classList.add('hidden');
      });
    });

    // Form submissions
    document.querySelectorAll('.download-form').forEach((form) => {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const f = e.target as HTMLFormElement;
        const email = (f.querySelector('input[type="email"]') as HTMLInputElement).value;
        const resourceId = f.dataset.resource;

        if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) return;

        // Store in localStorage
        submitted.push(resourceId);
        localStorage.setItem('de_downloads', JSON.stringify(submitted));

        // Hide form, show download link
        f.classList.add('hidden');
        document.getElementById(`link-${resourceId}`)?.classList.remove('hidden');
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initDownloadForms);
</script>
