---
interface NavItem {
  href: string;
  label: string;
  icon: string;
  match?: string; // pathname prefix that marks this item active
}

const navItems: NavItem[] = [
  { href: '/admin',           label: 'Dashboard',   icon: 'dashboard',     match: '/admin' },
  { href: '/admin/homepage',  label: 'Trang Chủ',   icon: 'home',          match: '/admin/homepage' },
  { href: '/admin/ebooks',    label: 'E-books',     icon: 'menu_book',     match: '/admin/ebooks' },
  { href: '/admin/questions', label: 'Câu Hỏi',    icon: 'question_answer', match: '/admin/questions' },
  { href: '/admin/resources', label: 'Resources',   icon: 'folder_shared', match: '/admin/resources' },
];

const settingsItems: NavItem[] = [
  { href: '/admin/settings/support', label: 'Ủng Hộ Tác Giả', icon: 'volunteer_activism', match: '/admin/settings/support' },
  { href: '/', label: 'Về site', icon: 'public' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

function isActive(item: NavItem): boolean {
  if (!item.match) return false;
  // Exact for /admin (Dashboard), prefix-match cho các mục con
  if (item.match === '/admin') return currentPath === '/admin';
  return currentPath === item.match || currentPath.startsWith(item.match + '/');
}
---

<aside class="h-screen w-64 fixed left-0 top-0 bg-surface border-r border-outline-variant/15 flex flex-col p-4 gap-6 z-50">
  <!-- Brand -->
  <a href="/admin" class="flex flex-col gap-1 mb-2 px-1">
    <h1 class="text-2xl font-bold text-primary tracking-tight leading-none">Dental Empire</h1>
    <span class="text-xs text-on-surface-variant/70">Knowledge Hub Admin</span>
  </a>

  <!-- Primary nav -->
  <nav class="flex-1 flex flex-col gap-2 overflow-y-auto scrollbar-hide">
    {navItems.map((item) => {
      const active = isActive(item);
      return (
        <a
          href={item.href}
          class:list={[
            'flex items-center gap-3 p-3 rounded-lg font-medium transition-colors active:scale-95 duration-150',
            active
              ? 'text-primary font-bold border-r-2 border-primary bg-surface-container-high'
              : 'text-on-surface-variant hover:bg-surface-container-high hover:text-on-surface',
          ]}
        >
          <span
            class="material-symbols-outlined"
            style={active ? "font-variation-settings: 'FILL' 1;" : undefined}
          >
            {item.icon}
          </span>
          <span class="text-sm">{item.label}</span>
        </a>
      );
    })}
  </nav>

  <!-- Footer area -->
  <div class="mt-auto flex flex-col gap-2 pt-4 border-t border-outline-variant/15">
    <a
      href="/admin/ebooks/new"
      class="bg-primary-container text-white py-3 px-4 rounded-lg font-bold cyan-glow hover:opacity-90 transition-all flex items-center justify-center gap-2 mb-2"
    >
      <span class="material-symbols-outlined text-[20px]">add</span>
      <span class="text-sm">New Content</span>
    </a>

    {settingsItems.map((item) => {
      const active = isActive(item);
      return (
        <a
          href={item.href}
          class:list={[
            'flex items-center gap-3 p-3 rounded-lg font-medium transition-colors',
            active
              ? 'text-primary bg-surface-container-high'
              : 'text-on-surface-variant hover:bg-surface-container-high hover:text-on-surface',
          ]}
        >
          <span class="material-symbols-outlined">{item.icon}</span>
          <span class="text-sm">{item.label}</span>
        </a>
      );
    })}

    <button
      id="admin-logout"
      type="button"
      class="flex items-center gap-3 p-3 rounded-lg font-medium text-on-surface-variant hover:bg-surface-container-high hover:text-on-surface transition-colors text-left"
    >
      <span class="material-symbols-outlined">logout</span>
      <span class="text-sm">Đăng xuất</span>
    </button>
  </div>
</aside>

<script>
  import { signOut } from '../../lib/auth-client';

  document.getElementById('admin-logout')?.addEventListener('click', async () => {
    await signOut();
    window.location.href = '/login';
  });
</script>
