---
import { adminNav, type AdminNavItem } from '../../data/admin-nav';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

function isActive(item: AdminNavItem): boolean {
  if (!item.match) return false;
  // Exact cho /admin (Dashboard), prefix-match cho các mục con
  if (item.match === '/admin') return currentPath === '/admin';
  return currentPath === item.match || currentPath.startsWith(item.match + '/');
}
---

<aside
  id="admin-sidebar"
  class="admin-sidebar h-screen fixed left-0 top-0 bg-surface border-r border-outline-variant/15 flex flex-col z-50"
  style="width: 16rem;"
>
  <!-- Brand + toggle -->
  <div class="flex items-center gap-2.5 px-4 pt-4 pb-3" id="sidebar-header">
    <a href="/admin" class="flex items-center gap-2.5 hover:opacity-80 transition-opacity flex-shrink-0">
      <img src="/icons/icon-192.png" alt="Dental Empire" class="w-10 h-10 rounded-lg shrink-0" width="40" height="40" />
      <div class="flex flex-col gap-0.5 overflow-hidden">
        <h1 class="text-lg font-bold text-primary tracking-tight leading-none whitespace-nowrap sidebar-section-label">Dental Empire</h1>
        <span class="text-[10px] text-on-surface-variant/70 leading-none whitespace-nowrap sidebar-section-label">Knowledge Hub Admin</span>
      </div>
    </a>
    <button
      id="sidebar-toggle"
      type="button"
      title="Thu gọn / Mở rộng sidebar"
      class="ml-auto p-1.5 rounded-md hover:bg-surface-container-high text-on-surface-variant hover:text-on-surface transition-colors flex-shrink-0"
      aria-label="Thu gọn sidebar"
    >
      <span class="material-symbols-outlined text-lg">chevron_left</span>
    </button>
    <button
      id="sidebar-close"
      type="button"
      title="Đóng menu"
      class="sidebar-mobile-close ml-auto p-1.5 rounded-md hover:bg-surface-container-high text-on-surface-variant hover:text-on-surface transition-colors flex-shrink-0"
      aria-label="Đóng menu"
    >
      <span class="material-symbols-outlined text-lg">close</span>
    </button>
  </div>

  <!-- Sections nav: scrollable list of grouped items -->
  <nav class="flex-1 flex flex-col gap-3 overflow-y-auto scrollbar-hide px-2 sidebar-section" aria-label="Menu quản trị">
    {adminNav.map((section) => (
      <div class="flex flex-col gap-1">
        <div class="sidebar-section-label px-3 pb-1 text-[11px] font-bold tracking-wider text-on-surface-variant/60 uppercase whitespace-nowrap overflow-hidden">
          {section.label}
        </div>
        {section.items.map((item) => {
          const active = isActive(item);
          return (
            <a
              href={item.href}
              aria-current={active ? 'page' : undefined}
              class:list={[
                'flex items-center gap-3 p-3 rounded-lg font-medium transition-colors active:scale-95 duration-150',
                active
                  ? 'text-primary font-bold border-r-2 border-primary bg-surface-container-high'
                  : 'text-on-surface-variant hover:bg-surface-container-high hover:text-on-surface',
              ]}
            >
              <span
                class="material-symbols-outlined"
                style={active ? "font-variation-settings: 'FILL' 1;" : undefined}
              >
                {item.icon}
              </span>
              <span class="text-sm sidebar-section-label whitespace-nowrap overflow-hidden">{item.label}</span>
            </a>
          );
        })}
      </div>
    ))}
  </nav>

  <!-- Footer area: quick-create CTA + logout -->
  <div class="mt-auto flex flex-col gap-2 pt-4 border-t border-outline-variant/15 sidebar-section px-2">
    <a
      href="/admin/ebooks/new"
      class="bg-primary-container text-white py-3 px-4 rounded-lg font-bold cyan-glow hover:opacity-90 transition-all flex items-center justify-center gap-2 mb-2"
    >
      <span class="material-symbols-outlined text-[20px]">add</span>
      <span class="text-sm sidebar-section-label">Tạo nội dung</span>
    </a>

    <button
      id="admin-logout"
      type="button"
      class="flex items-center gap-3 p-3 rounded-lg font-medium text-on-surface-variant hover:bg-surface-container-high hover:text-on-surface transition-colors text-left"
    >
      <span class="material-symbols-outlined">logout</span>
      <span class="text-sm sidebar-section-label">Đăng xuất</span>
    </button>
  </div>
</aside>
<button id="admin-sidebar-backdrop" class="admin-sidebar-backdrop" type="button" aria-label="Đóng menu"></button>

<script>
  import { signOut } from '../../lib/auth-client';

  const sidebar = document.getElementById('admin-sidebar');
  const toggleBtn = document.getElementById('sidebar-toggle');
  const closeBtn = document.getElementById('sidebar-close');
  const backdrop = document.getElementById('admin-sidebar-backdrop');
  const mobileQuery = window.matchMedia('(max-width: 1023px)');
  const isCollapsed = localStorage.getItem('sidebar-collapsed') === 'true';

  function applyCollapsed(collapsed: boolean) {
    if (!sidebar) return;
    sidebar.classList.toggle('collapsed', collapsed);
    document.body.classList.toggle('admin-sidebar-collapsed', collapsed);
    sidebar.style.width = collapsed ? '4rem' : '16rem';
    toggleBtn?.setAttribute('aria-label', collapsed ? 'Mở rộng sidebar' : 'Thu gọn sidebar');
    toggleBtn?.querySelector('span')?.classList.toggle('rotate-180', collapsed);
    document.querySelectorAll('.sidebar-section-label').forEach((el) => {
      (el as HTMLElement).style.display = collapsed ? 'none' : '';
    });
  }

  applyCollapsed(isCollapsed);

  function setMobileMenu(open: boolean) {
    if (!sidebar || !mobileQuery.matches) return;
    sidebar.classList.toggle('is-mobile-open', open);
    backdrop?.classList.toggle('is-visible', open);
    document.body.classList.toggle('admin-mobile-menu-open', open);
  }

  toggleBtn?.addEventListener('click', () => {
    const nowCollapsed = sidebar?.classList.contains('collapsed');
    localStorage.setItem('sidebar-collapsed', String(!nowCollapsed));
    applyCollapsed(!nowCollapsed);
  });

  document.getElementById('admin-menu-toggle')?.addEventListener('click', () => {
    setMobileMenu(!sidebar?.classList.contains('is-mobile-open'));
  });
  closeBtn?.addEventListener('click', () => setMobileMenu(false));
  backdrop?.addEventListener('click', () => setMobileMenu(false));
  document.querySelectorAll('#admin-sidebar nav a').forEach((link) => {
    link.addEventListener('click', () => setMobileMenu(false));
  });
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') setMobileMenu(false);
  });
  mobileQuery.addEventListener('change', () => setMobileMenu(false));

  document.getElementById('admin-logout')?.addEventListener('click', async () => {
    await signOut();
    window.location.href = '/login';
  });
</script>
