---
import { adminNav } from '../../data/admin-nav';

interface Props {
  searchPlaceholder?: string;
}

const { searchPlaceholder = 'Tìm nhanh chức năng quản trị...' } = Astro.props;
const navigationItems = adminNav.flatMap((section) => section.items);
---

<header
  class="admin-topbar fixed top-0 bg-surface-container/90 backdrop-blur-md border-b border-outline-variant/15 shadow-sm flex items-center h-16 px-4 sm:px-6 z-40"
>
  <div class="flex min-w-0 flex-1 items-center gap-2 sm:gap-4">
    <button id="admin-menu-toggle" type="button" class="admin-menu-toggle p-2 -ml-2 rounded-lg text-on-surface-variant hover:bg-surface-container-high hover:text-white transition-colors" aria-label="Mở menu quản trị">
      <span class="material-symbols-outlined">menu</span>
    </button>
    <div class="relative flex min-w-0 flex-1 items-center max-w-xl">
      <span class="material-symbols-outlined absolute left-3 text-on-surface-variant pointer-events-none">search</span>
      <input
        id="admin-command-input"
        type="text"
        placeholder={searchPlaceholder}
        autocomplete="off"
        aria-label="Tìm nhanh chức năng quản trị"
        aria-controls="admin-command-results"
        aria-expanded="false"
        class="bg-surface-container-low border border-outline-variant/30 text-on-surface text-sm rounded-xl pl-10 pr-14 py-2.5 w-full focus:ring-1 focus:ring-primary focus:border-primary outline-none"
      />
      <kbd class="hidden sm:block absolute right-3 rounded border border-outline-variant/30 px-1.5 py-0.5 text-[10px] font-medium text-on-surface-variant/70">Ctrl K</kbd>
      <div id="admin-command-results" class="admin-command-results hidden" role="listbox" aria-label="Kết quả tìm kiếm nhanh">
        {navigationItems.map((item) => (
          <a href={item.href} class="admin-command-item" data-command-item data-search={`${item.label} ${item.href}`} role="option">
            <span class="material-symbols-outlined text-[18px] text-primary">{item.icon}</span>
            <span>{item.label}</span>
          </a>
        ))}
        <p id="admin-command-empty" class="hidden px-3 py-3 text-sm text-on-surface-variant">Không tìm thấy chức năng phù hợp.</p>
      </div>
    </div>
  </div>

  <div class="ml-3 flex items-center gap-2 sm:gap-3">
    <a href="/" class="inline-flex items-center gap-2 rounded-lg px-2.5 py-2 text-on-surface-variant hover:bg-surface-container-high hover:text-primary transition-colors" title="Xem website">
      <span class="material-symbols-outlined text-[20px]">visibility</span>
      <span class="hidden lg:inline text-sm font-semibold">Xem website</span>
    </a>
    <div class="hidden sm:flex w-8 h-8 rounded-full border border-primary/30 bg-surface-container-high items-center justify-center text-primary" aria-label="Quản trị viên">
      <span class="material-symbols-outlined text-[20px]">person</span>
    </div>
  </div>
</header>

<script>
  const commandInput = document.getElementById('admin-command-input') as HTMLInputElement | null;
  const commandResults = document.getElementById('admin-command-results');
  const commandItems = Array.from(document.querySelectorAll<HTMLElement>('[data-command-item]'));
  const commandEmpty = document.getElementById('admin-command-empty');

  function filterCommands() {
    if (!commandInput || !commandResults) return;
    const query = commandInput.value.trim().toLocaleLowerCase('vi');
    let matches = 0;
    commandItems.forEach((item) => {
      const matched = !query || item.dataset.search?.toLocaleLowerCase('vi').includes(query);
      item.classList.toggle('hidden', !matched);
      if (matched) matches += 1;
    });
    commandResults.classList.toggle('hidden', false);
    commandInput.setAttribute('aria-expanded', 'true');
    commandEmpty?.classList.toggle('hidden', matches > 0);
  }

  function closeCommands() {
    commandResults?.classList.add('hidden');
    commandInput?.setAttribute('aria-expanded', 'false');
  }

  commandInput?.addEventListener('focus', filterCommands);
  commandInput?.addEventListener('input', filterCommands);
  commandInput?.addEventListener('keydown', (event) => {
    if (event.key === 'Enter') {
      const firstMatch = commandItems.find((item) => !item.classList.contains('hidden')) as HTMLAnchorElement | undefined;
      if (firstMatch) firstMatch.click();
    }
    if (event.key === 'Escape') {
      commandInput.blur();
      closeCommands();
    }
  });
  document.addEventListener('keydown', (event) => {
    if ((event.ctrlKey || event.metaKey) && event.key.toLocaleLowerCase() === 'k') {
      event.preventDefault();
      commandInput?.focus();
    }
  });
  document.addEventListener('click', (event) => {
    if (!(event.target instanceof Node) || !commandResults?.parentElement?.contains(event.target)) closeCommands();
  });
</script>
