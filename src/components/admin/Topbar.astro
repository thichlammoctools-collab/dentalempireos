---
interface Props {
  searchPlaceholder?: string;
}

const { searchPlaceholder = 'Search resources, users, content...' } = Astro.props;
---

<header
  class="fixed top-0 right-0 w-[calc(100%-256px)] bg-surface-container/80 backdrop-blur-md border-b border-outline-variant/15 shadow-sm flex justify-between items-center h-16 px-6 z-40"
>
  <!-- Search -->
  <div class="flex items-center gap-6">
    <div class="relative flex items-center">
      <span class="material-symbols-outlined absolute left-3 text-on-surface-variant pointer-events-none">search</span>
      <input
        type="text"
        placeholder={searchPlaceholder}
        class="bg-surface-container-low border border-outline-variant/30 text-on-surface text-sm rounded-full pl-10 pr-6 py-2 w-80 focus:ring-1 focus:ring-primary focus:border-primary outline-none"
      />
    </div>
  </div>

  <!-- Actions -->
  <div class="flex items-center gap-6">
    <div class="flex items-center gap-3">
      <a
        href="/"
        class="text-on-surface-variant hover:text-primary transition-opacity active:opacity-80 flex items-center gap-2"
      >
        <span class="material-symbols-outlined">visibility</span>
        <span class="text-sm font-semibold">Preview Site</span>
      </a>
      <button
        id="publish-btn"
        type="button"
        class="bg-primary-container text-white px-6 py-2 rounded-full font-bold cyan-glow hover:opacity-90 active:scale-95 transition-all text-sm flex items-center gap-2"
      >
        <span class="material-symbols-outlined text-[18px] publish-icon">rocket_launch</span>
        <span class="publish-label">Publish Changes</span>
      </button>
    </div>

    <div class="h-6 w-px bg-outline-variant/30"></div>

    <div class="flex items-center gap-4">
      <button type="button" class="text-on-surface-variant hover:text-primary relative" aria-label="Thông báo">
        <span class="material-symbols-outlined">notifications</span>
        <span class="absolute top-0 right-0 w-2 h-2 bg-error rounded-full"></span>
      </button>
      <button type="button" class="text-on-surface-variant hover:text-primary" aria-label="Tài khoản">
        <span class="material-symbols-outlined">settings_power</span>
      </button>
      <div
        class="w-8 h-8 rounded-full border border-primary/30 bg-surface-container-high flex items-center justify-center text-primary"
        aria-label="Admin"
      >
        <span class="material-symbols-outlined text-[20px]">person</span>
      </div>
    </div>
  </div>

  <!-- Toast notification -->
  <div id="publish-toast" class="publish-toast" aria-live="polite"></div>
</header>

<script>
  const btn = document.getElementById('publish-btn');
  const label = btn?.querySelector('.publish-label') as HTMLElement;
  const icon = btn?.querySelector('.publish-icon') as HTMLElement;
  const toast = document.getElementById('publish-toast');

  let publishing = false;

  function showToast(message: string, type: 'success' | 'error' = 'success') {
    if (!toast) return;
    toast.textContent = message;
    toast.className = `publish-toast publish-toast--visible publish-toast--${type}`;
    setTimeout(() => {
      toast.className = 'publish-toast';
    }, 4000);
  }

  async function publish() {
    if (publishing) return;
    publishing = true;

    if (btn) btn.disabled = true;
    if (label) label.textContent = 'Đang xuất bản...';
    if (icon) icon.textContent = 'sync';
    if (icon) icon.style.animation = 'spin 1s linear infinite';

    try {
      const res = await fetch('/api/admin/publish', { method: 'POST' });
      const data = await res.json();

      if (data.ok) {
        showToast(data.message || 'Đã xuất bản thành công!', 'success');
      } else {
        showToast(data.error || 'Xuất bản thất bại.', 'error');
      }
    } catch (err: any) {
      showToast(`Lỗi mạng: ${err.message}`, 'error');
    } finally {
      publishing = false;
      if (btn) btn.disabled = false;
      if (label) label.textContent = 'Publish Changes';
      if (icon) {
        icon.textContent = 'rocket_launch';
        icon.style.animation = '';
      }
    }
  }

  btn?.addEventListener('click', publish);
</script>

<style>
  /* Spinner animation for the publish icon */
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Toast notification */
  .publish-toast {
    position: fixed;
    bottom: 24px;
    right: 24px;
    padding: 14px 24px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 600;
    z-index: 9999;
    opacity: 0;
    transform: translateY(12px);
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s ease;
    max-width: 400px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .publish-toast--visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .publish-toast--success {
    background: rgba(46, 160, 67, 0.9);
    border: 1px solid rgba(46, 160, 67, 0.4);
    color: #fff;
  }

  .publish-toast--error {
    background: rgba(200, 50, 50, 0.9);
    border: 1px solid rgba(200, 50, 50, 0.4);
    color: #fff;
  }

  /* Disable cursor on button while loading */
  button:disabled {
    opacity: 0.7;
    cursor: wait;
  }
</style>
