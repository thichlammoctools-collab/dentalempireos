---
import type { SectionNode } from '../../lib/book-db';
import SectionItem from './SectionItem.astro';

interface Props {
  section: SectionNode;
  selectedId: string;
  depth?: number;
  /** Pre-computed outline number like "1", "1.2", "2.3.1". Pass empty string to hide. */
  number?: string;
}

const { section, selectedId, depth = 0, number = '' } = Astro.props;
const isSelected = section.id === selectedId;
const hasChildren = section.children.length > 0;

// Parse keywords for display
let keywordList: string[] = [];
if (section.keywords) {
  try {
    const trimmed = section.keywords.trim();
    if (trimmed.startsWith('[')) {
      keywordList = JSON.parse(trimmed);
    } else {
      keywordList = trimmed.split(',').map(s => s.trim()).filter(Boolean);
    }
  } catch {
    keywordList = section.keywords.split(',').map(s => s.trim()).filter(Boolean);
  }
}
---

<li
  data-section-item
  data-section-id={section.id}
  data-section-order={section.order}
  data-section-depth={depth}
  data-section-parent-id={section.parent_id ?? ''}
  data-section-keywords={section.keywords ?? '[]'}
  data-section-number={number}
  class:list={[
    'section-nestable relative flex flex-col gap-1 p-2.5 rounded-lg border transition-all duration-200',
    isSelected
      ? 'bg-primary/5 border-primary/30'
      : 'bg-surface-container-low border-outline-variant/30 hover:border-outline-variant hover:bg-surface-container',
  ]}
>
  <div class="flex items-center gap-2">
    <span
      class="section-drag-handle group cursor-grab active:cursor-grabbing text-on-surface-variant/50 hover:text-primary shrink-0 flex items-center justify-center w-7 h-8 rounded-md hover:bg-primary/10 transition-all duration-200"
      title="Kéo để sắp xếp"
      draggable="true"
    >
      <span class="material-symbols-outlined text-[18px] group-hover:scale-110 transition-transform duration-150">drag_indicator</span>
    </span>
    {hasChildren ? (
      <button data-section-toggle class="section-toggle-btn p-0.5 rounded hover:bg-white/5 transition-colors shrink-0" title="Thu gọn / Mở rộng">
        <span class="material-symbols-outlined text-[14px] section-toggle-icon text-on-surface-variant">expand_more</span>
      </button>
    ) : (
      <span class={`material-symbols-outlined text-[16px] ${section.level === 3 ? 'text-on-surface-variant' : 'text-primary'}`}>
        {section.level === 3 ? 'subdirectory_arrow_right' : 'menu_book'}
      </span>
    )}
    {number && (
      <span data-section-number class="inline-flex items-center justify-center min-w-[22px] h-[18px] px-1 text-[10px] font-bold tabular-nums rounded bg-surface-container-high text-primary/80 border border-primary/15 shrink-0 select-none" title={`Đề mục ${number}`}>
        {number}
      </span>
    )}
    <span data-section-title class={`flex-1 truncate text-sm cursor-pointer hover:text-primary/80 transition-colors ${section.level === 3 ? 'text-on-surface-variant' : 'text-white font-semibold'}`} title="Nhấp đôi để sửa tên">
      {section.title}
    </span>
    {hasChildren && (
      <span data-section-count class="text-[10px] text-on-surface-variant/40 tabular-nums select-none">{section.children.length} mục</span>
    )}
    <button data-section-edit class="p-1 rounded text-on-surface-variant hover:text-primary transition-colors" title="Sửa tên">
      <span class="material-symbols-outlined text-[14px]">edit</span>
    </button>
    <button data-section-add-sub class="p-1 rounded text-on-surface-variant hover:text-primary transition-colors" title="Thêm đề mục phụ">
      <span class="material-symbols-outlined text-[14px]">playlist_add</span>
    </button>
    <button data-section-delete class="p-1 rounded text-on-surface-variant hover:text-error transition-colors" title="Xoá">
      <span class="material-symbols-outlined text-[14px]">delete</span>
    </button>
    <button data-section-keywords class:list={[
      'p-1 rounded transition-colors',
      keywordList.length > 0
        ? 'text-primary hover:text-primary/80'
        : 'text-on-surface-variant hover:text-primary'
    ]} title={keywordList.length > 0 ? `Keywords: ${keywordList.join(', ')}` : 'Thêm keywords'}>
      <span class="material-symbols-outlined text-[14px]">sell</span>
    </button>
  </div>

  {keywordList.length > 0 && (
    <div class="flex flex-wrap gap-1 mt-0.5 pl-9">
      {keywordList.map(kw => (
        <span class="inline-flex items-center px-1.5 py-0.5 text-[9px] font-medium rounded bg-primary/10 text-primary border border-primary/20">{kw}</span>
      ))}
    </div>
  )}

  {hasChildren && (
    <ul data-section-list class="flex flex-col gap-2 pl-6 mt-1.5 border-l border-outline-variant/20">
      {section.children.map((child) => (
        <SectionItem section={child} selectedId={selectedId} depth={depth + 1} />
      ))}
    </ul>
  )}
</li>
