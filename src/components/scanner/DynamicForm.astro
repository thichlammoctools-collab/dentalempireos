---
// DynamicForm: Generic multi-step form that renders any survey_definition from DB.
// Pass surveyData (JSON-serializable) as a prop — generated by the parent page.
//
// Replaces SurveyForm.astro. Differences:
//   - No hardcoded question data — reads everything from the prop
//   - All question types (textarea/select/radio/yesno) supported
//   - Translations (VI/EN) come from the definition
//   - localStorage draft persistence keyed by survey id
//   - Submits JSON body to /api/scanner/submit

interface Props {
  surveyData: {
    id: string;
    slug: string;
    title_vi: string;
    title_en: string;
    description_vi: string | null;
    description_en: string | null;
    lead_fields: Record<string, any>;
    translations_vi: Record<string, string>;
    translations_en: Record<string, string>;
    sections: Array<{
      id: number;
      title_vi: string;
      title_en: string;
      subtitle_vi: string | null;
      subtitle_en: string | null;
      ref: string | null;
      questions: Array<{
        id: number;
        question_id: string;
        type: 'textarea' | 'select' | 'radio' | 'yesno';
        label_vi: string;
        label_en: string;
        placeholder_vi: string | null;
        placeholder_en: string | null;
        options_vi: string[] | null;
        options_en: string[] | null;
        scale_labels_vi: Record<string, string> | null;
        scale_labels_en: Record<string, string> | null;
        required: number;
        anchor: number;
      }>;
    }>;
  };
}

const { surveyData } = Astro.props;

const defaultScaleVi: Record<string, string> = {
  '1': 'Chưa có',
  '2': 'Đang bắt đầu',
  '3': 'Đã có nhưng chưa ổn định',
  '4': 'Ổn định',
  '5': 'Đầu tàu và nhất quán',
};

const defaultScaleEn: Record<string, string> = {
  '1': 'Not yet',
  '2': 'Starting',
  '3': 'Inconsistent',
  '4': 'Stable',
  '5': 'Exemplary',
};
---

<div id="survey-form" class="survey-wrap" data-default-lang="vi" data-survey-id={surveyData.id} data-survey-slug={surveyData.slug}>
  <!-- Language toggle -->
  <div class="lang-toggle">
    <button type="button" class="lang-btn active" data-lang="vi">Tiếng Việt</button>
    <button type="button" class="lang-btn" data-lang="en">English</button>
  </div>

  <!-- Stepper -->
  <div class="stepper">
    <div class="stepper-fill" id="stepper-fill"></div>
  </div>
  <div class="step-labels" id="step-labels"></div>

  <!-- Intro card -->
  <div class="card intro-card" id="card-intro">
    <h1 class="form-title" id="intro-title">{surveyData.title_vi}</h1>
    <p class="form-desc" id="intro-desc">{surveyData.description_vi ?? ''}</p>

    <div class="form-section">
      <h2 class="section-title" id="intro-info-title">Thông tin cơ bản</h2>
      <div id="intro-fields"></div>
    </div>

    <div class="nav-buttons">
      <div></div>
      <button type="button" class="btn btn-primary" id="btn-start">Bắt đầu →</button>
    </div>
  </div>

  <!-- Question cards -->
  <div id="parts-container"></div>

  <!-- Submit card -->
  <div class="card submit-card hidden" id="card-submit">
    <h2 class="section-title" id="submit-title">Sẵn sàng gửi?</h2>
    <p class="form-desc" id="submit-desc">Hệ thống sẽ lưu hồ sơ và bắt đầu phân tích...</p>

    <div class="nav-buttons">
      <button type="button" class="btn btn-ghost" id="btn-back-submit">← Quay lại</button>
      <button type="button" class="btn btn-primary" id="btn-submit">
        <span id="submit-btn-label">Gửi</span>
      </button>
    </div>

    <p id="submit-error" class="error-text hidden"></p>
  </div>
</div>

<script define:vars={{ surveyData, defaultScaleVi, defaultScaleEn }}>
  // NOTE: define:vars passes data as JS literals — no TypeScript allowed here
  const STORAGE_KEY = `dentalempire-scanner-draft-${surveyData.id}`;

  const wrap = document.getElementById('survey-form');
  const partsContainer = document.getElementById('parts-container');
  const stepperFill = document.getElementById('stepper-fill');
  const stepLabels = document.getElementById('step-labels');
  const cardIntro = document.getElementById('card-intro');
  const cardSubmit = document.getElementById('card-submit');
  const btnStart = document.getElementById('btn-start');
  const btnSubmit = document.getElementById('btn-submit');
  const btnBackSubmit = document.getElementById('btn-back-submit');
  const submitError = document.getElementById('submit-error');

  let currentLang = 'vi';
  let currentStep = -1;
  const answers = { lang: 'vi', survey_id: surveyData.id };
  const partEls = [];

  function t(vi, en) {
    return currentLang === 'vi' ? (vi ?? en ?? '') : (en ?? vi ?? '');
  }

  function getTrans(key, fallbackVi, fallbackEn) {
    const t = currentLang === 'vi'
      ? (surveyData.translations_vi?.[key] ?? fallbackVi)
      : (surveyData.translations_en?.[key] ?? fallbackEn);
    return t;
  }

  // ── Lead fields rendering ────────────────────────
  function buildIntroFields() {
    const container = document.getElementById('intro-fields');
    container.innerHTML = '';
    const lead = surveyData.lead_fields ?? {};
    const order = ['owner_name', 'clinic_name', 'clinic_address', 'email', 'years_in_operation', 'staff_count'];

    for (const fieldName of order) {
      const cfg = lead[fieldName];
      if (!cfg) continue;
      const label = t(cfg.label_vi, cfg.label_en);
      const placeholder = t(cfg.placeholder_vi, cfg.placeholder_en);
      const type = cfg.type ?? (fieldName === 'email' ? 'email' : fieldName.includes('_operation') || fieldName.includes('_count') ? 'number' : 'text');
      const required = cfg.required ?? false;

      const div = document.createElement('div');
      div.className = 'form-row';
      div.innerHTML = `
        <div class="form-col">
          <label class="form-label">${escapeHtml(label)}${required ? ' <span class="req">*</span>' : ''}</label>
          <input
            type="${type}"
            name="${fieldName}"
            class="form-input"
            ${required ? 'required' : ''}
            placeholder="${escapeHtml(placeholder ? placeholder : '')}"
            ${type === 'number' ? 'min="0" max="500"' : ''}
          />
        </div>
      `;
      container.appendChild(div);
    }
  }

  // ── Draft persistence ────────────────────────────
  function saveDraft() {
    try {
      const data = { lang: currentLang, step: currentStep, answers };
      localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
    } catch {}
  }

  function loadDraft() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return false;
      const data = JSON.parse(raw);
      if (!data || typeof data !== 'object') return false;
      Object.assign(answers, data.answers ?? {});
      currentLang = (data.lang === 'en' ? 'en' : 'vi');
      currentStep = typeof data.step === 'number' ? data.step : -1;
      return true;
    } catch {
      return false;
    }
  }

  function clearDraft() {
    try { localStorage.removeItem(STORAGE_KEY); } catch {}
  }

  // ── Build part cards ─────────────────────────────
  function buildParts() {
    partsContainer.innerHTML = '';
    partEls.length = 0;

    surveyData.sections.forEach((section, idx) => {
      const card = document.createElement('div');
      card.className = 'card part-card hidden';
      card.dataset.step = String(idx);
      card.dataset.sectionId = String(section.id);

      const ref = section.ref
        ? `<div class="part-ref">${escapeHtml(t(section.ref, section.ref))}</div>`
        : '';

      card.innerHTML = `
        <div class="part-header">
          ${ref}
          <h2 class="part-title">${escapeHtml(t(section.title_vi, section.title_en))}</h2>
          <p class="part-subtitle">${escapeHtml(t(section.subtitle_vi, section.subtitle_en))}</p>
        </div>
      `;

      section.questions.forEach((q) => {
        const block = document.createElement('div');
        block.className = 'question' + (q.anchor ? ' anchor' : '');
        const anchorBadge = q.anchor
          ? `<span class="anchor-badge">⭐ ${currentLang === 'vi' ? 'Câu neo' : 'Anchor'}</span>`
          : '';

        let inputHtml = '';
        if (q.type === 'textarea') {
          inputHtml = `<textarea class="form-textarea" name="${q.question_id}" placeholder="${escapeHtml(t(q.placeholder_vi, q.placeholder_en) ?? '')}" ${q.required ? 'required' : ''}></textarea>`;
        } else if (q.type === 'select') {
          const labels = q.scale_labels_vi ?? defaultScaleVi;
          const enLabels = q.scale_labels_en ?? defaultScaleEn;
          const pills = [1, 2, 3, 4, 5].map((n) => {
            const labelText = currentLang === 'en'
              ? (enLabels[String(n)] ?? labels[String(n)] ?? '')
              : (labels[String(n)] ?? enLabels[String(n)] ?? '');
            return `
              <label class="scale-option">
                <input type="radio" name="${q.question_id}" value="${n}" ${q.required ? 'required' : ''} />
                <span class="scale-pill">
                  <span class="scale-num">${n}</span>
                  <span class="scale-text">${escapeHtml(labelText)}</span>
                </span>
              </label>
            `;
          }).join('');
          inputHtml = `<div class="scale-group">${pills}</div>`;
        } else if (q.type === 'radio') {
          const opts = q.options_vi ?? [];
          const enOpts = q.options_en ?? [];
          const options = opts.map((opt, i) => {
            const enOpt = enOpts[i] ?? opt;
            const display = currentLang === 'en' ? enOpt : opt;
            return `
              <label class="radio-option">
                <input type="radio" name="${q.question_id}" value="${escapeHtml(opt)}" ${q.required ? 'required' : ''} />
                <span class="radio-label">${escapeHtml(display)}</span>
              </label>
            `;
          }).join('');
          inputHtml = `<div class="radio-group">${options}</div>`;
        } else if (q.type === 'yesno') {
          const yesLabel = currentLang === 'vi' ? 'Có' : 'Yes';
          const noLabel = currentLang === 'vi' ? 'Chưa' : 'No';
          inputHtml = `
            <div class="radio-group">
              <label class="radio-option">
                <input type="radio" name="${q.question_id}" value="1" ${q.required ? 'required' : ''} />
                <span class="radio-label">${escapeHtml(yesLabel)}</span>
              </label>
              <label class="radio-option">
                <input type="radio" name="${q.question_id}" value="0" ${q.required ? 'required' : ''} />
                <span class="radio-label">${escapeHtml(noLabel)}</span>
              </label>
            </div>
          `;
        }

        block.innerHTML = `
          ${anchorBadge}
          <label class="q-label">${escapeHtml(t(q.label_vi, q.label_en))}</label>
          ${inputHtml}
        `;
        card.appendChild(block);
      });

      // Nav buttons
      const nav = document.createElement('div');
      nav.className = 'nav-buttons';
      nav.innerHTML = `
        <button type="button" class="btn btn-ghost" data-action="prev">← ${currentLang === 'vi' ? 'Quay lại' : 'Back'}</button>
        <button type="button" class="btn btn-primary" data-action="next">${currentLang === 'vi' ? 'Tiếp tục' : 'Next'} →</button>
      `;
      card.appendChild(nav);

      nav.querySelector('[data-action="prev"]')?.addEventListener('click', () => goTo(currentStep - 1));
      nav.querySelector('[data-action="next"]')?.addEventListener('click', () => goTo(currentStep + 1));

      card.addEventListener('change', (e) => { saveFromEvent(e); saveDraft(); });
      card.addEventListener('input', (e) => { saveFromEvent(e); saveDraft(); });

      partsContainer.appendChild(card);
      partEls.push(card);
    });

    applyAnswersToDom();
  }

  function saveFromEvent(e) {
    const target = e.target;
    if (!target.name) return;
    if (target.type === 'radio') {
      answers[target.name] = target.value;
    } else {
      answers[target.name] = target.value;
    }
  }

  function applyAnswersToDom() {
    document.querySelectorAll('input, textarea').forEach((el) => {
      if (!el.name) return;
      const val = answers[el.name];
      if (val == null || val === '') return;
      if (el.type === 'radio') {
        if (el.checked !== undefined && el.value === String(val)) el.checked = true;
      } else {
        el.value = String(val);
      }
    });
  }

  // ── Step labels ─────────────────────────────────
  function buildStepLabels() {
    const labels = surveyData.sections.map((section, idx) => {
      const title = t(section.title_vi, section.title_en);
      const num = title.match(/^\s*(?:PHẦN|PART)\s*(\d+)/i);
      const n = num ? num[1] : String(idx + 1);
      return `<span data-step-idx="${idx}">${n}</span>`;
    });
    labels.push(`<span data-step-idx="${surveyData.sections.length}">${currentLang === 'vi' ? 'Gửi' : 'Submit'}</span>`);
    stepLabels.innerHTML = labels.join('');
  }

  // ── Navigation ──────────────────────────────────
  function goTo(step) {
    if (step < -1 || step > surveyData.sections.length) return;

    // Validate intro required fields when leaving intro
    if (currentStep === -1 && step >= 0) {
      const lead = surveyData.lead_fields ?? {};
      for (const [fieldName, cfg] of Object.entries(lead)) {
        if (cfg && cfg.required) {
          const el = document.querySelector(`[name="${fieldName}"]`);
          if (!el?.value?.trim()) {
            alert(currentLang === 'vi' ? 'Vui lòng điền đầy đủ thông tin bắt buộc.' : 'Please fill all required fields.');
            return;
          }
        }
      }
      // Save intro fields
      ['owner_name', 'clinic_name', 'clinic_address', 'email', 'years_in_operation', 'staff_count'].forEach((k) => {
        const el = document.querySelector(`[name="${k}"]`);
        if (el) answers[k] = el.value || null;
      });
    }

    currentStep = step;
    cardIntro.classList.toggle('hidden', step !== -1);
    cardSubmit.classList.toggle('hidden', step !== surveyData.sections.length);
    partEls.forEach((el, i) => el.classList.toggle('hidden', i !== step));

    // Stepper
    const total = surveyData.sections.length + 1;
    const progress = step < 0 ? 0 : step >= surveyData.sections.length ? 100 : Math.round((step / surveyData.sections.length) * 100);
    stepperFill.style.width = `${progress}%`;

    stepLabels.querySelectorAll('span').forEach((s) => {
      const idx = parseInt(s.dataset.stepIdx ?? '-1', 10);
      s.classList.toggle('active', idx === step);
    });

    window.scrollTo({ top: 0, behavior: 'smooth' });
    saveDraft();
  }

  // ── Submit ──────────────────────────────────────
  async function submit() {
    submitError.classList.add('hidden');
    btnSubmit.disabled = true;
    const original = btnSubmit.innerHTML;
    btnSubmit.innerHTML = `<span>${getTrans('submitting', 'Đang xử lý...', 'Processing...')}</span>`;

    // Final read of all fields
    document.querySelectorAll('input, textarea').forEach((el) => {
      if (el.name && (el.type === 'text' || el.type === 'email' || el.type === 'number' || el.tagName === 'TEXTAREA')) {
        if (el.value) answers[el.name] = el.value;
      }
    });
    answers.lang = currentLang;

    try {
      const res = await fetch('/api/scanner/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(answers),
      });
      const data = await res.json();
      if (!res.ok) {
        throw new Error(data.error || 'Submit failed');
      }
      clearDraft();
      window.location.href = data.redirect || `/scanner/result/${surveyData.id}`;
    } catch (err) {
      const msg = err instanceof Error ? err.message : 'Submit failed';
      submitError.textContent = msg;
      submitError.classList.remove('hidden');
      btnSubmit.disabled = false;
      btnSubmit.innerHTML = original;
    }
  }

  // ── Language switching ──────────────────────────
  function setLang(lang, skipNav) {
    currentLang = lang;
    answers.lang = lang;

    document.querySelectorAll('.lang-btn').forEach((b) => {
      b.classList.toggle('active', b.dataset.lang === lang);
    });

    // Update intro
    buildIntroFields();
    (document.getElementById('intro-title')).textContent = t(surveyData.title_vi, surveyData.title_en);
    (document.getElementById('intro-desc') ).textContent = t(surveyData.description_vi, surveyData.description_en) || '';
    (document.getElementById('intro-info-title') ).textContent =
      currentLang === 'vi' ? 'Thông tin cơ bản' : 'Basic Information';
    (document.getElementById('submit-title') ).textContent =
      getTrans('submit_title', 'Sẵn sàng gửi?', 'Ready to submit?');
    (document.getElementById('submit-desc') ).textContent =
      getTrans('submit_desc', 'Hệ thống sẽ lưu hồ sơ và bắt đầu phân tích...', 'We will save your profile and begin the AI analysis...');
    (document.getElementById('submit-btn-label') ).textContent =
      getTrans('submitButton', 'Gửi Hồ Sơ', 'Submit Profile');
    btnStart.textContent = getTrans('start', 'Bắt đầu →', 'Start →');
    btnBackSubmit.textContent = getTrans('back', '← Quay lại', '← Back');

    buildParts();
    buildStepLabels();
    if (!skipNav) goTo(currentStep);
  }

  function escapeHtml(s) {
    return s.replace(/[&<>"']/g, (c) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
    }[c] ?? c));
  }

  // ── Init ────────────────────────────────────────
  const hasDraft = loadDraft();
  setLang(currentLang, true);

  document.querySelectorAll('.lang-btn').forEach((b) => {
    b.addEventListener('click', () => { setLang(b.dataset.lang); saveDraft(); });
  });
  btnStart.addEventListener('click', () => goTo(0));
  btnSubmit.addEventListener('click', () => submit());
  btnBackSubmit.addEventListener('click', () => goTo(surveyData.sections.length - 1));

  // Populate intro from draft
  buildIntroFields();
  document.querySelectorAll('.intro-card input[name]').forEach((el) => {
    const v = answers[el.name];
    if (v != null && v !== '') el.value = String(v);
  });

  if (hasDraft && typeof currentStep === 'number' && currentStep >= 0 && currentStep < surveyData.sections.length) {
    goTo(currentStep);

    const banner = document.createElement('div');
    banner.id = 'restore-banner';
    banner.innerHTML = `
      <div style="background:rgba(59,130,246,0.15); border:1px solid rgba(59,130,246,0.3); border-radius:0.5rem; padding:0.75rem 1rem; margin-bottom:1rem; display:flex; justify-content:space-between; align-items:center; gap:0.5rem; flex-wrap:wrap;">
        <span style="color:var(--on-surface); font-size:0.85rem;">
          ${currentLang === 'vi' ? '📋 Bạn có bản nháp chưa hoàn thành.' : '📋 You have an unfinished draft.'}
        </span>
        <button type="button" id="clear-draft-btn" style="background:transparent; border:1px solid var(--outline-variant); color:var(--on-surface-variant); border-radius:0.375rem; padding:0.3rem 0.75rem; font-size:0.8rem; cursor:pointer; white-space:nowrap;">
          ${currentLang === 'vi' ? 'Xoá & bắt đầu lại' : 'Clear & start over'}
        </button>
      </div>
    `;
    wrap.insertBefore(banner, wrap.children[1]);
    document.getElementById('clear-draft-btn')?.addEventListener('click', () => {
      clearDraft();
      window.location.reload();
    });
  } else {
    currentStep = -1;
    goTo(-1);
  }
</script>

<style>
  .survey-wrap {
    max-width: 760px;
    margin: 0 auto;
    padding: 1rem 0 4rem;
  }

  /* Lang toggle */
  .lang-toggle {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: 1.5rem;
  }
  .lang-btn {
    background: var(--surface-container);
    color: var(--on-surface-variant);
    border: 1px solid var(--outline-variant);
    border-radius: 999px;
    padding: 0.45rem 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }
  .lang-btn.active {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
  }

  /* Stepper */
  .stepper {
    height: 4px;
    background: var(--surface-container);
    border-radius: 999px;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }
  .stepper-fill {
    height: 100%;
    background: linear-gradient(90deg, #3b82f6, #f59e0b);
    width: 0%;
    transition: width 0.4s ease;
  }
  .step-labels {
    display: flex;
    justify-content: space-between;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 0.25rem;
  }
  .step-labels span {
    font-size: 0.7rem;
    color: var(--on-surface-variant);
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 0.25rem;
    transition: all 0.2s;
  }
  .step-labels span.active {
    background: rgba(59, 130, 246, 0.15);
    color: #3b82f6;
  }

  /* Cards */
  .card {
    background: var(--surface);
    border: 1px solid var(--outline-variant);
    border-radius: 1rem;
    padding: 1.75rem;
    margin-bottom: 1.25rem;
  }

  .form-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--on-surface);
    margin: 0 0 0.5rem;
  }
  .form-desc {
    color: var(--on-surface-variant);
    line-height: 1.6;
    margin: 0 0 1.5rem;
    font-size: 0.95rem;
  }

  .form-section { margin-top: 1rem; }
  .section-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--on-surface);
    margin: 0 0 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .form-col-full { grid-column: 1 / -1; }
  .form-col { display: flex; flex-direction: column; }
  .form-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--on-surface-variant);
    margin-bottom: 0.4rem;
  }
  .req { color: #ef4444; }

  .form-input,
  .form-textarea {
    width: 100%;
    background: var(--surface-container);
    border: 1px solid var(--outline-variant);
    border-radius: 0.6rem;
    padding: 0.7rem 0.9rem;
    color: var(--on-surface);
    font-size: 0.95rem;
    font-family: inherit;
    transition: border-color 0.2s;
  }
  .form-input:focus,
  .form-textarea:focus {
    outline: none;
    border-color: var(--primary);
  }
  .form-textarea {
    min-height: 100px;
    resize: vertical;
    line-height: 1.5;
  }

  /* Part header */
  .part-header { margin-bottom: 1.5rem; }
  .part-ref {
    font-size: 0.75rem;
    font-weight: 600;
    color: #f59e0b;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.4rem;
  }
  .part-title {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--on-surface);
    margin: 0 0 0.4rem;
  }
  .part-subtitle {
    color: var(--on-surface-variant);
    line-height: 1.5;
    margin: 0;
    font-size: 0.95rem;
  }

  /* Questions */
  .question {
    margin-bottom: 1.5rem;
    padding: 1rem;
    border-radius: 0.75rem;
    border: 1px solid transparent;
