---
interface Props {
  type?: 'info' | 'tip' | 'warning' | 'danger';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const icons = {
  info: 'M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z',
  tip: 'M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18',
  warning: 'M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z',
  danger: 'M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z',
};

const colors = {
  info: 'bg-blue-50 border-blue-200 dark:bg-blue-900/20 dark:border-blue-800',
  tip: 'bg-emerald-50 border-emerald-200 dark:bg-emerald-900/20 dark:border-emerald-800',
  warning: 'bg-amber-50 border-amber-200 dark:bg-amber-900/20 dark:border-amber-800',
  danger: 'bg-red-50 border-red-200 dark:bg-red-900/20 dark:border-red-800',
};

const iconColors = {
  info: 'text-blue-500 dark:text-blue-400',
  tip: 'text-emerald-500 dark:text-emerald-400',
  warning: 'text-amber-500 dark:text-amber-400',
  danger: 'text-red-500 dark:text-red-400',
};

const defaultTitles = {
  info: 'Thông tin',
  tip: 'Mẹo hay',
  warning: 'Cảnh báo',
  danger: 'Lưu ý quan trọng',
};
---

<div class:list={['rounded-xl border p-4 my-6', colors[type]]}>
  <div class="flex items-start gap-3">
    <svg class:list={['h-5 w-5 mt-0.5 shrink-0', iconColors[type]]} fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d={icons[type]} />
    </svg>
    <div class="flex-1 min-w-0">
      {title && (
        <p class:list={['font-semibold text-sm mb-1', iconColors[type]]}>
          {title || defaultTitles[type]}
        </p>
      )}
      <div class="text-sm text-navy-700 dark:text-navy-200 leading-relaxed">
        <slot />
      </div>
    </div>
  </div>
</div>
