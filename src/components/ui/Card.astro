---
interface Props {
  title: string;
  description?: string;
  href?: string;
  class?: string;
}

const { title, description, href, class: className = '' } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={[
    'group block bg-white dark:bg-navy-800 rounded-2xl p-6 border border-navy-100 dark:border-navy-700',
    'shadow-sm hover:shadow-xl transition-all duration-300',
    href && 'hover:-translate-y-1',
    className,
  ]}
>
  {Astro.slots.has('image') && (
    <div class="mb-4 overflow-hidden rounded-xl">
      <slot name="image" />
    </div>
  )}

  {Astro.slots.has('badge') && (
    <div class="mb-3">
      <slot name="badge" />
    </div>
  )}

  <h3 class="text-lg font-bold text-navy-900 dark:text-white mb-2 group-hover:text-accent-500 transition-colors">
    {title}
  </h3>

  {description && (
    <p class="text-sm text-navy-600 dark:text-navy-300 leading-relaxed">
      {description}
    </p>
  )}

  {Astro.slots.has('default') && (
    <div class="mt-4">
      <slot />
    </div>
  )}
</Tag>
