---
/**
 * AccessGate — Server-side content gating component.
 * Checks if user has active access to a product before showing premium content.
 *
 * Usage:
 *   <AccessGate productId="course-premium" user={locals.user}>
 *     <p>Premium content here...</p>
 *   </AccessGate>
 *
 * If user is not logged in → shows login prompt.
 * If user has no access → shows purchase prompt.
 * If user has access → renders the slotted content.
 */

import { env } from 'cloudflare:workers';
import { checkUserAccess } from '../lib/access-check';

interface Props {
  productId: string;
  user?: import('better-auth').User | null;
  /** Optional: custom "buy" URL instead of generic payment button */
  buyUrl?: string;
}

const { productId, user, buyUrl } = Astro.props;

let hasAccess = false;

if (user) {
  try {
    hasAccess = await checkUserAccess(env.DB, user.id, productId);
  } catch {
    // Fail open — if DB check fails, don't block content
    hasAccess = false;
  }
}
---

{hasAccess ? (
  <slot />
) : user ? (
  <div class="relative">
    <div class="blur-sm pointer-events-none select-none">
      <slot />
    </div>
    <div class="absolute inset-0 flex items-center justify-center bg-surface/80 backdrop-blur-sm rounded-xl">
      <div class="text-center p-6">
        <svg class="w-10 h-10 text-primary mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
        <p class="text-white font-bold text-sm mb-3">Nội dung Premium</p>
        <p class="text-on-surface-variant text-xs mb-4">Mua để mở khóa nội dung này</p>
        {buyUrl ? (
          <a href={buyUrl} class="inline-block px-5 py-2 btn-primary-metallic font-bold rounded-lg text-xs">
            Xem chi tiết & Mua
          </a>
        ) : (
          <button
            data-gate-product={productId}
            class="gate-buy-btn px-5 py-2 btn-primary-metallic font-bold rounded-lg text-xs"
          >
            Mua ngay
          </button>
        )}
      </div>
    </div>
  </div>
) : (
  <div class="relative">
    <div class="blur-sm pointer-events-none select-none">
      <slot />
    </div>
    <div class="absolute inset-0 flex items-center justify-center bg-surface/80 backdrop-blur-sm rounded-xl">
      <div class="text-center p-6">
        <svg class="w-10 h-10 text-primary mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
        <p class="text-white font-bold text-sm mb-3">Đăng nhập để xem</p>
        <p class="text-on-surface-variant text-xs mb-4">Nội dung này dành cho thành viên đã mua</p>
        <a href={`/login?redirect=${encodeURIComponent(Astro.url.pathname)}`} class="inline-block px-5 py-2 btn-primary-metallic font-bold rounded-lg text-xs">
          Đăng nhập
        </a>
      </div>
    </div>
  </div>
)}

<script>
  // Handle "Mua ngay" buttons inside AccessGate overlays
  document.querySelectorAll('.gate-buy-btn').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const productId = target.dataset.gateProduct;
      if (!productId) return;

      target.textContent = 'Đang xử lý...';
      target.disabled = true;

      try {
        const resp = await fetch('/api/payos/create-payment', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ product_id: productId }),
        });

        const data = await resp.json() as Record<string, unknown>;
        if (data.checkoutUrl) {
          window.location.href = data.checkoutUrl as string;
        } else {
          alert((data.error as string) || 'Lỗi tạo thanh toán');
          target.textContent = 'Mua ngay';
          target.disabled = false;
        }
      } catch {
        alert('Lỗi kết nối');
        target.textContent = 'Mua ngay';
        target.disabled = false;
      }
    });
  });
</script>
