---
interface Props {
  postSlug?: string;
  postTitle?: string;
}
const { postSlug = '', postTitle = '' } = Astro.props;
const popupId = 'newsletter-popup';
const utmParams = `utm_source=blog&utm_medium=popup&utm_campaign=ebook${postSlug ? `&utm_content=${postSlug}` : ''}`;
---

<!-- Newsletter Popup -->
<div
  id={popupId}
  class="fixed inset-0 z-[200] hidden"
  role="dialog"
  aria-modal="true"
  aria-labelledby="popup-title"
>
  <!-- Backdrop -->
  <div
    id={`${popupId}-backdrop`}
    class="absolute inset-0 bg-black/60 backdrop-blur-sm"
  ></div>

  <!-- Modal (desktop) / Bottom sheet (mobile) -->
  <div class="absolute inset-x-0 bottom-0 sm:inset-0 sm:flex sm:items-center sm:justify-center sm:p-6">

    <!-- Card -->
    <div
      id={`${popupId}-card`}
      class="relative w-full sm:max-w-md mx-auto sm:mx-0 bg-[#0f172a] border border-primary/20 rounded-t-3xl sm:rounded-2xl p-6 sm:p-8 shadow-2xl shadow-black/50"
      style="animation: popup-slide-up 0.4s cubic-bezier(0.34,1.56,0.64,1) forwards;"
    >
      <!-- Close button -->
      <button
        type="button"
        id={`${popupId}-close`}
        class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-full bg-surface-container text-on-surface-variant hover:bg-surface-container-high hover:text-white transition-colors"
        aria-label="Đóng"
      >
        <span class="material-symbols-outlined text-[18px]">close</span>
      </button>

      <!-- Icon -->
      <div class="w-12 h-12 rounded-2xl bg-primary/10 border border-primary/20 flex items-center justify-center mb-4">
        <span class="material-symbols-outlined text-2xl text-primary">mail</span>
      </div>

      <!-- Title -->
      <h2 id="popup-title" class="text-xl font-bold text-white mb-2 leading-tight">
        Nhận ebook miễn phí
      </h2>
      <p class="text-sm text-on-surface-variant mb-5 leading-relaxed">
        Đăng ký email để nhận ngay <strong class="text-white">Dental Empire OS</strong> — bộ sưu tập 32 chương đầy đủ về quản trị phòng khám nha khoa.
      </p>

      <!-- Form -->
      <form
        id={`${popupId}-form`}
        class="space-y-3"
        data-post-slug={postSlug}
        data-post-title={postTitle}
      >
        <input
          type="email"
          name="email"
          placeholder="Email của bạn..."
          required
          autocomplete="email"
          class="w-full px-4 py-3 bg-surface border border-outline-variant rounded-xl text-white text-sm placeholder:text-white/30 focus:ring-2 focus:ring-primary focus:outline-none"
        />
        <button
          type="submit"
          class="w-full py-3 bg-primary text-white rounded-xl text-sm font-bold hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-2"
        >
          <span class="material-symbols-outlined text-[18px]">send</span>
          Nhận ebook ngay
        </button>
      </form>

      <!-- Success state (hidden by default) -->
      <div id={`${popupId}-success`} class="hidden text-center py-4">
        <div class="w-14 h-14 rounded-full bg-green-500/10 border border-green-500/20 flex items-center justify-center mx-auto mb-3">
          <span class="material-symbols-outlined text-3xl text-green-400">check_circle</span>
        </div>
        <p class="text-base font-bold text-white mb-1">Đăng ký thành công!</p>
        <p class="text-sm text-on-surface-variant">Vui lòng kiểm tra email để nhận ebook.</p>
      </div>

      <!-- Footer note -->
      <p class="text-[11px] text-center text-on-surface-variant/50 mt-4">
        Không spam · Hủy đăng ký bất cứ lúc nào
      </p>
    </div>
  </div>
</div>

<style>
  @keyframes popup-slide-up {
    from { transform: translateY(100%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
</style>

<script define:vars={{ popupId }}>
  (function () {
    const STORAGE_KEY = 'popup_seen' + (typeof window !== 'undefined' && window.location.pathname ? window.location.pathname.replace(/\//g, '_') : '');

    const backdrop = document.getElementById(popupId + '-backdrop');
    const closeBtn = document.getElementById(popupId + '-close');
    const popup = document.getElementById(popupId);
    const card = document.getElementById(popupId + '-card');
    const form = document.getElementById(popupId + '-form');
    const successEl = document.getElementById(popupId + '-success');

    if (!popup || !form || !closeBtn || !backdrop) return;

    function showPopup() {
      popup.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      // Focus email input
      setTimeout(() => {
        const emailInput = form.querySelector('input[type="email"]');
        if (emailInput) emailInput.focus();
      }, 100);
    }

    function hidePopup() {
      popup.classList.add('hidden');
      document.body.style.overflow = '';
    }

    // Close on backdrop click
    backdrop.addEventListener('click', hidePopup);

    // Close on button
    closeBtn.addEventListener('click', hidePopup);

    // Close on ESC
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !popup.classList.contains('hidden')) {
        hidePopup();
      }
    });

    // Trigger: scroll 60% or idle 20s
    let triggered = false;
    function trigger() {
      if (triggered) return;
      if (localStorage.getItem(STORAGE_KEY)) return;
      triggered = true;
      showPopup();
      localStorage.setItem(STORAGE_KEY, '1');
    }

    // Scroll-based trigger
    function onScroll() {
      if (triggered) return;
      const scrolled = window.scrollY + window.innerHeight;
      const total = document.documentElement.scrollHeight;
      if (scrolled / total >= 0.60) {
        trigger();
        window.removeEventListener('scroll', onScroll);
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });

    // Idle fallback
    setTimeout(() => {
      if (!triggered) trigger();
    }, 20000);

    // Form submit
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const emailInput = form.querySelector('input[type="email"]');
      if (!emailInput) return;
      const email = emailInput.value;
      const postSlug = form.dataset.postSlug || '';
      const postTitle = form.dataset.postTitle || '';

      const submitBtn = form.querySelector('button[type="submit"]');
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="material-symbols-outlined text-[18px] animate-spin">progress_activity</span> Đang gửi...';
      }

      try {
        const res = await fetch('/api/newsletter', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, post_slug: postSlug }),
        });
        const data = await res.json();
        if (data.success) {
          form.classList.add('hidden');
          if (successEl) successEl.classList.remove('hidden');
          setTimeout(hidePopup, 2500);
        } else {
          alert(data.error || 'Có lỗi xảy ra. Vui lòng thử lại.');
        }
      } catch {
        alert('Có lỗi xảy ra. Vui lòng thử lại.');
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.innerHTML = '<span class="material-symbols-outlined text-[18px]">send</span> Nhận ebook ngay';
        }
      }
    });
  })();
</script>
