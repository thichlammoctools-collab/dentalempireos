---
interface Props {
  chapterId: string;
  chapterTitle?: string;
}

const { chapterId, chapterTitle = '' } = Astro.props;
---

<!-- Mobile: Bottom sheet only (desktop uses ReviewDrawer's question tab) -->
<div
  id="question-drawer-mobile"
  class="fixed z-[102] rounded-t-3xl overflow-hidden flex-col shadow-2xl hidden"
  style="
    background: var(--reader-chrome-bg);
    left: 0; right: 0; bottom: 0;
    width: 100%; max-width: 100%;
    max-height: min(95vh, calc(100dvh - 20px));
    transform-origin: bottom center;
    transform: translateY(100%);
    opacity: 0; pointer-events: none;
    padding-bottom: env(safe-area-inset-bottom, 0px);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
  "
>
  <!-- Handle -->
  <div class="flex justify-center pt-3 pb-1 cursor-pointer select-none" id="question-handle">
    <div class="w-10 h-1 rounded-full" style="background: var(--reader-border);"></div>
  </div>

  <!-- Header -->
  <div class="flex items-center justify-between px-5 py-3 shrink-0" style="border-bottom: 1px solid var(--reader-border);">
    <div class="flex items-center gap-2">
      <span class="material-symbols-outlined text-primary text-xl">support_agent</span>
      <div>
        <h3 class="text-sm font-bold" style="color: var(--reader-chrome-text);">Hỏi Tác Giả</h3>
        {chapterTitle && (
          <p class="text-[11px] truncate max-w-[200px]" style="color: var(--reader-chrome-text-muted);">{chapterTitle}</p>
        )}
      </div>
    </div>
    <button id="question-close-mobile" class="w-8 h-8 rounded-full flex items-center justify-center transition-colors hover:bg-surface-container-high" title="Đóng">
      <span class="material-symbols-outlined text-base" style="color: var(--reader-chrome-text-muted);">close</span>
    </button>
  </div>

  <!-- Content -->
  <div class="flex-1 overflow-y-auto px-5 py-4">
    <div id="question-logged-out-mobile" class="hidden text-center py-10">
      <span class="material-symbols-outlined text-5xl block mb-4 opacity-30" style="color: var(--reader-chrome-text-muted);">lock</span>
      <p class="text-xs mb-4" style="color: var(--reader-chrome-text-muted);">Đăng nhập để đặt câu hỏi cho tác giả</p>
      <a href="/login" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-xl bg-primary text-on-primary text-xs font-bold">
        <span class="material-symbols-outlined text-sm">login</span> Đăng nhập
      </a>
    </div>

    <form id="question-form-mobile" class="flex flex-col gap-3">
      <input type="hidden" name="chapter_id" value={chapterId} />
      <div>
        <label class="text-[11px] font-bold uppercase tracking-wider mb-1.5 block" style="color: var(--reader-chrome-text-muted);">Tiêu đề</label>
        <input
          type="text"
          name="title"
          placeholder="Tóm tắt câu hỏi..."
          class="w-full rounded-xl px-3 py-2.5 text-xs outline-none focus:border-primary"
          style="background: var(--reader-chrome-surface); border: 1px solid var(--reader-border); color: var(--reader-chrome-text);"
          required
          maxlength="200"
        />
      </div>
      <div>
        <label class="text-[11px] font-bold uppercase tracking-wider mb-1.5 block" style="color: var(--reader-chrome-text-muted);">Chi tiết</label>
        <textarea
          name="body"
          rows={4}
          placeholder="Mô tả chi tiết câu hỏi..."
          class="w-full rounded-xl px-3 py-2.5 text-xs outline-none focus:border-primary resize-y"
          style="background: var(--reader-chrome-surface); border: 1px solid var(--reader-border); color: var(--reader-chrome-text);"
          required
        ></textarea>
      </div>
      <button
        type="submit"
        id="question-submit-mobile"
        class="w-full py-2.5 rounded-xl bg-primary text-on-primary font-bold text-xs flex items-center justify-center gap-2 hover:opacity-90 transition-opacity"
      >
        <span class="material-symbols-outlined text-base">send</span>
        Gửi câu hỏi
      </button>
      <p class="text-[10px] text-center" style="color: var(--reader-chrome-text-muted);">Tác giả sẽ nhận thông báo và trả lời sớm nhất có thể.</p>
    </form>

    <div id="question-success-mobile" class="hidden text-center py-8">
      <span class="material-symbols-outlined text-primary text-5xl mb-4 block">check_circle</span>
      <p class="text-xs font-bold mb-1" style="color: var(--reader-chrome-text);">Câu hỏi đã được gửi!</p>
      <p class="text-[11px]" style="color: var(--reader-chrome-text-muted);">Tác giả sẽ trả lời trong thời gian sớm nhất.</p>
    </div>
  </div>
</div>

<style>
  @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
</style>

<script>
  (function () {
    const trigger = document.getElementById('question-trigger');
    const mobileDrawer = document.getElementById('question-drawer-mobile');
    const closeBtn = document.getElementById('question-close-mobile');
    const handle = document.getElementById('question-handle');

    let isOpen = false;
    let isMobile = false;

    /* ── Auth check: show mobile trigger ── */
    async function checkAuth() {
      try {
        const res = await fetch('/api/notifications/unread-count', { credentials: 'include' });
        trigger?.classList.toggle('hidden', !res.ok);
      } catch { trigger?.classList.remove('hidden'); }
    }
    checkAuth();

    /* ── Open / Close (mobile only) ── */
    function open() {
      if (!mobileDrawer) return;
      isOpen = true;
      mobileDrawer.classList.remove('hidden');
      requestAnimationFrame(() => {
        mobileDrawer.style.opacity = '1';
        mobileDrawer.style.pointerEvents = 'auto';
        mobileDrawer.style.transform = 'translateY(0)';
      });
    }

    function close() {
      if (!mobileDrawer) return;
      isOpen = false;
      mobileDrawer.style.opacity = '0';
      mobileDrawer.style.pointerEvents = 'none';
      mobileDrawer.style.transform = 'translateY(100%)';
      setTimeout(() => mobileDrawer.classList.add('hidden'), 350);
    }

    trigger?.addEventListener('click', () => isOpen ? close() : open());
    closeBtn?.addEventListener('click', close);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && isOpen) close(); });

    /* ── Submit ── */
    const form = document.getElementById('question-form-mobile') as HTMLFormElement;
    const submitBtn = document.getElementById('question-submit-mobile') as HTMLButtonElement;
    const successEl = document.getElementById('question-success-mobile');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const title = (formData.get('title') as string)?.trim();
      const body = (formData.get('body') as string)?.trim();
      const chapterId = formData.get('chapter_id') as string;
      if (!title || !body) return;

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="material-symbols-outlined text-base" style="animation:spin 1s linear infinite">progress_activity</span> Đang gửi...';
      }

      try {
        const res = await fetch('/api/questions', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'include',
          body: JSON.stringify({ chapter_id: chapterId, title, body }),
        });
        if (!res.ok) {
          if (res.status === 401) { window.location.href = '/login'; return; }
          alert('Có lỗi xảy ra, vui lòng thử lại.');
          if (submitBtn) { submitBtn.disabled = false; submitBtn.innerHTML = '<span class="material-symbols-outlined text-base">send</span> Gửi câu hỏi'; }
          return;
        }
        form.classList.add('hidden'); successEl?.classList.remove('hidden');
        setTimeout(() => {
          form.reset(); form.classList.remove('hidden'); successEl?.classList.add('hidden');
          if (submitBtn) { submitBtn.disabled = false; submitBtn.innerHTML = '<span class="material-symbols-outlined text-base">send</span> Gửi câu hỏi'; }
        }, 2500);
      } catch {
        alert('Lỗi kết nối. Vui lòng thử lại.');
        if (submitBtn) { submitBtn.disabled = false; submitBtn.innerHTML = '<span class="material-symbols-outlined text-base">send</span> Gửi câu hỏi'; }
      }
    });

    /* ── Touch drag to dismiss ── */
    let startY = 0, deltaY = 0, dragging = false;
    handle?.addEventListener('touchstart', (e: Event) => {
      startY = (e as TouchEvent).touches[0].clientY; dragging = true;
      if (mobileDrawer) mobileDrawer.style.transition = 'none';
    }, { passive: true });
    document.addEventListener('touchmove', (e: Event) => {
      if (!dragging) return;
      deltaY = (e as TouchEvent).touches[0].clientY - startY;
      if (deltaY > 0 && mobileDrawer) mobileDrawer.style.transform = `translateY(${deltaY}px)`;
    }, { passive: true });
    document.addEventListener('touchend', () => {
      if (!dragging) return; dragging = false;
      if (mobileDrawer) mobileDrawer.style.transition = '';
      if (deltaY > 80) close();
      else if (mobileDrawer) mobileDrawer.style.transform = isOpen ? 'translateY(0)' : 'translateY(100%)';
      deltaY = 0;
    });

    window.addEventListener('resize', () => { if (isOpen) close(); });
  })();
</script>
