---
interface Props {
  chapterId: string;
  chapterTitle?: string;
}

const { chapterId, chapterTitle = '' } = Astro.props;
---

<!-- Desktop FAB: REMOVED — use toolbar #toolbar-ask-btn instead to avoid duplicates -->

<!-- Overlay -->
<div
  id="question-overlay"
  class="question-overlay fixed inset-0 z-[90] bg-black/50 backdrop-blur-sm hidden transition-opacity duration-300"
  aria-hidden="true"
></div>

<!-- Floating card: same markup for both desktop & mobile, only size differs -->
<div
  id="question-drawer"
  class="fixed rounded-2xl overflow-hidden flex flex-col shadow-2xl"
  style="
    background: var(--reader-chrome-bg);

    /* Desktop: slide-in from right (like ReviewDrawer) */
    right: 0; top: 0; bottom: 0; left: auto;
    width: 420px; max-width: 90vw;
    max-height: 100vh; transform-origin: right center;
    transform: translateX(100%);
    transition: transform 0.3s ease;
  "
>
  <!-- Handle (mobile visual cue) -->
  <div class="flex justify-center pt-3 pb-1 cursor-pointer select-none lg:hidden" id="question-handle">
    <div class="w-10 h-1 rounded-full" style="background: var(--reader-border);"></div>
  </div>

  <!-- Header -->
  <div class="flex items-center justify-between px-5 py-4 shrink-0" style="border-bottom: 1px solid rgba(255,255,255,0.06);">
    <div class="flex items-center gap-2">
      <span class="material-symbols-outlined text-primary text-xl">support_agent</span>
      <div>
        <h3 class="text-sm font-bold" style="color: var(--reader-chrome-text);">Hỏi Tác Giả</h3>
        {chapterTitle && (
          <p class="text-[11px] truncate max-w-[220px]" style="color: var(--reader-chrome-text-muted);">{chapterTitle}</p>
        )}
      </div>
    </div>
    <button id="question-close" class="w-8 h-8 rounded-full flex items-center justify-center transition-colors hover:bg-surface-container-high" title="Đóng">
      <span class="material-symbols-outlined text-base" style="color: var(--reader-chrome-text-muted);">close</span>
    </button>
  </div>

  <!-- Content -->
  <div class="flex-1 overflow-y-auto px-5 py-4">
    <div id="question-logged-out" class="hidden text-center py-10">
      <span class="material-symbols-outlined text-5xl block mb-4 opacity-30" style="color: var(--reader-chrome-text-muted);">lock</span>
      <p class="text-xs mb-4" style="color: var(--reader-chrome-text-muted);">Đăng nhập để đặt câu hỏi cho tác giả</p>
      <a href="/login" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-xl bg-primary text-on-primary text-xs font-bold">
        <span class="material-symbols-outlined text-sm">login</span> Đăng nhập
      </a>
    </div>

    <form id="question-form" class="flex flex-col gap-3">
      <input type="hidden" name="chapter_id" value={chapterId} />
      <div>
        <label class="text-[11px] font-bold uppercase tracking-wider mb-1.5 block" style="color: var(--reader-chrome-text-muted);">Tiêu đề</label>
        <input
          type="text"
          name="title"
          placeholder="Tóm tắt câu hỏi..."
          class="w-full r-surface border rounded-xl px-3 py-2.5 text-xs outline-none focus:border-primary" style="border-color: var(--reader-border);"
          style="color: var(--reader-chrome-text);"
          required
          maxlength="200"
        />
      </div>
      <div>
        <label class="text-[11px] font-bold uppercase tracking-wider mb-1.5 block" style="color: var(--reader-chrome-text-muted);">Chi tiết</label>
        <textarea
          name="body"
          rows={4}
          placeholder="Mô tả chi tiết câu hỏi..."
          class="w-full bg-surface-container border border-outline-variant/30 rounded-xl px-3 py-2.5 text-xs outline-none focus:border-primary resize-y"
          style="color: var(--reader-chrome-text);"
          required
        ></textarea>
      </div>
      <button
        type="submit"
        id="question-submit"
        class="w-full py-2.5 rounded-xl bg-primary text-on-primary font-bold text-xs flex items-center justify-center gap-2 hover:opacity-90 transition-opacity"
      >
        <span class="material-symbols-outlined text-base">send</span>
        Gửi câu hỏi
      </button>
      <p class="text-[10px] text-center" style="color: var(--reader-chrome-text-muted);">Tác giả sẽ nhận thông báo và trả lời sớm nhất có thể.</p>
    </form>

    <div id="question-success" class="hidden text-center py-8">
      <span class="material-symbols-outlined text-primary text-5xl mb-4 block">check_circle</span>
      <p class="text-xs font-bold mb-1" style="color: var(--reader-chrome-text);">Câu hỏi đã được gửi!</p>
      <p class="text-[11px]" style="color: var(--reader-chrome-text-muted);">Tác giả sẽ trả lời trong thời gian sớm nhất.</p>
    </div>
  </div>
</div>

<style>
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* ── Mobile: bottom-sheet pattern (matches SectionNavMobile) ── */
  @media (max-width: 1023px) {
    #question-drawer {
      left: 0; right: 0; bottom: 0; top: auto;
      width: 100%; max-width: 100%;
      max-height: min(85dvh, calc(100dvh - 80px));
      max-height: min(85vh, calc(100vh - 80px));
      margin: 0;
      border-radius: 1.5rem 1.5rem 0 0;
      transform: translateY(100%);
      transform-origin: bottom center;
      padding-bottom: env(safe-area-inset-bottom, 16px);
      transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
      z-index: 95;
    }

    #question-drawer.question-open {
      transform: translateY(0) !important;
    }

    #question-drawer .overflow-y-auto {
      padding-bottom: max(env(safe-area-inset-bottom, 16px), 120px);
    }
  }

  /* ── Desktop: slide-in from right ── */
  @media (min-width: 1024px) {
    #question-drawer {
      border-radius: 0;
      border-left: 1px solid var(--reader-border);
      z-index: 102;
    }
  }
</style>
<script>
  (function () {
    const trigger = document.getElementById('question-trigger');
    const overlay = document.getElementById('question-overlay');
    const drawer = document.getElementById('question-drawer');
    const closeBtn = document.getElementById('question-close');
    const handle = document.getElementById('question-handle');
    const toolbarBtn = document.getElementById('toolbar-ask-btn');

    let isOpen = false;

    /* ── Auth check: show triggers if logged in ── */
    async function checkAuth() {
      try {
        const res = await fetch('/api/notifications/unread-count', { credentials: 'include' });
        if (res.ok) {
          // Mobile: show the question-trigger FAB in SectionNavMobile
          trigger?.classList.remove('hidden');
          // Desktop: show toolbar button
          toolbarBtn?.classList.remove('hidden');
        }
      } catch { /* not logged in — keep hidden */ }
    }
    checkAuth();

    /* ── Mobile keyboard handling ── */
    const isMobile = () => window.innerWidth < 1024;

    function applyMobileKeyboardOffset() {
      if (!isMobile() || !drawer || !isOpen) return;
      const vv = window.visualViewport;
      if (vv) {
        // When keyboard opens, adjust the drawer height and ensure content is visible
        const keyboardHeight = window.innerHeight - vv.height - vv.offsetTop;
        const content = drawer.querySelector('.overflow-y-auto') as HTMLElement;
        
        if (keyboardHeight > 50) {
          // Keyboard is open - reduce max-height and ensure form is visible
          const newMaxHeight = Math.max(40, (vv.height / window.innerHeight) * 100);
          drawer.style.maxHeight = `${newMaxHeight}dvh`;
          
          // Scroll to ensure input is visible
          setTimeout(() => {
            const activeElement = document.activeElement as HTMLElement;
            if (activeElement && (activeElement.tagName === 'INPUT' || activeElement.tagName === 'TEXTAREA')) {
              activeElement.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
          }, 100);
        } else {
          // Keyboard closed - reset max-height
          drawer.style.maxHeight = '';
        }
      }
    }

    if (window.visualViewport) {
      window.visualViewport.addEventListener('resize', applyMobileKeyboardOffset);
      window.visualViewport.addEventListener('scroll', applyMobileKeyboardOffset);
    }

    /* ── Focus handling for mobile inputs ── */
    if (isMobile()) {
      const inputs = drawer?.querySelectorAll('input, textarea');
      inputs?.forEach((input) => {
        input.addEventListener('focus', () => {
          // Small delay to let keyboard open
          setTimeout(() => {
            applyMobileKeyboardOffset();
            input.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }, 300);
        });
      });
    }

    /* ── Open / Close ── */
    function open() {
      isOpen = true;

      if (isMobile()) {
        // Close other mobile sheets first (mutual exclusion)
        (window as any).__closeSectionNav?.();
        (window as any).__closeReview?.();

        overlay?.classList.remove('hidden');
        drawer?.classList.add('question-open');
        applyMobileKeyboardOffset();
      } else {
        overlay?.classList.remove('hidden');
        if (drawer) drawer.style.transform = 'translateX(0)';
      }

      // Focus first input
      setTimeout(() => {
        const input = drawer?.querySelector('input[name="title"]') as HTMLInputElement;
        input?.focus();
      }, 350);
    }

    function close() {
      isOpen = false;

      if (isMobile()) {
        drawer?.classList.remove('question-open');
        overlay?.classList.add('hidden');
      } else {
        overlay?.classList.add('hidden');
        if (drawer) drawer.style.transform = 'translateX(100%)';
      }
    }

    /* ── Event bindings ── */
    // NOTE: Mobile #question-trigger click is handled by SectionNavMobile.astro
    // (it calls window.__openQuestionDrawer). Do NOT add a click listener on
    // trigger here — it would double-toggle (open then immediately close).
    toolbarBtn?.addEventListener('click', () => { isOpen ? close() : open(); });
    overlay?.addEventListener('click', close);
    closeBtn?.addEventListener('click', close);

    // Expose globally for mutual exclusion with SectionNavMobile / ReviewDrawer
    (window as any).__openQuestionDrawer = open;
    (window as any).__closeQuestionDrawer = close;

    // Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) close();
    });

    /* ── Submit ── */
    const form = document.getElementById('question-form') as HTMLFormElement;
    const submitBtn = document.getElementById('question-submit') as HTMLButtonElement;
    const successEl = document.getElementById('question-success');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const title = (formData.get('title') as string)?.trim();
      const body = (formData.get('body') as string)?.trim();
      const chapterId = formData.get('chapter_id') as string;
      if (!title || !body) return;

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="material-symbols-outlined text-base" style="animation:spin 1s linear infinite">progress_activity</span> Đang gửi...';
      }

      try {
        const res = await fetch('/api/questions', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ chapter_id: chapterId, title, body }),
        });

        if (!res.ok) {
          alert('Có lỗi xảy ra, vui lòng thử lại.');
          if (submitBtn) { submitBtn.disabled = false; submitBtn.innerHTML = '<span class="material-symbols-outlined text-base">send</span> Gửi câu hỏi'; }
          return;
        }

        form.classList.add('hidden');
        successEl?.classList.remove('hidden');
        setTimeout(() => {
          form.reset();
          form.classList.remove('hidden');
          successEl?.classList.add('hidden');
          if (submitBtn) { submitBtn.disabled = false; submitBtn.innerHTML = '<span class="material-symbols-outlined text-base">send</span> Gửi câu hỏi'; }
        }, 2500);
      } catch {
        alert('Lỗi kết nối. Vui lòng thử lại.');
        if (submitBtn) { submitBtn.disabled = false; submitBtn.innerHTML = '<span class="material-symbols-outlined text-base">send</span> Gửi câu hỏi'; }
      }
    });

    /* ── Mobile: touch drag to dismiss ── */
    let startY = 0;
    let deltaY = 0;
    let dragging = false;

    handle?.addEventListener('touchstart', (e: Event) => {
      startY = (e as TouchEvent).touches[0].clientY;
      dragging = true;
      if (drawer) drawer.style.transition = 'none';
    }, { passive: true });

    document.addEventListener('touchmove', (e: Event) => {
      if (!dragging || !isMobile()) return;
      deltaY = (e as TouchEvent).touches[0].clientY - startY;
      if (deltaY > 0 && drawer) drawer.style.transform = `translateY(${deltaY}px)`;
    }, { passive: true });

    document.addEventListener('touchend', () => {
      if (!dragging) return;
      dragging = false;
      if (drawer) drawer.style.transition = '';
      if (deltaY > 80) close();
      else if (drawer) drawer.style.transform = isOpen ? 'translateY(0)' : 'translateY(100%)';
      deltaY = 0;
    });

    // Resize: close on breakpoint change
    window.addEventListener('resize', () => {
      if (isOpen) close();
    });
  })();
</script>
