---
// Mobile-only floating trigger + bottom-sheet drawer for section/chapter navigation
// Rendered OUTSIDE #reader-app to avoid overflow:hidden clipping

interface SectionItem {
  title: string;
  slug: string;
  level: number;
}

interface ChapterNavItem {
  id: string;
  data: { title: string; tier: number; chapter: number };
}

interface TierGroup {
  tier: number;
  label: string;
  chapters: ChapterNavItem[];
}

interface ReviewStats {
  avgRating: number;
  totalReviews: number;
}

interface AttachmentItem {
  id: string;
  type: 'image' | 'file';
  title: string;
  url: string;
  caption?: string;
  filename?: string;
  mime?: string | null;
  mimeLabel?: string;
  sectionSlug: string;
  sectionTitle: string;
  ext?: string;
  previewable: boolean;
}

interface Props {
  sections: SectionItem[];
  groupedChapters?: TierGroup[];
  currentSlug?: string;
  reviewStats?: ReviewStats;
  attachments?: AttachmentItem[];
  chapterId?: string;
  chapterTitle?: string;
}

const {
  sections,
  groupedChapters = [],
  currentSlug = '',
  reviewStats = { avgRating: 0, totalReviews: 0 },
  attachments = [],
  chapterId = '',
  chapterTitle = '',
} = Astro.props;
const h2Count = sections.filter((s) => s.level === 2).length;
const attachmentCount = attachments.length;

let h2Idx = 0;
const numberedSections = sections.map((section) => {
  const isH3 = section.level === 3;
  const num = isH3 ? '' : String(++h2Idx).padStart(2, '0');
  return { ...section, isH3, num };
});

const currentChapterTitle = groupedChapters
  .flatMap((g) => g.chapters)
  .find((c) => c.id === currentSlug)?.data.title ?? '';
---

<!-- Floating trigger buttons (right side, above bottom bar) -->
<div class="fixed right-4 bottom-[calc(9rem+env(safe-area-inset-bottom,0px))] z-[55] pointer-events-none flex flex-col gap-2 lg:bottom-[calc(6rem+env(safe-area-inset-bottom,0px))]">
  <!-- Section nav: mobile only (desktop has sidebar) -->
  <button
    id="section-nav-trigger"
    class="pointer-events-auto flex items-center gap-1.5 px-3 py-2.5 rounded-full shadow-lg transition-all active:scale-95 lg:hidden"
    style="background: var(--color-surface-container-high); border: 1px solid var(--color-outline-variant); color: var(--color-on-surface); backdrop-filter: blur(12px);"
    aria-label="Mở mục lục"
  >
    <span class="material-symbols-outlined text-base">format_list_numbered</span>
    <span class="text-[11px] font-bold">Đề mục</span>
    <span class="text-[9px] text-on-surface-variant font-semibold">{sections.length}</span>
  </button>
  <!-- Review: always visible -->
  <button
    id="review-trigger"
    class="pointer-events-auto flex items-center gap-1.5 px-3 py-2.5 rounded-full shadow-lg transition-all active:scale-95"
    style="background: var(--color-surface-container-high); border: 1px solid var(--color-outline-variant); backdrop-filter: blur(12px);"
    aria-label="Mở đánh giá"
  >
    <span class="material-symbols-outlined text-base" style="color: var(--color-primary);">reviews</span>
    <span class="text-[11px] font-bold" style="color: var(--color-on-surface);">Đánh giá</span>
    {reviewStats.totalReviews > 0 && (
      <span class="text-[9px] font-bold px-1 py-0.5 rounded-full" style="background: var(--color-primary); color: white;">{reviewStats.totalReviews}</span>
    )}
  </button>
  <!-- Question: always visible -->
  <button
    id="question-trigger"
    class="pointer-events-auto flex items-center gap-1.5 px-3 py-2.5 rounded-full shadow-lg transition-all active:scale-95"
    style="background: var(--color-surface-container-high); border: 1px solid var(--color-outline-variant); backdrop-filter: blur(12px);"
    aria-label="Hỏi tác giả"
  >
    <span class="material-symbols-outlined text-base" style="color: var(--color-primary);">support_agent</span>
    <span class="text-[11px] font-bold" style="color: var(--color-on-surface);">Hỏi</span>
  </button>
</div>

<!-- Overlay -->
<div
  id="section-nav-overlay"
  class="fixed inset-0 z-[90] bg-black/50 backdrop-blur-sm hidden transition-opacity"
  aria-hidden="true"
></div>

<!-- Unified Drawer -->
<div
  id="section-nav-sheet"
  class="section-nav-sheet fixed inset-x-0 bottom-0 z-[95] rounded-t-3xl overflow-hidden flex flex-col shadow-2xl"
  style="background: var(--color-surface-container-low); max-height: 85vh;"
>
  <!-- Handle -->
  <div class="flex justify-center pt-3 pb-2 cursor-pointer select-none" id="section-nav-handle">
    <div class="w-10 h-1 rounded-full" style="background: var(--color-outline-variant);"></div>
  </div>

  <!-- Header -->
  <div class="px-5 pb-3 flex items-center justify-between" style="border-bottom: 1px solid rgba(255,255,255,0.06);">
    <div>
      <h3 class="text-sm font-bold flex items-center gap-2" style="color: var(--color-on-surface);">
        <span class="material-symbols-outlined text-primary text-base">format_list_numbered</span>
        Đề mục
      </h3>
      <p class="text-[10px] mt-0.5" style="color: var(--color-on-surface-variant);">{currentChapterTitle}</p>
    </div>
    <div class="flex items-center gap-2">
      <div class="w-20 h-1 rounded-full overflow-hidden" style="background: var(--color-surface-container-high);">
        <div id="section-nav-progress-mobile" class="h-full rounded-full" style="width: 0%; background: var(--color-tertiary); transition: width 0.3s;"></div>
      </div>
      <button id="section-nav-close" class="w-8 h-8 rounded-full flex items-center justify-center transition-colors" style="background: var(--color-surface-container-high);">
        <span class="material-symbols-outlined text-base" style="color: var(--color-on-surface-variant);">close</span>
      </button>
    </div>
  </div>

  <!-- Tab switcher: Đề mục / Chương -->
  <div class="flex px-4 pt-3 gap-1" id="section-nav-tabs">
    <button class="section-nav-tab flex-1 py-2 rounded-xl text-xs font-bold transition-all" data-tab="sections" style="background: rgba(146,204,255,0.1); color: var(--color-primary); border: 1px solid rgba(146,204,255,0.3);">
      <span class="material-symbols-outlined text-sm align-middle mr-1">format_list_numbered</span>
      Đề mục ({sections.length})
    </button>
    <button class="section-nav-tab flex-1 py-2 rounded-xl text-xs font-bold transition-all" data-tab="chapters" style="background: var(--color-surface-container-high); color: var(--color-on-surface-variant);">
      <span class="material-symbols-outlined text-sm align-middle mr-1">menu_book</span>
      Chương ({groupedChapters.flatMap((g) => g.chapters).length})
    </button>
    <button class="section-nav-tab flex-1 py-2 rounded-xl text-xs font-bold transition-all" data-tab="attachments" style="background: var(--color-surface-container-high); color: var(--color-on-surface-variant);">
      <span class="material-symbols-outlined text-sm align-middle mr-1">attachment</span>
      Đính kèm ({attachmentCount})
    </button>
  </div>

  <!-- Scrollable content: Section headings -->
  <nav class="flex-1 overflow-y-auto px-3 py-3 section-nav-panel" id="section-nav-panel-sections" data-panel="sections">
    {numberedSections.map((section) => (
      <a
        href={`#${section.slug}`}
        class:list={[
          'flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-all border-l-[3px]',
          section.isH3 ? 'pl-8 border-transparent' : 'border-transparent',
        ]}
        style="color: var(--color-on-surface-variant);"
        data-mobile-section-link={section.slug}
      >
        {!section.isH3 ? (
          <span class="text-[11px] font-bold w-6 shrink-0" style="color: var(--color-on-surface-variant);">{section.num}</span>
        ) : (
          <span class="w-1.5 h-1.5 rounded-full shrink-0" style="background: var(--color-on-surface-variant); opacity: 0.4;"></span>
        )}
        <span class="truncate text-xs font-medium">{section.title}</span>
      </a>
    ))}
    {sections.length === 0 && (
      <div class="py-8 text-center">
        <span class="material-symbols-outlined text-3xl block mb-2 opacity-30" style="color: var(--color-on-surface-variant);">article</span>
        <p class="text-xs" style="color: var(--color-on-surface-variant);">Chưa có đề mục</p>
      </div>
    )}
  </nav>

  <!-- Scrollable content: Chapter navigation -->
  <nav class="flex-1 overflow-y-auto px-3 py-3 space-y-1 section-nav-panel hidden" id="section-nav-panel-chapters" data-panel="chapters">
    {groupedChapters.map((group) => {
      const hasCurrent = group.chapters.some((ch) => ch.id === currentSlug);
      return (
        <div class="mobile-toc-group" data-tier={group.tier} data-current-tier={hasCurrent ? 'true' : 'false'}>
          <button
            class="mobile-toc-group-header flex items-center gap-2 px-3 py-2 w-full rounded-xl text-left transition-all border border-transparent"
            style="background: var(--color-surface-container-high);"
            data-mobile-toc-toggle
          >
            <span class="material-symbols-outlined text-primary text-[16px] mobile-toc-group-icon transition-transform duration-200">folder_open</span>
            <span class="text-xs font-bold flex-1 truncate" style="color: var(--color-on-surface-variant);">{group.label}</span>
            <span class="text-[10px] px-1.5 py-0.5 rounded" style="background: var(--color-surface-container-low); color: var(--color-on-surface-variant);">{group.chapters.length}</span>
            <span class="material-symbols-outlined text-[16px] transition-transform duration-200" style="color: var(--color-on-surface-variant);">expand_more</span>
          </button>
          <div class="mobile-toc-group-chapters overflow-hidden transition-all duration-300">
            {group.chapters.map((ch) => {
              const isCurrent = ch.id === currentSlug;
              return (
                <a
                  href={`/book/${ch.id}`}
                  class:list={[
                    'flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-all border-l-[3px]',
                    isCurrent ? 'border-primary' : 'border-transparent',
                  ]}
                  style={isCurrent
                    ? 'background: rgba(146,204,255,0.1); color: var(--color-primary); box-shadow: inset 0 0 0 1px rgba(146,204,255,0.15);'
                    : 'color: var(--color-on-surface-variant);'}
                  data-section-nav-chapter-link
                >
                  <span class="text-[10px] font-bold w-7 shrink-0" style="color: var(--color-on-surface-variant);">Ch{String(ch.data.chapter).padStart(2, '0')}</span>
                  <span class="truncate text-xs font-medium">{ch.data.title}</span>
                  {isCurrent && (
                    <span class="material-symbols-outlined text-primary text-base ml-auto shrink-0">play_arrow</span>
                  )}
                </a>
              );
            })}
          </div>
        </div>
      );
    })}
  </nav>

  <nav class="flex-1 overflow-y-auto px-3 py-3 section-nav-panel hidden" id="section-nav-panel-attachments" data-panel="attachments">
    {attachmentCount > 0 ? (
      attachments.map((item) => (
        <a
          href={`#attachment-${item.id}`}
          class="flex items-center justify-between gap-3 rounded-2xl border border-white/[0.06] bg-surface-container-high px-3 py-3 text-sm transition-all hover:border-primary/40 hover:bg-primary/5"
          data-mobile-attachment-link
        >
          <div class="min-w-0">
            <p class="text-sm font-semibold text-white truncate">{item.title}</p>
            <p class="text-[11px] text-on-surface-variant truncate">{item.sectionTitle}</p>
          </div>
          <span class="inline-flex h-6 items-center rounded-full bg-surface-container-low px-2 text-[10px] font-semibold text-on-surface-variant">{item.type === 'image' ? 'Hình' : item.ext ?? 'Tệp'}</span>
        </a>
      ))
    ) : (
      <div class="py-8 text-center">
        <span class="material-symbols-outlined text-3xl block mb-2 opacity-30" style="color: var(--color-on-surface-variant);">attachment</span>
        <p class="text-xs" style="color: var(--color-on-surface-variant);">Chưa có mục đính kèm trong chương này</p>
      </div>
    )}
  </nav>

  <!-- Footer -->
  <div class="px-5 py-3 shrink-0" style="border-top: 1px solid rgba(255,255,255,0.06);">
    <p class="text-[10px] font-semibold" style="color: var(--color-on-surface-variant);">
      {h2Count} mục chính · {sections.length - h2Count} mục con
    </p>
  </div>
</div>

<style>
  /* Mobile sheet: hidden by default, slides up when open */
  .section-nav-sheet {
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .section-nav-sheet.section-nav-open {
    transform: translateY(0) !important;
  }

  /* Active section in mobile drawer */
  [data-mobile-section-link].section-nav-active-mobile {
    border-color: var(--color-primary) !important;
    background: rgba(146, 204, 255, 0.08) !important;
    color: var(--color-primary) !important;
  }

  /* Mobile TOC group collapse */
  .mobile-toc-group[data-collapsed="true"] .mobile-toc-group-chapters {
    max-height: 0 !important;
    opacity: 0;
  }
  .mobile-toc-group[data-collapsed="true"] .mobile-toc-group-header .material-symbols-outlined:last-child {
    transform: rotate(-90deg);
  }
  .mobile-toc-group[data-collapsed="true"] .mobile-toc-group-icon {
    transform: rotate(-15deg);
  }

  /* Focus mode: hide floating triggers */
  body.focus-mode #section-nav-trigger,
  body.focus-mode #review-trigger {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }
  body.focus-mode:hover #section-nav-trigger,
  body.focus-mode:hover #review-trigger {
    opacity: 1;
    pointer-events: auto;
  }

  [data-mobile-section-link],
  [data-section-link] {
    scroll-margin-top: 6rem;
  }
</style>

<style>
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
</style>

<script>
  (function () {
    const READER_OFFSET = 80;

    function initMobileSectionNav() {
      const readerScroll = document.getElementById('reader-scroll');
      if (!readerScroll) return;

      const trigger = document.getElementById('section-nav-trigger');
      const overlay = document.getElementById('section-nav-overlay');
      const sheetEl = document.getElementById('section-nav-sheet');
      const handle = document.getElementById('section-nav-handle');
      const closeBtn = document.getElementById('section-nav-close');
      const mobileLinks = document.querySelectorAll('[data-mobile-section-link]');
      const mobileProgressBar = document.getElementById('section-nav-progress-mobile');

      // Mobile TOC collapsible groups
      const MOBILE_TOC_KEY = 'mobile-toc-collapsed';
      function getMobileCollapsed(): Set<number> {
        try {
          const raw = localStorage.getItem(MOBILE_TOC_KEY);
          if (!raw) return new Set();
          return new Set(JSON.parse(raw) as number[]);
        } catch { return new Set(); }
      }
      function saveMobileCollapsed(set: Set<number>) {
        try { localStorage.setItem(MOBILE_TOC_KEY, JSON.stringify([...set])); } catch {}
      }
      function applyMobileCollapsed() {
        const collapsed = getMobileCollapsed();
        document.querySelectorAll<HTMLElement>('.mobile-toc-group').forEach((g) => {
          const tier = Number(g.dataset.tier);
          const isCollapsed = collapsed.has(tier);
          g.dataset.collapsed = isCollapsed ? 'true' : 'false';
          const header = g.querySelector<HTMLElement>('[data-mobile-toc-toggle]');
          if (header) {
            header.setAttribute('aria-expanded', isCollapsed ? 'false' : 'true');
            const chevron = header.querySelector('.material-symbols-outlined:last-child');
            if (chevron) chevron.style.transform = isCollapsed ? 'rotate(-90deg)' : '';
          }
        });
      }
      function toggleMobileGroup(tier: number) {
        const collapsed = getMobileCollapsed();
        if (collapsed.has(tier)) collapsed.delete(tier);
        else collapsed.add(tier);
        saveMobileCollapsed(collapsed);
        applyMobileCollapsed();
      }
      applyMobileCollapsed();
      document.querySelectorAll<HTMLElement>('[data-mobile-toc-toggle]').forEach((btn) => {
        const group = btn.closest<HTMLElement>('.mobile-toc-group');
        const tier = group ? Number(group.dataset.tier) : NaN;
        btn.addEventListener('click', () => {
          if (!isNaN(tier)) toggleMobileGroup(tier);
        });
      });

      if (!trigger || !sheetEl) return;
      const sheet = sheetEl;

      function getActiveId(): string | null {
        // Read from desktop scroll-spy state or detect manually
        const activeLink = document.querySelector('[data-mobile-section-link].section-nav-active-mobile');
        if (activeLink) return (activeLink as HTMLElement).dataset.mobileSectionLink;

        // Fallback: find the heading closest to current scroll position
        const headings = document.querySelectorAll('.reader-content h2[id], .reader-content h3[id]');
        let bestId: string | null = null;
        let bestDist = Infinity;
        headings.forEach((h) => {
          const rect = h.getBoundingClientRect();
          const dist = Math.abs(rect.top - READER_OFFSET);
          if (dist < bestDist) {
            bestDist = dist;
            bestId = h.id;
          }
        });
        return bestId;
      }

      function openSheet() {
        sheet.classList.add('section-nav-open');
        if (overlay) overlay.classList.remove('hidden');

        // Highlight current section
        const currentId = getActiveId();
        if (currentId) {
          mobileLinks.forEach((link) => {
            const isActive = (link as HTMLElement).dataset.mobileSectionLink === currentId;
            link.classList.toggle('section-nav-active-mobile', isActive);
            // Scroll active link into view
            if (isActive) {
              setTimeout(() => link.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 100);
            }
          });
        }

        syncMobileProgress();
      }

      function closeSheet() {
        sheet.classList.remove('section-nav-open');
        if (overlay) overlay.classList.add('hidden');
      }

      function syncMobileProgress() {
        if (!mobileProgressBar) return;
        const { scrollTop, scrollHeight, clientHeight } = readerScroll;
        const maxScroll = scrollHeight - clientHeight;
        const pct = maxScroll > 0 ? Math.min(100, Math.round((scrollTop / maxScroll) * 100)) : 0;
        mobileProgressBar.style.width = `${pct}%`;
      }

      // Expose globally
      (window as any).__openSectionNav = openSheet;
      (window as any).__closeSectionNav = closeSheet;

      trigger.addEventListener('click', () => {
        sheet.classList.contains('section-nav-open') ? closeSheet() : openSheet();
      });
      overlay?.addEventListener('click', closeSheet);

      // ---- Review trigger ----
      // review-trigger click is handled by ReviewDrawer.astro script directly
      closeBtn?.addEventListener('click', closeSheet);

      // ---- Tab switching ----
      const tabs = document.querySelectorAll<HTMLElement>('.section-nav-tab');
      const panels = document.querySelectorAll<HTMLElement>('.section-nav-panel');

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const target = tab.dataset.tab;
          tabs.forEach((t) => {
            t.style.background = 'var(--color-surface-container-high)';
            t.style.color = 'var(--color-on-surface-variant)';
            t.style.border = 'none';
          });
          tab.style.background = 'rgba(146,204,255,0.1)';
          tab.style.color = 'var(--color-primary)';
          tab.style.border = '1px solid rgba(146,204,255,0.3)';

          panels.forEach((panel) => {
            if (panel.dataset.panel === target) {
              panel.classList.remove('hidden');
            } else {
              panel.classList.add('hidden');
            }
          });
        });
      });

      // Close on mobile section link click + smooth scroll
      mobileLinks.forEach((link) => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const hash = (link as HTMLAnchorElement).getAttribute('href');
          if (hash && hash !== '#') {
            const target = document.getElementById(hash.slice(1));
            if (target) {
              const top = target.getBoundingClientRect().top + readerScroll.scrollTop - READER_OFFSET;
              readerScroll.scrollTo({ top, behavior: 'smooth' });
            }
            history.replaceState(null, '', hash);
          }
          closeSheet();
        });
      });

      // Close on chapter link click
      sheet.querySelectorAll<HTMLElement>('[data-section-nav-chapter-link]').forEach((link) => {
        link.addEventListener('click', () => closeSheet());
      });

      const attachmentLinks = sheet.querySelectorAll<HTMLElement>('[data-mobile-attachment-link]');
      attachmentLinks.forEach((link) => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const hash = (link as HTMLAnchorElement).getAttribute('href');
          if (hash && hash !== '#') {
            const target = document.getElementById(hash.slice(1));
            if (target) {
              const top = target.getBoundingClientRect().top + readerScroll.scrollTop - READER_OFFSET;
              readerScroll.scrollTo({ top, behavior: 'smooth' });
            }
            history.replaceState(null, '', hash);
          }
          closeSheet();
        });
      });

      // Touch drag to close
      let startY = 0;
      let deltaY = 0;
      let dragging = false;

      handle?.addEventListener('touchstart', (e: Event) => {
        startY = (e as TouchEvent).touches[0].clientY;
        dragging = true;
        sheet.style.transition = 'none';
      }, { passive: true });

      document.addEventListener('touchmove', (e: Event) => {
        if (!dragging) return;
        deltaY = (e as TouchEvent).touches[0].clientY - startY;
        if (deltaY > 0) {
          sheet.style.transform = `translateY(${deltaY}px)`;
        }
      }, { passive: true });

      document.addEventListener('touchend', () => {
        if (!dragging) return;
        dragging = false;
        sheet.style.transition = '';
        if (deltaY > 80) {
          closeSheet();
        }
        sheet.style.transform = '';
        deltaY = 0;
      });

      // Keyboard: Escape to close
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && sheet.classList.contains('section-nav-open')) {
          closeSheet();
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initMobileSectionNav);
    } else {
      initMobileSectionNav();
    }
  })();
</script>
