---
// Mobile-only floating trigger + bottom-sheet drawer for section/chapter navigation
// Rendered OUTSIDE #reader-app to avoid overflow:hidden clipping

interface SectionItem {
  title: string;
  slug: string;
  level: number;
  sectionNumber: string;
}

interface ChapterNavItem {
  id: string;
  data: { title: string; tier: number; chapter: number };
}

interface TierGroup {
  tier: number;
  label: string;
  chapters: ChapterNavItem[];
}

interface ReviewStats {
  avgRating: number;
  totalReviews: number;
}

interface AttachmentItem {
  id: string;
  type: 'image' | 'file';
  title: string;
  url: string;
  caption?: string;
  filename?: string;
  mime?: string | null;
  mimeLabel?: string;
  sectionSlug: string;
  sectionTitle: string;
  ext?: string;
  previewable: boolean;
}

interface Props {
  sections: SectionItem[];
  groupedChapters?: TierGroup[];
  currentSlug?: string;
  reviewStats?: ReviewStats;
  attachments?: AttachmentItem[];
  chapterId?: string;
  chapterTitle?: string;
}

const {
  sections,
  groupedChapters = [],
  currentSlug = '',
  reviewStats = { avgRating: 0, totalReviews: 0 },
  attachments = [],
  chapterId = '',
  chapterTitle = '',
} = Astro.props;
const h2Count = sections.filter((s) => s.level === 2).length;
const attachmentCount = attachments.length;

const numberedSections = sections.map((section) => {
  const num = section.sectionNumber || '';
  const depth = num ? num.split('.').length : 0;
  return { ...section, num, depth };
});

const currentChapterTitle = groupedChapters
  .flatMap((g) => g.chapters)
  .find((c) => c.id === currentSlug)?.data.title ?? '';
---

<!-- Floating trigger buttons (right side, above bottom bar) -->
<!-- Collapsed: icon-only circular buttons, lower position -->
<div id="mobile-fab-container" class="lg:hidden fixed right-3 bottom-[calc(4.5rem+env(safe-area-inset-bottom,0px))] z-[55] pointer-events-none flex flex-col gap-2">
  <!-- Section nav: mobile only (desktop has sidebar) -->
  <button
    id="section-nav-trigger"
    class="mobile-fab-btn pointer-events-auto w-10 h-10 rounded-full shadow-lg transition-all active:scale-90"
    style="background: var(--reader-chrome-surface-high); border: 1px solid var(--reader-border); color: var(--reader-chrome-text); backdrop-filter: blur(12px);"
    aria-label="Mở mục lục"
  >
    <span class="material-symbols-outlined text-lg">format_list_numbered</span>
    <span class="sr-only">Đề mục ({sections.length})</span>
  </button>
  <!-- Review -->
  <button
    id="review-trigger"
    class="mobile-fab-btn pointer-events-auto relative w-10 h-10 rounded-full shadow-lg transition-all active:scale-90"
    style="background: var(--reader-chrome-surface-high); border: 1px solid var(--reader-border); backdrop-filter: blur(12px);"
    aria-label="Mở đánh giá"
  >
    <span class="material-symbols-outlined text-lg" style="color: var(--color-primary);">reviews</span>
    {reviewStats.totalReviews > 0 && (
      <span class="absolute -top-0.5 -right-0.5 w-4 h-4 text-[9px] font-bold rounded-full flex items-center justify-center" style="background: var(--color-primary); color: var(--color-on-primary);">{reviewStats.totalReviews > 9 ? '9+' : reviewStats.totalReviews}</span>
    )}
  </button>
  <!-- Question -->
  <button
    id="question-trigger"
    class="mobile-fab-btn pointer-events-auto hidden w-10 h-10 rounded-full shadow-lg transition-all active:scale-90"
    style="background: var(--reader-chrome-surface-high); border: 1px solid var(--reader-border); backdrop-filter: blur(12px);"
    aria-label="Hỏi tác giả"
  >
    <span class="material-symbols-outlined text-lg" style="color: var(--color-primary);">support_agent</span>
  </button>
</div>

<!-- Overlay -->
<div
  id="section-nav-overlay"
  class="fixed inset-0 z-[101] bg-black/50 backdrop-blur-sm hidden transition-opacity"
  aria-hidden="true"
></div>

<!-- Unified Drawer -->
<div
  id="section-nav-sheet"
  class="section-nav-sheet fixed inset-x-0 bottom-0 z-[102] rounded-t-3xl overflow-hidden flex flex-col shadow-2xl"
  style="background: var(--reader-chrome-bg); max-height: 85vh;"
>
  <!-- Handle -->
  <div class="flex justify-center pt-3 pb-2 cursor-pointer select-none" id="section-nav-handle">
    <div class="w-10 h-1 rounded-full" style="background: var(--reader-border);"></div>
  </div>

  <!-- Header -->
  <div class="px-5 pb-3 flex items-center justify-between" style="border-bottom: 1px solid var(--reader-border);">
    <div>
      <h3 class="text-sm font-bold flex items-center gap-2" style="color: var(--reader-chrome-text);">
        <span class="material-symbols-outlined text-primary text-base">format_list_numbered</span>
        Đề mục
      </h3>
      <p class="text-[10px] mt-0.5" style="color: var(--reader-chrome-text-muted);">{currentChapterTitle}</p>
    </div>
    <div class="flex items-center gap-2">
      <div class="w-32 h-2 rounded-full overflow-hidden" style="background: var(--reader-chrome-surface-high);">
        <div id="section-nav-progress-mobile" class="h-full rounded-full" style="width: 0%; background: var(--color-tertiary); transition: width 0.3s;"></div>
      </div>
      <button id="section-nav-close" class="w-8 h-8 rounded-full flex items-center justify-center transition-colors" style="background: var(--reader-chrome-surface-high);">
        <span class="material-symbols-outlined text-base" style="color: var(--reader-chrome-text-muted);">close</span>
      </button>
    </div>
  </div>

  <!-- Tab switcher: Đề mục / Chương -->
  <div class="flex px-4 pt-3 gap-1" id="section-nav-tabs">
    <button class="section-nav-tab flex-1 py-2 rounded-xl text-xs font-bold transition-all" data-tab="sections" style="background: rgba(146,204,255,0.1); color: var(--color-primary); border: 1px solid rgba(146,204,255,0.3);">
      <span class="material-symbols-outlined text-sm align-middle mr-1">format_list_numbered</span>
      Đề mục ({sections.length})
    </button>
    <button class="section-nav-tab flex-1 py-2 rounded-xl text-xs font-bold transition-all" data-tab="chapters" style="background: var(--reader-chrome-surface-high); color: var(--reader-chrome-text-muted);">
      <span class="material-symbols-outlined text-sm align-middle mr-1">menu_book</span>
      Chương ({groupedChapters.flatMap((g) => g.chapters).length})
    </button>
    <button class="section-nav-tab flex-1 py-2 rounded-xl text-xs font-bold transition-all" data-tab="attachments" style="background: var(--reader-chrome-surface-high); color: var(--reader-chrome-text-muted);">
      <span class="material-symbols-outlined text-sm align-middle mr-1">attachment</span>
      Đính kèm ({attachmentCount})
    </button>
  </div>

  <!-- Scrollable content: Section headings -->
  <nav class="flex-1 overflow-y-auto px-3 py-3 section-nav-panel" id="section-nav-panel-sections" data-panel="sections">
    {numberedSections.map((section) => {
      const indentPx = (section.depth - 1) * 14;
      const isChild = section.depth > 1;
      return (
        <a
          href={`#${section.slug}`}
          class:list={[
            'flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-all border-l-[3px]',
            isChild ? 'border-transparent' : 'border-transparent',
          ]}
          style={`color: var(--reader-chrome-text-muted); padding-left: ${12 + indentPx}px`}
          data-mobile-section-link={section.slug}
        >
          {section.num ? (
            <span class="text-[11px] font-bold shrink-0" style="color: var(--reader-chrome-text-muted); min-width: 2.5em;">{section.num}</span>
          ) : (
            <span class="w-1.5 h-1.5 rounded-full shrink-0" style="background: var(--reader-chrome-text-muted); opacity: 0.4;"></span>
          )}
          <span class="truncate text-xs font-medium">{section.title}</span>
        </a>
      );
    })}
    {sections.length === 0 && (
      <div class="py-8 text-center">
        <span class="material-symbols-outlined text-3xl block mb-2 opacity-30" style="color: var(--reader-chrome-text-muted);">article</span>
        <p class="text-xs" style="color: var(--reader-chrome-text-muted);">Chưa có đề mục</p>
      </div>
    )}
  </nav>

  <!-- Scrollable content: Chapter navigation -->
  <nav class="flex-1 overflow-y-auto px-3 py-3 space-y-1 section-nav-panel hidden" id="section-nav-panel-chapters" data-panel="chapters">
    {groupedChapters.map((group) => {
      const hasCurrent = group.chapters.some((ch) => ch.id === currentSlug);
      return (
        <div class="mobile-toc-group" data-tier={group.tier} data-current-tier={hasCurrent ? 'true' : 'false'}>
          <button
            class="mobile-toc-group-header flex items-center gap-2 px-3 py-2 w-full rounded-xl text-left transition-all border border-transparent"
            style="background: var(--reader-chrome-surface-high);"
            data-mobile-toc-toggle
          >
            <span class="material-symbols-outlined text-primary text-[16px] mobile-toc-group-icon transition-transform duration-200">folder_open</span>
            <span class="text-xs font-bold flex-1 truncate" style="color: var(--reader-chrome-text-muted);">{group.label}</span>
            <span class="text-[10px] px-1.5 py-0.5 rounded" style="background: var(--reader-chrome-bg); color: var(--reader-chrome-text-muted);">{group.chapters.length}</span>
            <span class="material-symbols-outlined text-[16px] transition-transform duration-200" style="color: var(--reader-chrome-text-muted);">expand_more</span>
          </button>
          <div class="mobile-toc-group-chapters overflow-hidden transition-all duration-300">
            {group.chapters.map((ch) => {
              const isCurrent = ch.id === currentSlug;
              return (
                <a
                  href={`/book/${ch.id}`}
                  class:list={[
                    'flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-all border-l-[3px]',
                    isCurrent ? 'border-primary' : 'border-transparent',
                  ]}
                  style={isCurrent
                    ? 'background: rgba(146,204,255,0.1); color: var(--color-primary); box-shadow: inset 0 0 0 1px rgba(146,204,255,0.15);'
                    : 'color: var(--reader-chrome-text-muted);'}
                  data-section-nav-chapter-link
                >
                  <span class="text-[10px] font-bold w-7 shrink-0" style="color: var(--reader-chrome-text-muted);">Ch{String(ch.data.chapter).padStart(2, '0')}</span>
                  <span class="truncate text-xs font-medium">{ch.data.title}</span>
                  {isCurrent && (
                    <span class="material-symbols-outlined text-primary text-base ml-auto shrink-0">play_arrow</span>
                  )}
                </a>
              );
            })}
          </div>
        </div>
      );
    })}
  </nav>

  <nav class="flex-1 overflow-y-auto px-3 py-3 section-nav-panel hidden" id="section-nav-panel-attachments" data-panel="attachments">
    {attachmentCount > 0 ? (
      attachments.map((item) => (
        <a
          href={`#attachment-${item.id}`}
          class="flex items-center justify-between gap-3 rounded-2xl border px-3 py-3 text-sm transition-all hover:border-primary/40 hover:bg-primary/5" style="border-color: var(--reader-border); background: var(--reader-chrome-surface-high);"
          data-mobile-attachment-link
        >
          <div class="min-w-0">
            <p class="text-sm font-semibold r-text truncate">{item.title}</p>
            <p class="text-[11px] r-text-muted truncate">{item.sectionTitle}</p>
          </div>
          <span class="inline-flex h-6 items-center rounded-full px-2 text-[10px] font-semibold r-text-muted" style="background: var(--reader-chrome-bg);">{item.type === 'image' ? 'Hình' : item.ext ?? 'Tệp'}</span>
        </a>
      ))
    ) : (
      <div class="py-8 text-center">
        <span class="material-symbols-outlined text-3xl block mb-2 opacity-30" style="color: var(--reader-chrome-text-muted);">attachment</span>
        <p class="text-xs" style="color: var(--reader-chrome-text-muted);">Chưa có mục đính kèm trong chương này</p>
      </div>
    )}
  </nav>

  <!-- Footer -->
  <div class="px-5 py-3 shrink-0" style="border-top: 1px solid var(--reader-border);">
    <p class="text-[10px] font-semibold" style="color: var(--reader-chrome-text-muted);">
      {h2Count} mục chính · {sections.length - h2Count} mục con
    </p>
  </div>
</div>

<style>
  /* Mobile FAB compact buttons */
  .mobile-fab-btn {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Mobile sheet: hidden by default, slides up when open */
  .section-nav-sheet {
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .section-nav-sheet.section-nav-open {
    transform: translateY(0) !important;
  }

  /* Active section in mobile drawer */
  [data-mobile-section-link].section-nav-active-mobile {
    border-color: var(--color-primary) !important;
    background: rgba(146, 204, 255, 0.08) !important;
    color: var(--color-primary) !important;
  }

  /* Mobile TOC group collapse */
  .mobile-toc-group[data-collapsed="true"] .mobile-toc-group-chapters {
    max-height: 0 !important;
    opacity: 0;
  }
  .mobile-toc-group[data-collapsed="true"] .mobile-toc-group-header .material-symbols-outlined:last-child {
    transform: rotate(-90deg);
  }
  .mobile-toc-group[data-collapsed="true"] .mobile-toc-group-icon {
    transform: rotate(-15deg);
  }

  [data-mobile-section-link],
  [data-section-link] {
    scroll-margin-top: 6rem;
  }
</style>

<style>
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
</style>

<script>
  (function () {
    const READER_OFFSET = 80;

    function initMobileSectionNav() {
      const readerScroll = document.getElementById('reader-scroll');
      if (!readerScroll) return;

      const trigger = document.getElementById('section-nav-trigger');
      const overlay = document.getElementById('section-nav-overlay');
      const sheetEl = document.getElementById('section-nav-sheet');
      const handle = document.getElementById('section-nav-handle');
      const closeBtn = document.getElementById('section-nav-close');
      const mobileLinks = document.querySelectorAll('[data-mobile-section-link]');
      const mobileProgressBar = document.getElementById('section-nav-progress-mobile');

      // Mobile TOC collapsible groups
      const MOBILE_TOC_KEY = 'mobile-toc-collapsed';
      function getMobileCollapsed(): Set<number> {
        try {
          const raw = localStorage.getItem(MOBILE_TOC_KEY);
          if (!raw) return new Set();
          return new Set(JSON.parse(raw) as number[]);
        } catch { return new Set(); }
      }
      function saveMobileCollapsed(set: Set<number>) {
        try { localStorage.setItem(MOBILE_TOC_KEY, JSON.stringify([...set])); } catch {}
      }
      function applyMobileCollapsed() {
        const collapsed = getMobileCollapsed();
        document.querySelectorAll<HTMLElement>('.mobile-toc-group').forEach((g) => {
          const tier = Number(g.dataset.tier);
          const isCollapsed = collapsed.has(tier);
          g.dataset.collapsed = isCollapsed ? 'true' : 'false';
          const header = g.querySelector<HTMLElement>('[data-mobile-toc-toggle]');
          if (header) {
            header.setAttribute('aria-expanded', isCollapsed ? 'false' : 'true');
            const chevron = header.querySelector('.material-symbols-outlined:last-child');
            if (chevron) chevron.style.transform = isCollapsed ? 'rotate(-90deg)' : '';
          }
        });
      }
      function toggleMobileGroup(tier: number, forceOpen?: boolean) {
        const collapsed = getMobileCollapsed();
        if (forceOpen === true) {
          collapsed.delete(tier);
        } else if (forceOpen === false) {
          collapsed.add(tier);
        } else {
          if (collapsed.has(tier)) collapsed.delete(tier);
          else collapsed.add(tier);
        }
        saveMobileCollapsed(collapsed);
        applyMobileCollapsed();
      }
      applyMobileCollapsed();
      document.querySelectorAll<HTMLElement>('[data-mobile-toc-toggle]').forEach((btn) => {
        const group = btn.closest<HTMLElement>('.mobile-toc-group');
        const tier = group ? Number(group.dataset.tier) : NaN;
        btn.addEventListener('click', () => {
          if (!isNaN(tier)) toggleMobileGroup(tier);
        });
      });

      if (!trigger || !sheetEl) return;
      const sheet = sheetEl;

      function getActiveId(): string | null {
        const activeLink = document.querySelector('[data-mobile-section-link].section-nav-active-mobile');
        if (activeLink) return (activeLink as HTMLElement).dataset.mobileSectionLink;
        const headings = document.querySelectorAll('.reader-content h2[id], .reader-content h3[id]');
        let bestId: string | null = null;
        let bestDist = Infinity;
        headings.forEach((h) => {
          const rect = h.getBoundingClientRect();
          const dist = Math.abs(rect.top - READER_OFFSET);
          if (dist < bestDist) { bestDist = dist; bestId = h.id; }
        });
        return bestId;
      }

      function openSheet() {
        (window as any).__closeReview?.();
        (window as any).__closeQuestionDrawer?.();
        sheet.classList.add('section-nav-open');
        if (overlay) overlay.classList.remove('hidden');
        const currentId = getActiveId();
        if (currentId) {
          mobileLinks.forEach((link) => {
            const isActive = (link as HTMLElement).dataset.mobileSectionLink === currentId;
            link.classList.toggle('section-nav-active-mobile', isActive);
            if (isActive) setTimeout(() => link.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 100);
          });
        }
        syncMobileProgress();
      }

      function closeSheet() {
        sheet.classList.remove('section-nav-open');
        if (overlay) overlay.classList.add('hidden');
      }

      function syncMobileProgress() {
        if (!mobileProgressBar) return;
        const { scrollTop, scrollHeight, clientHeight } = readerScroll;
        const maxScroll = scrollHeight - clientHeight;
        const pct = maxScroll > 0 ? Math.min(100, Math.round((scrollTop / maxScroll) * 100)) : 0;
        mobileProgressBar.style.width = `${pct}%`;
      }

      (window as any).__openSectionNav = openSheet;
      (window as any).__closeSectionNav = closeSheet;

      trigger.addEventListener('click', () => {
        sheet.classList.contains('section-nav-open') ? closeSheet() : openSheet();
      });
      overlay?.addEventListener('click', closeSheet);

      // Question trigger (mobile)
      const questionTrigger = document.getElementById('question-trigger');
      questionTrigger?.addEventListener('click', () => {
        closeSheet();
        (window as any).__openQuestionDrawer?.();
      });
      closeBtn?.addEventListener('click', closeSheet);

      // Tab switching
      const tabs = document.querySelectorAll<HTMLElement>('.section-nav-tab');
      const panels = document.querySelectorAll<HTMLElement>('.section-nav-panel');
      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const target = tab.dataset.tab;
          tabs.forEach((t) => {
            t.style.background = 'var(--reader-chrome-surface-high)';
            t.style.color = 'var(--reader-chrome-text-muted)';
            t.style.border = 'none';
          });
          tab.style.background = 'rgba(146,204,255,0.1)';
          tab.style.color = 'var(--color-primary)';
          tab.style.border = '1px solid rgba(146,204,255,0.3)';
          panels.forEach((panel) => {
            panel.classList.toggle('hidden', panel.dataset.panel !== target);
          });
        });
      });

      // Section links — expand parent group if collapsed on touchstart
      mobileLinks.forEach((link) => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const hash = (link as HTMLAnchorElement).getAttribute('href');
          if (hash && hash !== '#') {
            const target = document.getElementById(hash.slice(1));
            if (target) {
              const top = target.getBoundingClientRect().top + readerScroll.scrollTop - READER_OFFSET;
              readerScroll.scrollTo({ top, behavior: 'smooth' });
            } else {
              readerScroll.scrollTo({ top: 0, behavior: 'smooth' });
            }
            history.replaceState(null, '', hash);
          }
          closeSheet();
        });
      });

      // Chapter / attachment link clicks
      sheet.querySelectorAll<HTMLElement>('[data-section-nav-chapter-link]').forEach((link) => {
        link.addEventListener('click', () => closeSheet());
      });
      sheet.querySelectorAll<HTMLElement>('[data-mobile-attachment-link]').forEach((link) => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const hash = (link as HTMLAnchorElement).getAttribute('href');
          if (hash && hash !== '#') {
            const target = document.getElementById(hash.slice(1));
            if (target) {
              const top = target.getBoundingClientRect().top + readerScroll.scrollTop - READER_OFFSET;
              readerScroll.scrollTo({ top, behavior: 'smooth' });
            }
            history.replaceState(null, '', hash);
          }
          closeSheet();
        });
      });

      // === IMPROVED SWIPE TO CLOSE ===
      let startY = 0;
      let deltaY = 0;
      let startTime = 0;
      let startX = 0;
      let velocity = 0;
      let lastY = 0;
      let lastTime = 0;
      let dragging = false;
      let rafId: number | null = null;

      handle?.addEventListener('touchstart', (e: TouchEvent) => {
        if ((e.target as HTMLElement).closest('[data-mobile-section-link]')) return;
        startY = lastY = e.touches[0].clientY;
        startX = e.touches[0].clientX;
        startTime = lastTime = Date.now();
        velocity = 0;
        deltaY = 0;
        dragging = true;
        sheet.style.transition = 'none';
        overlay.style.transition = 'none';
        hoveredGroupTier = null;
      }, { passive: true });

      document.addEventListener('touchmove', (e: TouchEvent) => {
        if (!dragging) return;
        const now = Date.now();
        const currentY = e.touches[0].clientY;
        const currentX = e.touches[0].clientX;
        const dx = currentX - startX;
        const dy = currentY - startY;

        // Only drag down (not left/right)
        if (dy < 0) { deltaY = 0; return; }

        // If primarily horizontal swipe, ignore
        if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 10) return;

        deltaY = dy;
        const dt = now - lastTime;
        if (dt > 0) velocity = (currentY - lastY) / dt;
        lastY = currentY;
        lastTime = now;

        // Resistance: slower at the start, faster as you drag more
        const resistance = 1 - Math.min(0.5, deltaY / (sheet.offsetHeight * 0.6));
        const adjustedDelta = deltaY * resistance;

        if (rafId) cancelAnimationFrame(rafId);
        rafId = requestAnimationFrame(() => {
          sheet.style.transform = `translateY(${adjustedDelta}px)`;
          // Opacity of overlay fades based on drag distance
          const maxDelta = sheet.offsetHeight * 0.4;
          const opacity = Math.max(0, 1 - deltaY / maxDelta) * 0.5;
          overlay.style.opacity = String(opacity);
        });
      }, { passive: true });

      document.addEventListener('touchend', () => {
        if (!dragging) return;
        if (rafId) cancelAnimationFrame(rafId);
        if (expandTimer) clearTimeout(expandTimer);
        dragging = false;
        sheet.style.transition = '';
        overlay.style.transition = '';
        overlay.style.opacity = '';

        const shouldClose = deltaY > 80 || (deltaY > 40 && velocity > 0.5);
        if (shouldClose) {
          sheet.style.transition = 'transform 0.25s cubic-bezier(0.4, 0, 1, 1), opacity 0.2s ease';
          overlay.style.transition = 'opacity 0.25s ease';
          closeSheet();
        } else if (deltaY > 5) {
          sheet.style.transition = 'transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1)';
        }
        sheet.style.transform = '';
        deltaY = 0;
        velocity = 0;
      });

      // Keyboard: Escape to close
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && sheet.classList.contains('section-nav-open')) {
          closeSheet();
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initMobileSectionNav);
    } else {
      initMobileSectionNav();
    }
  })();
</script>
