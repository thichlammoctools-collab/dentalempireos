---
// Ask the Author - FAB button + modal form
// Only visible to logged-in users (checked via client-side session)
interface Props {
  chapterId: string;
  chapterTitle: string;
}

const { chapterId, chapterTitle } = Astro.props;
---

<!-- FAB Button — hidden: mobile uses #question-trigger in SectionNavMobile, desktop uses toolbar -->
<button
  id="ask-author-btn"
  class="hidden"
  title="Hỏi Tác Giả"
>
  <span class="material-symbols-outlined text-2xl">support_agent</span>
</button>

<!-- Modal Overlay -->
<div id="ask-author-modal" class="hidden fixed inset-0 z-[80] flex items-end sm:items-center justify-center">
  <div id="ask-author-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
  <div class="relative z-10 bg-surface rounded-t-2xl sm:rounded-2xl w-full sm:max-w-lg shadow-2xl border border-outline-variant/20 flex flex-col max-h-[90vh]">
    <!-- Header -->
    <div class="flex items-center justify-between px-5 py-4 border-b border-outline-variant/20">
      <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-primary text-xl">support_agent</span>
        <div>
          <h3 class="text-base font-bold text-white">Hỏi Tác Giả</h3>
          <p class="text-[11px] text-on-surface-variant truncate max-w-[240px]">{chapterTitle}</p>
        </div>
      </div>
      <button id="ask-author-close" class="w-8 h-8 flex items-center justify-center rounded-lg text-on-surface-variant hover:text-white hover:bg-surface-container-high transition-all">
        <span class="material-symbols-outlined text-lg">close</span>
      </button>
    </div>

    <!-- Form -->
    <form id="ask-author-form" class="flex flex-col gap-4 p-5 overflow-y-auto flex-1">
      <input type="hidden" name="chapter_id" value={chapterId} />

      <div>
        <label class="text-xs font-bold uppercase tracking-wider text-on-surface-variant mb-1.5 block">Tiêu đề câu hỏi</label>
        <input
          type="text"
          name="title"
          placeholder="Tóm tắt ngắn gọn câu hỏi của bạn..."
          class="w-full bg-surface-container border border-outline-variant/30 rounded-xl px-4 py-2.5 text-sm text-on-surface placeholder:text-on-surface-variant/50 outline-none focus:border-primary"
          required
          maxlength="200"
        />
      </div>

      <div>
        <label class="text-xs font-bold uppercase tracking-wider text-on-surface-variant mb-1.5 block">Nội dung chi tiết</label>
        <textarea
          name="body"
          rows={5}
          placeholder="Mô tả chi tiết câu hỏi của bạn. Hỗ trợ Markdown..."
          class="w-full bg-surface-container border border-outline-variant/30 rounded-xl px-4 py-2.5 text-sm text-on-surface placeholder:text-on-surface-variant/50 outline-none focus:border-primary resize-y"
          required
        />
      </div>

      <!-- Submit area -->
      <div class="flex items-center justify-between gap-3">
        <p id="ask-author-hint" class="text-[11px] text-on-surface-variant/70 flex-1">
          Tác giả sẽ nhận được thông báo và trả lời sớm nhất có thể.
        </p>
        <button
          type="submit"
          id="ask-author-submit"
          class="px-5 py-2.5 rounded-xl bg-primary text-on-primary font-bold text-sm hover:opacity-90 transition-all flex items-center gap-2"
        >
          <span class="material-symbols-outlined text-base">send</span>
          Gửi câu hỏi
        </button>
      </div>

      <!-- Success state -->
      <div id="ask-author-success" class="hidden text-center py-4">
        <span class="material-symbols-outlined text-primary text-5xl mb-3 block">check_circle</span>
        <p class="text-sm font-bold text-white mb-1">Câu hỏi đã được gửi!</p>
        <p class="text-xs text-on-surface-variant">Tác giả sẽ trả lời trong thời gian sớm nhất.</p>
      </div>
    </form>
  </div>
</div>

<script define:vars={{ chapterId }}>
  // ── Auth check & show FAB ──
  async function checkAuthAndShow() {
    try {
      const res = await fetch('/api/notifications/unread-count', { credentials: 'include' });
      if (res.ok) {
        document.getElementById('ask-author-btn')?.classList.remove('hidden');
        document.getElementById('toolbar-ask-btn')?.classList.remove('hidden');
        document.getElementById('question-trigger')?.classList.remove('hidden');
      }
    } catch { /* not logged in — keep hidden */ }
  }
  checkAuthAndShow();

  // ── Modal open/close ──
  const btn = document.getElementById('ask-author-btn');
  const modal = document.getElementById('ask-author-modal');
  const backdrop = document.getElementById('ask-author-backdrop');
  const closeBtn = document.getElementById('ask-author-close');
  const form = document.getElementById('ask-author-form');
  const submitBtn = document.getElementById('ask-author-submit');
  const hint = document.getElementById('ask-author-hint');
  const success = document.getElementById('ask-author-success');

  function openModal() {
    modal?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    // Focus first input
    setTimeout(() => {
      const input = modal?.querySelector('input[name="title"]');
      if (input) input.focus();
    }, 100);
  }

  // Expose globally for mobile question trigger
  window.__openAskAuthor = openModal;

  function closeModal() {
    modal?.classList.add('hidden');
    document.body.style.overflow = '';
    // Reset form
    if (form) form.reset();
    if (hint) hint.classList.remove('hidden');
    if (success) success.classList.add('hidden');
    if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = ''; }
  }

  btn?.addEventListener('click', openModal);
  document.getElementById('toolbar-ask-btn')?.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);

  // ESC to close
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
      closeModal();
    }
  });

  // ── Submit form ──
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const title = (formData.get('title') ?? '').toString().trim();
    const body = (formData.get('body') ?? '').toString().trim();

    if (!title || !body) return;

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span class="material-symbols-outlined text-base" style="animation:spin 1s linear infinite">progress_activity</span> Đang gửi...';
    }

    try {
      const res = await fetch('/api/questions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({
          chapter_id: chapterId,
          title,
          body,
        }),
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        alert(err.error || 'Có lỗi xảy ra, vui lòng thử lại.');
        if (submitBtn) { submitBtn.disabled = false; submitBtn.innerHTML = '<span class="material-symbols-outlined text-base">send</span> Gửi câu hỏi'; }
        return;
      }

      // Show success
      if (form) {
        form.querySelectorAll('div:not(#ask-author-success)').forEach(el => {
          if (el.id !== 'ask-author-success') el.classList.add('hidden');
        });
        form.querySelector('label')?.closest('div')?.classList.add('hidden');
      }
      success?.classList.remove('hidden');

      // Close after 2s
      setTimeout(closeModal, 2500);
    } catch {
      alert('Lỗi kết nối. Vui lòng thử lại.');
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<span class="material-symbols-outlined text-base">send</span> Gửi câu hỏi';
      }
    }
  });
</script>

<style>
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
</style>
