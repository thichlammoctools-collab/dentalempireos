---
import StarRating from './StarRating.astro';
import ReviewCard from './ReviewCard.astro';
import type { ReviewDisplay, ReviewStats } from '../../lib/review-db';

interface Props {
  reviews: ReviewDisplay[];
  stats: ReviewStats;
  chapterId: string;
  currentUserId?: string | null;
  showChapter?: boolean;
}

const { reviews, stats, chapterId, currentUserId = null, showChapter = false } = Astro.props;
const uniqueId = `review-list-${chapterId}`;
---

<div class="reviews-section" data-chapter-id={chapterId}>
  <!-- Stats Summary -->
  {stats.totalReviews > 0 && (
    <div class="flex items-center gap-4 mb-6 p-4 bg-surface-container-low rounded-2xl border border-outline-variant/30">
      <div class="text-center flex-shrink-0">
        <p class="text-3xl font-bold text-white">{stats.avgRating}</p>
        <StarRating name={`stats-${chapterId}`} value={Math.round(stats.avgRating)} readonly size="sm" />
      </div>
      <div class="border-l border-outline-variant/30 pl-4">
        <p class="text-sm text-on-surface-variant">
          Dựa trên <span class="font-semibold text-white">{stats.totalReviews}</span> đánh giá
        </p>
      </div>
    </div>
  )}

  <!-- Review Cards -->
  <div id={uniqueId} class="space-y-4">
    {reviews.length === 0 ? (
      <div class="text-center py-8">
        <span class="material-symbols-outlined text-4xl text-on-surface-variant/30 mb-2 block">rate_review</span>
        <p class="text-on-surface-variant text-sm">Chưa có đánh giá nào. Hãy là người đầu tiên chia sẻ cảm nhận!</p>
      </div>
    ) : (
      reviews.map((review) => (
        <ReviewCard
          review={review}
          showChapter={showChapter}
          currentUserId={currentUserId}
        />
      ))
    )}
  </div>

  <!-- Load More -->
  {reviews.length >= 10 && (
    <div class="text-center mt-6">
      <button
        class="review-load-more px-6 py-2.5 bg-surface-container-high hover:bg-surface-container border border-outline-variant/40 rounded-xl text-sm font-semibold text-on-surface-variant hover:text-white transition-all"
        data-offset={reviews.length}
        data-chapter-id={chapterId}
      >
        Xem thêm
      </button>
    </div>
  )}
</div>

<script>
  // Load more reviews
  document.querySelectorAll('.review-load-more').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const offset = parseInt(btn.getAttribute('data-offset') ?? '0');
      const chapterId = btn.getAttribute('data-chapter-id') ?? '';
      const container = btn.closest('.reviews-section');
      const listEl = container?.querySelector(`[id^="review-list-"]`);
      if (!listEl) return;

      btn.textContent = 'Đang tải...';

      try {
        const url = chapterId === 'latest'
          ? `/api/public/reviews/latest?limit=10&offset=${offset}`
          : `/api/public/reviews?chapter_id=${chapterId}&limit=10&offset=${offset}`;

        const res = await fetch(url);
        const data: any = await res.json();
        const newReviews = chapterId === 'latest' ? data : data.reviews;

        if (!newReviews || newReviews.length === 0) {
          btn.textContent = 'Hết rồi';
          (btn as HTMLButtonElement).disabled = true;
          return;
        }

        // Append new cards (simplified — just show raw HTML)
        for (const review of newReviews) {
          const card = document.createElement('div');
          card.innerHTML = `
            <article class="review-card bg-surface-container rounded-2xl border border-outline-variant/40 p-5">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-10 h-10 rounded-full bg-primary/15 text-primary flex items-center justify-center font-bold text-sm">
                  ${(review.user_name || review.author_name || 'Ẩn danh').charAt(0).toUpperCase()}
                </div>
                <div>
                  <p class="font-semibold text-white text-sm">${review.user_name || review.author_name || 'Ẩn danh'}</p>
                  ${review.chapter_title ? `<a href="/book/${review.chapter_id}" class="text-xs text-primary hover:underline">${review.chapter_title}</a>` : ''}
                </div>
              </div>
              <p class="text-sm text-on-surface-variant mb-1">${'★'.repeat(review.rating)}${'☆'.repeat(5 - review.rating)}</p>
              ${review.title ? `<p class="font-semibold text-white text-sm mb-1">${review.title}</p>` : ''}
              <p class="text-sm text-on-surface-variant leading-relaxed whitespace-pre-line">${review.content}</p>
            </article>
          `;
          listEl.appendChild(card.firstElementChild!);
        }

        btn.setAttribute('data-offset', String(offset + newReviews.length));
        btn.textContent = 'Xem thêm';
      } catch {
        btn.textContent = 'Thử lại';
      }
    });
  });

  // Delete review
  document.querySelectorAll('.review-delete-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-review-id');
      if (!id || !confirm('Bạn muốn xóa review này?')) return;

      try {
        const res = await fetch(`/api/public/reviews/${id}`, { method: 'DELETE' });
        if (res.ok) {
          const card = btn.closest('.review-card');
          card?.remove();
        }
      } catch {
        // silent
      }
    });
  });
</script>
