---
import StarRating from './StarRating.astro';
import ReviewForm from './ReviewForm.astro';
import ReviewList from './ReviewList.astro';
import type { ReviewDisplay, ReviewStats } from '../../lib/review-db';

interface Props {
  chapterId: string;
  reviews: ReviewDisplay[];
  stats: ReviewStats;
  isLoggedIn: boolean;
  currentUserId?: string | null;
}

const { chapterId, reviews, stats, isLoggedIn, currentUserId = null } = Astro.props;
---

<!-- Overlay -->
<div
  id="review-overlay"
  class="fixed inset-0 z-[88] bg-black/50 backdrop-blur-sm"
  style="display: none; opacity: 0; transition: opacity 0.3s;"
  aria-hidden="true"
></div>

<!-- Desktop: slide-in from right -->
<aside
  id="review-drawer-desktop"
  class="hidden lg:flex fixed right-0 top-0 bottom-0 z-[90] flex-col shadow-2xl"
  style="width: 420px; background: var(--color-surface-container-low); transform: translateX(100%); transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1); border-left: 1px solid rgba(255,255,255,0.06);"
>
  <!-- Header -->
  <div class="flex items-center justify-between px-5 py-4 shrink-0" style="border-bottom: 1px solid rgba(255,255,255,0.06);">
    <div class="flex items-center gap-2">
      <span class="material-symbols-outlined text-primary text-xl">reviews</span>
      <h3 class="text-sm font-bold" style="color: var(--color-on-surface);">Đánh Giá</h3>
      {stats.totalReviews > 0 && (
        <span class="text-[10px] px-1.5 py-0.5 rounded-full font-bold" style="background: var(--color-surface-container-high); color: var(--color-on-surface-variant);">
          {stats.totalReviews}
        </span>
      )}
    </div>
    <button id="review-close-desktop" class="w-8 h-8 rounded-full flex items-center justify-center transition-colors hover:bg-surface-container-high" title="Đóng">
      <span class="material-symbols-outlined text-base" style="color: var(--color-on-surface-variant);">close</span>
    </button>
  </div>

  <!-- Scrollable content -->
  <div class="flex-1 overflow-y-auto px-5 py-4 space-y-5">
    {stats.totalReviews > 0 ? (
      <div class="flex items-center gap-4 p-4 rounded-2xl" style="background: var(--color-surface-container); border: 1px solid rgba(255,255,255,0.06);">
        <div class="text-center flex-shrink-0">
          <p class="text-3xl font-bold" style="color: var(--color-on-surface);">{stats.avgRating}</p>
          <StarRating name={`desk-stats-${chapterId}`} value={Math.round(stats.avgRating)} readonly size="sm" />
        </div>
        <div class="border-l pl-4" style="border-color: rgba(255,255,255,0.06);">
          <p class="text-xs" style="color: var(--color-on-surface-variant);">
            Dựa trên <span class="font-semibold" style="color: var(--color-on-surface);">{stats.totalReviews}</span> đánh giá
          </p>
        </div>
      </div>
    ) : (
      <div class="text-center py-4">
        <span class="material-symbols-outlined text-3xl block mb-2" style="color: var(--color-on-surface-variant); opacity: 0.3;">rate_review</span>
        <p class="text-xs" style="color: var(--color-on-surface-variant);">Chưa có đánh giá nào. Hãy là người đầu tiên!</p>
      </div>
    )}

    <ReviewForm chapterId={chapterId} isLoggedIn={isLoggedIn} />

    <ReviewList
      reviews={reviews}
      stats={stats}
      chapterId={chapterId}
      currentUserId={currentUserId}
    />
  </div>
</aside>

<!-- Mobile: bottom sheet (always in DOM, controlled by transform) -->
<div
  id="review-drawer-mobile"
  class="fixed inset-x-0 bottom-0 z-[95] rounded-t-3xl overflow-hidden flex flex-col shadow-2xl"
  style="background: var(--color-surface-container-low); max-height: 88vh; transform: translateY(100%); transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1); display: none;"
>
  <!-- Handle -->
  <div class="flex justify-center pt-3 pb-2 cursor-pointer select-none" id="review-handle">
    <div class="w-10 h-1 rounded-full" style="background: var(--color-outline-variant);"></div>
  </div>

  <!-- Header -->
  <div class="px-5 pb-3 flex items-center justify-between shrink-0" style="border-bottom: 1px solid rgba(255,255,255,0.06);">
    <div class="flex items-center gap-2">
      <span class="material-symbols-outlined text-primary text-lg">reviews</span>
      <h3 class="text-sm font-bold" style="color: var(--color-on-surface);">Đánh Giá</h3>
      {stats.totalReviews > 0 && (
        <span class="text-[10px] px-1.5 py-0.5 rounded-full font-bold" style="background: var(--color-surface-container-high); color: var(--color-on-surface-variant);">
          {stats.totalReviews}
        </span>
      )}
    </div>
    <button id="review-close-mobile" class="w-8 h-8 rounded-full flex items-center justify-center" style="background: var(--color-surface-container-high);">
      <span class="material-symbols-outlined text-base" style="color: var(--color-on-surface-variant);">close</span>
    </button>
  </div>

  <!-- Scrollable content -->
  <div class="flex-1 overflow-y-auto px-5 py-4 space-y-5">
    {stats.totalReviews > 0 ? (
      <div class="flex items-center gap-4 p-4 rounded-2xl" style="background: var(--color-surface-container); border: 1px solid rgba(255,255,255,0.06);">
        <div class="text-center flex-shrink-0">
          <p class="text-3xl font-bold" style="color: var(--color-on-surface);">{stats.avgRating}</p>
          <StarRating name={`mob-stats-${chapterId}`} value={Math.round(stats.avgRating)} readonly size="sm" />
        </div>
        <div class="border-l pl-4" style="border-color: rgba(255,255,255,0.06);">
          <p class="text-xs" style="color: var(--color-on-surface-variant);">
            Dựa trên <span class="font-semibold" style="color: var(--color-on-surface);">{stats.totalReviews}</span> đánh giá
          </p>
        </div>
      </div>
    ) : (
      <div class="text-center py-4">
        <span class="material-symbols-outlined text-3xl block mb-2" style="color: var(--color-on-surface-variant); opacity: 0.3;">rate_review</span>
        <p class="text-xs" style="color: var(--color-on-surface-variant);">Chưa có đánh giá nào. Hãy là người đầu tiên!</p>
      </div>
    )}

    <ReviewForm chapterId={chapterId} isLoggedIn={isLoggedIn} />

    <ReviewList
      reviews={reviews}
      stats={stats}
      chapterId={chapterId}
      currentUserId={currentUserId}
    />
  </div>
</div>

<!-- Floating trigger button -->
<button
  id="review-trigger"
  class="fixed z-[55] flex items-center gap-1.5 px-3 py-2.5 rounded-full shadow-lg transition-all active:scale-95"
  style="background: var(--color-surface-container-high); border: 1px solid var(--color-outline-variant); backdrop-filter: blur(12px); bottom: calc(4.5rem + env(safe-area-inset-bottom, 0px)); right: 1rem;"
  aria-label="Mở đánh giá"
>
  <span class="material-symbols-outlined text-base" style="color: var(--color-primary);">reviews</span>
  <span class="text-[11px] font-bold" style="color: var(--color-on-surface);">Đánh giá</span>
  {stats.totalReviews > 0 && (
    <span class="text-[9px] font-bold px-1 py-0.5 rounded-full" style="background: var(--color-primary); color: white;">{stats.totalReviews}</span>
  )}
</button>

<style>
  /* Focus mode: hide trigger */
  body.focus-mode #review-trigger {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }
  body.focus-mode:hover #review-trigger {
    opacity: 1;
    pointer-events: auto;
  }

  /* Scrollbar styling inside drawers */
  #review-drawer-desktop ::-webkit-scrollbar,
  #review-drawer-mobile ::-webkit-scrollbar {
    width: 3px;
  }
  #review-drawer-desktop ::-webkit-scrollbar-thumb,
  #review-drawer-mobile ::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.08);
    border-radius: 99px;
  }
</style>

<script>
  (function () {
    const trigger = document.getElementById('review-trigger');
    const overlay = document.getElementById('review-overlay');
    const desktop = document.getElementById('review-drawer-desktop');
    const mobile = document.getElementById('review-drawer-mobile');
    const closeDesktop = document.getElementById('review-close-desktop');
    const closeMobile = document.getElementById('review-close-mobile');
    const handle = document.getElementById('review-handle');

    if (!trigger || !overlay) return;

    let isOpen = false;
    let isMobile = false;

    function open() {
      isOpen = true;
      isMobile = window.innerWidth < 1024;

      // Show overlay
      overlay.style.display = 'block';
      // Force reflow then animate opacity
      overlay.offsetHeight;
      overlay.style.opacity = '1';

      if (isMobile && mobile) {
        mobile.style.display = 'flex';
        // Force reflow before animating
        mobile.offsetHeight;
        mobile.style.transform = 'translateY(0)';
      } else if (desktop) {
        desktop.style.transform = 'translateX(0)';
      }
    }

    function close() {
      isOpen = false;

      // Animate overlay out
      overlay.style.opacity = '0';
      setTimeout(() => {
        overlay.style.display = 'none';
      }, 300);

      if (desktop) {
        desktop.style.transform = 'translateX(100%)';
      }
      if (mobile) {
        mobile.style.transform = 'translateY(100%)';
        setTimeout(() => {
          if (!isOpen) mobile!.style.display = 'none';
        }, 350);
      }
    }

    trigger.addEventListener('click', () => {
      isOpen ? close() : open();
    });

    overlay.addEventListener('click', close);
    closeDesktop?.addEventListener('click', close);
    closeMobile?.addEventListener('click', close);

    // Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) close();
    });

    // Mobile: touch drag to close
    let startY = 0;
    let deltaY = 0;
    let dragging = false;

    handle?.addEventListener('touchstart', (e: Event) => {
      startY = (e as TouchEvent).touches[0].clientY;
      dragging = true;
      if (mobile) mobile.style.transition = 'none';
    }, { passive: true });

    document.addEventListener('touchmove', (e: Event) => {
      if (!dragging) return;
      deltaY = (e as TouchEvent).touches[0].clientY - startY;
      if (deltaY > 0 && mobile) {
        mobile.style.transform = `translateY(${deltaY}px)`;
      }
    }, { passive: true });

    document.addEventListener('touchend', () => {
      if (!dragging) return;
      dragging = false;
      if (mobile) mobile.style.transition = '';
      if (deltaY > 80) {
        close();
      } else if (mobile) {
        mobile.style.transform = isOpen ? 'translateY(0)' : 'translateY(100%)';
      }
      deltaY = 0;
    });

    // Resize: close on breakpoint change
    window.addEventListener('resize', () => {
      if (isOpen) close();
    });
  })();
</script>
