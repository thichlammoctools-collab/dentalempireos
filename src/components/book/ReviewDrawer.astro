---
import StarRating from './StarRating.astro';
import ReviewForm from './ReviewForm.astro';

interface Props {
  chapterId: string;
  chapterTitle?: string;
  isLoggedIn: boolean;
  currentUserId?: string | null;
}

const { chapterId, chapterTitle = '', isLoggedIn, currentUserId = null } = Astro.props;
---

<!-- Overlay -->
<div
  id="review-overlay"
  class="fixed inset-0 z-[101] bg-black/50 backdrop-blur-sm"
  style="opacity: 0; pointer-events: none; transition: opacity 0.3s ease;"
  aria-hidden="true"
></div>

<!-- ═══════════ DESKTOP: Slide-in panel with tabs ═══════════ -->
<aside
  id="review-drawer-desktop"
  class="fixed right-0 top-0 bottom-0 z-[102] flex-col shadow-2xl"
  style="width: 440px; background: var(--reader-chrome-bg); display: none; transform: translateX(100%); transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);"
  data-chapter-id={chapterId}
  data-chapter-title={chapterTitle}
  data-is-logged-in={isLoggedIn}
  data-current-user-id={currentUserId}
>
  <!-- Header -->
  <div class="shrink-0 border-b" style="border-color: var(--reader-border);">
    <div class="flex items-center justify-between px-5 pt-4 pb-0">
      <div class="flex items-center gap-2">
        <span id="review-badge-desktop" class="text-[10px] px-1.5 py-0.5 rounded-full font-bold r-surface-high r-text-muted hidden">0</span>
      </div>
      <button id="review-close-desktop" class="w-8 h-8 rounded-full flex items-center justify-center transition-colors hover:bg-surface-container-high" title="Đóng">
        <span class="material-symbols-outlined text-base r-text-muted">close</span>
      </button>
    </div>
    <!-- Tab bar -->
    <div class="flex px-5 gap-1" id="desktop-review-tabs">
      <button class="desktop-tab flex-1 py-2.5 text-xs font-bold rounded-t-xl transition-all flex items-center justify-center gap-1.5" data-tab="reviews" style="background: rgba(146,204,255,0.1); color: var(--color-primary); border-bottom: 2px solid var(--color-primary);">
        <span class="material-symbols-outlined text-[15px]">reviews</span>
        Đánh giá
      </button>
      <button class="desktop-tab flex-1 py-2.5 text-xs font-bold rounded-t-xl transition-all flex items-center justify-center gap-1.5" data-tab="question" style="background: transparent; color: var(--reader-chrome-text-muted); border-bottom: 2px solid transparent;">
        <span class="material-symbols-outlined text-[15px]">support_agent</span>
        Hỏi tác giả
      </button>
    </div>
  </div>

  <!-- ══ Reviews panel ══ -->
  <div id="desktop-panel-reviews" class="flex-1 overflow-y-auto px-5 py-4 space-y-5">
    <div id="review-skeleton-desktop" class="space-y-4">
      <div class="animate-pulse flex items-center gap-4 p-4 rounded-2xl r-surface">
        <div class="w-16 h-12 r-surface-high rounded-lg"></div>
        <div class="flex-1 space-y-2">
          <div class="h-4 r-surface-high rounded w-24"></div>
          <div class="h-3 r-surface-high rounded w-16"></div>
        </div>
      </div>
      <div class="animate-pulse space-y-3">
        <div class="h-20 r-surface rounded-xl"></div>
        <div class="h-20 r-surface rounded-xl"></div>
      </div>
    </div>

    <div id="review-content-desktop" class="hidden space-y-5"></div>

    <ReviewForm chapterId={chapterId} isLoggedIn={isLoggedIn} />

    <div id="reviews-list-desktop" class="space-y-4"></div>
  </div>

  <!-- ══ Question panel ══ -->
  <div id="desktop-panel-question" class="flex-1 overflow-y-auto px-6 py-5 space-y-5" style="display: none;">
    <!-- Logged out state -->
    <div id="question-logged-out-desktop" class:list={['text-center py-12', !isLoggedIn ? '' : 'hidden']}>
      <div class="w-14 h-14 rounded-full mx-auto mb-4 flex items-center justify-center" style="background: var(--reader-chrome-surface-high);">
        <span class="material-symbols-outlined text-2xl" style="color: var(--reader-chrome-text-muted);">lock</span>
      </div>
      <p class="text-sm font-semibold mb-1" style="color: var(--reader-chrome-text);">Đăng nhập để đặt câu hỏi</p>
      <p class="text-xs mb-5" style="color: var(--reader-chrome-text-muted);">Bạn cần đăng nhập để gửi câu hỏi cho tác giả.</p>
      <a href="/login" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-primary text-on-primary text-sm font-bold hover:opacity-90 transition-opacity">
        <span class="material-symbols-outlined text-base">login</span> Đăng nhập
      </a>
    </div>

    <!-- Form -->
    <form id="question-form-desktop" class:list={['flex flex-col gap-4', isLoggedIn ? '' : 'hidden']}>
      <input type="hidden" name="chapter_id" value={chapterId} />
      <div>
        <label class="text-[11px] font-bold uppercase tracking-widest mb-2 block" style="color: var(--reader-chrome-text-muted);">Tiêu đề câu hỏi</label>
        <input
          type="text"
          name="title"
          placeholder="Tóm tắt ngắn gọn câu hỏi của bạn..."
          class="w-full rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-primary/40 transition-all"
          style="background: var(--reader-chrome-surface); border: 1px solid var(--reader-border); color: var(--reader-chrome-text);"
          required
          maxlength="200"
        />
      </div>
      <div>
        <label class="text-[11px] font-bold uppercase tracking-widest mb-2 block" style="color: var(--reader-chrome-text-muted);">Nội dung chi tiết</label>
        <textarea
          name="body"
          rows={5}
          placeholder="Mô tả chi tiết câu hỏi của bạn. Càng cụ thể, tác giả càng dễ trả lời..."
          class="w-full rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-primary/40 transition-all resize-y"
          style="background: var(--reader-chrome-surface); border: 1px solid var(--reader-border); color: var(--reader-chrome-text);"
          required
        ></textarea>
      </div>
      <div class="flex items-center justify-between gap-3 pt-1">
        <p class="text-[11px] flex-1" style="color: var(--reader-chrome-text-muted);">
          Tác giả sẽ nhận thông báo và trả lời sớm nhất có thể.
        </p>
        <button
          type="submit"
          id="question-submit-desktop"
          class="px-6 py-3 rounded-xl bg-primary text-on-primary font-bold text-sm flex items-center gap-2 hover:opacity-90 transition-all shrink-0"
        >
          <span class="material-symbols-outlined text-base">send</span>
          Gửi câu hỏi
        </button>
      </div>
    </form>

    <!-- Success state -->
    <div id="question-success-desktop" class="hidden text-center py-10">
      <span class="material-symbols-outlined text-primary text-5xl mb-4 block">check_circle</span>
      <p class="text-base font-bold mb-1" style="color: var(--reader-chrome-text);">Câu hỏi đã được gửi!</p>
      <p class="text-sm" style="color: var(--reader-chrome-text-muted);">Tác giả sẽ trả lời trong thời gian sớm nhất.</p>
    </div>
  </div>
</aside>

<!-- ═══════════ MOBILE: Review bottom sheet ═══════════ -->
<div
  id="review-drawer-mobile"
  class="fixed inset-x-0 bottom-0 z-[103] rounded-t-3xl overflow-hidden flex flex-col shadow-2xl"
  style="background: var(--color-surface-container-low); max-height: 88vh; display: none; transform: translateY(100%); transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);"
  data-chapter-id={chapterId}
  data-is-logged-in={isLoggedIn}
  data-current-user-id={currentUserId}
>
  <div class="flex justify-center pt-3 pb-2 cursor-grab select-none" id="review-handle">
    <div class="w-10 h-1.5 rounded-full bg-outline-variant"></div>
  </div>

  <div class="px-5 pb-3 flex items-center justify-between shrink-0 border-b r-border">
    <div class="flex items-center gap-2">
      <span class="material-symbols-outlined text-primary text-lg">reviews</span>
      <h3 class="text-sm font-bold r-text">Đánh Giá</h3>
      <span id="review-badge-mobile" class="text-[10px] px-1.5 py-0.5 rounded-full font-bold r-surface-high r-text-muted hidden">0</span>
    </div>
    <button id="review-close-mobile" class="w-8 h-8 rounded-full flex items-center justify-center bg-surface-container-high">
      <span class="material-symbols-outlined text-base r-text-muted">close</span>
    </button>
  </div>

  <div class="flex-1 overflow-y-auto px-5 py-4 space-y-5">
    <div id="review-skeleton-mobile" class="space-y-4">
      <div class="animate-pulse flex items-center gap-4 p-4 rounded-2xl r-surface">
        <div class="w-16 h-12 r-surface-high rounded-lg"></div>
        <div class="flex-1 space-y-2">
          <div class="h-4 r-surface-high rounded w-24"></div>
          <div class="h-3 r-surface-high rounded w-16"></div>
        </div>
      </div>
      <div class="animate-pulse space-y-3">
        <div class="h-20 r-surface rounded-xl"></div>
        <div class="h-20 r-surface rounded-xl"></div>
      </div>
    </div>

    <div id="review-content-mobile" class="hidden space-y-5"></div>

    <ReviewForm chapterId={chapterId} isLoggedIn={isLoggedIn} />

    <div id="reviews-list-mobile" class="space-y-4"></div>
  </div>
</div>

<style>
  #review-drawer-desktop ::-webkit-scrollbar,
  #review-drawer-mobile ::-webkit-scrollbar { width: 4px; }
  #review-drawer-desktop ::-webkit-scrollbar-thumb,
  #review-drawer-mobile ::-webkit-scrollbar-thumb { background: var(--reader-scrollbar); border-radius: 99px; }
  @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
  .animate-pulse { animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
</style>

<script>
  (function () {
    /* ── Elements ── */
    const overlay = document.getElementById('review-overlay');
    const desktop = document.getElementById('review-drawer-desktop');
    const mobile = document.getElementById('review-drawer-mobile');
    const trigger = document.getElementById('review-trigger');
    const toolbarReviewBtn = document.getElementById('toolbar-review-btn');
    const toolbarAskBtn = document.getElementById('toolbar-ask-btn');
    const closeDesktop = document.getElementById('review-close-desktop');
    const closeMobile = document.getElementById('review-close-mobile');
    const handle = document.getElementById('review-handle');

    let isOpen = false;
    let dataFetched = false;
    let currentChapterId = '';
    let isLoggedIn = false;
    let currentUserId = null;

    function getChapterData() {
      const container = mobile || desktop;
      if (container) {
        currentChapterId = container.dataset.chapterId || '';
        isLoggedIn = container.dataset.isLoggedIn === 'true';
        currentUserId = container.dataset.currentUserId || null;
      }
    }

    /* ═══════════ TAB SWITCHING (desktop only) ═══════════ */
    let activeTab = 'reviews';

    function switchTab(tabName: string) {
      activeTab = tabName;
      const reviewsPanel = document.getElementById('desktop-panel-reviews');
      const questionPanel = document.getElementById('desktop-panel-question');
      const tabs = document.querySelectorAll<HTMLElement>('#desktop-review-tabs .desktop-tab');

      tabs.forEach(tab => {
        const isActive = tab.dataset.tab === tabName;
        tab.style.background = isActive ? 'rgba(146,204,255,0.1)' : 'transparent';
        tab.style.color = isActive ? 'var(--color-primary)' : 'var(--reader-chrome-text-muted)';
        tab.style.borderBottom = isActive ? '2px solid var(--color-primary)' : '2px solid transparent';
      });

      if (reviewsPanel) reviewsPanel.style.display = tabName === 'reviews' ? '' : 'none';
      if (questionPanel) questionPanel.style.display = tabName === 'question' ? '' : 'none';

      // Auto-focus question input when switching to question tab
      if (tabName === 'question' && isLoggedIn) {
        setTimeout(() => {
          const input = document.getElementById('question-form-desktop')?.querySelector('input[name="title"]') as HTMLInputElement;
          input?.focus();
        }, 200);
      }
    }

    document.querySelectorAll<HTMLElement>('#desktop-review-tabs .desktop-tab').forEach(tab => {
      tab.addEventListener('click', () => switchTab(tab.dataset.tab || 'reviews'));
    });

    /* ═══════════ QUESTION SUBMIT (desktop, inside review panel) ═══════════ */
    const qForm = document.getElementById('question-form-desktop') as HTMLFormElement;
    const qSubmitBtn = document.getElementById('question-submit-desktop') as HTMLButtonElement;
    const qSuccessEl = document.getElementById('question-success-desktop');

    qForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(qForm);
      const title = (formData.get('title') as string)?.trim();
      const body = (formData.get('body') as string)?.trim();
      const chId = formData.get('chapter_id') as string;
      if (!title || !body) return;

      if (qSubmitBtn) {
        qSubmitBtn.disabled = true;
        qSubmitBtn.innerHTML = '<span class="material-symbols-outlined text-base" style="animation:spin 1s linear infinite">progress_activity</span> Đang gửi...';
      }

      try {
        const res = await fetch('/api/questions', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ chapter_id: chId, title, body }),
        });
        if (!res.ok) {
          if (res.status === 401) { window.location.href = '/login'; return; }
          alert('Có lỗi xảy ra, vui lòng thử lại.');
          if (qSubmitBtn) { qSubmitBtn.disabled = false; qSubmitBtn.innerHTML = '<span class="material-symbols-outlined text-base">send</span> Gửi câu hỏi'; }
          return;
        }
        qForm.classList.add('hidden');
        qSuccessEl?.classList.remove('hidden');
        setTimeout(() => {
          qForm.reset(); qForm.classList.remove('hidden');
          qSuccessEl?.classList.add('hidden');
          if (qSubmitBtn) { qSubmitBtn.disabled = false; qSubmitBtn.innerHTML = '<span class="material-symbols-outlined text-base">send</span> Gửi câu hỏi'; }
        }, 2500);
      } catch {
        alert('Lỗi kết nối. Vui lòng thử lại.');
        if (qSubmitBtn) { qSubmitBtn.disabled = false; qSubmitBtn.innerHTML = '<span class="material-symbols-outlined text-base">send</span> Gửi câu hỏi'; }
      }
    });

    /* ═══════════ REVIEWS FETCH ═══════════ */
    async function fetchReviews() {
      if (!currentChapterId) return;
      try {
        const response = await fetch(`/api/public/reviews?chapter_id=${encodeURIComponent(currentChapterId)}&limit=10&offset=0`, { credentials: 'include' });
        if (!response.ok) throw new Error('Failed to fetch');
        renderReviews(await response.json());
        dataFetched = true;
      } catch (error) { console.error('Error fetching reviews:', error); showError(); }
    }

    function renderStars(rating) { return '★'.repeat(rating) + '☆'.repeat(5 - rating); }

    function relativeDate(iso) {
      const diff = Math.floor((Date.now() - new Date(iso).getTime()) / 1000);
      if (diff < 60) return 'Vừa xong';
      if (diff < 3600) return `${Math.floor(diff / 60)} phút trước`;
      if (diff < 86400) return `${Math.floor(diff / 3600)} giờ trước`;
      const days = Math.floor(diff / 86400);
      if (days < 30) return `${days} ngày trước`;
      if (days < 365) return `${Math.floor(days / 30)} tháng trước`;
      return `${Math.floor(diff / 31536000)} năm trước`;
    }

    function renderReviews({ reviews = [], stats = { avgRating: 0, totalReviews: 0 } }) {
      const hasReviews = stats.totalReviews > 0;
      const badgeDesktop = document.getElementById('review-badge-desktop');
      const badgeMobile = document.getElementById('review-badge-mobile');
      if (badgeDesktop) { badgeDesktop.textContent = stats.totalReviews; badgeDesktop.classList.toggle('hidden', !hasReviews); }
      if (badgeMobile) { badgeMobile.textContent = stats.totalReviews; badgeMobile.classList.toggle('hidden', !hasReviews); }

      const statsHtml = hasReviews ? `
        <div class="flex items-center gap-4 p-4 rounded-2xl r-surface border" style="border-color: var(--reader-border);">
          <div class="text-center flex-shrink-0">
            <p class="text-3xl font-bold r-text">${stats.avgRating}</p>
            <div class="text-tertiary text-sm tracking-wider">${renderStars(Math.round(stats.avgRating))}</div>
          </div>
          <div class="border-l pl-4" style="border-color: var(--reader-border);">
            <p class="text-xs r-text-muted">Dựa trên <span class="font-semibold r-text">${stats.totalReviews}</span> đánh giá</p>
          </div>
        </div>
      ` : `
        <div class="text-center py-4">
          <span class="material-symbols-outlined text-3xl block mb-2 r-text-muted opacity-30">rate_review</span>
          <p class="text-xs r-text-muted">Chưa có đánh giá nào. Hãy là người đầu tiên!</p>
        </div>
      `;

      const reviewsHtml = reviews.length > 0 ? reviews.map(review => `
        <article class="review-card r-surface rounded-2xl border p-5 transition-all" style="border-color: var(--reader-border);" data-review-id="${review.id}">
          <div class="flex items-start justify-between gap-3 mb-3">
            <div class="flex items-center gap-3 min-w-0">
              ${review.user_image
                ? `<img src="${review.user_image}" alt="" class="w-10 h-10 rounded-full object-cover flex-shrink-0" loading="lazy">`
                : `<div class="w-10 h-10 rounded-full bg-primary/15 text-primary flex items-center justify-center font-bold text-sm flex-shrink-0">${(review.user_name?.charAt(0) || '?').toUpperCase()}</div>`
              }
              <div class="min-w-0">
                <p class="font-semibold r-text text-sm truncate">${review.user_name || review.author_name || 'Ẩn danh'}</p>
                <time class="text-xs r-text-muted" datetime="${review.createdAt}">${relativeDate(review.createdAt)}</time>
              </div>
            </div>
            ${currentUserId && review.user_id === currentUserId ? `
              <button class="review-delete-btn flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-lg r-text-muted hover:text-error hover:bg-error/10 transition-all" title="Xóa" data-review-id="${review.id}">
                <span class="material-symbols-outlined text-lg">delete</span>
              </button>
            ` : ''}
          </div>
          <div class="flex items-center gap-2 mb-2">
            <span class="text-tertiary text-sm tracking-wider">${renderStars(review.rating)}</span>
          </div>
          ${review.title ? `<p class="font-semibold r-text text-sm mb-1">${review.title}</p>` : ''}
          <p class="text-sm r-text-muted leading-relaxed whitespace-pre-line">${review.content}</p>
        </article>
      `).join('') : `
        <div class="text-center py-4">
          <span class="material-symbols-outlined text-3xl block mb-2 r-text-muted opacity-30">reviews</span>
          <p class="text-xs r-text-muted">Chưa có đánh giá.</p>
        </div>
      `;

      ['desktop', 'mobile'].forEach(type => {
        const skeleton = document.getElementById(`review-skeleton-${type}`);
        const content = document.getElementById(`review-content-${type}`);
        const list = document.getElementById(`reviews-list-${type}`);
        if (skeleton) skeleton.classList.add('hidden');
        if (content) { content.innerHTML = statsHtml; content.classList.remove('hidden'); }
        if (list) list.innerHTML = reviewsHtml;
      });

      bindDeleteButtons();
    }

    function showError() {
      ['desktop', 'mobile'].forEach(type => {
        const skeleton = document.getElementById(`review-skeleton-${type}`);
        const content = document.getElementById(`review-content-${type}`);
        if (skeleton) skeleton.classList.add('hidden');
        if (content) {
          content.innerHTML = `<div class="text-center py-4"><span class="material-symbols-outlined text-3xl block mb-2 text-error">error</span><p class="text-xs r-text-muted">Không thể tải đánh giá. Thử lại sau.</p></div>`;
          content.classList.remove('hidden');
        }
      });
    }

    function bindDeleteButtons() {
      document.querySelectorAll('.review-delete-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const id = btn.dataset.reviewId;
          if (!id || !confirm('Bạn muốn xóa review này?')) return;
          try {
            const res = await fetch(`/api/public/reviews/${id}`, { method: 'DELETE', credentials: 'include' });
            if (res.ok) { btn.closest('.review-card')?.remove(); dataFetched = false; fetchReviews(); }
          } catch (e) { console.error('Delete failed:', e); }
        });
      });
    }

    /* ═══════════ OPEN / CLOSE ═══════════ */
    function open(tab?: string) {
      getChapterData();
      isOpen = true;
      const isMobile = window.innerWidth < 1024;

      if (overlay) { overlay.style.opacity = '1'; overlay.style.pointerEvents = 'auto'; }

      if (isMobile && mobile) {
        mobile.style.display = 'flex';
        requestAnimationFrame(() => { mobile.style.transform = 'translateY(0)'; });
      } else if (desktop) {
        desktop.style.display = 'flex';
        requestAnimationFrame(() => { desktop.style.transform = 'translateX(0)'; });
        // Switch tab if requested
        if (tab) switchTab(tab);
      }

      document.body.style.overflow = 'hidden';
      if (!dataFetched) fetchReviews();
    }

    function close() {
      isOpen = false;
      if (overlay) { overlay.style.opacity = '0'; overlay.style.pointerEvents = 'none'; }
      if (desktop) { desktop.style.transform = 'translateX(100%)'; setTimeout(() => { desktop.style.display = 'none'; }, 350); }
      if (mobile) { mobile.style.transform = 'translateY(100%)'; setTimeout(() => { mobile.style.display = 'none'; }, 350); }
      document.body.style.overflow = '';
    }

    /* ═══════════ EVENT BINDINGS ═══════════ */
    // Mobile trigger (from SectionNavMobile)
    trigger?.addEventListener('click', () => isOpen ? close() : open());
    // Desktop toolbar: Review button → open with reviews tab
    toolbarReviewBtn?.addEventListener('click', () => isOpen ? close() : open('reviews'));
    // Desktop toolbar: Ask button → open with question tab
    toolbarAskBtn?.addEventListener('click', () => isOpen ? close() : open('question'));

    overlay?.addEventListener('click', close);
    closeDesktop?.addEventListener('click', close);
    closeMobile?.addEventListener('click', close);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && isOpen) close(); });

    /* ── Mobile touch drag ── */
    let startY = 0, currentY = 0;
    handle?.addEventListener('touchstart', (e) => { startY = e.touches[0].clientY; }, { passive: true });
    handle?.addEventListener('touchmove', (e) => {
      if (!isOpen || !mobile) return;
      currentY = e.touches[0].clientY;
      const diff = currentY - startY;
      if (diff > 0) mobile.style.transform = `translateY(${diff}px)`;
    }, { passive: true });
    handle?.addEventListener('touchend', () => {
      if (currentY - startY > 80) close();
      else if (mobile) mobile.style.transform = 'translateY(0)';
      currentY = 0;
    });

    window.addEventListener('resize', () => { if (isOpen) close(); });
  })();
</script>
