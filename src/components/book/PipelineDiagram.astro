---
// Interactive Patient Pipeline Diagram — mobile-first, stacked cards with colored accent bars
interface PipelineStage {
  name: string;
  label: string;
  icon: string;
  pct: number;
  color: string;
  colorClass: string;
  bgClass: string;
  accentClass: string;
}

interface Props {
  stages?: PipelineStage[];
  autoOptimize?: boolean;
  optimizeAt?: string;
}

const defaultStages: PipelineStage[] = [
  {
    name: 'Leads',
    label: 'LEADS',
    icon: 'group_add',
    pct: 85,
    color: '#92ccff',
    colorClass: 'text-primary',
    bgClass: 'bg-primary/10 border-primary/30',
    accentClass: 'bg-primary',
  },
  {
    name: 'Booking',
    label: 'BOOKING',
    icon: 'event_available',
    pct: 62,
    color: '#c6c6c6',
    colorClass: 'text-secondary',
    bgClass: 'bg-secondary/10 border-secondary/30',
    accentClass: 'bg-secondary',
  },
  {
    name: 'Treatment',
    label: 'TREATMENT',
    icon: 'medical_services',
    pct: 94,
    color: '#ffb77a',
    colorClass: 'text-tertiary',
    bgClass: 'bg-tertiary/10 border-tertiary/30',
    accentClass: 'bg-tertiary',
  },
  {
    name: 'Aftercare',
    label: 'AFTERCARE',
    icon: 'favorite',
    pct: 78,
    color: '#cce5ff',
    colorClass: 'text-primary',
    bgClass: 'bg-primary/10 border-primary/30',
    accentClass: 'bg-primary',
  },
];

const stages = Astro.props.stages ?? defaultStages;
const autoOptimize = Astro.props.autoOptimize ?? true;
const optimizeAt = Astro.props.optimizeAt ?? 'Booking';
---

<!-- Pipeline Diagram -->
<div class="my-8 rounded-2xl overflow-hidden border border-white/[0.06] bg-surface-container-low">
  <!-- Header -->
  <div class="flex items-center justify-between px-4 py-3 border-b border-white/[0.06]">
    <div class="flex items-center gap-2">
      <span class="material-symbols-outlined text-primary text-lg">account_tree</span>
      <h3 class="text-sm font-bold text-on-surface">Patient Pipeline</h3>
    </div>
    <button class="w-8 h-8 flex items-center justify-center rounded-lg text-on-surface-variant hover:text-primary hover:bg-surface-container transition-all active:scale-90 transition-transform" title="Làm mới" id="pipeline-refresh-btn">
      <span class="material-symbols-outlined text-base">refresh</span>
    </button>
  </div>

  <!-- Stages: Mobile-first stacked cards -->
  <div class="px-4 py-4 space-y-2" id="pipeline-stages">
    {stages.map((stage) => (
      <div
        class="pipeline-stage group relative flex items-center gap-3 p-3 rounded-xl border border-white/[0.06] bg-surface-container hover:bg-surface-container-high transition-all cursor-pointer active:scale-[0.98]"
        data-stage={stage.name.toLowerCase()}
        data-pct={stage.pct}
      >
        <!-- Left color accent bar -->
        <div class={`absolute left-0 top-0 bottom-0 w-0.5 rounded-l-xl ${stage.accentClass}`}></div>

        <!-- Icon circle -->
        <div class={`w-11 h-11 flex items-center justify-center rounded-full border flex-shrink-0 ${stage.bgClass} group-hover:scale-110 transition-transform duration-200`}>
          <span class={`material-symbols-outlined text-xl ${stage.colorClass}`}>{stage.icon}</span>
        </div>

        <!-- Content -->
        <div class="flex-1 min-w-0">
          <div class="flex justify-between items-end">
            <span class={`text-[10px] font-bold uppercase tracking-widest ${stage.colorClass}`}>{stage.label}</span>
            <span class={`text-sm font-bold ${stage.colorClass}`}>{stage.pct}%</span>
          </div>
          <div class="w-full h-1.5 bg-surface-container-highest rounded-full mt-1.5 overflow-hidden">
            <div
              class={`h-full rounded-full transition-all duration-700 ease-out ${stage.accentClass}`}
              style={`width: ${stage.pct}%;`}
              data-pipeline-bar
            ></div>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Auto-optimization notice -->
  {autoOptimize && (
    <div class="mx-4 mb-4 p-3 rounded-xl bg-primary/5 border border-primary/20">
      <div class="flex items-start gap-2">
        <span class="material-symbols-outlined text-primary text-base mt-0.5" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
        <p class="text-[11px] text-on-surface-variant leading-relaxed">
          Hệ thống đang tự động tối ưu tỷ lệ tại <strong class="text-on-surface">bước {optimizeAt}</strong> dựa trên dữ liệu 7 ngày qua.
        </p>
      </div>
    </div>
  )}
</div>

<script>
  // Pipeline interaction: refresh animation
  document.getElementById('pipeline-refresh-btn')?.addEventListener('click', function () {
    const icon = this.querySelector('.material-symbols-outlined') as HTMLElement;
    if (icon) {
      icon.style.transition = 'transform 0.5s ease-in-out';
      icon.style.transform = 'rotate(360deg)';
      setTimeout(() => { icon.style.transform = ''; }, 600);
    }

    // Simulate data refresh with bar animation
    document.querySelectorAll('[data-pipeline-bar]').forEach((bar) => {
      const el = bar as HTMLElement;
      const current = parseInt(el.style.width) || parseInt(el.getAttribute('style')?.match(/width:\s*(\d+)/)?.[1] ?? '0');
      const variation = Math.floor(Math.random() * 10) - 5;
      const target = Math.min(100, Math.max(10, current + variation));
      el.style.transition = 'width 0.8s ease-out';
      el.style.width = target + '%';
    });
  });

  // Stage click → scroll to related section
  document.querySelectorAll('.pipeline-stage').forEach((stage) => {
    stage.addEventListener('click', () => {
      const name = stage.getAttribute('data-stage');
      if (!name) return;
      const heading = document.querySelector(`article h2[id*="${name}"], .reader-content h2[id*="${name}"]`);
      if (heading) {
        heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
</script>
