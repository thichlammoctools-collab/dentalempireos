---
// Desktop-only sticky right sidebar for section headings (with scroll-spy)
// Compact design: auto-scrolls active item into view

interface SectionItem {
  title: string;
  slug: string;
  level: number;
  sectionNumber: string;
}

interface AttachmentItem {
  id: string;
  type: 'image' | 'file';
  title: string;
  url: string;
  caption?: string;
  filename?: string;
  mime?: string | null;
  mimeLabel?: string;
  sectionSlug: string;
  sectionTitle: string;
  ext?: string;
  previewable: boolean;
}

interface Props {
  sections: SectionItem[];
  attachments?: AttachmentItem[];
  chapterId?: string;
  chapterTitle?: string;
}

const { sections, attachments = [], chapterId = '', chapterTitle = '' } = Astro.props;
const attachmentCount = attachments.length;

const numberedSections = sections.map((section) => {
  const num = section.sectionNumber || '';
  const depth = num ? num.split('.').length : 0;
  const isRoot = depth <= 1;
  const indentPx = Math.max(0, depth - 1) * 12;
  const linkColorStyle = isRoot
    ? 'color: var(--reader-chrome-text); opacity: 0.8;'
    : 'color: var(--reader-chrome-text-muted); opacity: 0.55;';
  const linkStyle = `padding-left: ${8 + indentPx}px; ${linkColorStyle}`;
  const numStyle = 'min-width: 2em';
  const linkCls = isRoot
    ? 'section-nav-link group flex items-center gap-1.5 rounded-md text-[14px] transition-all duration-150 font-semibold py-1.5 px-2'
    : 'section-nav-link group flex items-center gap-1.5 rounded-md text-[14px] transition-all duration-150 py-1 px-2';
  const numCls = isRoot
    ? 'font-mono tabular-nums shrink-0 transition-colors text-[10px] text-primary/50'
    : 'font-mono tabular-nums shrink-0 transition-colors text-[10px] text-primary/30';
  return { ...section, num, depth, linkCls, linkStyle, numCls, numStyle };
});
---

<!-- ============ DESKTOP: Compact right sidebar ============ -->
<aside
  id="section-nav-desktop"
  class="section-nav-desktop hidden lg:flex flex-col sticky top-20 self-start w-[350px] shrink-0 max-h-[calc(100vh-6rem)] overflow-y-auto border-r"
  style="background: var(--reader-chrome-bg); border-color: var(--reader-border);"
>
  <!-- Header: inline title + attachment link -->
  <div class="px-3 pt-3 pb-1.5 sticky top-0 z-10 backdrop-blur-sm border-b" style="background: var(--reader-chrome-bg); border-color: var(--reader-border);">
    <div class="flex items-center justify-between">
      <h3 class="text-[13px] font-bold uppercase tracking-wider flex items-center gap-1.5" style="color: var(--reader-chrome-text-muted);">
        <span class="material-symbols-outlined text-[15px] text-primary/70">format_list_numbered</span>
        Đề mục
      </h3>
      {attachmentCount > 0 && (
        <a href="#attachments-summary" class="flex items-center gap-1 px-1.5 py-0.5 rounded-md text-[10px] font-semibold text-primary/70 hover:text-primary hover:bg-primary/5 transition-all" title={`${attachmentCount} tệp đính kèm`}>
          <span class="material-symbols-outlined text-[12px]">attachment</span>
          {attachmentCount}
        </a>
      )}
    </div>
  </div>

  <!-- Section links -->
  <nav class="flex-1 overflow-y-auto py-1.5 px-1.5" id="section-nav-links">
    {numberedSections.map((section) => (
      <a
        href={`#${section.slug}`}
        class={section.linkCls}
        style={section.linkStyle}
        data-section-link={section.slug}
      >
        {section.num && (
          <span class={section.numCls} style={section.numStyle}>{section.num}</span>
        )}
        <span class="truncate">{section.title}</span>
      </a>
    ))}
  </nav>
</aside>

<style>
  /* Active section highlight */
  .section-nav-link.section-nav-active {
    background: rgba(146, 204, 255, 0.1);
    color: var(--color-primary) !important;
  }
  .section-nav-link.section-nav-active .section-nav-num {
    color: var(--color-primary);
  }
  .section-nav-link:not(.section-nav-active):hover {
    background: var(--reader-chrome-surface);
    color: var(--reader-chrome-text);
  }

  /* Compact scrollbar */
  .section-nav-desktop::-webkit-scrollbar { width: 2px; }
  .section-nav-desktop::-webkit-scrollbar-thumb { background: var(--reader-scrollbar); border-radius: 99px; }
  .section-nav-desktop::-webkit-scrollbar-track { background: transparent; }

  [data-section-link] { scroll-margin-top: 6rem; }
</style>

<script>
  (function () {
    const READER_OFFSET = 80;

    function initDesktopSectionNav() {
      const readerScroll = document.getElementById('reader-scroll');
      if (!readerScroll) return;

      const sectionLinks = document.querySelectorAll('[data-section-link]');
      const headings = document.querySelectorAll('.reader-content h2[id], .reader-content h3[id]');

      if (headings.length > 0 && sectionLinks.length > 0) {
        let activeId: string | null = null;

        const observer = new IntersectionObserver(
          (entries) => {
            const visible = entries
              .filter((e) => e.isIntersecting)
              .sort((a, b) => Math.abs(a.boundingClientRect.top) - Math.abs(b.boundingClientRect.top));

            if (visible.length > 0) {
              const id = visible[0].target.id;
              if (id !== activeId) {
                activeId = id;
                sectionLinks.forEach((link) => {
                  const isActive = (link as HTMLElement).dataset.sectionLink === id;
                  link.classList.toggle('section-nav-active', isActive);
                  // Auto-scroll active link into view within the nav
                  if (isActive) {
                    const navLinks = document.getElementById('section-nav-links');
                    if (navLinks) {
                      const linkRect = link.getBoundingClientRect();
                      const navRect = navLinks.getBoundingClientRect();
                      // Only scroll if link is outside visible area
                      if (linkRect.top < navRect.top + 40 || linkRect.bottom > navRect.bottom - 20) {
                        link.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                      }
                    }
                  }
                });
              }
            }
          },
          { rootMargin: `-${READER_OFFSET}px 0px -60% 0px`, threshold: 0 }
        );

        headings.forEach((h) => observer.observe(h));
      }

      // Click to scroll within reader
      sectionLinks.forEach((link) => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const hash = (link as HTMLAnchorElement).getAttribute('href');
          if (hash && hash !== '#') {
            const target = document.getElementById(hash.slice(1));
            if (target) {
              const top = target.getBoundingClientRect().top + readerScroll.scrollTop - READER_OFFSET;
              readerScroll.scrollTo({ top, behavior: 'smooth' });
            } else {
              // Heading was stripped from DOM (first heading removed to avoid dupe with BookHeader)
              readerScroll.scrollTo({ top: 0, behavior: 'smooth' });
            }
            history.replaceState(null, '', hash);
          }
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initDesktopSectionNav);
    } else {
      initDesktopSectionNav();
    }
  })();
</script>
