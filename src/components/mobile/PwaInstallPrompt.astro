---
// PWA install prompt — floating banner phía dưới mobile.
// Tự ẩn nếu user đã cài app (standalone) hoặc đã dismiss.
// iOS Safari: hướng dẫn Share → Add to Home Screen.
// Android Chrome: button "Cài đặt" trigger beforeinstallprompt.
---

<div
  id="pwa-install-prompt"
  class="fixed left-2 right-2 z-[101] lg:hidden hidden transition-all duration-300"
  style="bottom: calc(64px + env(safe-area-inset-bottom, 0px) + 8px);"
  role="dialog"
  aria-label="Hướng dẫn cài đặt ứng dụng"
>
  <div class="relative flex items-start gap-3 p-3 rounded-2xl bg-surface-container-highest border shadow-2xl backdrop-blur-xl" style="border-color: var(--color-outline-variant);">
    <!-- App icon -->
    <div class="shrink-0 w-11 h-11 rounded-xl bg-primary/15 flex items-center justify-center overflow-hidden">
      <img src="/icons/icon-192.png" alt="Dental Empire" class="w-11 h-11 rounded-xl" width="44" height="44" />
    </div>

    <!-- Content -->
    <div class="flex-1 min-w-0">
      <!-- iOS variant -->
      <div data-variant="ios" class="hidden">
        <p class="text-sm font-semibold text-on-surface leading-tight">Cài Dental Empire</p>
        <p class="text-xs text-on-surface-variant leading-snug mt-0.5">
          Bấm
          <span class="inline-flex items-center justify-center w-4 h-4 align-middle mx-0.5">
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-primary"><path d="M12 2l1.5 4.5L18 8l-4.5 1.5L12 14l-1.5-4.5L6 8l4.5-1.5L12 2zM5 16l1 3 3 1-3 1-1 3-1-3-3-1 3-1 1-3zm14 0l.7 2.3 2.3.7-2.3.7-.7 2.3-.7-2.3-2.3-.7 2.3-.7.7-2.3zM12 17l.8 2.5 2.5.8-2.5.8-.8 2.5-.8-2.5-2.5-.8 2.5-.8L12 17z"/></svg>
          </span>
          (Share) rồi chọn <strong class="text-on-surface">"Thêm vào MH chính"</strong>
        </p>
      </div>
      <!-- Android variant -->
      <div data-variant="android" class="hidden">
        <p class="text-sm font-semibold text-on-surface leading-tight">Cài Dental Empire</p>
        <p class="text-xs text-on-surface-variant leading-snug mt-0.5">Đọc nhanh hơn, dùng offline, tiết kiệm pin.</p>
      </div>
      <!-- Fallback (desktop or unknown) -->
      <div data-variant="other" class="hidden">
        <p class="text-sm font-semibold text-on-surface leading-tight">Cài Dental Empire</p>
        <p class="text-xs text-on-surface-variant leading-snug mt-0.5">Thêm app vào màn hình để truy cập nhanh.</p>
      </div>
    </div>

    <!-- Action button (Android only) -->
    <button
      id="pwa-install-btn"
      data-variant-show="android"
      type="button"
      class="hidden shrink-0 px-3 py-1.5 rounded-lg bg-primary text-on-primary text-xs font-semibold hover:bg-primary/90 active:scale-95 transition-all"
    >
      Cài đặt
    </button>

    <!-- Close button -->
    <button
      id="pwa-install-close"
      type="button"
      aria-label="Đóng"
      class="shrink-0 -mt-1 -mr-1 w-7 h-7 rounded-full flex items-center justify-center hover:bg-surface-container transition-colors"
    >
      <span class="material-symbols-outlined text-base text-on-surface-variant">close</span>
    </button>
  </div>
</div>

<style>
  #pwa-install-prompt.is-visible {
    display: block;
    animation: pwa-slide-up 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes pwa-slide-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  (function () {
    var banner = document.getElementById('pwa-install-prompt');
    var installBtn = document.getElementById('pwa-install-btn');
    var closeBtn = document.getElementById('pwa-install-close');
    if (!banner || !closeBtn) return;

    // Đã cài app (standalone) → không hiện
    var isStandalone =
      window.matchMedia('(display-mode: standalone)').matches ||
      window.matchMedia('(display-mode: fullscreen)').matches ||
      (window.navigator as any).standalone === true;
    if (isStandalone) return;

    // Đã dismiss trong 7 ngày qua → không hiện
    var DISMISS_KEY = 'pwa-install-dismissed-at';
    var DISMISS_DAYS = 7;
    try {
      var dismissedAt = parseInt(localStorage.getItem(DISMISS_KEY) || '0', 10);
      if (dismissedAt && Date.now() - dismissedAt < DISMISS_DAYS * 24 * 60 * 60 * 1000) return;
    } catch (e) {}

    // Detect platform
    var ua = navigator.userAgent;
    var isIOS = /iPad|iPhone|iPod/.test(ua) && !(window as any).MSStream;
    var isAndroid = /Android/.test(ua);

    var variant: 'ios' | 'android' | 'other' = 'other';
    if (isIOS) variant = 'ios';
    else if (isAndroid) variant = 'android';

    function show() {
      if (!banner) return;
      // Show correct variant
      banner.querySelectorAll('[data-variant]').forEach(function (el) {
        if (el.getAttribute('data-variant') === variant) el.classList.remove('hidden');
        else el.classList.add('hidden');
      });
      // Show install button only for Android
      if (installBtn) {
        if (variant === 'android' && (window as any).__deferredPrompt) {
          installBtn.classList.remove('hidden');
        } else {
          installBtn.classList.add('hidden');
        }
      }
      banner.classList.remove('hidden');
      banner.classList.add('is-visible');
    }

    function hide(reason?: 'dismissed' | 'installed') {
      if (!banner) return;
      banner.classList.remove('is-visible');
      setTimeout(function () { banner.classList.add('hidden'); }, 300);
      if (reason === 'dismissed') {
        try { localStorage.setItem(DISMISS_KEY, String(Date.now())); } catch (e) {}
      } else if (reason === 'installed') {
        try { localStorage.setItem(DISMISS_KEY, String(Date.now())); } catch (e) {}
      }
    }

    closeBtn.addEventListener('click', function () { hide('dismissed'); });

    if (installBtn) {
      installBtn.addEventListener('click', async function () {
        var promptEvent = (window as any).__deferredPrompt;
        if (!promptEvent) { hide('dismissed'); return; }
        promptEvent.prompt();
        try {
          var choice = await promptEvent.userChoice;
          if (choice && choice.outcome === 'accepted') hide('installed');
          else hide('dismissed');
        } catch (e) {
          hide('dismissed');
        }
        (window as any).__deferredPrompt = null;
      });
    }

    // iOS: show sau 4s (không có beforeinstallprompt)
    if (isIOS) {
      setTimeout(show, 4000);
      return;
    }

    // Android: đợi beforeinstallprompt (Chrome heuristic)
    var shown = false;
    function tryShow() {
      if (shown) return;
      // Android cần beforeinstallprompt mới cho install; nếu không có vẫn hiện "other" hướng dẫn
      if (variant === 'android' && !(window as any).__deferredPrompt) return;
      shown = true;
      setTimeout(show, 4000);
    }

    window.addEventListener('beforeinstallprompt', function (e: Event) {
      e.preventDefault();
      (window as any).__deferredPrompt = e;
      tryShow();
    });

    // Fallback: nếu 8s không có prompt thì vẫn hiện banner với variant "other" cho Android
    if (isAndroid) {
      setTimeout(function () {
        if (shown) return;
        shown = true;
        show();
      }, 8000);
    }
  })();
</script>