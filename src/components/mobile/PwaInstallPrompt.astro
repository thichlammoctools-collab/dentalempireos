---
// PWA install prompt — floating banner mobile only.
// Android: collapsed → click expand → 5-step guide + email capture
// iOS: always expanded (no beforeinstallprompt) → step-by-step guide
// Desktop: NOT shown (lg:hidden)
---

<div
  id="pwa-install-prompt"
  class="fixed left-3 right-3 z-[101] lg:hidden hidden transition-all duration-300"
  style="bottom: calc(64px + env(safe-area-inset-bottom, 0px) + 10px);"
  role="alert"
>
  <div class="rounded-2xl bg-surface-container-highest border shadow-2xl overflow-hidden transition-all duration-300" style="border-color: var(--color-outline-variant);">

    <!-- ========== ANDROID (collapsed → expandable) ========== -->
    <div data-variant="android" class="hidden">
      <!-- Collapsed state (default) -->
      <div id="android-collapsed" class="flex items-center gap-3 p-3">
        <img src="/icons/icon-192.png" alt="" class="w-10 h-10 rounded-lg shrink-0" width="40" height="40" />
        <div class="flex-1 min-w-0">
          <p class="text-sm font-bold text-on-surface leading-tight">📖 Hướng dẫn cài Android</p>
          <p class="text-[11px] text-on-surface-variant leading-snug mt-0.5">Đọc offline, mở nhanh từ màn hình chính</p>
        </div>
        <button id="pwa-expand-btn" type="button"
          class="shrink-0 px-3 py-1.5 rounded-lg bg-primary text-on-primary text-[11px] font-bold hover:bg-primary/90 active:scale-95 transition-all">
          Xem ngay →
        </button>
        <button id="pwa-install-close-android" type="button" aria-label="Đóng"
          class="shrink-0 w-7 h-7 rounded-full flex items-center justify-center hover:bg-surface-container transition-colors">
          <span class="material-symbols-outlined text-sm text-on-surface-variant">close</span>
        </button>
      </div>

      <!-- Expanded state -->
      <div id="android-expanded" class="hidden p-4 pt-3">
        <div class="flex items-center justify-between mb-3">
          <p class="text-sm font-bold text-on-surface">📖 Hướng dẫn cài Android</p>
          <button id="pwa-collapse-btn" type="button"
            class="w-7 h-7 rounded-full flex items-center justify-center hover:bg-surface-container transition-colors">
            <span class="material-symbols-outlined text-sm text-on-surface-variant">expand_less</span>
          </button>
        </div>

        <div class="space-y-2.5">
          <!-- Step 1 -->
          <div class="flex items-center gap-3 p-2.5 rounded-xl bg-surface-container">
            <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
              <span class="text-xs font-black text-primary">1</span>
            </div>
            <p class="text-xs text-on-surface leading-snug">Mở trang này bằng <strong class="text-primary">Chrome</strong></p>
          </div>
          <!-- Step 2 -->
          <div class="flex items-center gap-3 p-2.5 rounded-xl bg-surface-container">
            <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
              <span class="text-xs font-black text-primary">2</span>
            </div>
            <p class="text-xs text-on-surface leading-snug">Bấm <strong class="text-primary">⋮</strong> (3 chấm trên cùng)</p>
          </div>
          <!-- Step 3 -->
          <div class="flex items-center gap-3 p-2.5 rounded-xl bg-surface-container">
            <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
              <span class="text-xs font-black text-primary">3</span>
            </div>
            <p class="text-xs text-on-surface leading-snug">Bấm <strong class="text-primary">Cài ứng dụng</strong> hoặc <strong class="text-primary">Thêm vào MH chính</strong></p>
          </div>
          <!-- Step 4 -->
          <div class="flex items-center gap-3 p-2.5 rounded-xl bg-surface-container">
            <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
              <span class="text-xs font-black text-primary">4</span>
            </div>
            <p class="text-xs text-on-surface leading-snug">Đổi tên → <strong class="text-primary">Dental Empire</strong></p>
          </div>
          <!-- Step 5 -->
          <div class="flex items-center gap-3 p-2.5 rounded-xl bg-green-500/10">
            <div class="w-9 h-9 rounded-lg bg-green-500/10 flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-green-400 text-base">check_circle</span>
            </div>
            <p class="text-xs text-on-surface leading-snug"><strong class="text-green-400">Bấm THÊM</strong> ✅ — Icon Dental Empire sẽ xuất hiện trên MH chính</p>
          </div>
        </div>

        <!-- Email capture -->
        <div class="mt-3 p-3 rounded-xl bg-primary/5 border border-primary/20">
          <p class="text-xs text-on-surface mb-2">📧 Để lại email, mình sẽ báo khi có ebook mới (miễn phí).</p>
          <div class="flex gap-2">
            <input type="email" id="pwa-email-input" placeholder="email@gmail.com"
              class="flex-1 px-3 py-2 text-xs bg-surface-container border border-outline-variant/30 rounded-lg text-on-surface placeholder:text-on-surface-variant/40 focus:outline-none focus:ring-1 focus:ring-primary" />
            <button id="pwa-email-submit" type="button"
              class="shrink-0 px-3 py-2 rounded-lg bg-primary text-on-primary text-xs font-bold hover:bg-primary/90 active:scale-95 transition-all">
              Gửi
            </button>
          </div>
          <p id="pwa-email-msg" class="text-[10px] text-green-400 mt-1 hidden"></p>
        </div>
      </div>
    </div>

    <!-- ========== iOS (always expanded) ========== -->
    <div data-variant="ios" class="hidden">
      <div class="p-4">
        <div class="flex items-center justify-between mb-3">
          <p class="text-sm font-bold text-on-surface">📖 Hướng dẫn cài iOS</p>
          <button id="pwa-install-close-ios" type="button" aria-label="Đóng"
            class="w-7 h-7 rounded-full flex items-center justify-center hover:bg-surface-container transition-colors">
            <span class="material-symbols-outlined text-sm text-on-surface-variant">close</span>
          </button>
        </div>

        <div class="space-y-2.5">
          <!-- Step 1 -->
          <div class="flex items-center gap-3 p-2.5 rounded-xl bg-surface-container">
            <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
              <span class="text-xs font-black text-primary">1</span>
            </div>
            <p class="text-xs text-on-surface leading-snug">Mở trang này trên <strong class="text-primary">Safari</strong></p>
          </div>
          <!-- Step 2 -->
          <div class="flex items-center gap-3 p-2.5 rounded-xl bg-surface-container">
            <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
              <span class="text-xs font-black text-primary">2</span>
            </div>
            <p class="text-xs text-on-surface leading-snug">Bấm <strong class="text-primary">↗️ Chia sẻ</strong> (icon mũi tên trên cùng)</p>
          </div>
          <!-- Step 3 -->
          <div class="flex items-center gap-3 p-2.5 rounded-xl bg-surface-container">
            <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
              <span class="text-xs font-black text-primary">3</span>
            </div>
            <p class="text-xs text-on-surface leading-snug">Cuộn xuống → chọn <strong class="text-primary">"Thêm vào MH chính"</strong></p>
          </div>
          <!-- Step 4 -->
          <div class="flex items-center gap-3 p-2.5 rounded-xl bg-surface-container">
            <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
              <span class="text-xs font-black text-primary">4</span>
            </div>
            <p class="text-xs text-on-surface leading-snug">Đổi tên → <strong class="text-primary">Dental Empire</strong></p>
          </div>
          <!-- Step 5 -->
          <div class="flex items-center gap-3 p-2.5 rounded-xl bg-green-500/10">
            <div class="w-9 h-9 rounded-lg bg-green-500/10 flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-green-400 text-base">check_circle</span>
            </div>
            <p class="text-xs text-on-surface leading-snug"><strong class="text-green-400">Bấm THÊM</strong> ✅ — Icon Dental Empire sẽ xuất hiện trên MH chính</p>
          </div>
        </div>

        <!-- Email capture -->
        <div class="mt-3 p-3 rounded-xl bg-primary/5 border border-primary/20">
          <p class="text-xs text-on-surface mb-2">📧 Để lại email, mình sẽ báo khi có ebook mới (miễn phí).</p>
          <div class="flex gap-2">
            <input type="email" id="pwa-email-input" placeholder="email@gmail.com"
              class="flex-1 px-3 py-2 text-xs bg-surface-container border border-outline-variant/30 rounded-lg text-on-surface placeholder:text-on-surface-variant/40 focus:outline-none focus:ring-1 focus:ring-primary" />
            <button id="pwa-email-submit" type="button"
              class="shrink-0 px-3 py-2 rounded-lg bg-primary text-on-primary text-xs font-bold hover:bg-primary/90 active:scale-95 transition-all">
              Gửi
            </button>
          </div>
          <p id="pwa-email-msg" class="text-[10px] text-green-400 mt-1 hidden"></p>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  #pwa-install-prompt.is-visible {
    display: block !important;
    animation: pwa-slide-up 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes pwa-slide-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  (function () {
    var banner = document.getElementById('pwa-install-prompt');
    if (!banner) return;

    // Not on desktop
    if (window.matchMedia('(min-width: 1024px)').matches) return;

    // Already installed
    var isStandalone =
      window.matchMedia('(display-mode: standalone)').matches ||
      window.matchMedia('(display-mode: fullscreen)').matches ||
      (window.navigator as any).standalone === true;
    if (isStandalone) return;

    // Dismissed in last 7 days
    var DISMISS_KEY = 'pwa-install-dismissed-at';
    try {
      var dismissedAt = parseInt(localStorage.getItem(DISMISS_KEY) || '0', 10);
      if (dismissedAt && Date.now() - dismissedAt < 7 * 24 * 60 * 60 * 1000) return;
    } catch (e) {}

    var ua = navigator.userAgent;
    var isIOS = /iPad|iPhone|iPod/.test(ua) && !(window as any).MSStream;
    var isAndroid = /Android/.test(ua);

    var variant: 'ios' | 'android' = isIOS ? 'ios' : 'android';

    function show() {
      banner.querySelectorAll('[data-variant]').forEach(function (el) { el.classList.add('hidden'); });
      var target = banner.querySelector('[data-variant="' + variant + '"]');
      if (target) target.classList.remove('hidden');

      // Android: if deferred prompt available, auto-expand
      if (variant === 'android' && (window as any).__deferredPrompt) {
        var collapsed = document.getElementById('android-collapsed');
        var expanded = document.getElementById('android-expanded');
        if (collapsed) collapsed.classList.add('hidden');
        if (expanded) expanded.classList.remove('hidden');
        // Replace "Xem ngay" with install button
        var expandBtn = document.getElementById('pwa-expand-btn');
        if (expandBtn) {
          expandBtn.textContent = 'Cài đặt';
          expandBtn.onclick = async function () {
            var e = (window as any).__deferredPrompt;
            if (!e) { hide(); return; }
            e.prompt();
            var choice = await e.userChoice;
            if (choice?.outcome === 'accepted') hide();
            (window as any).__deferredPrompt = null;
          };
        }
      }

      banner.classList.remove('hidden');
      banner.classList.add('is-visible');
    }

    function hide() {
      banner.classList.remove('is-visible');
      setTimeout(function () { banner.classList.add('hidden'); }, 300);
      try { localStorage.setItem(DISMISS_KEY, String(Date.now())); } catch (e) {}
    }

    // Close buttons
    banner.querySelectorAll('[id^="pwa-install-close"]').forEach(function (btn) {
      (btn as HTMLElement).onclick = function () { hide(); };
    });

    // Android expand/collapse
    var expandBtn = document.getElementById('pwa-expand-btn');
    var collapseBtn = document.getElementById('pwa-collapse-btn');
    var androidCollapsed = document.getElementById('android-collapsed');
    var androidExpanded = document.getElementById('android-expanded');

    expandBtn && expandBtn.addEventListener('click', function () {
      androidCollapsed?.classList.add('hidden');
      androidExpanded?.classList.remove('hidden');
    });

    collapseBtn && collapseBtn.addEventListener('click', function () {
      androidExpanded?.classList.add('hidden');
      androidCollapsed?.classList.remove('hidden');
    });

    // Email capture (shared)
    var emailSubmit = document.getElementById('pwa-email-submit');
    var emailInput = document.getElementById('pwa-email-input');
    var emailMsg = document.getElementById('pwa-email-msg');
    emailSubmit?.addEventListener('click', async function () {
      if (!emailInput || !emailMsg) return;
      var email = (emailInput as HTMLInputElement).value.trim();
      if (!email || !email.includes('@')) {
        emailMsg.textContent = '⚠️ Vui lòng nhập đúng email';
        emailMsg.classList.remove('hidden', 'text-green-400');
        emailMsg.classList.add('text-red-400');
        return;
      }
      try {
        await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
      } catch (e) {}
      emailMsg.textContent = '✅ Cảm ơn bạn! Mình sẽ báo khi có ebook mới.';
      emailMsg.classList.remove('hidden', 'text-red-400');
      emailMsg.classList.add('text-green-400');
      (emailInput as HTMLInputElement).value = '';
    });

    // === Show timing ===
    // iOS: always show (no beforeinstallprompt)
    if (isIOS) { setTimeout(show, 4000); return; }

    // Android: try deferred prompt first
    var shown = false;
    function tryShow() {
      if (shown) return;
      shown = true;
      show();
    }

    window.addEventListener('beforeinstallprompt', function (e: Event) {
      e.preventDefault();
      (window as any).__deferredPrompt = e;
      setTimeout(tryShow, 1000);
    });

    // Android fallback: 8s
    setTimeout(function () { if (!shown) tryShow(); }, 8000);
  })();
</script>