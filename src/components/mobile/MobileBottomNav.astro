---
interface TierGroup {
  tier: number;
  label: string;
  chapters: Array<{ id: string; data: { title: string; tier: number; chapter: number } }>;
}

interface Props {
  currentPath: string;
  groupedChapters?: TierGroup[];
  currentSlug?: string;
  isReading?: boolean;
}

const { currentPath, groupedChapters = [], currentSlug = '' } = Astro.props;

const getNavState = () => {
  if (currentPath === '/') return 'home';
  if (currentPath.startsWith('/book') && !currentPath.includes('/book/')) return 'library';
  if (currentPath.startsWith('/blog')) return 'blog';
  if (currentPath.startsWith('/resources')) return 'resources';
  if (currentPath.startsWith('/videos')) return 'videos';
  return '';
};

const activeNav = getNavState();
---

<!-- ========== MENU DRAWER ========== -->
<div id="menu-overlay" class="fixed inset-0 z-[104] bg-black/50 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"></div>

<div
  id="menu-drawer"
  class="fixed top-0 right-0 z-[105] w-[85vw] max-w-xs h-full bg-surface-container-lowest transform translate-x-full transition-transform duration-300 ease-out flex flex-col shadow-2xl lg:hidden"
>
  <!-- Header -->
  <div class="flex items-center justify-between px-5 py-4 border-b" style="border-color: var(--color-outline-variant);">
    <div class="flex items-center gap-2">
      <span class="material-symbols-outlined text-primary">menu</span>
      <span class="text-sm font-medium text-on-surface">Menu</span>
    </div>
    <button id="menu-close" class="flex items-center justify-center w-9 h-9 rounded-full hover:bg-surface-container-high transition-colors">
      <span class="material-symbols-outlined text-on-surface-variant">close</span>
    </button>
  </div>

  <!-- Content -->
  <div class="flex-1 overflow-y-auto">

    <!-- Auth: Logged Out -->
    <div id="menu-auth-logged-out" class="px-4 pt-4 pb-2 space-y-2">
      <a href="/signin" class="flex items-center gap-3 p-3 rounded-xl bg-primary text-on-primary font-medium hover:bg-primary/90 transition-colors">
        <span class="material-symbols-outlined text-sm">login</span>
        <span>Đăng nhập</span>
      </a>
      <a href="/signup" class="flex items-center gap-3 p-3 rounded-xl bg-surface-container hover:bg-surface-container-high transition-colors">
        <span class="material-symbols-outlined text-sm text-on-surface-variant">person_add</span>
        <span class="text-sm text-on-surface">Đăng ký</span>
      </a>
    </div>

    <!-- Auth: Logged In -->
    <div id="menu-auth-logged-in" class="hidden px-4 pt-4 pb-2">
      <div class="flex items-center gap-3 p-3 rounded-xl bg-surface-container mb-2">
        <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center">
          <span class="material-symbols-outlined text-primary">person</span>
        </div>
        <div class="flex-1 min-w-0">
          <p id="menu-user-name" class="text-sm font-medium text-on-surface truncate">Người dùng</p>
          <p id="menu-user-email" class="text-xs text-on-surface-variant truncate"></p>
        </div>
      </div>
      <a href="/my-questions" class="flex items-center gap-3 p-3 rounded-xl hover:bg-surface-container transition-colors">
        <span class="material-symbols-outlined text-sm text-on-surface-variant">quiz</span>
        <span class="text-sm text-on-surface">Câu hỏi của tôi</span>
      </a>
      <button id="menu-logout" class="w-full flex items-center gap-3 p-3 rounded-xl hover:bg-surface-container transition-colors text-left">
        <span class="material-symbols-outlined text-sm text-on-surface-variant">logout</span>
        <span class="text-sm text-on-surface">Đăng xuất</span>
      </button>
    </div>

    <div class="mx-4 my-2 border-t" style="border-color: var(--color-outline-variant);"></div>

    <!-- Navigation -->
    <nav class="px-4 py-2 space-y-1">
      <a href="/#courses" class="flex items-center gap-3 p-3 rounded-xl hover:bg-surface-container transition-colors">
        <span class="material-symbols-outlined text-sm text-on-surface-variant">school</span>
        <span class="text-sm text-on-surface">Khóa học</span>
      </a>
      <a href="/#resources" class="flex items-center gap-3 p-3 rounded-xl hover:bg-surface-container transition-colors">
        <span class="material-symbols-outlined text-sm text-on-surface-variant">folder_special</span>
        <span class="text-sm text-on-surface">Tài nguyên</span>
      </a>
      <a href="/#reviews" class="flex items-center gap-3 p-3 rounded-xl hover:bg-surface-container transition-colors">
        <span class="material-symbols-outlined text-sm text-on-surface-variant">rate_review</span>
        <span class="text-sm text-on-surface">Đánh giá</span>
      </a>
      <a href="/#about" class="flex items-center gap-3 p-3 rounded-xl hover:bg-surface-container transition-colors">
        <span class="material-symbols-outlined text-sm text-on-surface-variant">info</span>
        <span class="text-sm text-on-surface">Giới thiệu</span>
      </a>
    </nav>

    <div class="mx-4 my-2 border-t" style="border-color: var(--color-outline-variant);"></div>

    <!-- Bookmarks -->
    <div id="menu-bookmarks" class="hidden px-4 py-2">
      <p class="text-xs font-medium text-on-surface-variant uppercase tracking-wider px-3 mb-2">Đã lưu gần đây</p>
      <div id="menu-bookmarks-list" class="space-y-1"></div>
    </div>

    <!-- Theme Toggle -->
    <div class="px-4 py-3">
      <button id="menu-theme-toggle" class="flex items-center justify-between w-full p-3 rounded-xl bg-surface-container hover:bg-surface-container-high transition-colors">
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-sm text-on-surface-variant">dark_mode</span>
          <span class="text-sm text-on-surface">Chế độ tối</span>
        </div>
        <div class="relative w-10 h-6 bg-surface-container-high rounded-full p-0.5">
          <div id="menu-theme-knob" class="w-5 h-5 bg-on-surface-variant rounded-full transition-transform duration-200"></div>
        </div>
      </button>
    </div>
  </div>
</div>

<!-- ========== BOTTOM NAV ========== -->
<nav
  id="mobile-bottom-nav"
  class="fixed bottom-0 left-0 right-0 z-[100] backdrop-blur-xl border-t lg:hidden"
  style="background: var(--reader-chrome-bg, var(--color-surface-container-lowest)); border-color: var(--reader-border, var(--color-outline-variant)); padding-bottom: env(safe-area-inset-bottom, 0px);"
>
  <div class="flex items-center justify-around h-16">
    <!-- Trang chủ -->
    <a
      href="/"
      class:list={[
        'flex flex-col items-center justify-center flex-1 h-full gap-0.5 transition-all duration-200',
        activeNav === 'home' ? 'text-primary' : 'text-on-surface-variant'
      ]}
    >
      <span class="material-symbols-outlined text-2xl">home</span>
      <span class="text-[10px] font-medium">Trang chủ</span>
    </a>

    <!-- Blog -->
    <a
      href="/blog"
      class:list={[
        'flex flex-col items-center justify-center flex-1 h-full gap-0.5 transition-all duration-200',
        activeNav === 'blog' ? 'text-primary' : 'text-on-surface-variant'
      ]}
    >
      <span class="material-symbols-outlined text-2xl">article</span>
      <span class="text-[10px] font-medium">Blog</span>
    </a>

    <!-- Đọc sách -->
    <a
      href="/book"
      class:list={[
        'flex flex-col items-center justify-center flex-1 h-full gap-0.5 transition-all duration-200',
        activeNav === 'library' ? 'text-primary' : 'text-on-surface-variant'
      ]}
    >
      <span class="material-symbols-outlined text-2xl">menu_book</span>
      <span class="text-[10px] font-medium">Đọc sách</span>
    </a>

    <!-- Tài nguyên -->
    <a
      href="/resources"
      class:list={[
        'flex flex-col items-center justify-center flex-1 h-full gap-0.5 transition-all duration-200',
        activeNav === 'resources' ? 'text-primary' : 'text-on-surface-variant'
      ]}
    >
      <span class="material-symbols-outlined text-2xl">folder_special</span>
      <span class="text-[10px] font-medium">Tài nguyên</span>
    </a>

    <!-- Video -->
    <a
      href="/videos"
      class:list={[
        'flex flex-col items-center justify-center flex-1 h-full gap-0.5 transition-all duration-200',
        activeNav === 'videos' ? 'text-primary' : 'text-on-surface-variant'
      ]}
    >
      <span class="material-symbols-outlined text-2xl">play_circle</span>
      <span class="text-[10px] font-medium">Video</span>
    </a>
  </div>
</nav>

<!-- ========== CHAPTER DRAWER ========== -->
<div
  id="mobile-chapter-drawer"
  class="fixed inset-x-0 bottom-0 z-[95] rounded-t-3xl shadow-2xl transform translate-y-full transition-transform duration-300 ease-out lg:hidden flex flex-col"
  style="background: var(--reader-chrome-bg, var(--color-surface-container-lowest)); max-height: 70vh;"
>
  <div id="chapter-drawer-handle" class="flex justify-center pt-3 pb-2 cursor-grab active:cursor-grabbing">
    <div class="w-12 h-1.5 rounded-full bg-outline-variant"></div>
  </div>
  <div class="px-5 pb-3 border-b" style="border-color: var(--reader-border, var(--color-outline-variant));">
    <h3 class="text-lg font-bold r-text">Thư viện sách</h3>
    <p class="text-xs r-text-muted mt-1">Chọn chương để đọc</p>
  </div>
  <div class="flex-1 overflow-y-auto px-4 py-3 space-y-2" id="chapter-drawer-content">
    {groupedChapters.map((group) => (
      <div class="tier-group" data-tier={group.tier}>
        <button
          class="tier-toggle w-full flex items-center justify-between px-3 py-2.5 rounded-xl bg-surface-container-high/50 hover:bg-surface-container-high transition-colors"
          data-tier={group.tier}
        >
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-lg">folder</span>
            <span class="text-sm font-semibold r-text">{group.label}</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-xs r-text-muted r-surface px-2 py-0.5 rounded-full">
              {group.chapters.length} chương
            </span>
            <span class="material-symbols-outlined r-text-muted tier-chevron transition-transform">expand_more</span>
          </div>
        </button>
        <div class="tier-chapters hidden space-y-1 mt-1 pl-2">
          {group.chapters.map((ch: TierGroup['chapters'][number]) => {
            const isActive = ch.id === currentSlug;
            return (
              <a
                href={`/book/${ch.id}`}
                class:list={[
                  'flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-all',
                  isActive
                    ? 'bg-primary/10 text-primary border-l-2 border-primary'
                    : 'r-text-muted r-hover-text r-hover'
                ]}
              >
                <span class="text-xs font-mono text-on-surface-variant/60 w-8">
                  Ch{String(ch.data.chapter).padStart(2, '0')}
                </span>
                <span class="flex-1 truncate">{ch.data.title}</span>
                {isActive && <span class="material-symbols-outlined text-primary text-lg">play_arrow</span>}
              </a>
            );
          })}
        </div>
      </div>
    ))}
  </div>
</div>

<!-- Chapter drawer overlay -->
<div
  id="mobile-drawer-overlay"
  class="fixed inset-0 z-[90] bg-black/50 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"
></div>

<style>
  body.drawer-open { overflow: hidden; }
  .tier-group[data-expanded="true"] .tier-chapters { display: block; }
  .tier-group[data-expanded="true"] .tier-chevron { transform: rotate(180deg); }
  #chapter-drawer-content::-webkit-scrollbar { width: 4px; }
  #chapter-drawer-content::-webkit-scrollbar-thumb { background: var(--reader-scrollbar); border-radius: 4px; }
  @supports (padding-bottom: env(safe-area-inset-bottom)) {
    #mobile-bottom-nav { padding-bottom: env(safe-area-inset-bottom); }
  }
</style>

<script>
  (function() {
    // ====== MENU DRAWER ======
    var menuOverlay = document.getElementById('menu-overlay');
    var menuDrawer = document.getElementById('menu-drawer');
    var menuClose = document.getElementById('menu-close');
    var menuBtn = document.getElementById('mobile-nav-menu');
    var authLoggedOut = document.getElementById('menu-auth-logged-out');
    var authLoggedIn = document.getElementById('menu-auth-logged-in');
    var userNameEl = document.getElementById('menu-user-name');
    var userEmailEl = document.getElementById('menu-user-email');
    var logoutBtn = document.getElementById('menu-logout');
    var bookmarksSection = document.getElementById('menu-bookmarks');
    var bookmarksList = document.getElementById('menu-bookmarks-list');
    var themeToggle = document.getElementById('menu-theme-toggle');
    var themeKnob = document.getElementById('menu-theme-knob');
    var isMenuOpen = false;

    function openMenu() {
      isMenuOpen = true;
      if (menuOverlay) menuOverlay.classList.add('opacity-100', 'pointer-events-auto');
      if (menuOverlay) menuOverlay.classList.remove('opacity-0', 'pointer-events-none');
      if (menuDrawer) menuDrawer.style.transform = 'translateX(0)';
      document.body.style.overflow = 'hidden';
      loadUserState();
      loadBookmarks();
      initThemeKnob();
    }

    function closeMenu() {
      isMenuOpen = false;
      if (menuOverlay) menuOverlay.classList.remove('opacity-100', 'pointer-events-auto');
      if (menuOverlay) menuOverlay.classList.add('opacity-0', 'pointer-events-none');
      if (menuDrawer) menuDrawer.style.transform = 'translateX(100%)';
      document.body.style.overflow = '';
    }

    async function loadUserState() {
      try {
        var res = await fetch('/api/auth/get-session', { credentials: 'include' });
        var session: any = null;
        try { session = await res.json(); } catch {}
        if (session && session.user) {
          if (authLoggedIn) authLoggedIn.classList.remove('hidden');
          if (authLoggedOut) authLoggedOut.classList.add('hidden');
          if (userNameEl) userNameEl.textContent = session.user.name || 'Người dùng';
          if (userEmailEl) userEmailEl.textContent = session.user.email || '';
        } else {
          if (authLoggedIn) authLoggedIn.classList.add('hidden');
          if (authLoggedOut) authLoggedOut.classList.remove('hidden');
        }
      } catch (e) {
        if (authLoggedIn) authLoggedIn.classList.add('hidden');
        if (authLoggedOut) authLoggedOut.classList.remove('hidden');
      }
    }

    function loadBookmarks() {
      if (!bookmarksSection || !bookmarksList) return;
      var items: any[] = [];
      try {
        var bookmarks = JSON.parse(localStorage.getItem('deos_bookmarks') || '[]');
        bookmarks.forEach(function(b: any) { items.push({id:b.id, title:b.title, url:b.url, scrollPct:b.scrollPct, type:'bookmark', savedAt:b.savedAt}); });
      } catch(e) {}
      try {
        var rp = JSON.parse(localStorage.getItem('deos_read_progress') || '{}');
        var currentPath = location.pathname;
        Object.keys(rp).forEach(function(id) {
          var d = rp[id];
          if (d.url && d.url !== currentPath && d.pct > 0 && !items.some(function(i){return i.id===id;})) {
            items.push({id:id, title:d.title, url:d.url, scrollPct:d.pct, type:'progress', ts:d.ts});
          }
        });
      } catch(e) {}
      items.sort(function(a,b){ return (b.savedAt||b.ts||0) - (a.savedAt||b.ts||0); });
      if (items.length > 0) {
        bookmarksSection.classList.remove('hidden');
        var html = '';
        items.slice(0, 8).forEach(function(b) {
          var icon = b.type === 'bookmark' ? 'bookmark' : 'auto_stories';
          var pctBadge = b.scrollPct ? '<span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-primary/15 text-primary shrink-0">'+b.scrollPct+'%</span>' : '';
          html += '<a href="'+b.url+'" class="flex items-center gap-2 p-2.5 rounded-xl bg-surface-container hover:bg-surface-container-high transition-colors group">'
            + '<span class="material-symbols-outlined text-sm text-on-surface-variant/60 group-hover:text-primary shrink-0">'+icon+'</span>'
            + '<span class="flex-1 text-sm truncate text-on-surface-variant group-hover:text-on-surface">'+(b.title||'Chương')+'</span>'
            + pctBadge + '</a>';
        });
        bookmarksList.innerHTML = html;
      } else {
        bookmarksSection.classList.add('hidden');
      }
    }

    function initThemeKnob() {
      if (!themeKnob) return;
      var isDark = document.documentElement.classList.contains('dark');
      themeKnob.style.transform = isDark ? 'translateX(24px)' : 'translateX(0)';
    }

    menuBtn && menuBtn.addEventListener('click', function() {
      isMenuOpen ? closeMenu() : openMenu();
    });
    menuClose && menuClose.addEventListener('click', closeMenu);
    menuOverlay && menuOverlay.addEventListener('click', closeMenu);

    logoutBtn && logoutBtn.addEventListener('click', function() {
      fetch('/api/auth/logout', { method: 'POST', credentials: 'include' })
        .then(function() { window.location.reload(); })
        .catch(function() { window.location.href = '/'; });
    });

    themeToggle && themeToggle.addEventListener('click', function() {
      var isDark = document.documentElement.classList.toggle('dark');
      if (themeKnob) {
        themeKnob.style.transform = isDark ? 'translateX(24px)' : 'translateX(0)';
      }
    });

    // Swipe drawer left to close
    var menuStartX = 0;
    menuDrawer && menuDrawer.addEventListener('touchstart', function(e) {
      menuStartX = e.touches[0].clientX;
    }, { passive: true });
    if (menuDrawer) {
      menuDrawer.addEventListener('touchmove', function(e) {
        if (!isMenuOpen) return;
        var diff = e.touches[0].clientX - menuStartX;
        if (diff > 0) {
          menuDrawer!.style.transform = 'translateX(' + diff + 'px)';
        }
      }, { passive: true });
      menuDrawer.addEventListener('touchend', function(e) {
        var diff = e.changedTouches[0].clientX - menuStartX;
        if (diff > 80) {
          closeMenu();
        } else if (isMenuOpen) {
          menuDrawer!.style.transform = 'translateX(0)';
        }
      });
    }

    // ====== CHAPTER DRAWER ======
    var chapterDrawer = document.getElementById('mobile-chapter-drawer');
    var chapterOverlay = document.getElementById('mobile-drawer-overlay');
    var libraryBtn = document.getElementById('mobile-nav-library');
    var chapterHandle = document.getElementById('chapter-drawer-handle');
    var isChapterOpen = false;
    var startY = 0, currentY = 0;

    function openChapter() {
      isChapterOpen = true;
      if (chapterDrawer) {
        chapterDrawer.classList.remove('translate-y-full');
        chapterDrawer.classList.add('translate-y-0');
      }
      if (chapterOverlay) {
        chapterOverlay.classList.remove('opacity-0', 'pointer-events-none');
        chapterOverlay.classList.add('opacity-100', 'pointer-events-auto');
      }
      document.body.classList.add('drawer-open');
      var currentLink: HTMLElement | null = chapterDrawer ? chapterDrawer.querySelector<HTMLElement>('a[href*="' + location.pathname + '"]') : null;
      if (currentLink) {
        var tierGroup = currentLink.closest('.tier-group');
        if (tierGroup) {
          tierGroup.setAttribute('data-expanded', 'true');
          var linkRef: HTMLElement = currentLink;
          setTimeout(function() { linkRef.scrollIntoView({ behavior: 'smooth', block: 'center' }); }, 100);
        }
      }
    }

    function closeChapter() {
      isChapterOpen = false;
      if (chapterDrawer) {
        chapterDrawer.classList.add('translate-y-full');
        chapterDrawer.classList.remove('translate-y-0');
      }
      if (chapterOverlay) {
        chapterOverlay.classList.add('opacity-0', 'pointer-events-none');
        chapterOverlay.classList.remove('opacity-100', 'pointer-events-auto');
      }
      document.body.classList.remove('drawer-open');
    }

    libraryBtn && libraryBtn.addEventListener('click', function() {
      isChapterOpen ? closeChapter() : openChapter();
    });
    chapterOverlay && chapterOverlay.addEventListener('click', closeChapter);

    document.querySelectorAll('.tier-toggle').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var tier = btn.closest('.tier-group');
        var isExpanded = tier && tier.getAttribute('data-expanded') === 'true';
        if (tier) tier.setAttribute('data-expanded', String(!isExpanded));
      });
    });

    chapterHandle && chapterHandle.addEventListener('touchstart', function(e) {
      startY = e.touches[0].clientY;
    }, { passive: true });
    chapterHandle && chapterHandle.addEventListener('touchmove', function(e) {
      if (!isChapterOpen) return;
      currentY = e.touches[0].clientY;
      var diff = currentY - startY;
      if (diff > 0 && chapterDrawer) {
        chapterDrawer.style.transform = 'translateY(' + diff + 'px)';
      }
    }, { passive: true });
    chapterHandle && chapterHandle.addEventListener('touchend', function() {
      var diff = currentY - startY;
      if (diff > 100) {
        closeChapter();
      } else if (chapterDrawer) {
        chapterDrawer.style.removeProperty('transform');
      }
      currentY = 0;
    });

    // ====== SHARED ======
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        if (isMenuOpen) closeMenu();
        if (isChapterOpen) closeChapter();
      }
    });

    // Expose for inline onclick
    (window as any).__menuOpen = openMenu;
    (window as any).__menuClose = closeMenu;

    // Double-tap nav buttons to scroll to top
    var lastTap = 0;
    document.querySelectorAll('#mobile-bottom-nav a, #mobile-bottom-nav button').forEach(function(el) {
      el.addEventListener('click', function() {
        var now = Date.now();
        if (now - lastTap < 300) {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
        lastTap = now;
      });
    });
  })();
</script>
