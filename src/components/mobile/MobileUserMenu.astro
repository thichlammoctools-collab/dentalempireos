---
// Mobile slide-out user menu
---

<!-- User Menu Overlay -->
<div
  id="mobile-user-overlay"
  class="fixed inset-0 z-[105] bg-black/50 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300"
></div>

<!-- User Menu Drawer -->
<div
  id="mobile-user-drawer"
  class="fixed top-0 right-0 z-[106] w-[85vw] max-w-xs h-full bg-surface-container-low transform translate-x-full transition-transform duration-300 ease-out flex flex-col"
>
  <!-- Header -->
  <div class="flex items-center justify-between px-5 py-4 border-b border-outline-variant">
    <div class="flex items-center gap-2">
      <span class="material-symbols-outlined text-primary">account_circle</span>
      <span class="text-sm font-medium text-on-surface">Menu</span>
    </div>
    <button
      id="mobile-user-close"
      class="flex items-center justify-center w-9 h-9 rounded-full hover:bg-surface-container-high transition-colors"
      aria-label="Đóng menu"
    >
      <span class="material-symbols-outlined text-on-surface-variant">close</span>
    </button>
  </div>

  <!-- Content -->
  <div class="flex-1 overflow-y-auto">

    <!-- Logged Out State -->
    <div id="user-logged-out" class="px-4 pt-4 pb-2 space-y-2">
      <a
        href="/signin"
        class="flex items-center gap-3 p-3 rounded-xl bg-primary text-on-primary font-medium hover:bg-primary/90 transition-colors"
      >
        <span class="material-symbols-outlined text-sm">login</span>
        <span>Đăng nhập</span>
      </a>
      <a
        href="/signup"
        class="flex items-center gap-3 p-3 rounded-xl bg-surface-container hover:bg-surface-container-high transition-colors"
      >
        <span class="material-symbols-outlined text-sm text-on-surface-variant">person_add</span>
        <span class="text-sm text-on-surface">Đăng ký</span>
      </a>
    </div>

    <!-- Logged In State -->
    <div id="user-logged-in" class="hidden px-4 pt-4 pb-2">
      <div class="flex items-center gap-3 p-3 rounded-xl bg-surface-container mb-2">
        <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center">
          <span class="material-symbols-outlined text-primary">person</span>
        </div>
        <div class="flex-1 min-w-0">
          <p id="user-name" class="text-sm font-medium text-on-surface truncate">Người dùng</p>
          <p id="user-email" class="text-xs text-on-surface-variant truncate"></p>
        </div>
      </div>
      <a
        href="/my-questions"
        class="flex items-center gap-3 p-3 rounded-xl hover:bg-surface-container transition-colors"
      >
        <span class="material-symbols-outlined text-sm text-on-surface-variant">quiz</span>
        <span class="text-sm text-on-surface">Câu hỏi của tôi</span>
      </a>
      <button
        id="user-logout-btn"
        class="w-full flex items-center gap-3 p-3 rounded-xl hover:bg-surface-container transition-colors text-left"
      >
        <span class="material-symbols-outlined text-sm text-on-surface-variant">logout</span>
        <span class="text-sm text-on-surface">Đăng xuất</span>
      </button>
    </div>

    <!-- Divider -->
    <div class="mx-4 my-2 border-t border-outline-variant"></div>

    <!-- Navigation -->
    <nav class="px-4 py-2 space-y-1">
      <a href="/#courses" class="flex items-center gap-3 p-3 rounded-xl hover:bg-surface-container transition-colors">
        <span class="material-symbols-outlined text-sm text-on-surface-variant">school</span>
        <span class="text-sm text-on-surface">Khóa học</span>
      </a>
      <a href="/#resources" class="flex items-center gap-3 p-3 rounded-xl hover:bg-surface-container transition-colors">
        <span class="material-symbols-outlined text-sm text-on-surface-variant">folder_special</span>
        <span class="text-sm text-on-surface">Tài nguyên</span>
      </a>
      <a href="/#reviews" class="flex items-center gap-3 p-3 rounded-xl hover:bg-surface-container transition-colors">
        <span class="material-symbols-outlined text-sm text-on-surface-variant">rate_review</span>
        <span class="text-sm text-on-surface">Đánh giá</span>
      </a>
      <a href="/#about" class="flex items-center gap-3 p-3 rounded-xl hover:bg-surface-container transition-colors">
        <span class="material-symbols-outlined text-sm text-on-surface-variant">info</span>
        <span class="text-sm text-on-surface">Giới thiệu</span>
      </a>
    </nav>

    <!-- Divider -->
    <div class="mx-4 my-2 border-t border-outline-variant"></div>

    <!-- Bookmarks -->
    <div id="bookmarks-section" class="hidden px-4 py-2">
      <p class="text-xs font-medium text-on-surface-variant uppercase tracking-wider px-3 mb-2">Đã lưu gần đây</p>
      <div id="bookmarks-list" class="space-y-1"></div>
    </div>

    <!-- Theme Toggle -->
    <div class="px-4 py-3">
      <button
        id="theme-toggle"
        class="flex items-center justify-between w-full p-3 rounded-xl bg-surface-container hover:bg-surface-container-high transition-colors"
      >
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-sm text-on-surface-variant">dark_mode</span>
          <span class="text-sm text-on-surface">Chế độ tối</span>
        </div>
        <div class="relative w-10 h-6 bg-surface-container-high rounded-full p-0.5">
          <div id="theme-knob" class="w-5 h-5 bg-on-surface-variant rounded-full transition-transform duration-200" style="transform: translateX(16px)"></div>
        </div>
      </button>
    </div>

  </div>
</div>

<style>
  #mobile-user-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }
  #mobile-user-drawer.open {
    transform: translateX(0);
  }
</style>

<script>
  var overlay = document.getElementById('mobile-user-overlay');
  var drawer = document.getElementById('mobile-user-drawer');
  var closeBtn = document.getElementById('mobile-user-close');
  var logoutBtn = document.getElementById('user-logout-btn');
  var loggedOutSection = document.getElementById('user-logged-out');
  var loggedInSection = document.getElementById('user-logged-in');
  var userNameEl = document.getElementById('user-name');
  var userEmailEl = document.getElementById('user-email');

  var isOpen = false;

  function open() {
    isOpen = true;
    if (overlay) overlay.classList.add('open');
    if (drawer) drawer.classList.add('open');
    document.body.style.overflow = 'hidden';
    loadUserState();
    loadBookmarks();
  }

  function close() {
    isOpen = false;
    if (overlay) overlay.classList.remove('open');
    if (drawer) drawer.classList.remove('open');
    document.body.style.overflow = '';
  }

  async function loadUserState() {
    try {
      var res = await fetch('/api/auth/get-session', { credentials: 'include' });
      var session = await res.json().catch(function() { return null; });
      if (session && session.user) {
        if (loggedInSection) loggedInSection.classList.remove('hidden');
        if (loggedOutSection) loggedOutSection.classList.add('hidden');
        if (userNameEl) userNameEl.textContent = session.user.name || 'Người dùng';
        if (userEmailEl) userEmailEl.textContent = session.user.email || '';
      } else {
        if (loggedInSection) loggedInSection.classList.add('hidden');
        if (loggedOutSection) loggedOutSection.classList.remove('hidden');
      }
    } catch (e) {
      if (loggedInSection) loggedInSection.classList.add('hidden');
      if (loggedOutSection) loggedOutSection.classList.remove('hidden');
    }
  }

  function loadBookmarks() {
    var section = document.getElementById('bookmarks-section');
    var list = document.getElementById('bookmarks-list');
    if (!section || !list) return;
    var items = [];
    try {
      var bookmarks = JSON.parse(localStorage.getItem('deos_bookmarks') || '[]');
      bookmarks.forEach(function(b) { items.push({id:b.id, title:b.title, url:b.url, scrollPct:b.scrollPct, type:'bookmark', savedAt:b.savedAt}); });
    } catch(e) {}
    try {
      var rp = JSON.parse(localStorage.getItem('deos_read_progress') || '{}');
      var currentPath = location.pathname;
      Object.keys(rp).forEach(function(id) {
        var d = rp[id];
        if (d.url && d.url !== currentPath && d.pct > 0 && !items.some(function(i){return i.id===id;})) {
          items.push({id:id, title:d.title, url:d.url, scrollPct:d.pct, type:'progress', ts:d.ts});
        }
      });
    } catch(e) {}
    items.sort(function(a,b){ return (b.savedAt||b.ts||0) - (a.savedAt||b.ts||0); });
    if (items.length > 0) {
      section.classList.remove('hidden');
      var html = '';
      items.slice(0, 8).forEach(function(b) {
        var icon = b.type === 'bookmark' ? 'bookmark' : 'auto_stories';
        var pctBadge = b.scrollPct ? '<span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-primary/15 text-primary shrink-0">'+b.scrollPct+'%</span>' : '';
        html += '<a href="'+b.url+'" class="flex items-center gap-2 p-2.5 rounded-xl bg-surface-container hover:bg-surface-container-high transition-colors group">'
          + '<span class="material-symbols-outlined text-sm text-on-surface-variant/60 group-hover:text-primary shrink-0">'+icon+'</span>'
          + '<span class="flex-1 text-sm truncate text-on-surface-variant group-hover:text-on-surface">'+(b.title||'Chương')+'</span>'
          + pctBadge + '</a>';
      });
      list.innerHTML = html;
    } else {
      section.classList.add('hidden');
    }
  }

  closeBtn && closeBtn.addEventListener('click', close);
  overlay && overlay.addEventListener('click', close);

  var startX = 0;
  drawer && drawer.addEventListener('touchstart', function(e) {
    startX = e.touches[0].clientX;
  }, { passive: true });

  drawer && drawer.addEventListener('touchmove', function(e) {
    if (!isOpen) return;
    var diff = e.touches[0].clientX - startX;
    if (diff > 0) {
      drawer.style.transform = 'translateX(' + diff + 'px)';
    }
  }, { passive: true });

  drawer && drawer.addEventListener('touchend', function(e) {
    var diff = e.changedTouches[0].clientX - startX;
    if (diff > 80) {
      close();
    } else {
      if (drawer) drawer.style.transform = '';
    }
  });

  var themeBtn = document.getElementById('theme-toggle');
  var themeKnob = document.getElementById('theme-knob');
  var isDark = document.documentElement.classList.contains('dark');

  themeBtn && themeBtn.addEventListener('click', function() {
    isDark = !isDark;
    document.documentElement.classList.toggle('dark', isDark);
    if (themeKnob) {
      themeKnob.style.transform = isDark ? 'translateX(24px)' : 'translateX(0)';
    }
  });

  if (themeKnob) {
    themeKnob.style.transform = isDark ? 'translateX(24px)' : 'translateX(0)';
  }

  logoutBtn && logoutBtn.addEventListener('click', function() {
    fetch('/api/auth/logout', { method: 'POST', credentials: 'include' })
      .then(function() { window.location.reload(); })
      .catch(function() { window.location.href = '/'; });
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && isOpen) close();
  });

  (window).openUserMenu = open;
  (window).closeUserMenu = close;
  document.addEventListener('open-user-menu', open);
</script>
