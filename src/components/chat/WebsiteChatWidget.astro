---
interface Props {
  pageType?: 'book' | 'blog' | 'resource' | 'home';
  pageSlug?: string;
  chapterId?: string;
}

const { pageType = 'home', pageSlug = '', chapterId = '' } = Astro.props;
---

<div id="website-chat-root">
  <!-- Trigger button -->
  <button
    id="website-chat-trigger"
    type="button"
    aria-label="Mở trợ lý AI"
    aria-expanded="false"
    aria-controls="website-chat-panel"
    onclick="var p=document.getElementById('website-chat-panel'),t=document.getElementById('website-chat-trigger');var o=p.classList.contains('chat-panel-open');p.classList.toggle('chat-panel-open',!o);t.classList.toggle('chat-open',!o);document.body.classList.toggle('chat-active',!o);t.setAttribute('aria-expanded',!o);if(!o){setTimeout(function(){var i=document.getElementById('chat-input');if(i)i.focus()},100)}"
  >
    <span class="material-symbols-outlined trigger-icon" id="chat-trigger-icon">chat</span>
  </button>

  <!-- Chat panel -->
  <div id="website-chat-panel" role="dialog" aria-label="Trợ lý AI" aria-modal="true" style="background:#fafaf9;box-shadow:-4px 0 40px rgba(0,0,0,0.15)">
    <!-- Header -->
    <div id="chat-panel-header" style="background:#fff;border-bottom-color:#e5e5e5">
      <div class="chat-avatar-icon">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <rect width="20" height="20" rx="5" fill="#f97316"/>
          <path d="M10 4C6.686 4 4 6.686 4 10s2.686 6 6 6 6-2.686 6-6-2.686-6-6-6zm0 10.5c-2.49 0-4.5-2.015-4.5-4.5S7.51 5.5 10 5.5s4.5 2.015 4.5 4.5-2.01 4.5-4.5 4.5z" fill="white"/>
          <circle cx="10" cy="10" r="1.5" fill="white"/>
        </svg>
      </div>
      <div class="chat-header-info">
        <div class="chat-header-title">Claude Assistant</div>
        <div class="chat-header-sub">Trợ lý nội dung Dental Empire</div>
      </div>
      <div class="chat-header-actions">
        <a id="chat-panel-expand-btn" class="chat-action-btn" href="/ai-chat" aria-label="Mở rộng" title="Mở rộng">
          <span class="material-symbols-outlined" style="font-size:18px;">open_in_full</span>
        </a>
        <button id="chat-panel-close" class="chat-action-btn" aria-label="Đóng">
          <span class="material-symbols-outlined" style="font-size:18px;">close</span>
        </button>
      </div>
    </div>

    <!-- Messages -->
    <div id="chat-messages-area" style="background:#fafaf9">
      <div id="chat-welcome">
        <div class="welcome-icon">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
            <rect width="40" height="40" rx="10" fill="#fef3c7"/>
            <path d="M20 8C12.268 8 6 14.268 6 22s6.268 14 14 14 14-6.268 14-14S27.732 8 20 8zm0 24c-5.523 0-10-4.477-10-10S14.477 12 20 12s10 4.477 10 10-4.477 10-10 10z" fill="#f97316"/>
            <circle cx="20" cy="22" r="3" fill="#f97316"/>
            <path d="M20 12v3M20 29v-3M12 22h-3M31 22h-3" stroke="#f97316" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="welcome-title">Chào bạn!</div>
        <div class="welcome-desc">Tôi là trợ lý AI của Dental Empire OS.<br>Hỏi tôi về nội dung sách, blog hoặc tài nguyên nhé!</div>
      </div>

      <div id="chat-suggestions">
        <div class="suggestions-label">💡 Gợi ý:</div>
        <div class="suggestions-chips">
          <button class="suggestion-chip" data-msg="Sách quản trị phòng khám nha khoa có những nội dung gì?">📖 Sách gồm những phần nào?</button>
          <button class="suggestion-chip" data-msg="Có khóa học miễn phí nào không?">🎓 Khóa học miễn phí?</button>
          <button class="suggestion-chip" data-msg="Cách xây dựng KPI cho nhân viên phòng khám nha khoa?">📊 Cách xây dựng KPI?</button>
        </div>
      </div>
    </div>

    <!-- Rate limit -->
    <div id="chat-rate-limit-banner" class="chat-rate-limit-banner" style="display:none">
      <span>Còn <strong id="chat-rate-remaining">3</strong> lượt miễn phí ·</span>
      <a href="/login">Đăng nhập</a> để không giới hạn
    </div>

    <!-- Input -->
    <div id="chat-input-area" style="background:#fff;border-top-color:#e5e5e5">
      <div class="chat-input-wrapper" style="background:#f5f5f4;border-color:#e5e5e5">
        <textarea id="chat-input" placeholder="Nhập câu hỏi..." rows="1" aria-label="Nhập câu hỏi"></textarea>
        <button id="chat-send-btn" aria-label="Gửi">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M9 1.5L16.5 9L9 16.5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M1.5 9H16.5" stroke="white" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  #website-chat-root { font-family: 'Be Vietnam Pro', system-ui, sans-serif; }

  /* Trigger */
  #website-chat-trigger {
    position: fixed;
    z-index: 1001;
    right: 16px;
    bottom: calc(1rem + env(safe-area-inset-bottom, 0px));
    width: 52px;
    height: 52px;
    border-radius: 14px;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    background: #f97316;
    color: #fff;
    box-shadow: 0 4px 20px rgba(249, 115, 22, 0.4);
  }
  @media (max-width: 640px) {
    #website-chat-trigger { bottom: calc(1rem + 64px + env(safe-area-inset-bottom, 0px)); }
  }
  #website-chat-trigger:hover { transform: scale(1.06); box-shadow: 0 6px 28px rgba(249, 115, 22, 0.5); }
  #website-chat-trigger:active { transform: scale(0.96); }
  #website-chat-trigger.chat-open { background: #ea580c; transform: none; box-shadow: 0 2px 12px rgba(249, 115, 22, 0.3); }

  /* Panel */
  #website-chat-panel {
    position: fixed;
    z-index: 1002;
    right: 0; top: 0; bottom: 0;
    width: 400px;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.32s cubic-bezier(0.4, 0, 0.2, 1);
    background: var(--chat-bg, #fafaf9);
    box-shadow: var(--chat-shadow, -4px 0 40px rgba(0,0,0,0.15));
    overflow: hidden;
  }
  #website-chat-panel.chat-panel-open { transform: translateX(0); }
  #website-chat-panel.chat-expanded { width: 520px; }
  @media (max-width: 1023px) { #website-chat-panel { width: 380px; } }
  @media (max-width: 640px) {
    #website-chat-panel { width: 100vw; right: 0; bottom: calc(64px + env(safe-area-inset-bottom)); }
  }
  /* Hide mobile FABs and chapter nav when chat panel is open */
  body.chat-active #mobile-fab-container,
  body.chat-active .chapter-nav-fixed { display: none !important; }

  /* Header */
  #chat-panel-header {
    padding: 14px 16px; display: flex; align-items: center; gap: 10px; flex-shrink: 0;
    background: var(--chat-header-bg, #fff); border-bottom: 1px solid var(--chat-header-border, #e5e5e5);
  }
  .chat-avatar-icon { width: 38px; height: 38px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .chat-header-info { flex: 1; min-width: 0; }
  .chat-header-title { font-size: 15px; font-weight: 700; color: var(--chat-header-title, #1c1917); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .chat-header-sub { font-size: 12px; color: var(--chat-header-sub, #78716c); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .chat-header-actions { display: flex; align-items: center; gap: 4px; flex-shrink: 0; }
  .chat-action-btn { width: 34px; height: 34px; border-radius: 8px; border: none; background: transparent; color: var(--chat-action-btn, #a8a29e); cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; text-decoration: none; }
  .chat-action-btn:hover { background: var(--chat-action-hover, #f5f5f4); color: var(--chat-action-hover-color, #57534e); }

  /* Messages */
  #chat-messages-area { flex: 1; overflow-y: auto; padding: 16px 14px; display: flex; flex-direction: column; gap: 12px; background: var(--chat-msg-bg, #fafaf9); scroll-behavior: smooth; }
  #chat-messages-area::-webkit-scrollbar { width: 4px; }
  #chat-messages-area::-webkit-scrollbar-thumb { background: var(--chat-scrollbar, #d6d3d1); border-radius: 4px; }

  /* Welcome */
  #chat-welcome { display: flex; flex-direction: column; align-items: center; text-align: center; padding: 20px 12px 8px; gap: 8px; }
  .welcome-icon { margin-bottom: 4px; }
  .welcome-title { font-size: 18px; font-weight: 700; color: #1c1917; }
  .welcome-desc { font-size: 13px; color: #78716c; line-height: 1.6; }

  /* Suggestions */
  #chat-suggestions { padding: 4px 0 8px; }
  .suggestions-label { font-size: 12px; font-weight: 500; color: #a8a29e; margin-bottom: 8px; padding-left: 2px; }
  .suggestions-chips { display: flex; flex-direction: column; gap: 6px; }
  .suggestion-chip { background: #fff; border: 1.5px solid #e5e5e5; border-radius: 10px; padding: 8px 12px; font-size: 13px; font-family: inherit; color: #44403c; cursor: pointer; text-align: left; transition: all 0.15s; line-height: 1.4; }
  .suggestion-chip:hover { border-color: #f97316; background: #fff7ed; color: #ea580c; }
  .suggestion-chip:active { transform: scale(0.98); }

  /* Messages */
  .chat-msg { display: flex; align-items: flex-end; gap: 8px; animation: msgIn 0.2s ease-out; }
  @keyframes msgIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
  .chat-msg.user { align-self: flex-end; flex-direction: row-reverse; }
  .chat-msg.assistant { align-self: flex-start; }
  .chat-avatar-small { width: 26px; height: 26px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; flex-shrink: 0; font-weight: 600; }
  .chat-msg.user .chat-avatar-small { background: #f97316; color: #fff; }
  .chat-msg.assistant .chat-avatar-small { background: #fef3c7; color: #f97316; border: 1.5px solid #fed7aa; }
  .chat-msg-body { display: flex; flex-direction: column; gap: 4px; max-width: 80%; }
  .chat-msg-bubble { padding: 10px 14px; border-radius: 16px; font-size: 13.5px; line-height: 1.6; word-break: break-word; }
  .chat-msg.user .chat-msg-bubble { background: #f97316; color: #fff; border-bottom-right-radius: 4px; }
  .chat-msg.assistant .chat-msg-bubble { background: #fef9f3; color: #1c1917; border: 1px solid #e7e5e4; border-bottom-left-radius: 4px; }

  /* Sources */
  .chat-source-links { display: flex; flex-direction: column; gap: 3px; padding-top: 2px; }
  .chat-source-link { display: flex; align-items: center; gap: 5px; font-size: 12px; color: #78716c; text-decoration: none; padding: 2px 0; }
  .chat-source-link:hover { color: #ea580c; }
  .chat-source-type { font-size: 11px; background: #f5f5f4; padding: 1px 5px; border-radius: 4px; color: #78716c; }

  /* Follow-up */
  .chat-followup { display: flex; flex-direction: column; gap: 5px; margin-top: 6px; }
  .chat-followup-label { font-size: 11.5px; color: #a8a29e; font-weight: 500; }
  .chat-followup-btn { background: #fff; border: 1.5px solid #e5e5e5; border-radius: 8px; padding: 6px 10px; font-size: 12.5px; font-family: inherit; color: #57534e; cursor: pointer; text-align: left; transition: all 0.15s; }
  .chat-followup-btn:hover { border-color: #f97316; background: #fff7ed; color: #ea580c; }

  /* Typing */
  .chat-typing { display: flex; align-items: center; gap: 8px; padding: 10px 14px; background: #fef9f3; border: 1px solid #e7e5e4; border-radius: 16px; border-bottom-left-radius: 4px; font-size: 13px; color: #a8a29e; font-style: italic; width: fit-content; }
  .chat-typing-dots { display: flex; gap: 3px; }
  .chat-typing-dots span { width: 5px; height: 5px; border-radius: 50%; background: #d6d3d1; animation: typingBounce 1.2s ease-in-out infinite; }
  .chat-typing-dots span:nth-child(2) { animation-delay: 0.2s; }
  .chat-typing-dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes typingBounce { 0%, 60%, 100% { transform: translateY(0); opacity: 0.5; } 30% { transform: translateY(-5px); opacity: 1; } }

  /* Rate limit */
  .chat-rate-limit-banner { padding: 8px 16px; background: #fff7ed; border-top: 1px solid #fed7aa; font-size: 12px; color: #78716c; text-align: center; flex-shrink: 0; }
  .chat-rate-limit-banner strong { color: #ea580c; }
  .chat-rate-limit-banner a { color: #ea580c; font-weight: 600; text-decoration: none; margin-left: 4px; }
  .chat-rate-limit-banner a:hover { text-decoration: underline; }

  /* Input */
  #chat-input-area { flex-shrink: 0; padding: 10px 14px 14px; background: #fff; border-top: 1px solid #e5e5e5; }
  .chat-input-wrapper { display: flex; align-items: flex-end; gap: 8px; background: #f5f5f4; border: 1.5px solid #e5e5e5; border-radius: 14px; padding: 8px 8px 8px 14px; transition: border-color 0.2s; }
  .chat-input-wrapper:focus-within { border-color: #f97316; background: #fff; }
  #chat-input { flex: 1; background: none; border: none; outline: none; color: #1c1917; font-size: 14px; font-family: inherit; line-height: 1.5; resize: none; max-height: 90px; overflow-y: auto; }
  #chat-input::placeholder { color: #a8a29e; }
  #chat-send-btn { width: 36px; height: 36px; border-radius: 50%; border: none; background: #f97316; color: #fff; cursor: pointer; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: transform 0.15s, opacity 0.15s; }
  #chat-send-btn:hover { transform: scale(1.06); }
  #chat-send-btn:active { transform: scale(0.95); }
  #chat-send-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  /* Markdown */
  .chat-msg-bubble h1, .chat-msg-bubble h2, .chat-msg-bubble h3 { color: inherit; margin: 6px 0 3px; font-weight: 600; }
  .chat-msg-bubble h2 { font-size: 14px; }
  .chat-msg-bubble h3 { font-size: 13px; }
  .chat-msg-bubble p { margin: 3px 0; }
  .chat-msg-bubble ul, .chat-msg-bubble ol { margin: 3px 0; padding-left: 18px; }
  .chat-msg-bubble li { margin: 2px 0; }
  .chat-msg-bubble strong { font-weight: 700; }
  .chat-msg-bubble em { font-style: italic; }
  .chat-msg-bubble a { color: #ea580c; }
  .chat-msg-bubble code { background: rgba(0,0,0,0.06); padding: 1px 5px; border-radius: 4px; font-size: 12px; }
</style>

<script define:vars={{ pageType, pageSlug, chapterId }}>
(function () {
  // Load marked + dompurify as classic scripts to avoid module issues
  function loadScripts() {
    return new Promise(function (resolve) {
      var resolved = false;
      function check() {
        if (resolved) return;
        if (typeof marked !== 'undefined' && typeof DOMPurify !== 'undefined') {
          resolved = true;
          resolve();
        }
      }
      // marked is already loaded globally
      if (typeof marked !== 'undefined') check();
      // Load DOMPurify if not available
      if (typeof DOMPurify === 'undefined') {
        var s = document.createElement('script');
        s.src = 'https://cdn.jsdelivr.net/npm/dompurify@3/dist/purify.min.js';
        s.onload = check;
        s.onerror = function () { resolved = true; resolve(); };
        document.head.appendChild(s);
      } else {
        check();
      }
      // Timeout fallback
      setTimeout(function () { if (!resolved) { resolved = true; resolve(); } }, 2000);
    });
  }

  loadScripts().then(function () {
    // ── Rate limit ───────────────────────────────────────────────
    var FREE_QUESTIONS = 3;
    var STORAGE_KEY = 'de_chat_free';
    function getFreeCount() { return parseInt(localStorage.getItem(STORAGE_KEY) || '0', 10); }
    function incFreeCount() {
      var c = getFreeCount() + 1;
      localStorage.setItem(STORAGE_KEY, String(c));
      return c;
    }

    // ── DOM refs ─────────────────────────────────────────────────
    var trigger = document.getElementById('website-chat-trigger');
    var panel = document.getElementById('website-chat-panel');
    var closeBtn = document.getElementById('chat-panel-close');
    var expandBtn = document.getElementById('chat-panel-expand-btn');
    var welcomeEl = document.getElementById('chat-welcome');
    var suggestionsEl = document.getElementById('chat-suggestions');
    var messagesArea = document.getElementById('chat-messages-area');
    var inputEl = document.getElementById('chat-input');
    var sendBtn = document.getElementById('chat-send-btn');
    var rateBanner = document.getElementById('chat-rate-limit-banner');
    var rateRemaining = document.getElementById('chat-rate-remaining');

    if (!trigger || !panel || !inputEl || !sendBtn || !messagesArea) {
      console.error('[chat] Missing elements');
      return;
    }

    // ── State ────────────────────────────────────────────────────
    var isLoading = false;
    var currentSources = [];

    // ── Rate limit UI ─────────────────────────────────────────────
    function updateRateLimit() {
      var count = getFreeCount();
      var remaining = Math.max(0, FREE_QUESTIONS - count);
      if (rateRemaining) rateRemaining.textContent = String(remaining);
      if (remaining === 0) {
        if (rateBanner) rateBanner.style.display = 'block';
        inputEl.placeholder = 'Đăng nhập để tiếp tục...';
        inputEl.disabled = true;
      }
    }
    updateRateLimit();

    // ── Helpers ──────────────────────────────────────────────────
    function autoResize() {
      inputEl.style.height = 'auto';
      inputEl.style.height = Math.min(inputEl.scrollHeight, 90) + 'px';
    }

    function scrollBottom() {
      messagesArea.scrollTop = messagesArea.scrollHeight;
    }

    function hideWelcome() {
      if (welcomeEl) welcomeEl.style.display = 'none';
      if (suggestionsEl) suggestionsEl.style.display = 'none';
    }

    function parseMarkdown(content) {
      try {
        var html = marked.parse(content);
        if (typeof DOMPurify !== 'undefined') {
          return DOMPurify.sanitize(html);
        }
        return html;
      } catch (e) {
        return content;
      }
    }

    function addMessage(role, content, sources) {
      hideWelcome();

      var msg = document.createElement('div');
      msg.className = 'chat-msg ' + role;

      var avatar = document.createElement('div');
      avatar.className = 'chat-avatar-small';
      avatar.textContent = role === 'user' ? '👤' : '🤖';
      msg.appendChild(avatar);

      var body = document.createElement('div');
      body.className = 'chat-msg-body';

      var bubble = document.createElement('div');
      bubble.className = 'chat-msg-bubble';
      bubble.innerHTML = parseMarkdown(content) || content;
      body.appendChild(bubble);

      if (sources && sources.length) {
        var srcEl = document.createElement('div');
        srcEl.className = 'chat-source-links';
        for (var i = 0; i < Math.min(sources.length, 3); i++) {
          var s = sources[i];
          var a = document.createElement('a');
          a.href = s.url;
          a.className = 'chat-source-link';
          a.target = '_blank';
          a.rel = 'noopener';
          var icon = s.content_type === 'book' ? '📖' : s.content_type === 'blog' ? '📝' : '📄';
          a.innerHTML = '<span class="chat-source-type">' + icon + '</span> ' + (s.title || 'Xem chi tiết');
          srcEl.appendChild(a);
        }
        body.appendChild(srcEl);
      }

      msg.appendChild(body);
      messagesArea.appendChild(msg);
      scrollBottom();
      return { el: msg, bubble: bubble };
    }

    function showTyping() {
      hideWelcome();
      var el = document.createElement('div');
      el.className = 'chat-msg assistant';
      el.id = 'chat-typing-indicator';
      el.innerHTML = '<div class="chat-avatar-small">🤖</div><div class="chat-typing">Đang suy nghĩ<span class="chat-typing-dots"><span></span><span></span><span></span></span></div>';
      messagesArea.appendChild(el);
      scrollBottom();
    }

    function removeTyping() {
      var el = document.getElementById('chat-typing-indicator');
      if (el) el.remove();
    }

    function appendFollowup(suggestions) {
      if (!suggestions || !suggestions.length) return;
      var lastMsg = messagesArea.lastElementChild;
      if (!lastMsg) return;
      var body = lastMsg.querySelector('.chat-msg-body');
      if (!body) return;

      var fu = document.createElement('div');
      fu.className = 'chat-followup';
      fu.innerHTML = '<div class="chat-followup-label">💡 Hỏi tiếp:</div>';
      for (var fi = 0; fi < Math.min(suggestions.length, 3); fi++) {
        var s = suggestions[fi];
        var btn = document.createElement('button');
        btn.className = 'chat-followup-btn';
        btn.textContent = s;
        btn.addEventListener('click', (function (ss) {
          return function () { inputEl.value = ss; autoResize(); sendMessage(); };
        })(s));
        fu.appendChild(btn);
      }
      body.appendChild(fu);
    }

    // ── Send message ─────────────────────────────────────────────
    function sendMessage() {
      if (isLoading) return;
      var text = inputEl.value.trim();
      if (!text) return;

      var count = getFreeCount();
      if (count >= FREE_QUESTIONS) {
        inputEl.placeholder = 'Đăng nhập để tiếp tục...';
        inputEl.disabled = true;
        return;
      }

      isLoading = true;
      sendBtn.disabled = true;

      var userText = text;
      inputEl.value = '';
      autoResize();

      addMessage('user', userText);
      incFreeCount();
      updateRateLimit();
      showTyping();
      currentSources = [];

      var accumulatedText = '';
      var lastRender = 0;
      var lastMsgBubble = null;

      fetch('/api/website-chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          message: userText,
          page_type: pageType !== 'home' ? pageType : undefined,
          page_slug: pageSlug || undefined,
        }),
      }).then(function (res) {
        if (!res.ok || !res.body) {
          return res.json().catch(function () { return { error: 'Lỗi kết nối' }; }).then(function (d) { throw new Error(d.error || 'Lỗi kết nối'); });        }

        removeTyping();
        var result = addMessage('assistant', '');
        lastMsgBubble = result.bubble;
        var reader = res.body.getReader();
        var decoder = new TextDecoder();
        var buffer = '';

        function pump() {
          reader.read().then(function (result2) {
            if (result2.done) {
              // Final render
              if (lastMsgBubble) {
                lastMsgBubble.innerHTML = parseMarkdown(accumulatedText);
              }
              if (currentSources.length) {
                var body2 = messagesArea.lastElementChild.querySelector('.chat-msg-body');
                if (body2) {
                  var srcEl = document.createElement('div');
                  srcEl.className = 'chat-source-links';
                  for (var si = 0; si < Math.min(currentSources.length, 3); si++) {
                    var s2 = currentSources[si];
                    var a2 = document.createElement('a');
                    a2.href = s2.url;
                    a2.className = 'chat-source-link';
                    a2.target = '_blank';
                    a2.rel = 'noopener';
                    var icon2 = s2.content_type === 'book' ? '📖' : s2.content_type === 'blog' ? '📝' : '📄';
                    a2.innerHTML = '<span class="chat-source-type">' + icon2 + '</span> ' + (s2.title || 'Xem chi tiết');
                    srcEl.appendChild(a2);
                  }
                  body2.appendChild(srcEl);
                }
              }
              appendFollowup(['Tôi muốn biết thêm chi tiết...', 'Có ví dụ cụ thể không?', 'Cảm ơn bạn!']);
              scrollBottom();
              return;
            }

            buffer += decoder.decode(result2.value, { stream: true });
            var lines = buffer.split('\n');
            buffer = lines.pop() || '';

            for (var li = 0; li < lines.length; li++) {
              var trimmed = lines[li].trim();
              if (!trimmed.startsWith('data: ')) continue;
              var dataStr = trimmed.slice(6).trim();
              if (!dataStr) continue;
              try {
                var parsed = JSON.parse(dataStr);
                if (parsed.event === 'chunks_used') {
                  currentSources = parsed.sources || [];
                } else if (parsed.event === 'chunk') {
                  accumulatedText += parsed.text || '';
                  var now = Date.now();
                  if (now - lastRender > 60 && lastMsgBubble) {
                    lastMsgBubble.textContent = accumulatedText;
                    scrollBottom();
                    lastRender = now;
                  }
                } else if (parsed.event === 'done') {
                  currentSources = parsed.sources || currentSources;
                } else if (parsed.event === 'error') {
                  throw new Error(parsed.message || 'Lỗi AI');
                }
              } catch (e) {
                if (e.message !== 'Lỗi AI') console.warn('[chat] SSE:', e);
              }
            }
            pump();
          }).catch(function (err) {
            removeTyping();
            addMessage('assistant', '❌ **Lỗi:** ' + (err.message || 'Kết nối thất bại. Vui lòng thử lại.'));
            isLoading = false;
            sendBtn.disabled = false;
          });
        }
        pump();
      }).catch(function (err) {
        removeTyping();
        addMessage('assistant', '❌ **Lỗi:** ' + (err.message || 'Kết nối thất bại. Vui lòng thử lại.'));
        isLoading = false;
        sendBtn.disabled = false;
      }).finally(function () {
        isLoading = false;
        sendBtn.disabled = false;
        inputEl.focus();
      });
    }

    // ── Event bindings ──────────────────────────────────────────
    // Suggestion chips
    var chips = document.querySelectorAll('.suggestion-chip');
    for (var ci = 0; ci < chips.length; ci++) {
      chips[ci].addEventListener('click', function () {
        var msg2 = this.getAttribute('data-msg') || this.textContent.trim() || '';
        if (!msg2) return;
        inputEl.value = msg2;
        autoResize();
        sendMessage();
      });
    }

    // Send button
    sendBtn.addEventListener('click', sendMessage);

    // Enter key
    inputEl.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendMessage();
      }
    });

    // Auto-resize
    inputEl.addEventListener('input', autoResize);

    // Close button
    closeBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      panel.classList.remove('chat-panel-open');
      panel.style.pointerEvents = 'none';
      trigger.classList.remove('chat-open');
      document.body.classList.remove('chat-active');
      trigger.setAttribute('aria-expanded', 'false');
    });

    // Click outside panel to close
    document.addEventListener('click', function (e) {
      if (!panel.classList.contains('chat-panel-open')) return;
      if (panel.contains(e.target) || trigger.contains(e.target)) return;
      panel.classList.remove('chat-panel-open');
      panel.style.pointerEvents = 'none';
      trigger.classList.remove('chat-open');
      document.body.classList.remove('chat-active');
      trigger.setAttribute('aria-expanded', 'false');
    });

    // Re-enable pointer-events when panel opens
    var observer = new MutationObserver(function () {
      if (panel.classList.contains('chat-panel-open')) {
        panel.style.pointerEvents = '';
      } else {
        panel.style.pointerEvents = 'none';
      }
    });
    observer.observe(panel, { attributes: true, attributeFilter: ['class'] });

    // Expand button
    var isExpanded = false;
    expandBtn.addEventListener('click', function (e) {
      e.preventDefault();
      isExpanded = !isExpanded;
      panel.classList.toggle('chat-expanded', isExpanded);
      expandBtn.title = isExpanded ? 'Thu nhỏ' : 'Mở rộng';
      expandBtn.querySelector('span').textContent = isExpanded ? 'close_fullscreen' : 'open_in_full';
    });

    // Escape key
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && panel.classList.contains('chat-panel-open')) {
        panel.classList.remove('chat-panel-open');
        panel.style.pointerEvents = 'none';
        trigger.classList.remove('chat-open');
        document.body.classList.remove('chat-active');
        trigger.setAttribute('aria-expanded', 'false');
      }
    });

  }).catch(function (err) {
    console.error('[chat] Init error:', err);
  });
})();
</script>
