---
interface Props {
  pageType?: 'book' | 'blog' | 'resource' | 'home';
  pageSlug?: string;
  chapterId?: string;
}

const { pageType = 'home', pageSlug = '', chapterId = '' } = Astro.props;
---
<style>
  /* ── Floating trigger ─────────────────────────────────────────── */
  #website-chat-trigger {
    position: fixed;
    right: 16px;
    bottom: calc(1rem + env(safe-area-inset-bottom, 0px));
    z-index: 9999;
    width: 52px;
    height: 52px;
    border-radius: 16px;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    box-shadow: 0 4px 24px rgba(146,204,255,0.25), 0 1px 4px rgba(0,0,0,0.4);
    transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    background: linear-gradient(135deg, #92ccff 0%, #5ba8e0 100%);
    color: #0d1117;
  }
  #website-chat-trigger:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 32px rgba(146,204,255,0.4), 0 2px 8px rgba(0,0,0,0.4);
  }
  #website-chat-trigger:active {
    transform: scale(0.95);
  }
  #website-chat-trigger .trigger-icon {
    font-size: 22px;
    transition: transform 0.3s ease;
  }
  #website-chat-trigger.chat-open .trigger-icon {
    transform: rotate(90deg);
  }
  #website-chat-trigger .trigger-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.02em;
    display: none;
  }
  @media (min-width: 640px) {
    #website-chat-trigger { width: auto; padding: 0 16px; border-radius: 52px; }
    #website-chat-trigger .trigger-label { display: block; }
  }

  /* Pulse animation on idle */
  @keyframes chatPulse {
    0%, 100% { box-shadow: 0 4px 24px rgba(146,204,255,0.25), 0 1px 4px rgba(0,0,0,0.4); }
    50%       { box-shadow: 0 4px 32px rgba(146,204,255,0.5), 0 1px 4px rgba(0,0,0,0.4); }
  }
  #website-chat-trigger:not(.chat-open) {
    animation: chatPulse 3s ease-in-out infinite;
  }
  #website-chat-trigger.chat-open {
    animation: none;
  }

  /* ── Chat panel ──────────────────────────────────────────────── */
  #website-chat-panel {
    position: fixed;
    right: 16px;
    bottom: calc(72px + env(safe-area-inset-bottom, 0px));
    z-index: 9998;
    width: min(400px, calc(100vw - 32px));
    height: min(600px, calc(100vh - 160px));
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transform: scale(0.8) translateY(20px);
    transform-origin: bottom right;
    opacity: 0;
    pointer-events: none;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 24px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(146,204,255,0.15);
  }
  #website-chat-panel.chat-panel-open {
    transform: scale(1) translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  /* Chat header */
  #chat-panel-header {
    padding: 14px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
    background: linear-gradient(135deg, #1e2a3a 0%, #0f1923 100%);
    border-bottom: 1px solid rgba(146,204,255,0.12);
  }
  .chat-avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: linear-gradient(135deg, #92ccff 0%, #5ba8e0 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 0 16px rgba(146,204,255,0.3);
  }
  .chat-header-info { flex: 1; min-width: 0; }
  .chat-header-title {
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .chat-header-sub {
    font-size: 11px;
    color: rgba(146,204,255,0.7);
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .chat-header-sub::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 6px #4ade80;
  }
  .chat-close-btn {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.6);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    flex-shrink: 0;
  }
  .chat-close-btn:hover {
    background: rgba(255,255,255,0.15);
    color: #fff;
  }

  /* Messages area */
  #chat-messages-area {
    flex: 1;
    overflow-y: auto;
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    background: #0d1117;
    scroll-behavior: smooth;
  }
  #chat-messages-area::-webkit-scrollbar { width: 4px; }
  #chat-messages-area::-webkit-scrollbar-track { background: transparent; }
  #chat-messages-area::-webkit-scrollbar-thumb { background: rgba(146,204,255,0.2); border-radius: 4px; }

  /* Message bubbles */
  .chat-msg {
    display: flex;
    flex-direction: column;
    max-width: 85%;
    animation: msgIn 0.25s ease-out;
  }
  @keyframes msgIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .chat-msg.user { align-self: flex-end; align-items: flex-end; }
  .chat-msg.assistant { align-self: flex-start; align-items: flex-start; }

  .chat-msg-bubble {
    padding: 10px 14px;
    border-radius: 16px;
    font-size: 13px;
    line-height: 1.55;
    word-break: break-word;
  }
  .chat-msg.user .chat-msg-bubble {
    background: linear-gradient(135deg, #92ccff 0%, #5ba8e0 100%);
    color: #0d1117;
    border-bottom-right-radius: 4px;
  }
  .chat-msg.assistant .chat-msg-bubble {
    background: #1c2333;
    color: #e6edf3;
    border-bottom-left-radius: 4px;
    border: 1px solid rgba(146,204,255,0.1);
  }

  /* Typing indicator */
  .chat-typing {
    display: flex;
    gap: 4px;
    padding: 10px 14px;
    background: #1c2333;
    border-radius: 16px;
    border-bottom-left-radius: 4px;
    border: 1px solid rgba(146,204,255,0.1);
    width: fit-content;
  }
  .chat-typing span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(146,204,255,0.5);
    animation: typingBounce 1.2s ease-in-out infinite;
  }
  .chat-typing span:nth-child(2) { animation-delay: 0.2s; }
  .chat-typing span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes typingBounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.5; }
    30%            { transform: translateY(-6px); opacity: 1; }
  }

  /* Source links */
  .chat-source-link {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 6px;
    padding: 6px 10px;
    background: rgba(146,204,255,0.08);
    border: 1px solid rgba(146,204,255,0.15);
    border-radius: 10px;
    text-decoration: none;
    font-size: 11px;
    color: rgba(146,204,255,0.8);
    transition: all 0.2s;
    max-width: 100%;
    overflow: hidden;
  }
  .chat-source-link:hover {
    background: rgba(146,204,255,0.15);
    color: #92ccff;
  }
  .chat-source-link .source-icon {
    font-size: 14px;
    flex-shrink: 0;
  }
  .chat-source-link .source-label {
    font-weight: 600;
    flex-shrink: 0;
  }
  .chat-source-link .source-title {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
    min-width: 0;
  }

  /* Error message */
  .chat-error {
    padding: 8px 14px;
    background: rgba(239,68,68,0.1);
    border: 1px solid rgba(239,68,68,0.2);
    border-radius: 12px;
    font-size: 12px;
    color: #f87171;
    text-align: center;
  }

  /* Input area */
  #chat-input-area {
    padding: 10px 12px;
    display: flex;
    gap: 8px;
    align-items: flex-end;
    background: #0d1117;
    border-top: 1px solid rgba(146,204,255,0.08);
    flex-shrink: 0;
  }
  #chat-input {
    flex: 1;
    background: #1c2333;
    border: 1px solid rgba(146,204,255,0.15);
    border-radius: 14px;
    padding: 10px 14px;
    font-size: 13px;
    color: #e6edf3;
    resize: none;
    outline: none;
    line-height: 1.5;
    max-height: 100px;
    min-height: 44px;
    field-sizing: content;
    transition: border-color 0.2s;
    font-family: inherit;
  }
  #chat-input:focus {
    border-color: rgba(146,204,255,0.4);
  }
  #chat-input::placeholder { color: rgba(255,255,255,0.25); }
  #chat-send-btn {
    width: 44px;
    height: 44px;
    border-radius: 14px;
    border: none;
    background: linear-gradient(135deg, #92ccff 0%, #5ba8e0 100%);
    color: #0d1117;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all 0.2s;
  }
  #chat-send-btn:hover:not(:disabled) {
    transform: scale(1.05);
    box-shadow: 0 4px 16px rgba(146,204,255,0.3);
  }
  #chat-send-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  /* Welcome state */
  #chat-welcome {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 24px;
    text-align: center;
  }
  #chat-welcome .welcome-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(146,204,255,0.15) 0%, rgba(146,204,255,0.05) 100%);
    border: 1px solid rgba(146,204,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 4px;
  }
  #chat-welcome h3 {
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    margin: 0;
  }
  #chat-welcome p {
    font-size: 12px;
    color: rgba(255,255,255,0.4);
    margin: 0;
    line-height: 1.5;
  }
  .suggestion-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: center;
    margin-top: 4px;
  }
  .suggestion-chip {
    padding: 5px 12px;
    background: rgba(146,204,255,0.08);
    border: 1px solid rgba(146,204,255,0.15);
    border-radius: 20px;
    font-size: 11px;
    color: rgba(146,204,255,0.7);
    cursor: pointer;
    transition: all 0.2s;
  }
  .suggestion-chip:hover {
    background: rgba(146,204,255,0.18);
    color: #92ccff;
    border-color: rgba(146,204,255,0.3);
  }
</style>

<div id="website-chat-root">
  <!-- Trigger button -->
  <button
    id="website-chat-trigger"
    aria-label="Mở trợ lý AI"
    aria-expanded="false"
    aria-controls="website-chat-panel"
  >
    <span class="material-symbols-outlined trigger-icon" id="chat-trigger-icon">chat</span>
    <span class="trigger-label">Hỏi AI</span>
  </button>

  <!-- Chat panel -->
  <div
    id="website-chat-panel"
    role="dialog"
    aria-label="Trợ lý AI"
    aria-modal="true"
  >
    <!-- Header -->
    <div id="chat-panel-header">
      <div class="chat-avatar">
        <span class="material-symbols-outlined" style="font-size:20px;color:#0d1117;">psychology</span>
      </div>
      <div class="chat-header-info">
        <div class="chat-header-title">Trợ lý AI</div>
        <div class="chat-header-sub">Dental Empire OS</div>
      </div>
      <button id="chat-panel-close" class="chat-close-btn" aria-label="Đóng">
        <span class="material-symbols-outlined" style="font-size:18px;">close</span>
      </button>
    </div>

    <!-- Messages / Welcome -->
    <div id="chat-messages-area">
      <div id="chat-welcome">
        <div class="welcome-icon">
          <span class="material-symbols-outlined text-primary" style="font-size:28px;">auto_awesome</span>
        </div>
        <h3>Xin chào! Tôi có thể giúp gì?</h3>
        <p>Hỏi tôi về nội dung sách, blog,<br>hoặc bất kỳ chủ đề nào trên website</p>
        <div class="suggestion-chips" id="suggestion-chips">
          <button class="suggestion-chip" data-question="Sách quản trị phòng khám nha khoa có những nội dung gì?">Tìm hiểu về sách</button>
          <button class="suggestion-chip" data-question="Các bài blog gần đây nói về gì?">Blog gần đây</button>
          <button class="suggestion-chip" data-question="Làm sao để tăng doanh thu phòng khám nha khoa?">Tăng doanh thu</button>
          <button class="suggestion-chip" data-question="Có khóa học nào miễn phí không?">Khóa học</button>
        </div>
      </div>
    </div>

    <!-- Input -->
    <div id="chat-input-area">
      <textarea
        id="chat-input"
        placeholder="Hỏi về nội dung website..."
        rows="1"
        aria-label="Nhập câu hỏi"
      ></textarea>
      <button id="chat-send-btn" aria-label="Gửi">
        <span class="material-symbols-outlined" style="font-size:20px;">arrow_upward</span>
      </button>
    </div>
  </div>
</div>

<script define:vars={{ pageType, pageSlug, chapterId }}>
(function () {
  // ── State ───────────────────────────────────────────────────────
  let isOpen = false;
  let isLoading = false;
  let sources = []; // {url, title, content_type}

  const trigger      = document.getElementById('website-chat-trigger');
  const panel        = document.getElementById('website-chat-panel');
  const closeBtn     = document.getElementById('chat-panel-close');
  const welcomeEl    = document.getElementById('chat-welcome');
  const messagesArea = document.getElementById('chat-messages-area');
  const inputEl      = document.getElementById('chat-input');
  const sendBtn      = document.getElementById('chat-send-btn');
  const chips        = document.querySelectorAll('.suggestion-chip');

  // ── Panel toggle ────────────────────────────────────────────────
  function openPanel() {
    isOpen = true;
    trigger.classList.add('chat-open');
    trigger.setAttribute('aria-expanded', 'true');
    panel.classList.add('chat-panel-open');
    if (inputEl) inputEl.focus();
  }

  function closePanel() {
    isOpen = false;
    trigger.classList.remove('chat-open');
    trigger.setAttribute('aria-expanded', 'false');
    panel.classList.remove('chat-panel-open');
  }

  trigger.addEventListener('click', () => isOpen ? closePanel() : openPanel());
  closeBtn.addEventListener('click', closePanel);

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) closePanel();
  });

  // ── Auto-resize textarea ─────────────────────────────────────────
  function autoResize() {
    if (!inputEl) return;
    inputEl.style.height = 'auto';
    inputEl.style.height = Math.min(inputEl.scrollHeight, 100) + 'px';
  }
  inputEl.addEventListener('input', autoResize);

  // ── Suggestion chips ─────────────────────────────────────────────
  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      const q = chip.dataset.question;
      if (q && inputEl) {
        inputEl.value = q;
        autoResize();
        sendMessage();
      }
    });
  });

  // ── Render helpers ───────────────────────────────────────────────
  function scrollToBottom() {
    if (messagesArea) messagesArea.scrollTop = messagesArea.scrollHeight;
  }

  function typeIcon(type) {
    if (type === 'book') return 'menu_book';
    if (type === 'blog') return 'article';
    return 'folder_special';
  }

  function typeLabel(type) {
    if (type === 'book') return 'Sách';
    if (type === 'blog') return 'Blog';
    return 'Tài nguyên';
  }

  function renderSourceLinks(srcs) {
    if (!srcs || srcs.length === 0) return '';
    const seen = new Set();
    return srcs.slice(0, 3).map(s => {
      if (seen.has(s.url)) return '';
      seen.add(s.url);
      return `<a href="${s.url}" class="chat-source-link" target="_blank" rel="noopener">
        <span class="material-symbols-outlined source-icon">${typeIcon(s.content_type)}</span>
        <span class="source-label">${typeLabel(s.content_type)}:</span>
        <span class="source-title">${s.title || 'Xem chi tiết'}</span>
        <span class="material-symbols-outlined" style="font-size:12px;flex-shrink:0;">open_in_new</span>
      </a>`;
    }).join('');
  }

  function addMessage(role, content, srcs) {
    // Remove welcome
    if (welcomeEl && welcomeEl.style.display !== 'none') {
      welcomeEl.style.display = 'none';
    }

    const msgEl = document.createElement('div');
    msgEl.className = `chat-msg ${role}`;
    const bubble = document.createElement('div');
    bubble.className = 'chat-msg-bubble';
    bubble.innerHTML = content;
    msgEl.appendChild(bubble);

    // Source links for assistant messages
    if (role === 'assistant' && srcs && srcs.length > 0) {
      const linksHtml = renderSourceLinks(srcs);
      if (linksHtml) {
        const linksEl = document.createElement('div');
        linksEl.innerHTML = linksHtml;
        msgEl.appendChild(linksEl);
      }
    }

    messagesArea.appendChild(msgEl);
    scrollToBottom();
    return msgEl;
  }

  function showTyping() {
    const el = document.createElement('div');
    el.className = 'chat-msg assistant';
    el.id = 'chat-typing-indicator';
    el.innerHTML = '<div class="chat-typing"><span></span><span></span><span></span></div>';
    messagesArea.appendChild(el);
    scrollToBottom();
  }

  function removeTyping() {
    const el = document.getElementById('chat-typing-indicator');
    if (el) el.remove();
  }

  function showError(msg) {
    removeTyping();
    const el = document.createElement('div');
    el.className = 'chat-error';
    el.textContent = msg;
    messagesArea.appendChild(el);
    scrollToBottom();
  }

  // ── Send message ────────────────────────────────────────────────
  async function sendMessage() {
    if (isLoading) return;
    const text = inputEl.value.trim();
    if (!text) return;

    isLoading = true;
    sendBtn.disabled = true;
    inputEl.value = '';
    autoResize();

    // Render user message
    addMessage('user', text, null);

    // Show typing
    showTyping();
    sources = [];

    try {
      const body = {
        message: text,
        page_type: pageType !== 'home' ? pageType : undefined,
        page_slug: pageSlug || undefined,
      };

      const res = await fetch('/api/website-chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      if (!res.ok) {
        let errMsg = 'Đã xảy ra lỗi. Vui lòng thử lại.';
        try {
          const data = await res.json();
          errMsg = data.error || errMsg;
        } catch {}
        removeTyping();
        showError(errMsg);
        return;
      }

      // SSE streaming
      removeTyping();
      const msgEl = addMessage('assistant', '', null);
      const bubbleEl = msgEl.querySelector('.chat-msg-bubble');

      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let buffer = '';
      let currentSources = [];

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        buffer += decoder.decode(value, { stream: true });
        const lines = buffer.split('\n');
        buffer = lines.pop() ?? '';

        for (const line of lines) {
          const trimmed = line.trim();
          if (!trimmed.startsWith('data: ')) continue;
          const data = trimmed.slice(6).trim();
          if (!data) continue;

          try {
            const parsed = JSON.parse(data);

            if (parsed.event === 'chunks_used') {
              currentSources = parsed.sources || [];
            } else if (parsed.event === 'chunk') {
              bubbleEl.textContent += parsed.data?.text || '';
              scrollToBottom();
            } else if (parsed.event === 'done') {
              currentSources = parsed.sources || currentSources;
            } else if (parsed.event === 'error') {
              throw new Error(parsed.data?.message || 'Stream error');
            }
          } catch (e) {
            if (e.message !== 'Stream error') console.warn('[chat] SSE parse error:', e);
          }
        }
      }

      // Render source links after stream completes
      if (currentSources.length > 0) {
        const linksEl = document.createElement('div');
        linksEl.innerHTML = renderSourceLinks(currentSources);
        msgEl.appendChild(linksEl);
        scrollToBottom();
      }

    } catch (e) {
      removeTyping();
      showError('Kết nối thất bại. Vui lòng kiểm tra mạng và thử lại.');
      console.error('[chat] send error:', e);
    } finally {
      isLoading = false;
      sendBtn.disabled = false;
    }
  }

  // ── Event bindings ───────────────────────────────────────────────
  sendBtn.addEventListener('click', sendMessage);
  inputEl.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  // ── Mobile: shift widget down when mobile bottom nav is present ──
  function getSafeAreaInset() {
    const style = getComputedStyle(document.documentElement);
    const sat = style.getPropertyValue('--sat') || style.getPropertyValue('padding-bottom') || '0';
    return parseInt(sat) || 0;
  }

  function isBottomNavVisible() {
    const nav = document.getElementById('mobile-bottom-nav');
    if (!nav) return false;
    const style = getComputedStyle(nav);
    return style.display !== 'none' && window.innerWidth < 1024;
  }

  function adjustBottomOffset() {
    const isMobile = window.innerWidth < 1024;
    const navVisible = isBottomNavVisible();
    const fabExists = !!document.getElementById('blog-section-fab');
    const sat = getSafeAreaInset();

    if (isMobile) {
      if (navVisible) {
        // Mobile pages (home, blog listing, resources): above bottom nav
        const navHeight = 64;
        trigger.style.bottom = `${navHeight + sat + 16}px`;
        panel.style.bottom = `${navHeight + sat + 72}px`;
      } else {
        // Reader pages (book, standalone pages): at bottom with safe area
        trigger.style.bottom = `${16 + sat}px`;
        panel.style.bottom = `${72 + sat}px`;
      }

      // Avoid blog TOC FAB on blog post pages
      if (fabExists) {
        trigger.style.right = '70px';
      } else {
        trigger.style.right = '';
      }
    } else {
      // Desktop: reset to CSS defaults
      trigger.style.bottom = '';
      trigger.style.right = '';
      panel.style.bottom = '';
    }
  }
  adjustBottomOffset();
  window.addEventListener('resize', adjustBottomOffset);

})();
</script>
