---
// QuestionThread - displays original question + replies + reply form
import { marked } from 'marked';

interface Reply {
  id: string;
  user_name: string;
  user_email: string;
  user_image: string | null;
  body: string;
  is_admin: number;
  createdAt: string;
}

interface Props {
  questionId: string;
  questionTitle: string;
  questionBody: string;
  questionUser: string;
  questionDate: string;
  replies: Reply[];
  showReplyForm?: boolean;
  status?: string;
}

const {
  questionId,
  questionTitle,
  questionBody,
  questionUser,
  questionDate,
  replies,
  showReplyForm = true,
  status = 'open',
} = Astro.props;

marked.use({ breaks: true });
function renderMd(text: string): string {
  return marked.parse(text) as string;
}
---

<!-- Question Thread -->
<div class="flex flex-col gap-4">
  <!-- Original Question -->
  <div class="glass-card rounded-xl p-5">
    <div class="flex items-center gap-3 mb-3">
      <div class="w-9 h-9 rounded-full bg-primary/15 flex items-center justify-center flex-shrink-0">
        <span class="material-symbols-outlined text-primary text-base">person</span>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-bold text-white">{questionUser}</p>
        <p class="text-[11px] text-on-surface-variant">{questionDate}</p>
      </div>
    </div>
    <div class="prose prose-invert prose-sm max-w-none reader-content" set:html={renderMd(questionBody)} />
  </div>

  <!-- Replies -->
  {replies.length > 0 && (
    <div class="flex flex-col gap-3">
      {replies.map(reply => (
        <div class:list={[
          'rounded-xl p-5',
          reply.is_admin
            ? 'bg-primary/5 border border-primary/15 ml-4 sm:ml-8'
            : 'glass-card mr-4 sm:mr-8',
        ]}>
          <div class="flex items-center gap-2.5 mb-2.5">
            <div class:list={[
              'w-7 h-7 rounded-full flex items-center justify-center',
              reply.is_admin ? 'bg-primary/20' : 'bg-tertiary/15',
            ]}>
              <span class:list={[
                'material-symbols-outlined text-sm',
                reply.is_admin ? 'text-primary' : 'text-tertiary',
              ]}>
                {reply.is_admin ? 'shield_person' : 'person'}
              </span>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-xs font-bold text-white">{reply.user_name || reply.user_email}</p>
              <p class="text-[10px] text-on-surface-variant">
                {reply.is_admin ? 'Tác giả' : 'Bạn'} · {reply.createdAt}
              </p>
            </div>
          </div>
          <div class="prose prose-invert prose-sm max-w-none reader-content" set:html={renderMd(reply.body)} />
        </div>
      ))}
    </div>
  )}

  <!-- Reply form -->
  {showReplyForm && status !== 'closed' && (
    <div class="glass-card rounded-xl p-5">
      <form id={`reply-form-${questionId}`} class="flex flex-col gap-3">
        <textarea
          id={`reply-body-${questionId}`}
          rows={3}
          placeholder="Viết câu trả lời..."
          class="w-full bg-surface-container border border-outline-variant/30 rounded-xl px-4 py-2.5 text-sm text-on-surface placeholder:text-on-surface-variant/50 outline-none focus:border-primary resize-y"
          required
        />
        <div class="flex justify-end">
          <button
            type="submit"
            data-question-id={questionId}
            class="reply-submit-btn px-5 py-2 rounded-xl bg-primary text-on-primary font-bold text-sm hover:opacity-90 transition-all flex items-center gap-2"
          >
            <span class="material-symbols-outlined text-base">send</span>
            Gửi
          </button>
        </div>
      </form>
    </div>
  )}

  {status === 'closed' && showReplyForm && (
    <div class="text-center py-4 text-on-surface-variant/50 text-sm">
      <span class="material-symbols-outlined text-2xl block mb-2">lock</span>
      Câu hỏi này đã đóng.
    </div>
  )}
</div>

<script>
  // Handle reply form submissions
  document.querySelectorAll('.reply-submit-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      const questionId = (btn as HTMLElement).dataset.questionId;
      const textarea = document.getElementById(`reply-body-${questionId}`) as HTMLTextAreaElement;
      const body = textarea?.value?.trim();
      if (!body || !questionId) return;

      const submitBtn = btn as HTMLButtonElement;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Đang gửi...';

      try {
        const res = await fetch(`/api/questions/${questionId}/reply`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ body }),
        });

        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          alert(err.error || 'Có lỗi xảy ra');
          return;
        }

        window.location.reload();
      } catch {
        alert('Lỗi kết nối');
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<span class="material-symbols-outlined text-base">send</span> Gửi';
      }
    });
  });
</script>
